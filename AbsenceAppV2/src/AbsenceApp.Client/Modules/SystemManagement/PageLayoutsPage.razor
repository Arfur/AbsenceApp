@page "/v2/system/pages/layouts"
@layout MainLayoutV2
@namespace AbsenceApp.Client.Modules.SystemManagement

@using AbsenceApp.Client.Shared

<PageTemplateV2 PageTitleText="Page Layouts">

    <ChildContent>
        <TablePageTemplateV2
            PageTitle="Page Layouts"
            TotalRows="_rows.Count"
            CurrentPage="1"
            ShowEntries="10"
            ActiveFilters="_chips"
            OnClearAllFilters="() => Task.CompletedTask">

            <TableHeader>
                <th class="tpt-th">ID</th>
                <th class="tpt-th">Layout Name</th>
                <th class="tpt-th">Template File</th>
                <th class="tpt-th">Pages Using</th>
                <th class="tpt-th">Actions</th>
            </TableHeader>

            <TableBody>
                @if (_rows.Count == 0)
                {
                    <tr><td colspan="5" class="tpt-td tpt-td--empty">No page layouts defined.</td></tr>
                }
                else
                {
                    @foreach (var r in _rows)
                    {
                        <tr class="tpt-tr">
                            <td class="tpt-td">@r.Id</td>
                            <td class="tpt-td">@r.Name</td>
                            <td class="tpt-td">@r.TemplateFile</td>
                            <td class="tpt-td">@r.PagesUsing</td>
                            <td class="tpt-td">
                                <span class="dsv2-table__row-action">Edit</span>
                            </td>
                        </tr>
                    }
                }
            </TableBody>

            <Pagination>
                <button class="tpt-page-btn tpt-page-btn--active">1</button>
            </Pagination>

        </TablePageTemplateV2>
    </ChildContent>

</PageTemplateV2>

@code {
    private readonly List<LayoutRowVm> _rows  = [];
    private readonly List<FilterChip>  _chips = [];

    private sealed record LayoutRowVm(int Id, string Name, string TemplateFile, int PagesUsing);
}
