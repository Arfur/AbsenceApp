@page "/v2/system/pages/metadata"
@layout MainLayoutV2
@namespace AbsenceApp.Client.Modules.SystemManagement

@using AbsenceApp.Client.Shared

<PageTemplateV2 PageTitleText="Page Metadata">

    <ChildContent>
        <TablePageTemplateV2
            PageTitle="Page Metadata"
            TotalRows="_rows.Count"
            CurrentPage="1"
            ShowEntries="10"
            ActiveFilters="_chips"
            OnClearAllFilters="() => Task.CompletedTask">

            <TableHeader>
                <th class="tpt-th">ID</th>
                <th class="tpt-th">Page</th>
                <th class="tpt-th">Title Tag</th>
                <th class="tpt-th">Description</th>
                <th class="tpt-th">Keywords</th>
                <th class="tpt-th">Actions</th>
            </TableHeader>

            <TableBody>
                @if (_rows.Count == 0)
                {
                    <tr><td colspan="6" class="tpt-td tpt-td--empty">No page metadata defined.</td></tr>
                }
                else
                {
                    @foreach (var r in _rows)
                    {
                        <tr class="tpt-tr">
                            <td class="tpt-td">@r.Id</td>
                            <td class="tpt-td">@r.PageName</td>
                            <td class="tpt-td">@r.TitleTag</td>
                            <td class="tpt-td">@r.Description</td>
                            <td class="tpt-td">@r.Keywords</td>
                            <td class="tpt-td">
                                <span class="dsv2-table__row-action">Edit</span>
                            </td>
                        </tr>
                    }
                }
            </TableBody>

            <Pagination>
                <button class="tpt-page-btn tpt-page-btn--active">1</button>
            </Pagination>

        </TablePageTemplateV2>
    </ChildContent>

</PageTemplateV2>

@code {
    private readonly List<MetadataRowVm> _rows  = [];
    private readonly List<FilterChip>    _chips = [];

    private sealed record MetadataRowVm(int Id, string PageName, string TitleTag, string Description, string Keywords);
}
