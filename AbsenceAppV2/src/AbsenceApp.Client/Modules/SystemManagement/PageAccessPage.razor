@page "/v2/system/page-access"
@layout MainLayoutV2
@namespace AbsenceApp.Client.Modules.SystemManagement

@using AbsenceApp.Client.Shared

<PageTemplateV2 PageTitleText="Page Access">

    <ChildContent>
        <TablePageTemplateV2
            PageTitle="Page Access"
            TotalRows="_rows.Count"
            CurrentPage="1"
            ShowEntries="10"
            ActiveFilters="_chips"
            OnClearAllFilters="() => Task.CompletedTask">

            <TableHeader>
                <th class="tpt-th">Page</th>
                <th class="tpt-th">Route</th>
                <th class="tpt-th">Category</th>
                <th class="tpt-th">Roles With Access</th>
                <th class="tpt-th">Actions</th>
            </TableHeader>

            <TableBody>
                @if (_rows.Count == 0)
                {
                    <tr><td colspan="5" class="tpt-td tpt-td--empty">No page access rules defined.</td></tr>
                }
                else
                {
                    @foreach (var r in _rows)
                    {
                        <tr class="tpt-tr">
                            <td class="tpt-td">@r.PageName</td>
                            <td class="tpt-td">@r.Route</td>
                            <td class="tpt-td">@r.Category</td>
                            <td class="tpt-td">@r.Roles</td>
                            <td class="tpt-td">
                                <span class="dsv2-table__row-action">Edit</span>
                            </td>
                        </tr>
                    }
                }
            </TableBody>

            <Pagination>
                <button class="tpt-page-btn tpt-page-btn--active">1</button>
            </Pagination>

        </TablePageTemplateV2>
    </ChildContent>

</PageTemplateV2>

@code {
    private readonly List<PageAccessRowVm> _rows  = [];
    private readonly List<FilterChip>      _chips = [];

    private sealed record PageAccessRowVm(string PageName, string Route, string Category, string Roles);
}
