@* ===========================================================================
   File        : PlaceholderPageV2.razor
   Namespace   : AbsenceApp.Client.ModulesV2
   Author      : Michael
   Version     : 1.2.3
   Created     : 2026-03-24
   Updated     : 2026-04-06
   ---------------------------------------------------------------------------
   Purpose     : Shared placeholder page for all V2 routes that are defined in
                 menu.json with status "Planned" but do not yet have a full
                 implementation. Prevents "Page not found" errors when users
                 navigate to these routes from the sidebar.
                 All routes here match exactly the hrefs in menu.json v6.0.0.
   ---------------------------------------------------------------------------
   Changes     :
     - 1.0.0  2026-03-24  Initial implementation covering all planned routes
                          from menu.json that have no dedicated module page.
     - 1.0.1  2026-03-25  Removed invalid @using Components.PageTemplatesV2 and/or
                          Components.TableV2. These components are provided via
                          the correct Framework namespaces through Modules/_Imports.razor.
     - 1.1.0  2026-03-26  Removed obsolete fully-qualified layout directive
                          'AbsenceApp.Client.Components.Layout.MainLayoutV2'
                          and replaced with 'MainLayoutV2' to align with V2
                          Framework layout structure. No functional changes.
     - 1.2.0  2026-03-26  Replaced @layout MainLayoutV2 with @layout MainLayoutV2;
                          MainLayoutV2 no longer exists — BaseLayoutV2 is the
                          V2 authenticated-shell layout (CS0246 build error fix).
     - (bumped)  2026-04-04  Phase 3 Stabilisation Issue 2: changed @layout from BaseLayoutV2 to MainLayoutV2 so all module pages use the canonical V2 shell layout with correct fixed-header padding.
     - 1.2.2  2026-04-05  Phase 3 Remediation Issue 1: added /v2/staff/details and /v2/students/details routes to match menu.json nav targets (previously only had singular /detail variants causing Page Not Found).
     - 1.2.3  2026-04-06  Phase 3 Route Repair: added /v2/dashboard/trends, /v2/classes/details, /v2/diagnostics, /v2/site to match exact hrefs in menu.json v6.0.0.
   ---------------------------------------------------------------------------
   Notes       :
     - DO NOT add Live routes here — Live routes must have dedicated pages.
     - When a planned route gets a dedicated page, remove its @page directive.
   ===========================================================================
*@

@* Dashboard planned routes *@
@page "/v2/dashboard/trends"
@page "/v2/dashboard/attendance"
@page "/v2/dashboard/safeguarding"

@* Students planned routes *@
@page "/v2/students/detail"
@page "/v2/students/details"

@* Staff planned routes *@
@page "/v2/staff/detail"
@page "/v2/staff/details"

@* People planned routes *@
@page "/v2/parents"

@* Academic planned routes *@
@page "/v2/classes/detail"
@page "/v2/classes/details"
@page "/v2/subjects"
@page "/v2/subjects/new"

@* Attendance planned routes *@
@page "/v2/attendance/staff"
@page "/v2/attendance/student"

@* Settings planned routes *@
@page "/v2/diagnostics"
@page "/v2/site"
@page "/v2/settings/diagnostics"
@page "/v2/settings/site-map"

@* System planned routes *@
@page "/v2/system/departments"
@page "/v2/system/job-titles"
@page "/v2/system/houses"
@page "/v2/system/year-groups"
@page "/v2/system/absence-types"
@* /v2/system/users — dedicated page: Modules/SystemManagement/UsersPage.razor *@
@* /v2/system/roles — dedicated page: Modules/SystemManagement/RolesPage.razor *@
@page "/v2/system/config/logo"
@page "/v2/system/config/buttons"
@page "/v2/system/config/fonts"
@page "/v2/system/config/table-defaults"
@page "/v2/system/config/spacing"

@layout MainLayoutV2
@inject AppStateService AppState
@inject NavigationManager Nav

@* =========================================================================
   Section: Coming soon placeholder
   ========================================================================= *@
<PageTemplateV2 PageTitleText="Coming Soon">

    <ChildContent>
        <div class="dsv2-placeholder">
            <i class="bi bi-tools dsv2-placeholder__icon" aria-hidden="true"></i>
            <h2 class="dsv2-placeholder__title">Feature in Development</h2>
            <p class="dsv2-placeholder__message">
                This section is planned and is currently under development.
                It will be available in an upcoming release.
            </p>
            <a href="javascript:history.back()" class="dsv2-btn dsv2-btn--secondary">
                <i class="bi bi-arrow-left" aria-hidden="true"></i> Go Back
            </a>
        </div>
    </ChildContent>

</PageTemplateV2>

@* =========================================================================
   Section: Code-behind
   ========================================================================= *@
@code {
    protected override void OnInitialized()
    {
        AppState.SetBreadcrumb("Coming Soon");
    }
}
