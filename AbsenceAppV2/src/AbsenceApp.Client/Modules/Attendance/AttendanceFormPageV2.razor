@* ===========================================================================
   File        : AttendanceFormPageV2.razor
   Namespace   : AbsenceApp.Client.Modules.Attendance
   Author      : Michael
   Version     : 1.1.0
   Created     : 2026-03-21
   Updated     : 2026-03-26
   ---------------------------------------------------------------------------
   Purpose     : V2 Attendance mark form page. Records an attendance mark for a
                 specific student in a class session using the V2
                 PageTemplateV2 primitive instead of deprecated FormPageV2 and
                 FormSectionV2. Delegates form state to AttendanceFormViewModelV2.
   ---------------------------------------------------------------------------
   Changes     :
     - 1.0.0  2026-03-21  Initial implementation (Phase 7).
     - 1.0.1  2026-03-25  Removed invalid V2 component imports.
     - 1.1.0  2026-03-26  Replaced FormPageV2 + FormSectionV2 with PageTemplateV2.
                          Updated namespace and layout. Preserved all bindings
                          and ViewModel logic.
   ---------------------------------------------------------------------------
   Notes       :
     - Route: /v2/attendance/{Id:long}/mark
     - Register AttendanceFormViewModelV2 as Scoped in Phase 10.
   ===========================================================================
*@

@page "/v2/attendance/{Id:long}/mark"
@layout BaseLayoutV2
@namespace AbsenceApp.Client.Modules.Attendance

@using AbsenceApp.Client.ViewModels.V2
@inject AttendanceFormViewModelV2 ViewModel
@inject AppStateService AppState
@inject NavigationManager Nav

<PageTemplateV2 PageTitleText="Mark Attendance">

    <ActionsContent>
        <button class="dsv2-btn dsv2-btn--primary"
                disabled="@ViewModel.IsBusy"
                @onclick="OnMark">
            @(ViewModel.IsBusy ? "Saving…" : "Submit Mark")
        </button>

        <button class="dsv2-btn dsv2-btn--secondary"
                disabled="@ViewModel.IsBusy"
                @onclick="@(() => Nav.NavigateTo($"/v2/attendance/{Id}"))">
            Cancel
        </button>
    </ActionsContent>

    <ChildContent>

        @if (ViewModel.Error is not null)
        {
            <div class="dsv2-alert dsv2-alert--danger" role="alert">
                @ViewModel.Error
            </div>
        }

        @* ---------------------------------------------------------------
           Attendance Mark
           --------------------------------------------------------------- *@
        <section class="dsv2-form-section">
            <header class="dsv2-form-section__header">
                <i class="bi bi-journal-check" aria-hidden="true"></i>
                <h2 class="dsv2-form-section__title">Attendance Mark</h2>
            </header>

            <div class="dsv2-form-section__body dsv2-grid-2col">

                <div class="dsv2-form-field">
                    <label class="dsv2-form-label" for="studentId">Student ID</label>
                    <input id="studentId" type="number" class="dsv2-form-input"
                           @bind="@ViewModel.StudentId" />
                </div>

                <div class="dsv2-form-field">
                    <label class="dsv2-form-label" for="markCode">Mark Code</label>
                    <input id="markCode" type="text" class="dsv2-form-input"
                           @bind="@ViewModel.MarkCode"
                           placeholder="P, A, L, …" />
                </div>

                <div class="dsv2-form-field">
                    <label class="dsv2-form-label" for="recordedBy">Recorded By (User ID)</label>
                    <input id="recordedBy" type="number" class="dsv2-form-input"
                           @bind="@ViewModel.RecordedBy" />
                </div>

                <div class="dsv2-form-field">
                    <label class="dsv2-form-label" for="notes">Notes</label>
                    <input id="notes" type="text" class="dsv2-form-input"
                           @bind="@ViewModel.Notes"
                           placeholder="Optional notes" />
                </div>

            </div>
        </section>

    </ChildContent>

</PageTemplateV2>

@code {
    [Parameter] public long Id { get; set; }

    protected override Task OnParametersSetAsync()
    {
        AppState.SetBreadcrumb("Attendance", "Mark Register");
        ViewModel.LoadForClass(Id);
        return Task.CompletedTask;
    }

    private async Task OnMark()
    {
        bool ok = await ViewModel.MarkAsync();
        if (ok)
            Nav.NavigateTo($"/v2/attendance/{Id}");
    }
}
