@* ===========================================================================
   File        : AttendanceFormPageV2.razor
   Namespace   : AbsenceApp.Client.ModulesV2.Attendance
   Author      : Michael
   Version     : 1.0.0
   Created     : 2026-03-21
   Updated     : 2026-03-21
   ---------------------------------------------------------------------------
   Purpose     : V2 Attendance mark form page. Records an attendance mark for a
                 specific student in a class session using FormPageV2 and
                 FormSectionV2. Delegates form state to AttendanceFormViewModelV2.
   ---------------------------------------------------------------------------
   Changes     :
     - 1.0.0  2026-03-21  Initial implementation (Phase 7).
   ---------------------------------------------------------------------------
   Notes       :
     - Route: /v2/attendance/{Id:long}/mark  (Id = class ID)
     - Register AttendanceFormViewModelV2 as Scoped in Phase 10.
   ===========================================================================
*@

@page "/v2/attendance/{Id:long}/mark"
@layout AbsenceApp.Client.Components.Layout.MainLayoutV2
@using AbsenceApp.Client.Components.PageTemplatesV2
@using AbsenceApp.Client.ViewModels.V2
@inject AttendanceFormViewModelV2 ViewModel
@inject AppStateService AppState
@inject NavigationManager Nav

@* =========================================================================
   Section: Attendance form
   ========================================================================= *@
<FormPageV2 PageTitle="Mark Attendance"
            BackHref="@($"/v2/attendance/{Id}")"
            BackLabel="Register"
            SubmitLabel="Submit Mark"
            BusyLabel="Saving�"
            CancelLabel="Cancel"
            IsBusy="ViewModel.IsBusy"
            OnSubmit="OnMark"
            OnCancel="@(() => Nav.NavigateTo($"/v2/attendance/{Id}"))">

    <BodyContent>
        @if (ViewModel.Error is not null)
        {
            <div class="dsv2-alert dsv2-alert--danger" role="alert">@ViewModel.Error</div>
        }

        <FormSectionV2 Title="Attendance Mark" Icon="bi-journal-check" Columns="2">
            <BodyContent>
                <div class="dsv2-form-field">
                    <label class="dsv2-form-label" for="studentId">Student ID</label>
                    <input id="studentId" type="number" class="dsv2-form-input"
                           @bind="@ViewModel.StudentId" />
                </div>

                <div class="dsv2-form-field">
                    <label class="dsv2-form-label" for="markCode">Mark Code</label>
                    <input id="markCode" type="text" class="dsv2-form-input"
                           @bind="@ViewModel.MarkCode"
                           placeholder="P, A, L, �" />
                </div>

                <div class="dsv2-form-field">
                    <label class="dsv2-form-label" for="recordedBy">Recorded By (User ID)</label>
                    <input id="recordedBy" type="number" class="dsv2-form-input"
                           @bind="@ViewModel.RecordedBy" />
                </div>

                <div class="dsv2-form-field">
                    <label class="dsv2-form-label" for="notes">Notes</label>
                    <input id="notes" type="text" class="dsv2-form-input"
                           @bind="@ViewModel.Notes"
                           placeholder="Optional notes" />
                </div>
            </BodyContent>
        </FormSectionV2>
    </BodyContent>

</FormPageV2>

@* =========================================================================
   Section: ViewModel wiring and form submission
   ========================================================================= *@
@code {
    [Parameter] public long Id { get; set; }

    protected override Task OnParametersSetAsync()
    {
        AppState.SetBreadcrumb("Attendance", "Mark Register");
        ViewModel.LoadForClass(Id);
        return Task.CompletedTask;
    }

    private async Task OnMark()
    {
        bool ok = await ViewModel.MarkAsync();
        if (ok) Nav.NavigateTo($"/v2/attendance/{Id}");
    }
}
