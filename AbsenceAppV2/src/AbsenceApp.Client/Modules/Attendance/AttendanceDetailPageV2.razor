@page "/v2/attendance/{Id:long}"
@layout MainLayoutV2
@namespace AbsenceApp.Client.Modules.Attendance

@using AbsenceApp.Client.ViewModels.V2
@inject AttendanceDetailViewModelV2 ViewModel
@inject AppStateService AppState
@inject NavigationManager Nav

<PageTemplateV2 PageTitleText="@PageTitle">

    <ActionsContent>
        @if (ViewModel.Register is not null)
        {
            <a href="@($"/v2/attendance/{Id}/mark")"
               class="dsv2-btn dsv2-btn--primary">
                Mark Attendance
            </a>
        }
    </ActionsContent>

    <ChildContent>

        @if (ViewModel.IsLoading)
        {
            <p class="dsv2-loading-text">Loading…</p>
        }
        else if (ViewModel.Error is not null)
        {
            <div class="dsv2-alert dsv2-alert--danger" role="alert">
                @ViewModel.Error
            </div>
        }
        else if (ViewModel.Register is not null)
        {
            var reg = ViewModel.Register;

            <section class="dsv2-detail-section">
                <header class="dsv2-detail-section__header">
                    <i class="bi bi-journal-check" aria-hidden="true"></i>
                    <h2 class="dsv2-detail-section__title">Register Details</h2>
                </header>

                <div class="dsv2-detail-section__body">

                    <span class="dsv2-detail-label">Register ID</span>
                    <span class="dsv2-detail-value">@reg.Id</span>

                    <span class="dsv2-detail-label">Class ID</span>
                    <span class="dsv2-detail-value">@reg.ClassId</span>

                    <span class="dsv2-detail-label">Date</span>
                    <span class="dsv2-detail-value">@reg.Date.ToString("dd MMM yyyy")</span>

                    <span class="dsv2-detail-label">Session</span>
                    <span class="dsv2-detail-value">@reg.Session</span>

                    <span class="dsv2-detail-label">Status</span>
                    <span class="dsv2-detail-value">@reg.Status</span>

                    <span class="dsv2-detail-label">Opened By</span>
                    <span class="dsv2-detail-value">@reg.OpenedBy</span>

                    <span class="dsv2-detail-label">Closed By</span>
                    <span class="dsv2-detail-value">
                        @(reg.ClosedBy.HasValue ? reg.ClosedBy.Value.ToString() : "—")
                    </span>

                    <span class="dsv2-detail-label">Created</span>
                    <span class="dsv2-detail-value">@reg.CreatedAt.ToString("dd MMM yyyy HH:mm")</span>

                    <span class="dsv2-detail-label">Updated</span>
                    <span class="dsv2-detail-value">@reg.UpdatedAt.ToString("dd MMM yyyy HH:mm")</span>

                </div>
            </section>
        }
        else
        {
            <p class="dsv2-loading-text">No register found for this class.</p>
        }

    </ChildContent>

</PageTemplateV2>

@code {
    [Parameter] public long Id { get; set; }

    private string PageTitle =>
        ViewModel.Register is not null
            ? $"Register – Class {ViewModel.Register.ClassId}"
            : "Attendance Register";

    protected override async Task OnParametersSetAsync()
    {
        AppState.SetBreadcrumb("Attendance", "Register");
        await ViewModel.LoadAsync(Id);
    }
}
