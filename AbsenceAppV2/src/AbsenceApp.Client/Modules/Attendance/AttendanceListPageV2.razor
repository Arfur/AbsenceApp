@page "/v2/attendance"
@layout MainLayoutV2
@namespace AbsenceApp.Client.Modules.Attendance

@using AbsenceApp.Client.Models.TableV2
@using AbsenceApp.Client.ViewModels.V2
@inject AttendanceListViewModelV2 ViewModel
@inject AppStateService AppState
@inject NavigationManager Nav

<PageTemplateV2 PageTitleText="Attendance">

    <ActionsContent>
        @if (_showExportMenu)
        {
            <div class="phv2-export-backdrop" @onclick="CloseExportMenu" aria-hidden="true"></div>
        }
        <div class="phv2-export-wrap">
            <button type="button"
                    class="phv2-btn phv2-btn--secondary"
                    @onclick="ToggleExportMenu"
                    aria-expanded="@_showExportMenu"
                    aria-haspopup="true">
                <i class="bi bi-download" aria-hidden="true"></i>
                Export
                <i class="bi @(_showExportMenu ? "bi-chevron-up" : "bi-chevron-down") phv2-btn__chevron" aria-hidden="true"></i>
            </button>
            @if (_showExportMenu)
            {
                <div class="phv2-export-dd" role="menu">
                    <button type="button" class="phv2-export-item" role="menuitem">
                        <i class="bi bi-file-earmark-pdf" aria-hidden="true"></i>
                        Export as PDF
                    </button>
                    <button type="button" class="phv2-export-item" role="menuitem">
                        <i class="bi bi-file-earmark-excel" aria-hidden="true"></i>
                        Export as Excel
                    </button>
                </div>
            }
        </div>
    </ActionsContent>

    <ChildContent>

        @if (ViewModel.Error is not null)
        {
            <div class="dsv2-alert dsv2-alert--danger" role="alert">
                @ViewModel.Error
            </div>
        }

        <TableV2 TItem="AbsenceApp.Core.DTOs.AttendanceDto"
                 Columns="AttendanceListViewModelV2.Columns"
                 Items="ViewModel.Items"
                 TotalCount="ViewModel.TotalCount"
                 IsLoading="ViewModel.IsLoading"
                 CurrentPage="ViewModel.Page"
                 PageSize="ViewModel.PageSize"
                 SortColumn="ViewModel.SortColumn"
                 SortAscending="ViewModel.SortAscending"
                 SearchPlaceholder="Search attendance…"
                 AriaLabel="Attendance table"
                 OnSearchChanged="OnSearch"
                 OnSortChanged="OnSort"
                 OnPageChanged="OnPageChanged"
                 OnPageSizeChanged="OnPageSizeChanged">

            <RowTemplate Context="record">
                <td class="dsv2-table__td">@record.AttendanceId</td>
                <td class="dsv2-table__td">@record.UserId</td>
                <td class="dsv2-table__td">
                    @(record.ClassId.HasValue ? record.ClassId.Value.ToString() : "—")
                </td>
                <td class="dsv2-table__td">@record.Status</td>
                <td class="dsv2-table__td">@record.Timestamp.ToString("dd MMM yyyy HH:mm")</td>
                <td class="dsv2-table__td">@record.RecordedBy</td>
            </RowTemplate>

            <RowActionsContent Context="record">
                @if (record.ClassId.HasValue)
                {
                    <a href="@($"/v2/attendance/{record.ClassId.Value}")"
                       class="dsv2-table__row-action">
                        View Register
                    </a>

                    <a href="@($"/v2/attendance/{record.ClassId.Value}/mark")"
                       class="dsv2-table__row-action">
                        Mark
                    </a>
                }
            </RowActionsContent>

        </TableV2>

    </ChildContent>

</PageTemplateV2>

@code {
    protected override async Task OnInitializedAsync()
    {
        AppState.SetBreadcrumb("Attendance", "Log Attendance");
        await ViewModel.LoadAsync();
    }

    private async Task OnSearch(string term) =>
        await ViewModel.SearchAsync(term);

    private async Task OnSort((string Column, bool Ascending) args) =>
        await ViewModel.SortAsync(args.Column, args.Ascending);

    private async Task OnPageChanged(int page) =>
        await ViewModel.GoToPageAsync(page);

    private async Task OnPageSizeChanged(int size) =>
        await ViewModel.ChangePageSizeAsync(size);

    private bool _showExportMenu;
    private void ToggleExportMenu() => _showExportMenu = !_showExportMenu;
    private void CloseExportMenu()  => _showExportMenu = false;
}
