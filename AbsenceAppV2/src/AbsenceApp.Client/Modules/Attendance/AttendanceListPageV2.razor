@* ===========================================================================
   File        : AttendanceListPageV2.razor
   Namespace   : AbsenceApp.Client.Modules.Attendance
   Author      : Michael
   Version     : 1.1.1
   Created     : 2026-03-21
   Updated     : 2026-04-04
   ---------------------------------------------------------------------------
   Purpose     : V2 Attendance list page. Displays a paged, searchable, sortable
                 table of attendance records using the V2 PageTemplateV2
                 primitive instead of deprecated StandardPageV2. Delegates all
                 data and state to AttendanceListViewModelV2.
   ---------------------------------------------------------------------------
   Changes     :
     - 1.0.0  2026-03-21  Initial implementation (Phase 7).
     - 1.0.1  2026-03-25  Removed invalid V2 component imports.
     - 1.1.0  2026-03-26  Replaced StandardPageV2 with PageTemplateV2.
                          Updated namespace and layout. Preserved table logic.
     - (bumped)  2026-04-04  Phase 3 Stabilisation Issue 2: changed @layout from BaseLayoutV2 to MainLayoutV2 so all module pages use the canonical V2 shell layout with correct fixed-header padding.
     - 1.2.0  2026-04-14  E9 Change 7: added Export dropdown (PDF/Excel, no
                          back-end action) in PageTemplateV2 ActionsContent.
   ---------------------------------------------------------------------------
   Notes       :
     - Route: /v2/attendance
     - Register AttendanceListViewModelV2 as Scoped in Phase 10.
   ===========================================================================
*@

@page "/v2/attendance"
@layout MainLayoutV2
@namespace AbsenceApp.Client.Modules.Attendance

@using AbsenceApp.Client.Shared
@using AbsenceApp.Client.ViewModels.V2
@inject AttendanceListViewModelV2 ViewModel
@inject AppStateService AppState
@inject NavigationManager Nav

<PageTemplateV2 PageTitleText="Attendance">

    <ActionsContent>
        @if (_showExportMenu)
        {
            <div class="phv2-export-backdrop" @onclick="CloseExportMenu" aria-hidden="true"></div>
        }
        <div class="phv2-export-wrap">
            <button type="button"
                    class="phv2-btn phv2-btn--secondary"
                    @onclick="ToggleExportMenu"
                    aria-expanded="@_showExportMenu"
                    aria-haspopup="true">
                <i class="bi bi-download" aria-hidden="true"></i>
                Export
                <i class="bi @(_showExportMenu ? "bi-chevron-up" : "bi-chevron-down") phv2-btn__chevron" aria-hidden="true"></i>
            </button>
            @if (_showExportMenu)
            {
                <div class="phv2-export-dd" role="menu">
                    <button type="button" class="phv2-export-item" role="menuitem">
                        <i class="bi bi-file-earmark-pdf" aria-hidden="true"></i>
                        Export as PDF
                    </button>
                    <button type="button" class="phv2-export-item" role="menuitem">
                        <i class="bi bi-file-earmark-excel" aria-hidden="true"></i>
                        Export as Excel
                    </button>
                </div>
            }
        </div>
    </ActionsContent>

    <ChildContent>

        @if (ViewModel.Error is not null)
        {
            <div class="dsv2-alert dsv2-alert--danger" role="alert">@ViewModel.Error</div>
        }

        <TablePageTemplateV2
            PageTitle="Attendance"
            TotalRows="@ViewModel.TotalCount"
            CurrentPage="@ViewModel.Page"
            ShowEntries="@ViewModel.PageSize"
            SearchValue="@ViewModel.SearchTerm"
            ActiveFilters="@_chips"
            OnShowEntriesChanged="@OnShowEntriesChanged"
            OnSearchChanged="@OnSearchChanged"
            OnClearAllFilters="@(() => Task.CompletedTask)">

            <TableHeader>
                <th class="tpt-th tpt-th--sm">
                    <button class="tpt-sort-btn @SortClass("attendanceId")"
                            @onclick="@(() => OnSort("attendanceId"))">
                        ID
                        <span class="tpt-sort-icons">
                            <span class="tpt-sort-up">▲</span>
                            <span class="tpt-sort-dn">▼</span>
                        </span>
                    </button>
                </th>
                <th class="tpt-th tpt-th--sm">
                    <button class="tpt-sort-btn @SortClass("userId")"
                            @onclick="@(() => OnSort("userId"))">
                        User ID
                        <span class="tpt-sort-icons">
                            <span class="tpt-sort-up">▲</span>
                            <span class="tpt-sort-dn">▼</span>
                        </span>
                    </button>
                </th>
                <th class="tpt-th tpt-th--sm">
                    <button class="tpt-sort-btn @SortClass("classId")"
                            @onclick="@(() => OnSort("classId"))">
                        Class ID
                        <span class="tpt-sort-icons">
                            <span class="tpt-sort-up">▲</span>
                            <span class="tpt-sort-dn">▼</span>
                        </span>
                    </button>
                </th>
                <th class="tpt-th tpt-th--sm">
                    <button class="tpt-sort-btn @SortClass("status")"
                            @onclick="@(() => OnSort("status"))">
                        Status
                        <span class="tpt-sort-icons">
                            <span class="tpt-sort-up">▲</span>
                            <span class="tpt-sort-dn">▼</span>
                        </span>
                    </button>
                </th>
                <th class="tpt-th">
                    <button class="tpt-sort-btn @SortClass("timestamp")"
                            @onclick="@(() => OnSort("timestamp"))">
                        Timestamp
                        <span class="tpt-sort-icons">
                            <span class="tpt-sort-up">▲</span>
                            <span class="tpt-sort-dn">▼</span>
                        </span>
                    </button>
                </th>
                <th class="tpt-th">Recorded By</th>
                <th class="tpt-th tpt-th--actions">Actions</th>
            </TableHeader>

            <TableBody>
                @if (ViewModel.IsLoading)
                {
                    @for (var i = 0; i < ViewModel.PageSize; i++)
                    {
                        <tr class="tpt-tr tpt-tr--skeleton">
                            @for (var c = 0; c < 7; c++) { <td class="tpt-td"><span class="tpt-skeleton"></span></td> }
                        </tr>
                    }
                }
                else if (ViewModel.Items.Count == 0)
                {
                    <tr><td colspan="7" class="tpt-td tpt-td--empty">No attendance records found.</td></tr>
                }
                else
                {
                    @foreach (var record in ViewModel.Items)
                    {
                        <tr class="tpt-tr">
                            <td class="tpt-td tpt-sno">@record.AttendanceId</td>
                            <td class="tpt-td">@record.UserId</td>
                            <td class="tpt-td">@(record.ClassId.HasValue ? record.ClassId.Value.ToString() : "—")</td>
                            <td class="tpt-td">
                                <span class="tpt-badge @(record.Status == "Present" ? "tpt-badge-active" : record.Status == "Absent" ? "tpt-badge-inactive" : "tpt-badge-pending")">
                                    @record.Status
                                </span>
                            </td>
                            <td class="tpt-td">@record.Timestamp.ToString("dd MMM yyyy HH:mm")</td>
                            <td class="tpt-td">@record.RecordedBy</td>
                            <td class="tpt-td tpt-td--actions">
                                <div class="tpt-actions">
                                    @if (record.ClassId.HasValue)
                                    {
                                        <button class="tpt-action-icon tpt-action-view" title="View Register"
                                                @onclick="@(() => Nav.NavigateTo($"/v2/attendance/{record.ClassId.Value}"))">
                                            <i class="bi bi-eye" aria-hidden="true"></i>
                                        </button>
                                        <button class="tpt-action-icon tpt-action-edit" title="Mark Attendance"
                                                @onclick="@(() => Nav.NavigateTo($"/v2/attendance/{record.ClassId.Value}/mark"))">
                                            <i class="bi bi-pencil" aria-hidden="true"></i>
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
            </TableBody>

            <Pagination>
                @{
                    var totalPages = ViewModel.PageSize > 0
                        ? (int)Math.Ceiling((double)ViewModel.TotalCount / ViewModel.PageSize) : 1;
                    var pg       = ViewModel.Page;
                    var winStart = Math.Max(1, pg - 4);
                    var winEnd   = Math.Min(totalPages, winStart + 9);
                    if (winEnd - winStart < 9) winStart = Math.Max(1, winEnd - 9);
                }
                <button class="tpt-page-btn tpt-page-prev" disabled="@(ViewModel.Page <= 1)"
                        @onclick="PrevPage">&#8592; Previous</button>
                @for (var i = winStart; i <= winEnd; i++)
                {
                    var pCopy = i;
                    <button class="tpt-page-btn @(pCopy == ViewModel.Page ? "tpt-active" : "")"
                            @onclick="@(() => GoToPage(pCopy))">@pCopy</button>
                }
                @if (winEnd < totalPages) { <span class="tpt-page-ellipsis">...</span> }
                <button class="tpt-page-btn tpt-page-next" disabled="@(ViewModel.Page >= totalPages)"
                        @onclick="NextPage">Next &#8594;</button>
            </Pagination>

        </TablePageTemplateV2>

    </ChildContent>

</PageTemplateV2>

@code {
    private List<FilterChip> _chips = [];
    private bool _showExportMenu;

    protected override async Task OnInitializedAsync()
    {
        AppState.SetBreadcrumb("Attendance", "Log Attendance");
        await ViewModel.LoadAsync();
    }

    private async Task OnSearchChanged(string term) =>
        await ViewModel.SearchAsync(term);

    private async Task OnShowEntriesChanged(int size) =>
        await ViewModel.ChangePageSizeAsync(size);

    private async Task OnSort(string column)
    {
        var asc = ViewModel.SortColumn == column ? !ViewModel.SortAscending : true;
        await ViewModel.SortAsync(column, asc);
    }

    private string SortClass(string column) =>
        ViewModel.SortColumn == column
            ? (ViewModel.SortAscending ? "asc" : "desc")
            : string.Empty;

    private async Task GoToPage(int page) =>
        await ViewModel.GoToPageAsync(page);

    private async Task PrevPage() =>
        await ViewModel.GoToPageAsync(ViewModel.Page - 1);

    private async Task NextPage() =>
        await ViewModel.GoToPageAsync(ViewModel.Page + 1);

    private void ToggleExportMenu() => _showExportMenu = !_showExportMenu;
    private void CloseExportMenu()  => _showExportMenu = false;
}
