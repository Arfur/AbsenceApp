@* ===========================================================================
   File        : UsersListPageV2.razor
   Namespace   : AbsenceApp.Client.Modules.Users
   Author      : Michael
   Version     : 2.1.0
   Created     : 2026-04-11
   Updated     : 2026-04-25
   ---------------------------------------------------------------------------
   Purpose     : E15 User Management — User List page.
                 Displays all user accounts using TablePageTemplateV2, matching
                 the StudentsListPageV2 layout: filter bar, search, sortable
                 columns, icon-based action buttons (edit + delete with
                 two-click confirm), sliding-window pagination, Export
                 dropdown, and Add User button (navigates to Staff list as
                 user creation requires a Staff record link).
   ---------------------------------------------------------------------------
   Changes     :
     - 1.0.0  2026-04-11  Initial creation (E15 User Management).
     - 2.0.0  2026-04-21  Converted to TablePageTemplateV2 (AllStudents parity).
                           Added Add User button (navigates to /v2/staff).
                           Replaced custom ulv2-* markup with tpt-* template.
                           Replaced single pencil action with pencil + trash
                           icons; trash uses two-click confirm pattern.
                           Added proper sliding-window pagination.
     - 2.1.0  2026-04-25  Corrected Edit User navigation route. Updated action
                           link from '/v2/users/{Id}/edit' to the correct
                           '/v2/system/users/{Id}' route to restore proper
                           navigation into UserFormPageV2 and fix "User not
                           found" caused by missing Id parameter.
   ---------------------------------------------------------------------------
   Notes       :
     - Route: /v2/users
     - Edit User navigates to /v2/system/users/{Id}.
     - User creation is Staff-linked only (/v2/users/{StaffId}/new). The
       Add User button guides the user to the Staff list to select a staff
       member and then click "Create User Account" on their detail page.
   ===========================================================================
*@

@page "/v2/users"
@layout MainLayoutV2
@namespace AbsenceApp.Client.Modules.Users

@using AbsenceApp.Client.Framework.PageTemplates
@using AbsenceApp.Client.ViewModels.V2
@using AbsenceApp.Client.Services.TableV2
@using AbsenceApp.Core.DTOs
@inject UserListViewModelV2 ViewModel
@inject AppStateService AppState
@inject NavigationManager Nav
@inject TableSettingsFileService SettingsFile
@implements IDisposable

<PageTemplateV2 PageTitleText="Users">

    <ActionsContent>
        @if (_showExportMenu)
        {
            <div class="phv2-export-backdrop" @onclick="CloseExportMenu" aria-hidden="true"></div>
        }
        <div class="phv2-export-wrap">
            <button type="button"
                    class="phv2-btn phv2-btn--secondary"
                    @onclick="ToggleExportMenu"
                    aria-expanded="@_showExportMenu"
                    aria-haspopup="true">
                <i class="bi bi-download" aria-hidden="true"></i>
                Export
                <i class="bi @(_showExportMenu ? "bi-chevron-up" : "bi-chevron-down") phv2-btn__chevron" aria-hidden="true"></i>
            </button>
            @if (_showExportMenu)
            {
                <div class="phv2-export-dd" role="menu">
                    <button type="button" class="phv2-export-item" role="menuitem">
                        <i class="bi bi-file-earmark-pdf" aria-hidden="true"></i>
                        Export as PDF
                    </button>
                    <button type="button" class="phv2-export-item" role="menuitem">
                        <i class="bi bi-file-earmark-excel" aria-hidden="true"></i>
                        Export as Excel
                    </button>
                </div>
            }
        </div>
        <button type="button"
                class="phv2-btn phv2-btn--add"
                title="Create a new user account linked to a staff member."
                @onclick="@(() => Nav.NavigateTo("/v2/users/new"))">
            <i class="bi bi-plus-circle" aria-hidden="true"></i>
            Add User
        </button>
    </ActionsContent>

    <ChildContent>

        @if (ViewModel.Error is not null)
        {
            <div class="dsv2-alert dsv2-alert--danger" role="alert">@ViewModel.Error</div>
        }

        <TablePageTemplateV2
            PageTitle="Users"
            TotalRows="@ViewModel.TotalCount"
            CurrentPage="@ViewModel.Page"
            ShowEntries="@ViewModel.PageSize"
            SearchValue="@ViewModel.SearchTerm"
            ActiveFilters="@_activeFilterChips"
            OnShowEntriesChanged="@OnShowEntriesChanged"
            OnSearchChanged="@OnSearchChanged"
            OnRemoveFilter="@OnRemoveFilter"
            OnClearAllFilters="@OnClearAllFilters">

            <Filters>
                <select class="tpt-filter-select"
                        value="@_f["roleName"]"
                        @onchange="@(e => SetFilter("roleName", "Role", e.Value?.ToString()))">
                    <option value="">All Roles</option>
                    @foreach (var r in _roleOptions)
                    {
                        <option value="@r">@r</option>
                    }
                </select>
                <select class="tpt-filter-select"
                        value="@_f["status"]"
                        @onchange="@(e => SetFilter("status", "Status", e.Value?.ToString()))">
                    <option value="">All Statuses</option>
                    <option value="active">Active</option>
                    <option value="inactive">Inactive</option>
                    <option value="suspended">Suspended</option>
                </select>
            </Filters>

            <TableHeader>
                @if (IsVisible("staff"))
                {
                    <th class="tpt-th">
                        <button class="tpt-sort-btn @SortClass("staffName")" @onclick="@(() => OnSort("staffName"))">
                            @ColLabel("staff")
                            <span class="tpt-sort-icons"><span class="tpt-sort-up">▲</span><span class="tpt-sort-dn">▼</span></span>
                        </button>
                    </th>
                }
                @if (IsVisible("full_name"))
                {
                    <th class="tpt-th">
                        <button class="tpt-sort-btn @SortClass("fullName")" @onclick="@(() => OnSort("fullName"))">
                            @ColLabel("full_name")
                            <span class="tpt-sort-icons"><span class="tpt-sort-up">▲</span><span class="tpt-sort-dn">▼</span></span>
                        </button>
                    </th>
                }
                @if (IsVisible("username"))
                {
                    <th class="tpt-th">
                        <button class="tpt-sort-btn @SortClass("username")" @onclick="@(() => OnSort("username"))">
                            @ColLabel("username")
                            <span class="tpt-sort-icons"><span class="tpt-sort-up">▲</span><span class="tpt-sort-dn">▼</span></span>
                        </button>
                    </th>
                }
                @if (IsVisible("email"))
                {
                    <th class="tpt-th">@ColLabel("email")</th>
                }
                @if (IsVisible("role"))
                {
                    <th class="tpt-th">
                        <button class="tpt-sort-btn @SortClass("roleName")" @onclick="@(() => OnSort("roleName"))">
                            @ColLabel("role")
                            <span class="tpt-sort-icons"><span class="tpt-sort-up">▲</span><span class="tpt-sort-dn">▼</span></span>
                        </button>
                    </th>
                }
                @if (IsVisible("status"))
                {
                    <th class="tpt-th">
                        <button class="tpt-sort-btn @SortClass("status")" @onclick="@(() => OnSort("status"))">
                            @ColLabel("status")
                            <span class="tpt-sort-icons"><span class="tpt-sort-up">▲</span><span class="tpt-sort-dn">▼</span></span>
                        </button>
                    </th>
                }
                <th class="tpt-th tpt-th--actions">Actions</th>
            </TableHeader>

            <TableBody>
                @if (ViewModel.IsLoading)
                {
                    @for (var i = 0; i < ViewModel.PageSize; i++)
                    {
                        <tr class="tpt-tr tpt-tr--skeleton">
                            @for (var c = 0; c < _colCount; c++)
                            {
                                <td class="tpt-td"><span class="tpt-skeleton"></span></td>
                            }
                        </tr>
                    }
                }
                else if (ViewModel.Items.Count == 0)
                {
                    <tr>
                        <td class="tpt-td tpt-td--empty" colspan="@_colCount">No users found.</td>
                    </tr>
                }
                else
                {
                    @foreach (var item in ViewModel.Items)
                    {
                        <tr class="tpt-tr">
                            @if (IsVisible("staff"))    { <td class="tpt-td">@item.StaffName</td> }
                            @if (IsVisible("full_name")) { <td class="tpt-td">@item.FullName</td> }
                            @if (IsVisible("username")) { <td class="tpt-td">@item.Username</td> }
                            @if (IsVisible("email"))    { <td class="tpt-td">@item.Email</td> }
                            @if (IsVisible("role"))
                            {
                                <td class="tpt-td">
                                    <span class="tpt-badge">@item.RoleName</span>
                                </td>
                            }
                            @if (IsVisible("status"))
                            {
                                <td class="tpt-td">
                                    <span class="tpt-badge tpt-badge-@item.Status.ToLowerInvariant()">@item.Status</span>
                                </td>
                            }
                            <td class="tpt-td tpt-td--actions">
                                <a href="/v2/users/@item.Id"
                                   class="tpt-action-icon tpt-action-edit"
                                   title="Edit @item.FullName">
                                    <i class="bi bi-pencil" aria-hidden="true"></i>
                                </a>
                                @if (_confirmDeleteId == item.Id)
                                {
                                    <button class="tpt-action-icon tpt-action-delete-confirm"
                                            title="Confirm delete"
                                            @onclick="@(() => ConfirmDeleteAsync(item.Id))">
                                        <i class="bi bi-check-circle" aria-hidden="true"></i>
                                    </button>
                                    <button class="tpt-action-icon tpt-action-cancel"
                                            title="Cancel"
                                            @onclick="@(() => _confirmDeleteId = null)">
                                        <i class="bi bi-x-circle" aria-hidden="true"></i>
                                    </button>
                                }
                                else
                                {
                                    <button class="tpt-action-icon tpt-action-delete"
                                            title="Delete @item.FullName"
                                            @onclick="@(() => _confirmDeleteId = item.Id)">
                                        <i class="bi bi-trash" aria-hidden="true"></i>
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                }
            </TableBody>

            <Pagination>
                @{
                    var totalPages = ViewModel.PageSize > 0
                        ? (int)Math.Ceiling((double)ViewModel.TotalCount / ViewModel.PageSize)
                        : 1;
                    var page     = ViewModel.Page;
                    var winStart = Math.Max(1, page - 4);
                    var winEnd   = Math.Min(totalPages, winStart + 9);
                    if (winEnd - winStart < 9) winStart = Math.Max(1, winEnd - 9);
                }
                <button class="tpt-page-btn tpt-page-prev"
                        disabled="@(page <= 1)"
                        @onclick="@(() => ViewModel.SetPage(page - 1))">
                    &#8592; Previous
                </button>
                @for (var p = winStart; p <= winEnd; p++)
                {
                    var pCopy = p;
                    <button class="tpt-page-btn @(pCopy == page ? "tpt-active" : "")"
                            @onclick="@(() => ViewModel.SetPage(pCopy))">
                        @pCopy
                    </button>
                }
                @if (winEnd < totalPages)
                {
                    <span class="tpt-page-ellipsis">...</span>
                }
                <button class="tpt-page-btn tpt-page-next"
                        disabled="@(page >= totalPages)"
                        @onclick="@(() => ViewModel.SetPage(page + 1))">
                    Next &#8594;
                </button>
            </Pagination>

        </TablePageTemplateV2>

    </ChildContent>

</PageTemplateV2>

@code {

    private bool  _showExportMenu;
    private long? _confirmDeleteId;

    private List<string> _roleOptions = [];

    private readonly Dictionary<string, string> _f = new()
    {
        ["roleName"] = "",
        ["status"]       = "",
    };

    private List<FilterChip> _activeFilterChips = [];

    private static readonly Dictionary<string, string> _keyToLabel = new()
    {
        ["roleName"] = "Role",
        ["status"]       = "Status",
    };

    private static readonly Dictionary<string, string> _labelToKey = new()
    {
        ["Role"]   = "roleName",
        ["Status"] = "status",
    };

    // =========================================================================
    // Table settings state
    // =========================================================================

    private List<TablePageSettingDto> _settings = [];

    private bool IsVisible(string fieldName) =>
        _settings.Count == 0 ||
        (_settings.FirstOrDefault(s => s.FieldName == fieldName)?.IsVisible ?? true);

    private string ColLabel(string fieldName) =>
        _settings.FirstOrDefault(s => s.FieldName == fieldName)?.DisplayLabel ?? fieldName;

    private int _colCount => _settings.Count == 0
        ? 7
        : _settings.Count(s => s.IsVisible) + 1;

    // =========================================================================
    // Lifecycle
    // =========================================================================

    protected override async Task OnInitializedAsync()
    {
        AppState.OnTableSettingsChanged += OnSettingsChanged;
        _settings = await SettingsFile.LoadAsync("users");
        await ViewModel.LoadAsync();
        RebuildRoleOptions();
    }

    private void OnSettingsChanged()
    {
        _ = InvokeAsync(async () =>
        {
            _settings = await SettingsFile.LoadAsync("users");
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        AppState.OnTableSettingsChanged -= OnSettingsChanged;
    }

    // =========================================================================
    // Search / show-entries
    // =========================================================================

    private Task OnSearchChanged(string term)
    {
        ViewModel.SetSearch(term);
        return Task.CompletedTask;
    }

    private Task OnShowEntriesChanged(int size)
    {
        ViewModel.SetPageSize(size);
        return Task.CompletedTask;
    }

    // =========================================================================
    // Filter helpers
    // =========================================================================

    private void SetFilter(string key, string label, string? value)
    {
        _f[key] = value ?? string.Empty;
        ViewModel.SetFilter(key, _f[key]);
        RebuildChips();
    }

    private Task OnRemoveFilter(FilterChip chip)
    {
        var key = _labelToKey.GetValueOrDefault(chip.Name ?? "");
        if (key is not null)
        {
            _f[key] = string.Empty;
            ViewModel.SetFilter(key, string.Empty);
        }
        RebuildChips();
        return Task.CompletedTask;
    }

    private Task OnClearAllFilters()
    {
        foreach (var key in _f.Keys.ToList()) _f[key] = string.Empty;
        ViewModel.SetFilter("roleName", string.Empty);
        ViewModel.SetFilter("status",       string.Empty);
        _activeFilterChips = [];
        return Task.CompletedTask;
    }

    private void RebuildChips() =>
        _activeFilterChips = _f
            .Where(kv => !string.IsNullOrWhiteSpace(kv.Value))
            .Select(kv => new FilterChip(_keyToLabel[kv.Key], kv.Value))
            .ToList();

    private void RebuildRoleOptions() =>
        _roleOptions = ViewModel.AllItems
            .Select(u => u.RoleName)
            .Where(r => !string.IsNullOrWhiteSpace(r))
            .Distinct()
            .OrderBy(x => x)
            .ToList();

    // =========================================================================
    // Sort
    // =========================================================================

    private void OnSort(string column) => ViewModel.SetSort(column);

    private string SortClass(string column) =>
        ViewModel.SortColumn != column ? "" :
        ViewModel.SortAscending ? "asc" : "desc";

    // =========================================================================
    // Delete (two-click confirm pattern)
    // =========================================================================

    private async Task ConfirmDeleteAsync(long userId)
    {
        _confirmDeleteId = null;
        await ViewModel.DeleteUserAsync(userId);
        RebuildRoleOptions();
    }

    // =========================================================================
    // Export menu
    // =========================================================================

    private void ToggleExportMenu() => _showExportMenu = !_showExportMenu;
    private void CloseExportMenu()  => _showExportMenu = false;
}
