@* ===========================================================================
   File        : UserFormPageV2.razor
   Namespace   : AbsenceApp.Client.Modules.Users
   Author      : Michael
   Version     : 4.4.0
   Created     : 2026-04-11
   Updated     : 2026-04-22
   ---------------------------------------------------------------------------
   Purpose     : E15 User Management — Add / Edit User — full profile page.
                 Routes:
                   /v2/users/new                  — create user (staff picker)
                   /v2/users/{StaffId:long}/new   — create user (pre-selected)
                   /v2/users/{Id:long}/edit        — edit / view full profile

                 Layout (both modes):
                   • Full-width dark navy banner: circular photo (left) +
                     identity block or staff selector (right).
                     Photo upload button appears in banner in edit mode only.
                   • Add mode: staff selector in banner; Account Details form +
                     Module Permissions below (disabled until staff selected).
                   • Edit mode: full-width 8-tab interface below banner:
                       0  Basic Info (User + UserProfile + Module Permissions
                                      + Change Password)
                       1  Contacts (Staff employment / contact)
                       2  Classes & Year Groups (StaffAssignments)
                       3  Devices (StaffDevices)
                       4  External Systems (StaffExternalAccounts)
                       5  Medical Records (placeholder)
                       6  Absence Records (Absences)
                       7  Login Audit (LoginAudit)
   ---------------------------------------------------------------------------
   Changes     :
     - 1.0.0  2026-04-11  Initial creation (E15 User Management).
     - 2.0.0  2026-04-21  Staff-linked create; removed FirstName/LastName/Phone.
     - 2.1.0  2026-04-21  Fixed UTF-8 encoding corruption in rendered UI text.
     - 3.0.0  2026-04-21  Full redesign: UserProfileViewModelV2, profile header,
                           8-tab interface, photo upload, change password panel.
     - 3.1.0  2026-04-21  Code-audit cleanup (redundant usings, dead CSS class).
     - 3.2.0  2026-04-22  Added /v2/users/new route with staff selector dropdown;
                           ?staffId= query-string pre-selection support.
     - 4.0.0  2026-04-22  Full layout teardown: dark navy profile banner replaces
                           header strip and two-column body; photo upload moved
                           into banner (edit mode); change password moved into
                           Tab 0; two-column layout removed.
     - 4.1.0  2026-04-22  Phase 3 (Behaviour): Added RemovePhoto button in banner;
                           added OnRemovePhoto handler calling ViewModel.RemovePhotoAsync.
     - 4.2.0  2026-04-22  Phase 5.2A (Form Tab Layouts): Replaced dsv2-form-* classes with
                           upv2-field/label/input throughout Tab 0; added upv2-dividers
                           between sections; converted Contacts tab KV grid to form-style
                           layout with upv2-value read-only boxes.
   ===========================================================================
*@

@page "/v2/users/new"
@page "/v2/users/{StaffId:long}/new"
@page "/v2/system/users/{Id:long}"
@layout MainLayoutV2
@namespace AbsenceApp.Client.Modules.Users

@using AbsenceApp.Client.Framework.Layout
@using AbsenceApp.Client.ViewModels.V2
@using AbsenceApp.Client.Shared.Components
@inject UserProfileViewModelV2 ViewModel
@inject NavigationManager Nav

<PageTemplateV2 PageTitleText="@PageTitle">

    <ActionsContent>
        @if (ViewModel.IsNew)
        {
            <button class="phv2-btn phv2-btn--primary"
                    disabled="@(ViewModel.IsSaving || ViewModel.LinkedStaff is null)"
                    @onclick="OnCreate">
                @(ViewModel.IsSaving ? "Creating..." : "Create User")
            </button>
            <button class="phv2-btn phv2-btn--secondary"
                    disabled="@ViewModel.IsSaving"
                    @onclick="@(() => Nav.NavigateTo("/v2/system/users"))">
                Cancel
            </button>
        }
        else
        {
            <button class="phv2-btn phv2-btn--primary"
                    disabled="@ViewModel.IsSaving"
                    @onclick="OnSaveProfile">
                @(ViewModel.IsSaving ? "Saving..." : "Save Changes")
            </button>
            <button class="phv2-btn phv2-btn--secondary"
                    @onclick="@(() => Nav.NavigateTo("/v2/system/users"))">
                Back to Users
            </button>
        }
    </ActionsContent>

    <ChildContent>

        @if (ViewModel.IsLoading)
        {
            <div class="upv2-loading">
                <i class="bi bi-arrow-clockwise spin" aria-hidden="true"></i>
                Loading...
            </div>
        }
        else
        {
            @if (ViewModel.Error is not null)
            {
                <div class="dsv2-alert dsv2-alert--danger" role="alert">@ViewModel.Error</div>
            }
            @if (ViewModel.Success is not null)
            {
                <div class="dsv2-alert dsv2-alert--success" role="status">@ViewModel.Success</div>
            }

            @* ────────────────────────── PROFILE BANNER ─────────────────────────── *@
            <div class="upv2-banner">

                @* Left: identity / add-mode content *@
                <div class="upv2-banner-identity">

                    @if (ViewModel.IsNew)
                    {
                        <h2 class="upv2-banner-name">New User Account</h2>

                        @if (ViewModel.StaffWithoutAccounts.Count > 0 && ViewModel.LinkedStaff is null)
                        {
                            <div class="upv2-banner-field">
                                <label class="upv2-banner-label" for="nu-staff">Select Staff Member</label>
                                <select id="nu-staff" class="upv2-banner-select" @onchange="OnStaffSelected">
                                    <option value="0">&mdash; Select staff member &mdash;</option>
                                    @foreach (var staff in ViewModel.StaffWithoutAccounts)
                                    {
                                        <option value="@staff.Id">@staff.FullName (@staff.StaffNumber)</option>
                                    }
                                </select>
                                <p class="upv2-field-hint">Only staff without an existing user account are listed.</p>
                            </div>
                        }
                        else if (ViewModel.StaffWithoutAccounts.Count == 0 && ViewModel.LinkedStaff is null)
                        {
                            <p class="upv2-banner-hint">All staff members already have user accounts.</p>
                        }

                        @if (ViewModel.LinkedStaff is not null)
                        {
                            <div class="upv2-banner-meta">
                                <span class="upv2-banner-username">@ViewModel.LinkedStaff.FullName</span>
                                <span class="upv2-badge upv2-badge--role">#@ViewModel.LinkedStaff.StaffNumber</span>
                            </div>
                            @if (!string.IsNullOrEmpty(ViewModel.LinkedStaff.WorkEmail))
                            {
                                <div class="upv2-banner-detail">
                                    <i class="bi bi-envelope" aria-hidden="true"></i>
                                    @ViewModel.LinkedStaff.WorkEmail
                                </div>
                            }
                        }
                    }
                    else
                    {
                        <h2 class="upv2-banner-name">@ViewModel.HeaderFullName</h2>
                        <div class="upv2-banner-meta">
                            <span class="upv2-banner-username">@@@ViewModel.Username</span>
                            @if (!string.IsNullOrEmpty(ViewModel.HeaderRoleName))
                            {
                                <span class="upv2-badge upv2-badge--role">@ViewModel.HeaderRoleName</span>
                            }
                            <span class="upv2-badge upv2-badge--status-@ViewModel.HeaderStatus.ToLower()">
                                @ViewModel.HeaderStatus
                            </span>
                            @if (ViewModel.HeaderIsAdmin)
                            {
                                <span class="upv2-badge upv2-badge--admin">Admin</span>
                            }
                        </div>
                        <div class="upv2-banner-detail">
                            <span><i class="bi bi-envelope" aria-hidden="true"></i> @ViewModel.HeaderEmail</span>
                            <span class="upv2-banner-sep">&middot;</span>
                            <span>
                                <i class="bi bi-clock-history" aria-hidden="true"></i>
                                Last login: @(ViewModel.HeaderLastLogin.HasValue
                                    ? ViewModel.HeaderLastLogin.Value.ToString("dd MMM yyyy HH:mm")
                                    : "Never")
                            </span>
                            <span class="upv2-banner-sep">&middot;</span>
                            <span>
                                <i class="bi bi-calendar3" aria-hidden="true"></i>
                                Joined: @ViewModel.HeaderCreatedAt.ToString("dd MMM yyyy")
                            </span>
                        </div>
                    }

                </div>

                @* Right: circular photo (right-aligned) *@
                <div class="upv2-banner-photo">
                    @if (ViewModel.PhotoDataUri is not null)
                    {
                        <img class="upv2-banner-avatar" src="@ViewModel.PhotoDataUri" alt="Profile photo" />
                    }
                    else
                    {
                        <div class="upv2-banner-avatar upv2-banner-avatar--placeholder">
                            <i class="bi bi-person-fill" aria-hidden="true"></i>
                        </div>
                    }

                    @if (!ViewModel.IsNew)
                    {
                        @if (ViewModel.PhotoError is not null)
                        {
                            <div class="upv2-banner-photo-error">@ViewModel.PhotoError</div>
                        }
                        <label class="upv2-banner-upload @(ViewModel.IsUploadingPhoto ? "upv2-banner-upload--busy" : "")">
                            <InputFile OnChange="OnPhotoChanged" accept="image/*"
                                       class="upv2-file-input" disabled="@ViewModel.IsUploadingPhoto" />
                            <i class="bi bi-camera" aria-hidden="true"></i>
                            @(ViewModel.IsUploadingPhoto ? "Uploading..." : "Upload Photo")
                        </label>
                        @if (ViewModel.PhotoDataUri is not null)
                        {
                            <button class="upv2-banner-upload"
                                    style="color:#fca5a5;border-color:rgba(252,165,165,.3)"
                                    disabled="@ViewModel.IsUploadingPhoto"
                                    @onclick="OnRemovePhoto">
                                <i class="bi bi-trash" aria-hidden="true"></i>
                                Remove
                            </button>
                        }
                    }
                </div>

            </div>
            @* ── end banner ── *@

            @* ──────────────────────── ADD USER FORM ─────────────────────── *@
            @if (ViewModel.IsNew)
            {
                <fieldset disabled="@(ViewModel.LinkedStaff is null)">
                <section class="dsv2-form-section">
                    <header class="dsv2-form-section__header">
                        <i class="bi bi-person-lock" aria-hidden="true"></i>
                        <h2 class="dsv2-form-section__title">Account Details</h2>
                    </header>
                    <div class="dsv2-form-section__body dsv2-grid-2col">

                        <div class="dsv2-form-field">
                            <label class="dsv2-form-label" for="nu-username">Username <span class="upv2-req">*</span></label>
                            <input id="nu-username" type="text" class="dsv2-form-input"
                                   @bind="ViewModel.Username" placeholder="Unique username" autocomplete="username" />
                        </div>

                        <div class="dsv2-form-field">
                            <label class="dsv2-form-label" for="nu-email">Email <span class="upv2-req">*</span></label>
                            <input id="nu-email" type="email" class="dsv2-form-input"
                                   @bind="ViewModel.Email" placeholder="user@school.edu" />
                        </div>

                        <div class="dsv2-form-field">
                            <label class="dsv2-form-label" for="nu-password">Password <span class="upv2-req">*</span></label>
                            <input id="nu-password" type="password" class="dsv2-form-input"
                                   @bind="ViewModel.Password" placeholder="Enter password" autocomplete="new-password" />
                        </div>

                        <div class="dsv2-form-field">
                            <label class="dsv2-form-label" for="nu-role">Role <span class="upv2-req">*</span></label>
                            <select id="nu-role" class="dsv2-form-input"
                                    value="@ViewModel.RoleTypeId"
                                    @onchange="@(e => ViewModel.RoleTypeId = int.Parse(e.Value?.ToString() ?? "0"))">
                                <option value="0">&mdash; Select role &mdash;</option>
                                @foreach (var role in ViewModel.RoleTypes)
                                {
                                    <option value="@role.Id">@role.DisplayName</option>
                                }
                            </select>
                        </div>

                    </div>
                </section>

                @* Module permissions *@
                <section class="dsv2-form-section">
                    <header class="dsv2-form-section__header">
                        <i class="bi bi-key" aria-hidden="true"></i>
                        <h2 class="dsv2-form-section__title">Module Permissions</h2>
                    </header>
                    <div class="dsv2-form-section__body">
                        @if (ViewModel.Permissions.Count == 0)
                        {
                            <p class="upv2-empty-msg">No pages configured. Add pages to the app_pages table first.</p>
                        }
                        else
                        {
                            <PermissionMatrixV2 Permissions="@ViewModel.Permissions" />
                        }
                    </div>
                </section>
                </fieldset>
            }

            @* ──────────────────────── EDIT USER TABS ──────────────────── *@
            else
            {
                    <div class="upv2-right-panel">

                        @* Tab navigation bar *@
                        <div class="upv2-tab-bar" role="tablist">
                            @RenderTabBtn(0, "bi-person",        "Basic Info")
                            @RenderTabBtn(1, "bi-telephone",     "Contacts")
                            @RenderTabBtn(2, "bi-diagram-3",     "Classes")
                            @RenderTabBtn(3, "bi-laptop",        "Devices")
                            @RenderTabBtn(4, "bi-plug",          "External")
                            @RenderTabBtn(5, "bi-heart-pulse",   "Medical")
                            @RenderTabBtn(6, "bi-calendar-x",    "Absences")
                            @RenderTabBtn(7, "bi-shield-check",  "Login Audit")
                        </div>

                        @* ── Tab 0: Basic User Info ───────────────────────────── *@
                        @if (ViewModel.ActiveTab == 0)
                        {
                            <div class="upv2-tab-pane" role="tabpanel">

                                <div class="upv2-section-title">Account Management</div>
                                <div class="upv2-divider"></div>
                                <div class="upv2-form-grid">

                                    <div class="upv2-field">
                                        <label class="upv2-label" for="eu-username">Username <span class="upv2-req">*</span></label>
                                        <input id="eu-username" type="text" class="upv2-input"
                                               @bind="ViewModel.Username" autocomplete="username" />
                                    </div>

                                    <div class="upv2-field">
                                        <label class="upv2-label" for="eu-email">Email <span class="upv2-req">*</span></label>
                                        <input id="eu-email" type="email" class="upv2-input"
                                               @bind="ViewModel.Email" />
                                    </div>

                                    <div class="upv2-field">
                                        <label class="upv2-label" for="eu-fname">First Name</label>
                                        <input id="eu-fname" type="text" class="upv2-input"
                                               @bind="ViewModel.FirstName" placeholder="First name" />
                                    </div>

                                    <div class="upv2-field">
                                        <label class="upv2-label" for="eu-lname">Last Name</label>
                                        <input id="eu-lname" type="text" class="upv2-input"
                                               @bind="ViewModel.LastName" placeholder="Last name" />
                                    </div>

                                    <div class="upv2-field">
                                        <label class="upv2-label" for="eu-nickname">Nickname / Preferred Name</label>
                                        <input id="eu-nickname" type="text" class="upv2-input"
                                               @bind="ViewModel.PreferredName" placeholder="Preferred name" />
                                    </div>

                                    <div class="upv2-field">
                                        <label class="upv2-label" for="eu-title">Title</label>
                                        <input id="eu-title" type="text" class="upv2-input"
                                               @bind="ViewModel.Title" placeholder="e.g. Mr, Mrs, Dr" />
                                    </div>

                                    <div class="upv2-field">
                                        <label class="upv2-label" for="eu-role">Role <span class="upv2-req">*</span></label>
                                        <select id="eu-role" class="upv2-input"
                                                value="@ViewModel.RoleTypeId"
                                                @onchange="@(e => ViewModel.RoleTypeId = int.Parse(e.Value?.ToString() ?? "0"))">
                                            <option value="0">&mdash; Select role &mdash;</option>
                                            @foreach (var role in ViewModel.RoleTypes)
                                            {
                                                <option value="@role.Id">@role.DisplayName</option>
                                            }
                                        </select>
                                    </div>

                                    <div class="upv2-field">
                                        <label class="upv2-label" for="eu-status">Status</label>
                                        <select id="eu-status" class="upv2-input"
                                                value="@ViewModel.Status"
                                                @onchange="@(e => ViewModel.Status = e.Value?.ToString() ?? "active")">
                                            <option value="active">Active</option>
                                            <option value="inactive">Inactive</option>
                                            <option value="suspended">Suspended</option>
                                        </select>
                                    </div>

                                    <div class="upv2-field" style="grid-column: 1 / -1;">
                                        <label class="upv2-label" for="eu-admin">Admin Account</label>
                                        <label style="display:flex;align-items:center;gap:.5rem;font-size:.875rem;cursor:pointer">
                                            <input id="eu-admin" type="checkbox" @bind="ViewModel.IsAdmin" />
                                            Grant full administrator privileges
                                        </label>
                                    </div>

                                </div>

                                <div class="upv2-section-title upv2-section-title--mt">Profile Details</div>
                                <div class="upv2-divider"></div>
                                <div class="upv2-form-grid">

                                    <div class="upv2-field">
                                        <label class="upv2-label" for="eu-dob">Date of Birth</label>
                                        <input id="eu-dob" type="date" class="upv2-input"
                                               value="@ViewModel.DateOfBirth.ToString("yyyy-MM-dd")"
                                               @onchange="@(e => { if (DateTime.TryParse(e.Value?.ToString(), out var d)) ViewModel.DateOfBirth = d; })" />
                                    </div>

                                    <div class="upv2-field">
                                        <label class="upv2-label" for="eu-gender">Gender</label>
                                        <select id="eu-gender" class="upv2-input"
                                                value="@ViewModel.Gender"
                                                @onchange="@(e => ViewModel.Gender = e.Value?.ToString())">
                                            <option value="">&mdash; Not specified &mdash;</option>
                                            <option value="Male">Male</option>
                                            <option value="Female">Female</option>
                                            <option value="Non-binary">Non-binary</option>
                                            <option value="Prefer not to say">Prefer not to say</option>
                                        </select>
                                    </div>

                                    <div class="upv2-field">
                                        <label class="upv2-label" for="eu-tz">Timezone</label>
                                        <input id="eu-tz" type="text" class="upv2-input"
                                               @bind="ViewModel.Timezone" placeholder="e.g. Europe/London" />
                                    </div>

                                    <div class="upv2-field">
                                        <label class="upv2-label" for="eu-lang">Language Code</label>
                                        <input id="eu-lang" type="text" class="upv2-input"
                                               @bind="ViewModel.LanguageCode" placeholder="e.g. en" maxlength="10" />
                                    </div>

                                </div>

                                <div class="upv2-section-title upv2-section-title--mt">About the User</div>
                                <div class="upv2-divider"></div>
                                <div class="upv2-field">
                                    <label class="upv2-label" for="eu-bio">Biographical Info</label>
                                    <textarea id="eu-bio" class="upv2-input upv2-textarea"
                                              @bind="ViewModel.Bio" rows="4"
                                              placeholder="Short biography or notes about this user..."></textarea>
                                </div>

                                @* Module permissions *@
                                <div class="upv2-section-title upv2-section-title--mt">
                                    <i class="bi bi-key" aria-hidden="true"></i> Module Permissions
                                </div>
                                <div class="upv2-divider"></div>
                                @if (ViewModel.Permissions.Count == 0)
                                {
                                    <p class="upv2-empty-msg">No pages configured.</p>
                                }
                                else
                                {
                                    <PermissionMatrixV2 Permissions="@ViewModel.Permissions" />
                                }

                                @* Change password *@
                                <div class="upv2-section-title upv2-section-title--mt">
                                    <i class="bi bi-lock" aria-hidden="true"></i> Change Password
                                </div>
                                <div class="upv2-divider"></div>
                                @if (ViewModel.PwError is not null)
                                {
                                    <div class="upv2-pw-msg upv2-pw-msg--error">@ViewModel.PwError</div>
                                }
                                @if (ViewModel.PwSuccess is not null)
                                {
                                    <div class="upv2-pw-msg upv2-pw-msg--success">@ViewModel.PwSuccess</div>
                                }
                                <div class="upv2-form-grid">
                                    <div class="upv2-field">
                                        <label class="upv2-label" for="pw-old">Current Password</label>
                                        <input id="pw-old" type="password" class="upv2-input"
                                               @bind="ViewModel.OldPassword" autocomplete="current-password"
                                               placeholder="Current password" />
                                    </div>
                                    <div class="upv2-field">
                                        <label class="upv2-label" for="pw-new">New Password</label>
                                        <input id="pw-new" type="password" class="upv2-input"
                                               @bind="ViewModel.NewPassword" autocomplete="new-password"
                                               placeholder="Minimum 8 characters" />
                                    </div>
                                </div>
                                <div class="upv2-pw-action">
                                    <button class="dsv2-btn dsv2-btn--secondary"
                                            disabled="@ViewModel.IsChangingPw"
                                            @onclick="OnChangePw">
                                        @(ViewModel.IsChangingPw ? "Saving..." : "Change Password")
                                    </button>
                                </div>

                            </div>
                        }

                        @* ── Tab 1: Contacts ──────────────────────────────────── *@
                        else if (ViewModel.ActiveTab == 1)
                        {
                            <div class="upv2-tab-pane" role="tabpanel">
                                @if (ViewModel.Contact is null)
                                {
                                    <div class="upv2-no-data">
                                        <i class="bi bi-info-circle"></i> No contact data available for this user.
                                    </div>
                                }
                                else
                                {
                                    var c = ViewModel.Contact;
                                    <div class="upv2-section-title">Contact Information</div>
                                    <div class="upv2-divider"></div>
                                    <div class="upv2-form-grid">
                                        <div class="upv2-field">
                                            <div class="upv2-label">Work Email</div>
                                            <div class="upv2-value">@(string.IsNullOrEmpty(c.WorkEmail) ? "—" : c.WorkEmail)</div>
                                        </div>
                                        <div class="upv2-field">
                                            <div class="upv2-label">Alt Email</div>
                                            <div class="upv2-value">@(string.IsNullOrEmpty(c.AltEmail) ? "—" : c.AltEmail)</div>
                                        </div>
                                        <div class="upv2-field">
                                            <div class="upv2-label">Mobile Phone</div>
                                            <div class="upv2-value">@(string.IsNullOrEmpty(c.PhoneMobile) ? "—" : c.PhoneMobile)</div>
                                        </div>
                                        <div class="upv2-field">
                                            <div class="upv2-label">Home Phone</div>
                                            <div class="upv2-value">@(string.IsNullOrEmpty(c.PhoneHome) ? "—" : c.PhoneHome)</div>
                                        </div>
                                        <div class="upv2-field">
                                            <div class="upv2-label">Emergency Phone</div>
                                            <div class="upv2-value">@(string.IsNullOrEmpty(c.PhoneEmergency) ? "—" : c.PhoneEmergency)</div>
                                        </div>
                                        <div class="upv2-field">
                                            <div class="upv2-label">Work Location</div>
                                            <div class="upv2-value">@(string.IsNullOrEmpty(c.WorkLocation) ? "—" : c.WorkLocation)</div>
                                        </div>
                                    </div>
                                    <div class="upv2-section-title upv2-section-title--mt">Employment</div>
                                    <div class="upv2-divider"></div>
                                    <div class="upv2-form-grid">
                                        <div class="upv2-field">
                                            <div class="upv2-label">Employment Type</div>
                                            <div class="upv2-value">@(string.IsNullOrEmpty(c.EmploymentType) ? "—" : c.EmploymentType)</div>
                                        </div>
                                        <div class="upv2-field">
                                            <div class="upv2-label">Contract Type</div>
                                            <div class="upv2-value">@(string.IsNullOrEmpty(c.ContractType) ? "—" : c.ContractType)</div>
                                        </div>
                                        <div class="upv2-field">
                                            <div class="upv2-label">Hire Date</div>
                                            <div class="upv2-value">@c.HireDate.ToString("dd MMM yyyy")</div>
                                        </div>
                                        <div class="upv2-field">
                                            <div class="upv2-label">End Date</div>
                                            <div class="upv2-value">@(c.EndDate.HasValue ? c.EndDate.Value.ToString("dd MMM yyyy") : "Current")</div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }

                        @* ── Tab 2: Classes & Year Groups ─────────────────────── *@
                        else if (ViewModel.ActiveTab == 2)
                        {
                            <div class="upv2-tab-pane" role="tabpanel">
                                @if (ViewModel.Classes.Count == 0)
                                {
                                    <div class="upv2-no-data">
                                        <i class="bi bi-info-circle"></i> No class assignments found for this staff member.
                                    </div>
                                }
                                else
                                {
                                    <div class="upv2-section-title">Class &amp; Role Assignments</div>
                                    <div class="upv2-divider"></div>
                                    <div class="upv2-table-container">
                                    <table class="upv2-table">
                                        <thead>
                                            <tr>
                                                <th>Location</th>
                                                <th>Start Date</th>
                                                <th>End Date</th>
                                                <th>Notes</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var row in ViewModel.Classes)
                                            {
                                                <tr>
                                                    <td>@row.LocationId</td>
                                                    <td>@row.StartDate.ToString("dd MMM yyyy")</td>
                                                    <td>@(row.EndDate.HasValue ? row.EndDate.Value.ToString("dd MMM yyyy") : "Current")</td>
                                                    <td>@(row.Notes ?? string.Empty)</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                    </div>
                                }
                            </div>
                        }

                        @* ── Tab 3: Devices ───────────────────────────────────── *@
                        else if (ViewModel.ActiveTab == 3)
                        {
                            <div class="upv2-tab-pane" role="tabpanel">
                                @if (ViewModel.Devices.Count == 0)
                                {
                                    <div class="upv2-no-data">
                                        <i class="bi bi-info-circle"></i> No devices assigned to this staff member.
                                    </div>
                                }
                                else
                                {
                                    <div class="upv2-section-title">Assigned Devices</div>
                                    <table class="upv2-table">
                                        <thead>
                                            <tr>
                                                <th>Device Type</th>
                                                <th>Serial Number</th>
                                                <th>Assigned</th>
                                                <th>Returned</th>
                                                <th>Status</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var row in ViewModel.Devices)
                                            {
                                                <tr>
                                                    <td>@row.DeviceType</td>
                                                    <td><code>@row.SerialNumber</code></td>
                                                    <td>@row.AssignedDate.ToString("dd MMM yyyy")</td>
                                                    <td>@(row.ReturnedDate.HasValue ? row.ReturnedDate.Value.ToString("dd MMM yyyy") : "—")</td>
                                                    <td>
                                                        @if (row.ReturnedDate.HasValue)
                                                        {
                                                            <span class="upv2-pill upv2-pill--grey">Returned</span>
                                                        }
                                                        else
                                                        {
                                                            <span class="upv2-pill upv2-pill--green">Active</span>
                                                        }
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                }
                            </div>
                        }

                        @* ── Tab 4: External Systems ──────────────────────────── *@
                        else if (ViewModel.ActiveTab == 4)
                        {
                            <div class="upv2-tab-pane" role="tabpanel">
                                @if (ViewModel.ExternalAccounts.Count == 0)
                                {
                                    <div class="upv2-no-data">
                                        <i class="bi bi-info-circle"></i> No external system accounts linked.
                                    </div>
                                }
                                else
                                {
                                    <div class="upv2-section-title">Linked External Accounts</div>
                                    <div class="upv2-divider"></div>
                                    <div class="upv2-table-container">
                                    <table class="upv2-table">
                                        <thead>
                                            <tr>
                                                <th>System</th>
                                                <th>Code</th>
                                                <th>Account Username</th>
                                                <th>Account Email</th>
                                                <th>Status</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var row in ViewModel.ExternalAccounts)
                                            {
                                                <tr>
                                                    <td>@row.SystemName</td>
                                                    <td><code>@row.SystemCode</code></td>
                                                    <td>@row.AccountUsername</td>
                                                    <td>@row.AccountEmail</td>
                                                    <td>
                                                        <span class="upv2-status @(row.Status == "active" ? "upv2-status--active" : "upv2-status--inactive")">
                                                            @row.Status
                                                        </span>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                    </div>
                                }
                            </div>
                        }

                        @* ── Tab 5: Medical Records ───────────────────────────── *@
                        else if (ViewModel.ActiveTab == 5)
                        {
                            <div class="upv2-tab-pane" role="tabpanel">
                                <div class="upv2-no-data upv2-no-data--center">
                                    <i class="bi bi-heart-pulse fs-1" aria-hidden="true"></i>
                                    <p>Medical records for staff are not currently tracked in this system.</p>
                                    <p class="upv2-no-data-sub">Student medical records are managed under Student Profiles.</p>
                                </div>
                            </div>
                        }

                        @* ── Tab 6: Absence Records ───────────────────────────── *@
                        else if (ViewModel.ActiveTab == 6)
                        {
                            <div class="upv2-tab-pane" role="tabpanel">
                                @if (ViewModel.Absences.Count == 0)
                                {
                                    <div class="upv2-no-data">
                                        <i class="bi bi-info-circle"></i> No absence records found for this staff member.
                                    </div>
                                }
                                else
                                {
                                    <div class="upv2-section-title">
                                        Absence History (@ViewModel.Absences.Count records)
                                    </div>
                                    <div class="upv2-divider"></div>
                                    <div class="upv2-table-container">
                                    <table class="upv2-table">
                                        <thead>
                                            <tr>
                                                <th>Type</th>
                                                <th>Status</th>
                                                <th>Start</th>
                                                <th>End</th>
                                                <th>Days</th>
                                                <th>Reported Via</th>
                                                <th>Approved</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var row in ViewModel.Absences)
                                            {
                                                <tr>
                                                    <td>@row.AbsenceType</td>
                                                    <td><span class="upv2-pill upv2-pill--status">@row.Status</span></td>
                                                    <td>@row.StartDate.ToString("dd MMM yyyy")</td>
                                                    <td>@row.EndDate.ToString("dd MMM yyyy")</td>
                                                    <td>@row.DurationDays</td>
                                                    <td>@row.ReportedVia</td>
                                                    <td>@(row.ApprovedAt.HasValue ? row.ApprovedAt.Value.ToString("dd MMM yyyy") : "Pending")</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                    </div>
                                }
                            </div>
                        }

                        @* ── Tab 7: Login Audit ───────────────────────────────── *@
                        else if (ViewModel.ActiveTab == 7)
                        {
                            <div class="upv2-tab-pane" role="tabpanel">
                                @if (ViewModel.LoginAudit.Count == 0)
                                {
                                    <div class="upv2-no-data">
                                        <i class="bi bi-info-circle"></i> No login audit records found for this user.
                                    </div>
                                }
                                else
                                {
                                    <div class="upv2-section-title">
                                        Login History (last @ViewModel.LoginAudit.Count entries)
                                    </div>
                                    <div class="upv2-divider"></div>
                                    <div class="upv2-table-container">
                                    <table class="upv2-table">
                                        <thead>
                                            <tr>
                                                <th>Date &amp; Time</th>
                                                <th>IP Address</th>
                                                <th>Result</th>
                                                <th>User Agent</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var row in ViewModel.LoginAudit)
                                            {
                                                <tr>
                                                    <td>@row.LoginTime.ToString("dd MMM yyyy HH:mm:ss")</td>
                                                    <td><code>@row.IpAddress</code></td>
                                                    <td>
                                                        @if (row.Success)
                                                        {
                                                            <span class="upv2-status upv2-status--active">Success</span>
                                                        }
                                                        else
                                                        {
                                                            <span class="upv2-status upv2-status--inactive">Failed</span>
                                                        }
                                                    </td>
                                                    <td class="upv2-ua">@row.UserAgent</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                    </div>
                                }
                            </div>
                        }

                    </div>
            }
        }

    </ChildContent>

</PageTemplateV2>

@code {

    [Parameter] public long? Id      { get; set; }   // edit route
    [Parameter] public long? StaffId { get; set; }   // /v2/users/{StaffId:long}/new route

    [SupplyParameterFromQuery(Name = "staffId")]
    public long? QueryStaffId { get; set; }          // /v2/users/new?staffId=… pre-selection

    private string PageTitle => ViewModel.IsNew
        ? "Add User Account"
        : (string.IsNullOrEmpty(ViewModel.HeaderFullName) ? "User Profile" : ViewModel.HeaderFullName);

    protected override async Task OnInitializedAsync()
    {
        if (Id.HasValue)
            await ViewModel.InitEditAsync(Id.Value);
        else
        {
            // Both /v2/users/new (with optional ?staffId=) and /v2/users/{StaffId}/new.
            var preselectedId = StaffId ?? QueryStaffId ?? 0L;
            await ViewModel.InitNewAsync((int)preselectedId);
        }
    }

    private async Task OnStaffSelected(ChangeEventArgs e)
    {
        var id = long.TryParse(e.Value?.ToString(), out var parsed) ? parsed : 0L;
        await ViewModel.SelectLinkedStaffAsync((int)id);
    }

    private async Task OnCreate()
    {
        var (ok, newId) = await ViewModel.CreateUserAsync();
        if (ok)
            Nav.NavigateTo($"/v2/users/{newId}/edit");
    }

    private async Task OnSaveProfile()
    {
        await ViewModel.SaveProfileAsync();
    }

    private async Task OnChangePw()
    {
        await ViewModel.ChangePasswordAsync();
    }

    private async Task OnPhotoChanged(InputFileChangeEventArgs e)
    {
        await ViewModel.UploadPhotoAsync(e.File);
    }

    private async Task OnRemovePhoto()
    {
        await ViewModel.RemovePhotoAsync();
    }

    private RenderFragment RenderTabBtn(int index, string icon, string label) =>
        @<button role="tab"
                 aria-selected="@(ViewModel.ActiveTab == index)"
                 class="upv2-tab-btn @(ViewModel.ActiveTab == index ? "upv2-tab-btn--active" : "")"
                 @onclick="@(() => ViewModel.SetTab(index))">
            <i class="bi @icon" aria-hidden="true"></i>
            <span>@label</span>
        </button>;
}
