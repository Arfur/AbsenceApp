@code {

    [Parameter] public long? Id      { get; set; }   // edit route
    [Parameter] public long? StaffId { get; set; }   // /v2/users/{StaffId:long}/new route

    [SupplyParameterFromQuery(Name = "staffId")]
    public long? QueryStaffId { get; set; }          // /v2/users/new?staffId=� pre-selection

    // Tracks which user was last loaded so OnParametersSetAsync can detect navigation.
    private long? _loadedId;

    private string PageTitle => ViewModel.IsNew
        ? "Add User Account"
        : (string.IsNullOrEmpty(ViewModel.HeaderFullName) ? "User Profile" : ViewModel.HeaderFullName);

    protected override async Task OnInitializedAsync()
    {
        if (Id.HasValue)
        {
            _loadedId = Id;
            await ViewModel.InitEditAsync(Id.Value);
        }
        else
        {
            // Both /v2/users/new (with optional ?staffId=) and /v2/users/{StaffId}/new.
            var preselectedId = StaffId ?? QueryStaffId;
            await ViewModel.InitNewAsync(preselectedId);
        }
    }

    // Fires when the user navigates to a different Id via the banner dropdown.
    // OnInitializedAsync only runs once per component lifetime; this handles re-use.
    protected override async Task OnParametersSetAsync()
    {
        if (Id.HasValue && Id != _loadedId)
        {
            _loadedId = Id;
            await ViewModel.InitEditAsync(Id.Value);
            StateHasChanged();
        }
        else if (!Id.HasValue && _loadedId.HasValue)
        {
            _loadedId = null;
            var preselectedId = StaffId ?? QueryStaffId;
            await ViewModel.InitNewAsync(preselectedId);
            StateHasChanged();
        }
    }

    private async Task OnStaffSelected(ChangeEventArgs e)
    {
        var id = long.TryParse(e.Value?.ToString(), out var parsed) ? parsed : 0L;
        await ViewModel.SelectLinkedStaffAsync((int)id);
    }

    private void OnUserSelectChanged(ChangeEventArgs e)
    {
        if (long.TryParse(e.Value?.ToString(), out var selectedId) && selectedId > 0)
            Nav.NavigateTo($"/v2/system/users/{selectedId}");
    }

    private async Task OnCreate()
    {
        var (ok, newId) = await ViewModel.CreateUserAsync();
        if (ok)
        {
            await ViewModel.RefreshDropdownsAsync();
            Nav.NavigateTo($"/v2/system/users/{newId}");
        }
    }

    private async Task OnSaveProfile()
    {
        await ViewModel.SaveProfileAsync();
    }

    private async Task OnChangePw()
    {
        await ViewModel.ChangePasswordAsync();
    }

    private async Task OnPhotoChanged(InputFileChangeEventArgs e)
    {
        await ViewModel.UploadPhotoAsync(e.File);
    }

    private async Task OnRemovePhoto()
    {
        await ViewModel.RemovePhotoAsync();
    }

    private RenderFragment RenderTabBtn(int index, string icon, string label, bool disabled = false) =>
        @<button role="tab"
                 aria-selected="@(ViewModel.ActiveTab == index)"
                 class="upv2-tab-btn @(ViewModel.ActiveTab == index ? "upv2-tab-btn--active" : "") @(disabled ? "upv2-tab-btn--disabled" : "")"
                 disabled="@disabled"
                 @onclick="@(() => ViewModel.SetTab(index))">
            <i class="bi @icon" aria-hidden="true"></i>
            <span>@label</span>
        </button>;
}
