@* ===========================================================================
   File        : SettingsFormPageV2.razor
   Namespace   : AbsenceApp.Client.Modules.Settings
   Author      : Michael
   Version     : 1.1.0
   Created     : 2026-03-21
   Updated     : 2026-03-26
   ---------------------------------------------------------------------------
   Purpose     : V2 Settings form/edit page. Allows inline editing of all field
                 settings for a specific table page using the V2 PageTemplateV2
                 primitive instead of deprecated FormPageV2 and FormSectionV2.
                 Delegates state and saves to SettingsModuleViewModelV2.
   ---------------------------------------------------------------------------
   Changes     :
     - 1.0.0  2026-03-21  Initial implementation (Phase 7).
     - 1.0.1  2026-03-25  Removed invalid V2 component imports.
     - 1.1.0  2026-03-26  Replaced FormPageV2 + FormSectionV2 with PageTemplateV2.
                          Updated namespace and layout. Added explicit form
                          structure and preserved all ViewModel logic.
   ---------------------------------------------------------------------------
   Notes       :
     - Route: /v2/settings/{PageName}/edit
     - Register SettingsModuleViewModelV2 as Scoped in Phase 10.
   ===========================================================================
*@

@page "/v2/settings/{PageName}/edit"
@layout BaseLayoutV2
@namespace AbsenceApp.Client.Modules.Settings

@using AbsenceApp.Client.ViewModels.V2
@inject SettingsModuleViewModelV2 ViewModel
@inject AppStateService AppState
@inject NavigationManager Nav

<PageTemplateV2 PageTitleText="@PageTitle">

    <ActionsContent>
        <button class="dsv2-btn dsv2-btn--primary"
                disabled="@ViewModel.IsBusy"
                @onclick="OnSave">
            @(ViewModel.IsBusy ? "Saving…" : "Save Settings")
        </button>

        <button class="dsv2-btn dsv2-btn--secondary"
                disabled="@ViewModel.IsBusy"
                @onclick="@(() => Nav.NavigateTo($"/v2/settings/{PageName}"))">
            Cancel
        </button>
    </ActionsContent>

    <ChildContent>

        @if (ViewModel.Error is not null)
        {
            <div class="dsv2-alert dsv2-alert--danger" role="alert">
                @ViewModel.Error
            </div>
        }

        @if (ViewModel.IsLoading)
        {
            <p class="dsv2-loading-text">Loading settings…</p>
        }
        else if (ViewModel.Settings.Count > 0)
        {
            <section class="dsv2-form-section">
                <header class="dsv2-form-section__header">
                    <i class="bi bi-sliders" aria-hidden="true"></i>
                    <h2 class="dsv2-form-section__title">Field Configuration</h2>
                </header>

                <div class="dsv2-form-section__body">

                    @foreach (var setting in ViewModel.Settings)
                    {
                        <div class="dsv2-settings-row">

                            <div class="dsv2-settings-row__field">
                                <span class="dsv2-settings-row__key">@setting.FieldName</span>
                            </div>

                            <div class="dsv2-form-field">
                                <label class="dsv2-form-label"
                                       for="@($"label-{setting.Id}")">
                                    Display Label
                                </label>

                                <input id="@($"label-{setting.Id}")"
                                       type="text"
                                       class="dsv2-form-input"
                                       @bind="@setting.DisplayLabel" />
                            </div>

                            <div class="dsv2-settings-row__flags">

                                <label class="dsv2-form-checkbox">
                                    <input type="checkbox" @bind="@setting.IsVisible" />
                                    Visible
                                </label>

                                <label class="dsv2-form-checkbox">
                                    <input type="checkbox" @bind="@setting.IsSortable" />
                                    Sortable
                                </label>

                                <label class="dsv2-form-checkbox">
                                    <input type="checkbox" @bind="@setting.IsSearchable" />
                                    Searchable
                                </label>

                                <label class="dsv2-form-checkbox">
                                    <input type="checkbox" @bind="@setting.IsFilterable" />
                                    Filterable
                                </label>

                                <div class="dsv2-form-field dsv2-form-field--inline">
                                    <label class="dsv2-form-label"
                                           for="@($"order-{setting.Id}")">
                                        Order
                                    </label>

                                    <input id="@($"order-{setting.Id}")"
                                           type="number"
                                           class="dsv2-form-input dsv2-form-input--narrow"
                                           @bind="@setting.DisplayOrder" />
                                </div>

                            </div>
                        </div>
                    }

                </div>
            </section>
        }
        else
        {
            <p class="dsv2-loading-text">
                No settings found for page "@PageName".
            </p>
        }

    </ChildContent>

</PageTemplateV2>

@code {
    [Parameter] public string PageName { get; set; } = string.Empty;

    private string PageTitle =>
        string.IsNullOrEmpty(PageName)
            ? "Edit Settings"
            : $"Edit Settings – {PageName}";

    private string BackLabel =>
        string.IsNullOrEmpty(PageName)
            ? "Settings"
            : PageName;

    protected override async Task OnParametersSetAsync()
    {
        AppState.SetBreadcrumb("Settings", PageName);
        await ViewModel.LoadSettingsAsync(PageName);
    }

    private async Task OnSave()
    {
        bool ok = await ViewModel.SaveSettingsAsync();
        if (ok)
            Nav.NavigateTo($"/v2/settings/{PageName}");
    }
}
