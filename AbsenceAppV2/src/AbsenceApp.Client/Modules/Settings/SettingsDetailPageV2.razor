@* ===========================================================================
   File        : SettingsDetailPageV2.razor
   Namespace   : AbsenceApp.Client.ModulesV2.Settings
   Author      : Michael
   Version     : 1.0.0
   Created     : 2026-03-21
   Updated     : 2026-03-21
   ---------------------------------------------------------------------------
   Purpose     : V2 Settings detail page. Displays all field settings for a
                 specific table page using DetailPageV2 and DetailSectionV2.
                 Delegates data loading to SettingsModuleViewModelV2.
   ---------------------------------------------------------------------------
   Changes     :
     - 1.0.0  2026-03-21  Initial implementation (Phase 7).
   ---------------------------------------------------------------------------
   Notes       :
     - Route: /v2/settings/{PageName}
     - Register SettingsModuleViewModelV2 as Scoped in Phase 10.
   ===========================================================================
*@

@page "/v2/settings/{PageName}"
@layout AbsenceApp.Client.Components.Layout.MainLayoutV2
@using AbsenceApp.Client.Components.PageTemplatesV2
@using AbsenceApp.Client.ViewModels.V2
@inject SettingsModuleViewModelV2 ViewModel
@inject AppStateService AppState
@inject NavigationManager Nav

@* =========================================================================
   Section: Settings detail
   ========================================================================= *@
<DetailPageV2 PageTitle="@PageTitle"
              BackHref="/v2/settings"
              BackLabel="Settings">

    <ActionsContent>
        <a href="@($"/v2/settings/{PageName}/edit")" class="dsv2-btn dsv2-btn--secondary">Edit Settings</a>
    </ActionsContent>

    <BodyContent>
        @if (ViewModel.IsLoading)
        {
            <p class="dsv2-loading-text">Loading�</p>
        }
        else if (ViewModel.Error is not null)
        {
            <div class="dsv2-alert dsv2-alert--danger" role="alert">@ViewModel.Error</div>
        }
        else if (ViewModel.Settings.Count > 0)
        {
            <DetailSectionV2 Title="Field Settings" Icon="bi-sliders">
                <BodyContent>
                    @foreach (var setting in ViewModel.Settings)
                    {
                        <span class="dsv2-detail-label">@setting.FieldName</span>
                        <span class="dsv2-detail-value">
                            @setting.DisplayLabel
                            <span class="dsv2-settings-flags">
                                @if (setting.IsVisible)   { <span class="dsv2-flag dsv2-flag--on">Visible</span> }
                                @if (setting.IsSortable)  { <span class="dsv2-flag dsv2-flag--on">Sortable</span> }
                                @if (setting.IsSearchable){ <span class="dsv2-flag dsv2-flag--on">Searchable</span> }
                                @if (setting.IsFilterable){ <span class="dsv2-flag dsv2-flag--on">Filterable</span> }
                            </span>
                        </span>
                    }
                </BodyContent>
            </DetailSectionV2>
        }
        else
        {
            <p class="dsv2-loading-text">No settings found for page "@PageName".</p>
        }
    </BodyContent>

</DetailPageV2>

@* =========================================================================
   Section: ViewModel wiring and navigation
   ========================================================================= *@
@code {
    [Parameter] public string PageName { get; set; } = string.Empty;

    private string PageTitle => string.IsNullOrEmpty(PageName)
        ? "Page Settings"
        : $"Settings � {PageName}";

    protected override async Task OnParametersSetAsync()
    {
        AppState.SetBreadcrumb("Settings", PageName);
        await ViewModel.LoadSettingsAsync(PageName);
    }
}
