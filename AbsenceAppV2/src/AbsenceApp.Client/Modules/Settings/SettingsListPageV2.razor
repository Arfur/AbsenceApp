@* ===========================================================================
   File        : SettingsListPageV2.razor
   Namespace   : AbsenceApp.Client.Modules.Settings
   Author      : Michael
   Version     : 1.1.0
   Created     : 2026-03-21
   Updated     : 2026-03-26
   ---------------------------------------------------------------------------
   Purpose     : V2 Settings list page. Lists all table settings pages sourced
                 from the diagnostics report using the V2 PageTemplateV2
                 primitive instead of the deprecated StandardPageV2 wrapper.
   ---------------------------------------------------------------------------
   Changes     :
     - 1.0.0  2026-03-21  Initial implementation (Phase 7).
     - 1.0.1  2026-03-25  Removed invalid V2 component imports.
     - 1.1.0  2026-03-26  Replaced StandardPageV2 with PageTemplateV2.
                          Updated namespace. Updated layout to BaseLayoutV2.
                          Corrected ChildContent slot usage.
   ---------------------------------------------------------------------------
   Notes       :
     - Route: /v2/settings
     - Register SettingsModuleViewModelV2 as Scoped in Phase 10.
   ===========================================================================
*@

@page "/v2/settings"
@layout BaseLayoutV2
@namespace AbsenceApp.Client.Modules.Settings

@using AbsenceApp.Client.ViewModels.V2
@inject SettingsModuleViewModelV2 ViewModel
@inject AppStateService AppState
@inject NavigationManager Nav

<PageTemplateV2 PageTitleText="Table Settings">

    <ChildContent>

        @if (ViewModel.IsDiagnosticsLoading)
        {
            <p class="dsv2-loading-text">Loading settings pages…</p>
        }
        else if (ViewModel.DiagnosticsError is not null)
        {
            <div class="dsv2-alert dsv2-alert--danger" role="alert">
                @ViewModel.DiagnosticsError
            </div>
        }
        else if (ViewModel.DiagnosticsReport is not null)
        {
            <div class="dsv2-settings-grid">
                @foreach (var pg in ViewModel.DiagnosticsReport.Pages)
                {
                    <div class="dsv2-settings-card">
                        <div class="dsv2-settings-card__header">
                            <i class="bi bi-table" aria-hidden="true"></i>
                            <span class="dsv2-settings-card__title">@pg.PageKey</span>
                            <span class="dsv2-settings-card__badge dsv2-settings-card__badge--@pg.Status.ToLowerInvariant()">
                                @pg.Status
                            </span>
                        </div>

                        <p class="dsv2-settings-card__meta">
                            @pg.SavedFields.Count saved fields • @pg.SchemaFields.Count schema fields
                        </p>

                        <div class="dsv2-settings-card__actions">
                            <a href="@($"/v2/settings/{pg.PageKey}")"
                               class="dsv2-btn dsv2-btn--secondary dsv2-btn--sm">View</a>

                            <a href="@($"/v2/settings/{pg.PageKey}/edit")"
                               class="dsv2-btn dsv2-btn--primary dsv2-btn--sm">Edit</a>
                        </div>
                    </div>
                }
            </div>

            @if (ViewModel.DiagnosticsReport.OrphanedDbPageKeys.Count > 0)
            {
                <div class="dsv2-alert dsv2-alert--warning" role="note">
                    <strong>Orphaned page keys in database:</strong>
                    @string.Join(", ", ViewModel.DiagnosticsReport.OrphanedDbPageKeys)
                </div>
            }
        }

    </ChildContent>

</PageTemplateV2>

@code {
    protected override async Task OnInitializedAsync()
    {
        AppState.SetBreadcrumb("Settings", "Table Settings");
        await ViewModel.LoadDiagnosticsAsync();
    }
}
