@* ===========================================================================
   File        : AuditLogListPageV2.razor
   Namespace   : AbsenceApp.Client.ModulesV2.AuditLog
   Author      : Michael
   Version     : 1.2.1
   Created     : 2026-03-21
   Updated     : 2026-04-04
   ---------------------------------------------------------------------------
   Purpose     : V2 Audit Log list page. Read-only paged table of audit log
                 entries using StandardPageV2 and TableV2. No add/edit/delete
                 actions – audit log entries are immutable.
   ---------------------------------------------------------------------------
   Changes     :
     - 1.0.0  2026-03-21  Initial implementation (Phase 7).
     - 1.0.1  2026-03-25  Removed invalid @using Components.PageTemplatesV2 and/or
                          Components.TableV2. These components are provided via
                          the correct Framework namespaces through Modules/_Imports.razor.
     - 1.1.0  2026-03-26  Replaced fully-qualified layout
                          'AbsenceApp.Client.Components.Layout.MainLayoutV2'
                          with 'MainLayoutV2' to remove dependency on the
                          obsolete Components.Layout namespace, and added an
                          explicit @using for Framework page templates so
                          StandardPageV2 resolves correctly. Normalised text
                          encoding for UI copy. No functional changes.
     - 1.2.0  2026-03-26  Replaced @layout MainLayoutV2 with @layout MainLayoutV2;
                          MainLayoutV2 no longer exists — BaseLayoutV2 is the
                          V2 authenticated-shell layout (CS0246 build error fix).
     - (bumped)  2026-04-04  Phase 3 Stabilisation Issue 2: changed @layout from BaseLayoutV2 to MainLayoutV2 so all module pages use the canonical V2 shell layout with correct fixed-header padding.
     - 1.3.0  2026-04-14  E9 Change 7: added Export dropdown (PDF/Excel, no
                          back-end action) in PageTemplateV2 ActionsContent.
   ---------------------------------------------------------------------------
   Notes       :
     - Route: /v2/auditlog
     - Register AuditLogListViewModelV2 as Scoped in Phase 10.
   ===========================================================================
*@

@page "/v2/auditlog"

@using AbsenceApp.Client.Framework.PageTemplates
@using AbsenceApp.Client.ViewModels.V2

@layout MainLayoutV2
@inject AuditLogListViewModelV2 ViewModel
@inject AppStateService AppState
@inject NavigationManager Nav

@* =========================================================================
   Section: Audit log list
   ========================================================================= *@
<PageTemplateV2 PageTitleText="Audit Log">

    <ActionsContent>
        @if (_showExportMenu)
        {
            <div class="phv2-export-backdrop" @onclick="CloseExportMenu" aria-hidden="true"></div>
        }
        <div class="phv2-export-wrap">
            <button type="button"
                    class="phv2-btn phv2-btn--secondary"
                    @onclick="ToggleExportMenu"
                    aria-expanded="@_showExportMenu"
                    aria-haspopup="true">
                <i class="bi bi-download" aria-hidden="true"></i>
                Export
                <i class="bi @(_showExportMenu ? "bi-chevron-up" : "bi-chevron-down") phv2-btn__chevron" aria-hidden="true"></i>
            </button>
            @if (_showExportMenu)
            {
                <div class="phv2-export-dd" role="menu">
                    <button type="button" class="phv2-export-item" role="menuitem">
                        <i class="bi bi-file-earmark-pdf" aria-hidden="true"></i>
                        Export as PDF
                    </button>
                    <button type="button" class="phv2-export-item" role="menuitem">
                        <i class="bi bi-file-earmark-excel" aria-hidden="true"></i>
                        Export as Excel
                    </button>
                </div>
            }
        </div>
    </ActionsContent>

    <ChildContent>
        @if (ViewModel.Error is not null)
        {
            <div class="dsv2-alert dsv2-alert--danger" role="alert">@ViewModel.Error</div>
        }

        <TableV2 TItem="AbsenceApp.Core.DTOs.AuditLogDto"
                 Columns="AuditLogListViewModelV2.Columns"
                 Items="ViewModel.Items"
                 TotalCount="ViewModel.TotalCount"
                 IsLoading="ViewModel.IsLoading"
                 CurrentPage="ViewModel.Page"
                 PageSize="ViewModel.PageSize"
                 SortColumn="ViewModel.SortColumn"
                 SortAscending="ViewModel.SortAscending"
                 SearchPlaceholder="Search audit log..."
                 AriaLabel="Audit log table"
                 OnSearchChanged="OnSearch"
                 OnSortChanged="OnSort"
                 OnPageChanged="OnPageChanged"
                 OnPageSizeChanged="OnPageSizeChanged">

            <RowTemplate Context="entry">
                <td class="dsv2-table__td">@entry.AuditId</td>
                <td class="dsv2-table__td">@entry.UserId</td>
                <td class="dsv2-table__td">@entry.Action</td>
                <td class="dsv2-table__td">@entry.Timestamp.ToString("dd MMM yyyy HH:mm")</td>
            </RowTemplate>

            <RowActionsContent Context="entry">
                <a href="@($"/v2/auditlog/{entry.AuditId}")" class="dsv2-table__row-action">View</a>
            </RowActionsContent>

        </TableV2>
    </ChildContent>

</PageTemplateV2>

@* =========================================================================
   Section: ViewModel wiring and table callbacks
   ========================================================================= *@
@code {
    protected override async Task OnInitializedAsync()
    {
        AppState.SetBreadcrumb("Audit Log");
        await ViewModel.LoadAsync();
    }

    private async Task OnSearch(string term) =>
        await ViewModel.SearchAsync(term);

    private async Task OnSort((string Column, bool Ascending) args) =>
        await ViewModel.SortAsync(args.Column, args.Ascending);

    private async Task OnPageChanged(int page) =>
        await ViewModel.GoToPageAsync(page);

    private async Task OnPageSizeChanged(int size) =>
        await ViewModel.ChangePageSizeAsync(size);

    private bool _showExportMenu;
    private void ToggleExportMenu() => _showExportMenu = !_showExportMenu;
    private void CloseExportMenu()  => _showExportMenu = false;
}
