@* ===========================================================================
   File        : DashboardPageV2.razor
   Namespace   : AbsenceApp.Client.Modules.Dashboard
   Author      : Michael
   Version     : 1.8.0
   Created     : 2026-03-21
   Updated     : 2026-03-28
   ---------------------------------------------------------------------------
   Purpose     : Dashboard page at /v2/dashboard. Composes PageTemplateV2 (outer
                 chrome) with DashboardPageTemplate (inner grid layout). Stat
                 cards are passed to DashboardPageTemplate's StatCards slot and
                 body panels are passed to ChildContent.
   ---------------------------------------------------------------------------
   Changes     :
     - 1.0.0  2026-03-21  Initial implementation.
     - 1.1.0  2026-03-23  Added @layout BaseLayoutV2 directive.
     - 1.1.1  2026-03-25  Removed invalid @using directives.
     - 1.2.0  2026-03-25  Moved to Modules/Dashboard. Corrected namespace.
     - 1.3.0  2026-03-25  Updated route to /v2/dashboard.
     - 1.4.0  2026-03-26  Replaced BodyContent with ChildContent to align with
                          PageTemplateV2 slot model.
     - 1.5.0  2026-03-27  Phase 3 Part 2: added inline placeholder stat cards
                          and two placeholder panels.
     - 1.6.0  2026-03-27  Phase 3 Shell Fix: wired to DashboardPageTemplate;
                          replaced dsv2-dashboard-page div structure with
                          DashboardPageTemplate component slots.
     - 1.7.0  2026-03-28  Section 1A: Added /v2/dashboard/overview alias route
                          so post-login navigation target matches requirement.     - 1.8.0  2026-03-28  Fixed PageTitleText from generic "Dashboard" to      
                          "Operational Overview" matching the sidebar menu label.   ---------------------------------------------------------------------------
   Notes       :
     - Phase 3 component. Static placeholder data only.
     - No DI registration required.
     - Inherits BaseLayoutV2 for consistent V2 page structure.
   ===========================================================================
*@

@page "/v2/dashboard"
@page "/v2/dashboard/overview"
@layout BaseLayoutV2
@namespace AbsenceApp.Client.Modules.Dashboard

<PageTemplateV2 PageTitleText="Operational Overview">

    @* =========================
       SECTION: ACTIONS BAR
       ========================= *@
    <ActionsContent>
        <span class="dsv2-page-action-hint">Overview as of today &mdash; placeholder data</span>
    </ActionsContent>

    @* =========================
       SECTION: CONTENT REGION
       DashboardPageTemplate handles the inner grid layout.
       ========================= *@
    <ChildContent>
        <DashboardPageTemplate>

            @* =========================
               SECTION: METRICS STRIP
               Six stat cards passed to the CARDS REGION slot.
               ========================= *@
            <StatCards>
                <div class="dsv2-stat-card dsv2-stat-card--blue">
                    <i class="bi bi-people dsv2-stat-card__icon"></i>
                    <span class="dsv2-stat-card__value">45</span>
                    <span class="dsv2-stat-card__label">Total Staff</span>
                </div>
                <div class="dsv2-stat-card dsv2-stat-card--teal">
                    <i class="bi bi-mortarboard dsv2-stat-card__icon"></i>
                    <span class="dsv2-stat-card__value">312</span>
                    <span class="dsv2-stat-card__label">Students Enrolled</span>
                </div>
                <div class="dsv2-stat-card dsv2-stat-card--orange">
                    <i class="bi bi-calendar-x dsv2-stat-card__icon"></i>
                    <span class="dsv2-stat-card__value">18</span>
                    <span class="dsv2-stat-card__label">Active Absences Today</span>
                </div>
                <div class="dsv2-stat-card dsv2-stat-card--green">
                    <i class="bi bi-check-circle dsv2-stat-card__icon"></i>
                    <span class="dsv2-stat-card__value">64</span>
                    <span class="dsv2-stat-card__label">Resolved This Week</span>
                </div>
                <div class="dsv2-stat-card dsv2-stat-card--red">
                    <i class="bi bi-exclamation-triangle dsv2-stat-card__icon"></i>
                    <span class="dsv2-stat-card__value">7</span>
                    <span class="dsv2-stat-card__label">Pending Reviews</span>
                </div>
                <div class="dsv2-stat-card dsv2-stat-card--purple">
                    <i class="bi bi-bar-chart dsv2-stat-card__icon"></i>
                    <span class="dsv2-stat-card__value">94.2%</span>
                    <span class="dsv2-stat-card__label">Attendance Rate</span>
                </div>
            </StatCards>

            @* =========================
               SECTION: BODY PANELS
               Two panels passed to the PANELS REGION (ChildContent) slot.
               ========================= *@
            <ChildContent>
                @* Recent Activity panel *@
                <div class="dsv2-dashboard-panel">
                    <div class="dsv2-dashboard-panel__header">
                        <h2 class="dsv2-dashboard-panel__title">
                            <i class="bi bi-activity"></i>
                            Recent Activity
                        </h2>
                    </div>
                    <div class="dsv2-dashboard-panel__body">
                        <ul class="dsv2-activity-list">
                            <li class="dsv2-activity-list__item">
                                <span class="dsv2-activity-list__dot dsv2-activity-list__dot--blue"></span>
                                <span>Jane Smith reported absent at 08:14</span>
                                <time class="dsv2-activity-list__time">09:00</time>
                            </li>
                            <li class="dsv2-activity-list__item">
                                <span class="dsv2-activity-list__dot dsv2-activity-list__dot--green"></span>
                                <span>Absence for Tom Briggs resolved</span>
                                <time class="dsv2-activity-list__time">09:32</time>
                            </li>
                            <li class="dsv2-activity-list__item">
                                <span class="dsv2-activity-list__dot dsv2-activity-list__dot--orange"></span>
                                <span>Register submitted &mdash; Year 9 English</span>
                                <time class="dsv2-activity-list__time">10:05</time>
                            </li>
                            <li class="dsv2-activity-list__item">
                                <span class="dsv2-activity-list__dot dsv2-activity-list__dot--red"></span>
                                <span>Medical note flagged for review</span>
                                <time class="dsv2-activity-list__time">10:47</time>
                            </li>
                            <li class="dsv2-activity-list__item">
                                <span class="dsv2-activity-list__dot dsv2-activity-list__dot--teal"></span>
                                <span>Student Aaliyah Hassan returned from absence</span>
                                <time class="dsv2-activity-list__time">11:15</time>
                            </li>
                        </ul>
                    </div>
                </div>

                @* Absence Summary panel *@
                <div class="dsv2-dashboard-panel">
                    <div class="dsv2-dashboard-panel__header">
                        <h2 class="dsv2-dashboard-panel__title">
                            <i class="bi bi-clipboard2-pulse"></i>
                            Absence Summary
                        </h2>
                    </div>
                    <div class="dsv2-dashboard-panel__body">
                        <table class="dsv2-summary-table">
                            <thead>
                                <tr>
                                    <th>Type</th>
                                    <th>Staff</th>
                                    <th>Students</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr><td>Sick Leave</td>     <td>4</td>  <td>11</td></tr>
                                <tr><td>Authorised</td>     <td>2</td>  <td>5</td></tr>
                                <tr><td>Unauthorised</td>   <td>0</td>  <td>2</td></tr>
                                <tr><td>Medical Appt.</td>  <td>1</td>  <td>3</td></tr>
                                <tr class="dsv2-summary-table__total">
                                    <td>Total Today</td>    <td>7</td>  <td>21</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </ChildContent>

        </DashboardPageTemplate>
    </ChildContent>

</PageTemplateV2>

@code {
    // No runtime parameters needed — all content is static placeholder data.
}
