@* ===========================================================================
   File        : _Imports.razor
   Namespace   : AbsenceApp.Client.Modules
   Author      : Michael
   Version     : 1.0.3
   Created     : 2026-03-25
   ---------------------------------------------------------------------------
   Purpose     : Global using directives for all Razor components under the
                 Modules/ subtree. Ensures that all V2 pages (Attendance,
                 AuditLog, Classes, Staff, Students, etc.) correctly resolve
                 Framework V2 components such as:
                   - TableV2
                   - RowTemplate
                   - RowActionsContent
                   - PaginationV2
                   - PageTemplateV2
                 This file intentionally avoids importing legacy namespaces
                 such as AbsenceApp.Client.Components.Table to prevent
                 duplicate component definitions (RZ9985).
   ---------------------------------------------------------------------------
   Changes     :
     - 1.0.0  2026-03-25  Initial implementation. Added Framework.Tables and
                          Framework.PageTemplates imports. Excluded all
                          legacy Components.Table namespaces.
     - 1.0.1  2026-03-25  Fixed @using AbsenceApp.Client.Framework.Layout to
                          AbsenceApp.Client.Framework.Layouts to match actual
                          auto-inferred namespace for the Framework/Layouts/
                          folder (CS0234 build error).
     - 1.0.2  2026-03-25  Attempted update to PageTemplatesV2 namespace after
                          folder restructuring (later found to be incorrect).
     - 1.0.3  2026-03-25  Corrected PageTemplates namespace to
                          AbsenceApp.Client.Framework.PageTemplates after
                          confirming final folder location.
   ---------------------------------------------------------------------------
   Notes       :
     - Modules depend on Framework V2 components, not legacy Components.Table.
     - This file must remain minimal and deterministic.
     - Do NOT add Components.Table here under any circumstances.
   ===========================================================================
*@

@* =========================================================================
   Framework and BCL usings
   ========================================================================= *@
@using System.Net.Http
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components.Routing
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.AspNetCore.Components.Web.Virtualization
@using Microsoft.JSInterop

@* =========================================================================
   Application usings — AbsenceApp-specific namespaces
   ========================================================================= *@
@using AbsenceApp.Client
@using AbsenceApp.Client.Services
@using AbsenceApp.Client.Shared
@using AbsenceApp.Core.Interfaces
@using AbsenceApp.Core.Navigation
@using AbsenceApp.Core.ViewModels
@using AbsenceApp.Core.DTOs

@* =========================================================================
   V2 Framework imports — REQUIRED for all V2 pages
   ========================================================================= *@
@using AbsenceApp.Client.Framework.Tables
@using AbsenceApp.Client.Framework.PageTemplates
@using AbsenceApp.Client.Framework.Layouts
@using AbsenceApp.Client.Components.Templates
