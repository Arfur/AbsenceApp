@* ===========================================================================
   File        : ClassesListPageV2.razor
   Namespace   : AbsenceApp.Client.Modules.Classes
   Author      : Michael
   Version     : 2.0.0
   Created     : 2026-03-21
   Updated     : 2026-04-06
   ---------------------------------------------------------------------------
   Purpose     : V2 Classes list page — V1-matching layout using
                 TablePageTemplateV2 with search, sort, and V1 pagination.
                 Delegates data and state to ClassesListViewModelV2.
   ---------------------------------------------------------------------------
   Changes     :
     - 1.0.0  2026-03-21  Initial implementation (Phase 7).
     - 1.0.1  2026-03-25  Removed invalid V2 component imports.
     - 1.1.0  2026-03-26  Replaced StandardPageV2 with PageTemplateV2.
     - 1.1.1  2026-04-04  Phase 3 Stabilisation Issue 2: changed @layout to
                          MainLayoutV2 for correct fixed-header shell.
     - 2.0.0  2026-04-06  Phase 3 V1 Parity Issue 4: rewrote to use
                          TablePageTemplateV2 (not TableV2). Replaced
                          ClassesApiServiceV2 (HTTP) with IClassService (EF
                          Core direct) via ClassesListViewModelV2.
     - 2.1.0  2026-04-14  E9 Change 7: moved 'Add Class' button and new
                          Export dropdown into PageTemplateV2 ActionsContent.
                          Removed ActionButtons slot from TablePageTemplateV2.
   ---------------------------------------------------------------------------
   Notes       :
     - Route: /v2/classes
   ===========================================================================
*@

@page "/v2/classes"
@layout MainLayoutV2
@namespace AbsenceApp.Client.Modules.Classes

@using AbsenceApp.Client.Shared
@using AbsenceApp.Client.ViewModels.V2
@inject ClassesListViewModelV2 ViewModel
@inject AppStateService AppState
@inject NavigationManager Nav

<PageTemplateV2 PageTitleText="Classes">

    <ActionsContent>
        @if (_showExportMenu)
        {
            <div class="phv2-export-backdrop" @onclick="CloseExportMenu" aria-hidden="true"></div>
        }
        <div class="phv2-export-wrap">
            <button type="button"
                    class="phv2-btn phv2-btn--secondary"
                    @onclick="ToggleExportMenu"
                    aria-expanded="@_showExportMenu"
                    aria-haspopup="true">
                <i class="bi bi-download" aria-hidden="true"></i>
                Export
                <i class="bi @(_showExportMenu ? "bi-chevron-up" : "bi-chevron-down") phv2-btn__chevron" aria-hidden="true"></i>
            </button>
            @if (_showExportMenu)
            {
                <div class="phv2-export-dd" role="menu">
                    <button type="button" class="phv2-export-item" role="menuitem">
                        <i class="bi bi-file-earmark-pdf" aria-hidden="true"></i>
                        Export as PDF
                    </button>
                    <button type="button" class="phv2-export-item" role="menuitem">
                        <i class="bi bi-file-earmark-excel" aria-hidden="true"></i>
                        Export as Excel
                    </button>
                </div>
            }
        </div>
        <button type="button"
                class="phv2-btn phv2-btn--add"
                @onclick="@(() => Nav.NavigateTo("/v2/classes/new"))">
            <i class="bi bi-plus-circle" aria-hidden="true"></i>
            Add Class
        </button>
    </ActionsContent>

    <ChildContent>

        @* Error banner *@
        @if (ViewModel.Error is not null)
        {
            <div class="dsv2-alert dsv2-alert--danger" role="alert">@ViewModel.Error</div>
        }

        <TablePageTemplateV2

            TotalRows="@ViewModel.TotalCount"
            CurrentPage="@ViewModel.Page"
            ShowEntries="@ViewModel.PageSize"
            SearchValue="@ViewModel.SearchTerm"
            ActiveFilters="@_activeFilterChips"

            OnShowEntriesChanged="@OnShowEntriesChanged"
            OnSearchChanged="@OnSearchChanged"
            OnRemoveFilter="@OnRemoveFilter"
            OnClearAllFilters="@OnClearAllFilters">

            <Filters>
                <select class="tpt-filter-select"
                        value="@GetFilter("name")"
                        @onchange="@(e => SetFilter("name", "Class Name", e.Value?.ToString()))">
                    <option value="">Class Name</option>
                    @foreach (var v in ViewModel.GetNameOptions())
                    {
                        <option value="@v">@v</option>
                    }
                </select>
                <select class="tpt-filter-select"
                        value="@GetFilter("code")"
                        @onchange="@(e => SetFilter("code", "Code", e.Value?.ToString()))">
                    <option value="">Code</option>
                    @foreach (var v in ViewModel.GetCodeOptions())
                    {
                        <option value="@v">@v</option>
                    }
                </select>
            </Filters>

            @* =========================================================
               TABLE HEADER
               ========================================================= *@
            <TableHeader>
                <th class="tpt-th">
                    <button class="tpt-sort-btn @SortClass("name")"
                            @onclick="@(() => OnSort("name"))">
                        Class Name
                        <span class="tpt-sort-icons">
                            <span class="tpt-sort-up">▲</span>
                            <span class="tpt-sort-dn">▼</span>
                        </span>
                    </button>
                </th>
                <th class="tpt-th">
                    <button class="tpt-sort-btn @SortClass("code")"
                            @onclick="@(() => OnSort("code"))">
                        Code
                        <span class="tpt-sort-icons">
                            <span class="tpt-sort-up">▲</span>
                            <span class="tpt-sort-dn">▼</span>
                        </span>
                    </button>
                </th>
                <th class="tpt-th">Description</th>
                <th class="tpt-th tpt-th--actions">Actions</th>
            </TableHeader>

            @* =========================================================
               TABLE BODY
               ========================================================= *@
            <TableBody>
                @if (ViewModel.IsLoading)
                {
                    @for (var i = 0; i < ViewModel.PageSize; i++)
                    {
                        <tr class="tpt-tr tpt-tr--skeleton">
                            <td class="tpt-td"><span class="tpt-skeleton"></span></td>
                            <td class="tpt-td"><span class="tpt-skeleton"></span></td>
                            <td class="tpt-td"><span class="tpt-skeleton"></span></td>
                            <td class="tpt-td"><span class="tpt-skeleton"></span></td>
                        </tr>
                    }
                }
                else if (ViewModel.Items.Count == 0)
                {
                    <tr>
                        <td class="tpt-td tpt-td--empty" colspan="4">No classes found.</td>
                    </tr>
                }
                else
                {
                    @foreach (var cls in ViewModel.Items)
                    {
                        <tr class="tpt-tr">
                            <td class="tpt-td">@cls.Name</td>
                            <td class="tpt-td">@(cls.Code ?? "—")</td>
                            <td class="tpt-td">@(cls.Description ?? "—")</td>
                            <td class="tpt-td tpt-td--actions">
                                <a href="@($"/v2/classes/{cls.Id}")"
                                   class="tpt-action-icon tpt-action-view" title="View">
                                    <i class="bi bi-eye" aria-hidden="true"></i>
                                </a>
                                <a href="@($"/v2/classes/{cls.Id}/edit")"
                                   class="tpt-action-icon tpt-action-edit" title="Edit">
                                    <i class="bi bi-pencil" aria-hidden="true"></i>
                                </a>
                            </td>
                        </tr>
                    }
                }
            </TableBody>

            @* =========================================================
               PAGINATION — 10-page sliding window + ellipsis
               ========================================================= *@
            <Pagination>
                @{
                    var totalPages = ViewModel.PageSize > 0
                        ? (int)Math.Ceiling((double)ViewModel.TotalCount / ViewModel.PageSize)
                        : 1;
                    var page     = ViewModel.Page;
                    var winStart = Math.Max(1, page - 4);
                    var winEnd   = Math.Min(totalPages, winStart + 9);
                    if (winEnd - winStart < 9) winStart = Math.Max(1, winEnd - 9);
                }

                <button class="tpt-page-btn tpt-page-prev"
                        disabled="@(page <= 1)"
                        @onclick="@(() => OnPageChanged(page - 1))">
                    &#8592; Previous
                </button>

                @for (var p = winStart; p <= winEnd; p++)
                {
                    var pCopy = p;
                    <button class="tpt-page-btn @(pCopy == page ? "tpt-active" : "")"
                            @onclick="@(() => OnPageChanged(pCopy))">
                        @pCopy
                    </button>
                }

                @if (winEnd < totalPages)
                {
                    <span class="tpt-page-ellipsis">...</span>
                }

                <button class="tpt-page-btn tpt-page-next"
                        disabled="@(page >= totalPages)"
                        @onclick="@(() => OnPageChanged(page + 1))">
                    Next &#8594;
                </button>
            </Pagination>

        </TablePageTemplateV2>

    </ChildContent>

</PageTemplateV2>

@code {

    // ─── Filter state ────────────────────────────────────────────────────────
    private readonly Dictionary<string, string> _f = new()
    {
        ["name"] = string.Empty,
        ["code"] = string.Empty,
    };

    private List<FilterChip> _activeFilterChips = [];

    private static readonly Dictionary<string, string> _keyToLabel = new()
    {
        ["name"] = "Class Name",
        ["code"] = "Code",
    };

    private static readonly Dictionary<string, string> _labelToKey =
        _keyToLabel.ToDictionary(kv => kv.Value, kv => kv.Key);

    private string GetFilter(string key) => _f.GetValueOrDefault(key, string.Empty);

    private async Task SetFilter(string key, string label, string? value)
    {
        _f[key] = value ?? string.Empty;
        RebuildChips();
        await ViewModel.SetFilterAsync(key, value ?? string.Empty);
    }

    private async Task OnRemoveFilter(FilterChip chip)
    {
        var key = _labelToKey.GetValueOrDefault(chip.Name ?? "");
        if (key is not null) _f[key] = string.Empty;
        RebuildChips();
        if (key is not null) await ViewModel.RemoveFilterAsync(key);
    }

    private async Task OnClearAllFilters()
    {
        foreach (var key in _f.Keys.ToList()) _f[key] = string.Empty;
        _activeFilterChips = [];
        await ViewModel.ClearAllFiltersAsync();
    }

    private void RebuildChips() =>
        _activeFilterChips = _f
            .Where(kv => !string.IsNullOrWhiteSpace(kv.Value))
            .Select(kv => new FilterChip(_keyToLabel[kv.Key], kv.Value))
            .ToList();

    // ─── Lifecycle ───────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        AppState.SetBreadcrumb("Classes", "All Classes");
        await ViewModel.LoadAsync();
    }

    private async Task OnSearchChanged(string term) =>
        await ViewModel.SearchAsync(term);

    private async Task OnSort(string column)
    {
        var ascending = ViewModel.SortColumn == column ? !ViewModel.SortAscending : true;
        await ViewModel.SortAsync(column, ascending);
    }

    private async Task OnPageChanged(int page) =>
        await ViewModel.GoToPageAsync(page);

    private async Task OnShowEntriesChanged(int size) =>
        await ViewModel.ChangePageSizeAsync(size);

    private string SortClass(string column) =>
        ViewModel.SortColumn != column ? "" :
        ViewModel.SortAscending ? "asc" : "desc";

    private bool _showExportMenu;
    private void ToggleExportMenu() => _showExportMenu = !_showExportMenu;
    private void CloseExportMenu()  => _showExportMenu = false;
}

