@page "/v2/classes/{Id:long}"
@layout MainLayoutV2
@namespace AbsenceApp.Client.Modules.Classes

@using AbsenceApp.Client.ViewModels.V2
@inject ClassDetailViewModelV2 ViewModel
@inject AppStateService AppState
@inject NavigationManager Nav

<PageTemplateV2 PageTitleText="@PageTitle">

    <ActionsContent>
        @if (ViewModel.Item is not null)
        {
            <a href="@($"/v2/classes/{Id}/edit")"
               class="dsv2-btn dsv2-btn--secondary">
                Edit
            </a>
        }
    </ActionsContent>

    <ChildContent>

        @if (ViewModel.IsLoading)
        {
            <p class="dsv2-loading-text">Loading…</p>
        }
        else if (ViewModel.Error is not null)
        {
            <div class="dsv2-alert dsv2-alert--danger" role="alert">
                @ViewModel.Error
            </div>
        }
        else if (ViewModel.Item is not null)
        {
            var item = ViewModel.Item;

            <section class="dsv2-detail-section">
                <header class="dsv2-detail-section__header">
                    <i class="bi bi-mortarboard" aria-hidden="true"></i>
                    <h2 class="dsv2-detail-section__title">Class Details</h2>
                </header>

                <div class="dsv2-detail-section__body">

                    <span class="dsv2-detail-label">Name</span>
                    <span class="dsv2-detail-value">@item.Name</span>

                    <span class="dsv2-detail-label">Code</span>
                    <span class="dsv2-detail-value">@(item.Code ?? "—")</span>

                    <span class="dsv2-detail-label">Description</span>
                    <span class="dsv2-detail-value">@(item.Description ?? "—")</span>

                </div>
            </section>
        }

    </ChildContent>

</PageTemplateV2>

@code {
    [Parameter] public long Id { get; set; }

    private string PageTitle =>
        ViewModel.Item is not null
            ? ViewModel.Item.Name
            : "Class";

    protected override async Task OnParametersSetAsync()
    {
        AppState.SetBreadcrumb("Classes", "Class Detail");
        await ViewModel.LoadAsync(Id);
    }
}
