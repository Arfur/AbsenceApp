@* ===========================================================================
   File        : StudentsListPageV2.razor
   Namespace   : AbsenceApp.Client.Modules.Students
   Author      : Michael
   Version     : 1.1.0
   Created     : 2026-03-21
   Updated     : 2026-03-26
   ---------------------------------------------------------------------------
   Purpose     : V2 Students list page. Displays a paged, searchable, sortable
                 table of students using the V2 PageTemplateV2 primitive
                 instead of deprecated StandardPageV2. Delegates all data and
                 state to StudentsListViewModelV2.
   ---------------------------------------------------------------------------
   Changes     :
     - 1.0.0  2026-03-21  Initial implementation (Phase 7).
     - 1.0.1  2026-03-25  Removed invalid V2 component imports.
     - 1.1.0  2026-03-26  Replaced StandardPageV2 with PageTemplateV2.
                          Updated namespace and layout. Preserved table logic.
   ---------------------------------------------------------------------------
   Notes       :
     - Route: /v2/students
     - Register StudentsListViewModelV2 as Scoped in Phase 10.
   ===========================================================================
*@

@page "/v2/students"
@layout BaseLayoutV2
@namespace AbsenceApp.Client.Modules.Students

@using AbsenceApp.Client.Models.TableV2
@using AbsenceApp.Client.ViewModels.V2
@inject StudentsListViewModelV2 ViewModel
@inject AppStateService AppState
@inject NavigationManager Nav

<PageTemplateV2 PageTitleText="Students">

    <ActionsContent>
        <button type="button"
                class="dsv2-btn dsv2-btn--primary"
                @onclick="GoToAdd">
            <i class="bi bi-plus-circle" aria-hidden="true"></i>
            Add Student
        </button>
    </ActionsContent>

    <ChildContent>

        @if (ViewModel.Error is not null)
        {
            <div class="dsv2-alert dsv2-alert--danger" role="alert">
                @ViewModel.Error
            </div>
        }

        <TableV2 TItem="AbsenceApp.Core.DTOs.StudentDto"
                 Columns="StudentsListViewModelV2.Columns"
                 Items="ViewModel.Items"
                 TotalCount="ViewModel.TotalCount"
                 IsLoading="ViewModel.IsLoading"
                 CurrentPage="ViewModel.Page"
                 PageSize="ViewModel.PageSize"
                 SortColumn="ViewModel.SortColumn"
                 SortAscending="ViewModel.SortAscending"
                 SearchPlaceholder="Search students…"
                 AriaLabel="Students table"
                 OnSearchChanged="OnSearch"
                 OnSortChanged="OnSort"
                 OnPageChanged="OnPageChanged"
                 OnPageSizeChanged="OnPageSizeChanged">

            <RowTemplate Context="student">
                <td class="dsv2-table__td">@student.AdmissionNumber</td>
                <td class="dsv2-table__td">@student.FirstName</td>
                <td class="dsv2-table__td">@student.LastName</td>
                <td class="dsv2-table__td">@student.Gender</td>
                <td class="dsv2-table__td">@student.Status</td>
                <td class="dsv2-table__td">@student.DateOfBirth.ToString("dd/MM/yyyy")</td>
                <td class="dsv2-table__td">@student.YearGroupId</td>
            </RowTemplate>

            <RowActionsContent Context="student">
                <a href="@DetailHref(student.Id)" class="dsv2-table__row-action">View</a>
                <a href="@EditHref(student.Id)" class="dsv2-table__row-action">Edit</a>
            </RowActionsContent>

        </TableV2>

    </ChildContent>

</PageTemplateV2>

@code {
    protected override async Task OnInitializedAsync()
    {
        AppState.SetBreadcrumb("Students", "All Students");
        await ViewModel.LoadAsync();
    }

    private async Task OnSearch(string term) =>
        await ViewModel.SearchAsync(term);

    private async Task OnSort((string Column, bool Ascending) args) =>
        await ViewModel.SortAsync(args.Column, args.Ascending);

    private async Task OnPageChanged(int page) =>
        await ViewModel.GoToPageAsync(page);

    private async Task OnPageSizeChanged(int size) =>
        await ViewModel.ChangePageSizeAsync(size);

    private void GoToAdd() =>
        Nav.NavigateTo("/v2/students/new");

    private static string DetailHref(long id) =>
        $"/v2/students/{id}";

    private static string EditHref(long id) =>
        $"/v2/students/{id}/edit";
}
