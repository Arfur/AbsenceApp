@* ===========================================================================
   File        : StudentProfilePageV2.razor
   Namespace   : AbsenceApp.Client.Modules.Students
   Author      : Michael
   Version     : 2.0.0
   Created     : 2026-05-05
   Updated     : 2026-05-05
   ---------------------------------------------------------------------------
   Purpose     : Combined view / edit / add student profile page.
                 View mode shows all tabs read-only.
                 Edit mode (Tab 0) allows editing all basic fields.
                 Add mode (/v2/students/new) initialises a blank form.
   ---------------------------------------------------------------------------
   Changes     :
     - 1.0.0  2026-05-05  Initial creation (view-only).
     - 2.0.0  2026-05-05  Phase 4: combined view+edit+add mode.
   ---------------------------------------------------------------------------
   Notes       :
     - Routes: /v2/students/{Id:int}  +  /v2/students/new
     - Tabs: 0=Profile, 1=Contacts, 2=Medical, 3=Flags,
             4=Additional, 5=Notes, 6=Absences
     - CSS prefix: spv2-*
   ===========================================================================
*@

@page "/v2/students/{Id:int}"
@page "/v2/students/new"
@layout MainLayoutV2
@namespace AbsenceApp.Client.Modules.Students

@using AbsenceApp.Client.ViewModels.V2
@inject StudentProfileViewModelV2 ViewModel
@inject NavigationManager Nav

<PageTemplateV2 PageTitleText="@PageTitle">

    <ActionsContent>
        @if (ViewModel.IsEditing)
        {
            <button class="spv2-btn spv2-btn--primary"
                    disabled="@ViewModel.IsSaving"
                    @onclick="OnSave">
                <i class="bi bi-check-lg" aria-hidden="true"></i> @(ViewModel.IsSaving ? "Saving…" : "Save Student")
            </button>
            @if (!ViewModel.IsNew)
            {
                <button class="spv2-btn spv2-btn--secondary"
                        disabled="@ViewModel.IsSaving"
                        @onclick="@(() => ViewModel.CancelEdit())">
                    <i class="bi bi-x-lg" aria-hidden="true"></i> Cancel
                </button>
            }
        }
        else
        {
            <button class="spv2-btn spv2-btn--primary"
                    @onclick="OnBeginEdit">
                <i class="bi bi-pencil" aria-hidden="true"></i> Edit
            </button>
            <button class="spv2-btn spv2-btn--secondary"
                    @onclick="@(() => Nav.NavigateTo($"/v2/students/{Id}/calendar"))">
                <i class="bi bi-calendar3" aria-hidden="true"></i> View Calendar
            </button>
        }
        <button class="spv2-btn spv2-btn--secondary"
                @onclick="@(() => Nav.NavigateTo("/v2/students"))">
            <i class="bi bi-arrow-left" aria-hidden="true"></i> Back to Students
        </button>
    </ActionsContent>

    <ChildContent>

        @if (ViewModel.IsLoading)
        {
            <div class="spv2-loading">
                <i class="bi bi-arrow-clockwise spin" aria-hidden="true"></i> Loading...
            </div>
        }
        else
        {
            @if (ViewModel.Error is not null)
            {
                <div class="dsv2-alert dsv2-alert--danger" role="alert">@ViewModel.Error</div>
            }

            @* ─── SAVE ERROR ───────────────────────────────────────────────── *@
            @if (ViewModel.SaveError is not null)
            {
                <div class="dsv2-alert dsv2-alert--danger" role="alert">@ViewModel.SaveError</div>
            }

            @* ─── PROFILE BANNER ───────────────────────────────────────────── *@
            <div class="spv2-banner">

                @* Left — avatar with upload *@
                <div class="spv2-banner-photo">
                    <label class="spv2-banner-avatar-label @(ViewModel.IsUploadingPhoto ? "spv2-banner-upload--busy" : "")">
                        <InputFile OnChange="OnPhotoChanged" accept="image/*"
                                   class="spv2-file-input" disabled="@ViewModel.IsUploadingPhoto" />
                        @if (ViewModel.PhotoDataUri is not null)
                        {
                            <img class="spv2-banner-avatar" src="@ViewModel.PhotoDataUri" alt="Student photo" />
                        }
                        else
                        {
                            <div class="spv2-banner-avatar spv2-banner-avatar--placeholder">
                                <i class="bi bi-person-circle" aria-hidden="true"></i>
                            </div>
                        }
                    </label>
                    @if (ViewModel.PhotoError is not null)
                    {
                        <div class="spv2-banner-photo-error">@ViewModel.PhotoError</div>
                    }
                    @if (ViewModel.PhotoDataUri is not null)
                    {
                        <button class="spv2-banner-remove-photo" @onclick="OnRemovePhoto">
                            <i class="bi bi-trash" aria-hidden="true"></i> Remove
                        </button>
                    }
                </div>

                @* Right — identity block *@
                <div class="spv2-banner-identity">
                    <div class="spv2-banner-name">@ViewModel.HeaderFullName</div>
                    <div class="spv2-banner-kv-row">
                        <span class="spv2-banner-kv-label">Admission No:</span>
                        <span class="spv2-banner-kv-value">@ViewModel.HeaderAdmissionNumber</span>
                    </div>
                    <div class="spv2-banner-kv-row">
                        <span class="spv2-banner-kv-label">Year Group:</span>
                        <span class="spv2-banner-kv-value">@ViewModel.HeaderYearGroup</span>
                    </div>
                    <div class="spv2-banner-kv-row">
                        <span class="spv2-banner-kv-label">Class:</span>
                        <span class="spv2-banner-kv-value">@ViewModel.HeaderClass</span>
                    </div>
                    <div class="spv2-banner-kv-row">
                        <span class="spv2-banner-kv-label">Status:</span>
                        <span class="spv2-badge spv2-badge--@ViewModel.HeaderStatus.ToLower()">
                            @ViewModel.HeaderStatus
                        </span>
                    </div>
                </div>
            </div>

            @* ─── TAB BAR ──────────────────────────────────────────────────── *@
            <div class="spv2-tab-bar">
                @foreach (var (label, idx) in Tabs)
                {
                    <button class="spv2-tab @(ViewModel.ActiveTab == idx ? "spv2-tab--active" : "")"
                            @onclick="@(() => ViewModel.SetTab(idx))">
                        @label
                    </button>
                }
            </div>

            @* ─── TAB CONTENT ──────────────────────────────────────────────── *@
            <div class="spv2-tab-content">

                @* Tab 0 — Profile (view or edit) *@
                @if (ViewModel.ActiveTab == 0)
                {
                    @if (ViewModel.IsEditing)
                    {
                        @* ── Edit / Add form ── *@
                        <div class="spv2-edit-form">

                            <div class="spv2-edit-section-title">Personal Details</div>
                            <div class="spv2-fields-grid spv2-fields-grid--edit">

                                <div class="spv2-form-field">
                                    <label class="spv2-form-label" for="fld-fname">First Name <span class="spv2-req">*</span></label>
                                    <input id="fld-fname" type="text" class="spv2-form-input"
                                           @bind="ViewModel.EditFirstName" />
                                </div>
                                <div class="spv2-form-field">
                                    <label class="spv2-form-label" for="fld-lname">Last Name <span class="spv2-req">*</span></label>
                                    <input id="fld-lname" type="text" class="spv2-form-input"
                                           @bind="ViewModel.EditLastName" />
                                </div>
                                <div class="spv2-form-field">
                                    <label class="spv2-form-label" for="fld-mnames">Middle Names</label>
                                    <input id="fld-mnames" type="text" class="spv2-form-input"
                                           @bind="ViewModel.EditMiddleNames" />
                                </div>
                                <div class="spv2-form-field">
                                    <label class="spv2-form-label" for="fld-prefname">Preferred Name</label>
                                    <input id="fld-prefname" type="text" class="spv2-form-input"
                                           @bind="ViewModel.EditPreferredName" />
                                </div>
                                <div class="spv2-form-field">
                                    <label class="spv2-form-label" for="fld-legalfname">Legal First Name</label>
                                    <input id="fld-legalfname" type="text" class="spv2-form-input"
                                           @bind="ViewModel.EditLegalFirstName" />
                                </div>
                                <div class="spv2-form-field">
                                    <label class="spv2-form-label" for="fld-legallname">Legal Last Name</label>
                                    <input id="fld-legallname" type="text" class="spv2-form-input"
                                           @bind="ViewModel.EditLegalLastName" />
                                </div>
                                <div class="spv2-form-field">
                                    <label class="spv2-form-label" for="fld-gender">Gender</label>
                                    <input id="fld-gender" type="text" class="spv2-form-input"
                                           @bind="ViewModel.EditGender" />
                                </div>
                                <div class="spv2-form-field">
                                    <label class="spv2-form-label" for="fld-dob">Date of Birth <span class="spv2-req">*</span></label>
                                    <input id="fld-dob" type="date" class="spv2-form-input"
                                           value="@ViewModel.EditDateOfBirth.ToString("yyyy-MM-dd")"
                                           @onchange="OnDobChanged" />
                                </div>

                            </div>

                            <div class="spv2-edit-section-title">Academic Details</div>
                            <div class="spv2-fields-grid spv2-fields-grid--edit">

                                <div class="spv2-form-field">
                                    <label class="spv2-form-label" for="fld-admno">Admission Number <span class="spv2-req">*</span></label>
                                    <input id="fld-admno" type="text" class="spv2-form-input"
                                           @bind="ViewModel.EditAdmissionNumber" />
                                </div>
                                <div class="spv2-form-field">
                                    <label class="spv2-form-label" for="fld-admdate">Admission Date <span class="spv2-req">*</span></label>
                                    <input id="fld-admdate" type="date" class="spv2-form-input"
                                           value="@ViewModel.EditAdmissionDate.ToString("yyyy-MM-dd")"
                                           @onchange="OnAdmissionDateChanged" />
                                </div>
                                <div class="spv2-form-field">
                                    <label class="spv2-form-label" for="fld-yeargroup">Year Group <span class="spv2-req">*</span></label>
                                    <select id="fld-yeargroup" class="spv2-form-input"
                                            @bind="ViewModel.EditYearGroupId">
                                        <option value="0">— Select —</option>
                                        @foreach (var yg in ViewModel.YearGroups)
                                        {
                                            <option value="@yg.Id">@yg.Name</option>
                                        }
                                    </select>
                                </div>
                                <div class="spv2-form-field">
                                    <label class="spv2-form-label" for="fld-class">Class</label>
                                    <select id="fld-class" class="spv2-form-input"
                                            value="@(ViewModel.EditClassId?.ToString() ?? "")"
                                            @onchange="OnClassChanged">
                                        <option value="">— None —</option>
                                        @foreach (var cl in ViewModel.Classes)
                                        {
                                            <option value="@cl.Id">@cl.Name</option>
                                        }
                                    </select>
                                </div>
                                <div class="spv2-form-field">
                                    <label class="spv2-form-label" for="fld-house">House</label>
                                    <select id="fld-house" class="spv2-form-input"
                                            value="@(ViewModel.EditHouseId?.ToString() ?? "")"
                                            @onchange="OnHouseChanged">
                                        <option value="">— None —</option>
                                        @foreach (var h in ViewModel.Houses)
                                        {
                                            <option value="@h.Id">@h.Name</option>
                                        }
                                    </select>
                                </div>
                                <div class="spv2-form-field">
                                    <label class="spv2-form-label" for="fld-status">Status <span class="spv2-req">*</span></label>
                                    <select id="fld-status" class="spv2-form-input"
                                            @bind="ViewModel.EditStatus">
                                        <option value="Active">Active</option>
                                        <option value="Inactive">Inactive</option>
                                        <option value="Suspended">Suspended</option>
                                        <option value="Left">Left</option>
                                    </select>
                                </div>

                            </div>

                            <div class="spv2-edit-section-title">Account</div>
                            <div class="spv2-fields-grid spv2-fields-grid--edit">

                                <div class="spv2-form-field">
                                    <label class="spv2-form-label" for="fld-username">Username</label>
                                    <input id="fld-username" type="text" class="spv2-form-input"
                                           @bind="ViewModel.EditUsername" />
                                </div>
                                <div class="spv2-form-field">
                                    <label class="spv2-form-label" for="fld-upn">UPN</label>
                                    <input id="fld-upn" type="text" class="spv2-form-input"
                                           @bind="ViewModel.EditUpn" />
                                </div>

                            </div>
                        </div>
                    }
                    else if (ViewModel.Student is not null)
                    {
                        @* ── View mode ── *@
                        var s = ViewModel.Student;
                        <div class="spv2-fields-grid">
                            <div class="spv2-field"><span class="spv2-label">First Name</span><span class="spv2-value">@s.FirstName</span></div>
                            <div class="spv2-field"><span class="spv2-label">Last Name</span><span class="spv2-value">@s.LastName</span></div>
                            <div class="spv2-field"><span class="spv2-label">Middle Names</span><span class="spv2-value">@(s.MiddleNames ?? "—")</span></div>
                            <div class="spv2-field"><span class="spv2-label">Preferred Name</span><span class="spv2-value">@(s.PreferredName ?? "—")</span></div>
                            <div class="spv2-field"><span class="spv2-label">Date of Birth</span><span class="spv2-value">@s.DateOfBirth.ToString("dd/MM/yyyy")</span></div>
                            <div class="spv2-field"><span class="spv2-label">Gender</span><span class="spv2-value">@(s.Gender ?? "—")</span></div>
                            <div class="spv2-field"><span class="spv2-label">Admission Number</span><span class="spv2-value">@s.AdmissionNumber</span></div>
                            <div class="spv2-field"><span class="spv2-label">Admission Date</span><span class="spv2-value">@s.AdmissionDate.ToString("dd/MM/yyyy")</span></div>
                            <div class="spv2-field"><span class="spv2-label">Year Group</span><span class="spv2-value">@s.YearGroupName</span></div>
                            <div class="spv2-field"><span class="spv2-label">Class</span><span class="spv2-value">@s.ClassName</span></div>
                            <div class="spv2-field"><span class="spv2-label">House</span><span class="spv2-value">@(s.HouseName ?? "—")</span></div>
                            <div class="spv2-field"><span class="spv2-label">Status</span><span class="spv2-value">@s.Status</span></div>
                            <div class="spv2-field"><span class="spv2-label">Username</span><span class="spv2-value">@(s.Username ?? "—")</span></div>
                            <div class="spv2-field"><span class="spv2-label">UPN</span><span class="spv2-value">@(s.Upn ?? "—")</span></div>
                        </div>
                    }
                }

                @* Tab 1 — Contacts *@
                @if (ViewModel.ActiveTab == 1)
                {
                    @if (ViewModel.Contacts.Count == 0)
                    {
                        <p class="spv2-empty">No contacts on record.</p>
                    }
                    else
                    {
                        @foreach (var c in ViewModel.Contacts)
                        {
                            <div class="spv2-card">
                                <div class="spv2-fields-grid">
                                    <div class="spv2-field"><span class="spv2-label">Name</span><span class="spv2-value">@c.ContactName</span></div>
                                    <div class="spv2-field"><span class="spv2-label">Relationship</span><span class="spv2-value">@c.Relationship</span></div>
                                    <div class="spv2-field"><span class="spv2-label">Phone</span><span class="spv2-value">@(c.Phone ?? "—")</span></div>
                                    <div class="spv2-field"><span class="spv2-label">Email</span><span class="spv2-value">@(c.Email ?? "—")</span></div>
                                    <div class="spv2-field"><span class="spv2-label">Primary</span><span class="spv2-value">@(c.IsPrimary ? "Yes" : "No")</span></div>
                                </div>
                            </div>
                        }
                    }
                }

                @* Tab 2 — Medical *@
                @if (ViewModel.ActiveTab == 2)
                {
                    @if (ViewModel.Medical.Count == 0)
                    {
                        <p class="spv2-empty">No medical records on record.</p>
                    }
                    else
                    {
                        @foreach (var m in ViewModel.Medical)
                        {
                            <div class="spv2-card">
                                <div class="spv2-fields-grid">
                                    <div class="spv2-field"><span class="spv2-label">Condition</span><span class="spv2-value">@m.MedicalCondition</span></div>
                                    <div class="spv2-field"><span class="spv2-label">Allergic</span><span class="spv2-value">@(m.IsAllergic ? "Yes" : "No")</span></div>
                                    <div class="spv2-field"><span class="spv2-label">Allergy Details</span><span class="spv2-value">@(m.AllergyDetails ?? "—")</span></div>
                                    <div class="spv2-field"><span class="spv2-label">Medication</span><span class="spv2-value">@(m.Medication ?? "—")</span></div>
                                    <div class="spv2-field"><span class="spv2-label">Emergency Action Plan</span><span class="spv2-value">@(m.EmergencyActionPlan ?? "—")</span></div>
                                </div>
                            </div>
                        }
                    }
                }

                @* Tab 3 — Flags *@
                @if (ViewModel.ActiveTab == 3)
                {
                    @if (ViewModel.Flags.Count == 0)
                    {
                        <p class="spv2-empty">No flags on record.</p>
                    }
                    else
                    {
                        <table class="spv2-table">
                            <thead>
                                <tr>
                                    <th>Flag Code</th>
                                    <th>Active</th>
                                    <th>Assigned</th>
                                    <th>Notes</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var f in ViewModel.Flags)
                                {
                                    <tr>
                                        <td>@f.FlagCode</td>
                                        <td>@(f.IsActive ? "Yes" : "No")</td>
                                        <td>@f.AssignedAt.ToString("dd/MM/yyyy")</td>
                                        <td>@(f.Notes ?? "—")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                }

                @* Tab 4 — Additional (placeholder) *@
                @if (ViewModel.ActiveTab == 4)
                {
                    <p class="spv2-empty">No additional information available.</p>
                }

                @* Tab 5 — Notes (placeholder) *@
                @if (ViewModel.ActiveTab == 5)
                {
                    <p class="spv2-empty">No notes on record.</p>
                }

                @* Tab 6 — Absences (CRUD) *@
                @if (ViewModel.ActiveTab == 6)
                {
                    <div class="spv2-absence-toolbar">
                        <button class="spv2-btn spv2-btn--primary"
                                @onclick="@(() => Nav.NavigateTo($"/v2/students/{Id}/absences/new"))">
                            <i class="bi bi-plus-circle" aria-hidden="true"></i> Add Absence
                        </button>
                    </div>

                    @if (_absenceDeleteError is not null)
                    {
                        <div class="dsv2-alert dsv2-alert--danger" role="alert">@_absenceDeleteError</div>
                    }

                    @if (ViewModel.Absences.Count == 0)
                    {
                        <p class="spv2-empty">No absence records on file.</p>
                    }
                    else
                    {
                        <table class="spv2-table spv2-absence-table">
                            <thead>
                                <tr>
                                    <th>Type</th>
                                    <th>Status</th>
                                    <th>Start</th>
                                    <th>End</th>
                                    <th>Days</th>
                                    <th>Notes</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var a in ViewModel.Absences)
                                {
                                    <tr>
                                        <td>@a.AbsenceTypeName</td>
                                        <td>@a.StatusName</td>
                                        <td>@a.StartDate.ToString("dd/MM/yyyy")</td>
                                        <td>@a.EndDate.ToString("dd/MM/yyyy")</td>
                                        <td>@a.DurationDays</td>
                                        <td>@(a.Notes ?? "—")</td>
                                        <td class="spv2-absence-actions">
                                            <button class="spv2-btn spv2-btn--icon"
                                                    title="Edit"
                                                    @onclick="@(() => Nav.NavigateTo($"/v2/students/{Id}/absences/{a.Id}/edit"))">
                                                <i class="bi bi-pencil" aria-hidden="true"></i>
                                            </button>
                                            <button class="spv2-btn spv2-btn--icon spv2-btn--danger"
                                                    title="Delete"
                                                    @onclick="@(() => OnDeleteAbsence(a.Id))">
                                                <i class="bi bi-trash" aria-hidden="true"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                }

            </div>
        }

    </ChildContent>

</PageTemplateV2>

@code {
    [Parameter] public int Id { get; set; }

    private static readonly (string Label, int Index)[] Tabs =
    [
        ("Profile",    0),
        ("Contacts",   1),
        ("Medical",    2),
        ("Flags",      3),
        ("Additional", 4),
        ("Notes",      5),
        ("Absences",   6),
    ];

    private bool _isNew => Id == 0;

    private string PageTitle => _isNew
        ? "Add Student"
        : (ViewModel.Student is not null ? $"{ViewModel.HeaderFullName} — Profile" : "Student Profile");

    private string? _absenceDeleteError;

    protected override async Task OnParametersSetAsync()
    {
        if (_isNew)
        {
            await ViewModel.InitNewAsync();
        }
        else
        {
            await ViewModel.InitAsync(Id);
        }
    }

    private async Task OnBeginEdit()
    {
        await ViewModel.BeginEditAsync();
    }

    private async Task OnSave()
    {
        var ok = await ViewModel.SaveAsync();
        if (ok && ViewModel.StudentId != 0)
            Nav.NavigateTo($"/v2/students/{ViewModel.StudentId}");
    }

    private async Task OnPhotoChanged(InputFileChangeEventArgs e)
    {
        await ViewModel.UploadPhotoAsync(e.File);
    }

    private void OnRemovePhoto() => ViewModel.RemovePhoto();

    private async Task OnDeleteAbsence(long absenceId)
    {
        _absenceDeleteError = null;
        await ViewModel.DeleteAbsenceAsync(absenceId);
        if (ViewModel.Error is not null)
            _absenceDeleteError = ViewModel.Error;
    }

    private void OnDobChanged(ChangeEventArgs e)
    {
        if (DateTime.TryParseExact(e.Value?.ToString(), "yyyy-MM-dd", null,
            System.Globalization.DateTimeStyles.None, out var dob))
            ViewModel.EditDateOfBirth = dob;
    }

    private void OnAdmissionDateChanged(ChangeEventArgs e)
    {
        if (DateOnly.TryParseExact(e.Value?.ToString(), "yyyy-MM-dd", out var d))
            ViewModel.EditAdmissionDate = d;
    }

    private void OnClassChanged(ChangeEventArgs e)
    {
        ViewModel.EditClassId = int.TryParse(e.Value?.ToString(), out var v) ? v : null;
    }

    private void OnHouseChanged(ChangeEventArgs e)
    {
        ViewModel.EditHouseId = int.TryParse(e.Value?.ToString(), out var v) ? v : null;
    }
}
