<maui:MauiWinUIApplication
    x:Class="AbsenceApp.Client.WinUI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:maui="using:Microsoft.Maui"
    xmlns:local="using:AbsenceApp.Client.WinUI">

    <!--
    ===========================================================================
     File        : App.xaml
     Namespace   : AbsenceApp.Client
     Platform    : Windows (WinUI 3)
     Author      : Michael
     Version     : 1.0.2
     Created     : 2026-03-13
     Updated     : 2026-05-08
    ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
     Purpose     : Windows-specific XAML root for the MAUI application.
                   This file defines the WinUI 3 application shell that hosts
                   the MAUI app via MauiWinUIApplication.
    ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
     Notes       :
       - No resources or startup logic belong in this file.
       - All bootstrap logic lives in:
           • Platforms/Windows/App.xaml.cs (WinUI host)
           • MauiProgram.cs (MAUI DI + Blazor setup)
       - The MauiWinUIApplication base class bridges WinUI 3 and MAUI.
    ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
     Changes     :
       - 1.0.0  2026-03-13  Initial implementation.
       - 1.0.1  2026-05-08  Namespace corrected to AbsenceApp.Client to align
                            with MAUI partial-class requirements.
    ===========================================================================
    -->

</maui:MauiWinUIApplication>
