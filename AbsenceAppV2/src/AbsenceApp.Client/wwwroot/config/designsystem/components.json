{
  "_comment": "AbsenceApp V2 Design System — components.json — Phase 2",
  "_description": "Global default configuration for V2 design system components. Loaded by DesignSystemConfigService.",
  "version": "2.0.0",
  "button": {
    "defaultVariant": "primary",
    "defaultSize": "md",
    "variants": ["primary", "secondary", "ghost", "danger", "success", "warning", "light", "dark", "outline-dark"],
    "sizes": {
      "sm": { "padding": "4px 10px",  "fontSize": "0.75rem", "height": "28px" },
      "md": { "padding": "6px 14px",  "fontSize": "0.875rem","height": "34px" },
      "lg": { "padding": "8px 18px",  "fontSize": "1rem",    "height": "40px" }
    }
  },
  "badge": {
    "defaultVariant": "neutral",
    "variants": ["neutral", "primary", "success", "warning", "danger", "info"]
  },
  "card": {
    "defaultPadding": "16px",
    "defaultRadius": "8px",
    "defaultShadow": "xs",
    "showDivider": true
  },
  "sectionHeader": {
    "showDivider": true,
    "titleSize": "1rem",
    "subtitleSize": "0.875rem"
  },
  "icon": {
    "defaultLibrary": "bootstrap-icons",
    "defaultSize": "1rem",
    "sizes": {
      "xs":  "0.75rem",
      "sm":  "0.875rem",
      "md":  "1rem",
      "lg":  "1.25rem",
      "xl":  "1.5rem",
      "2xl": "2rem"
    }
  },
  "iconButton": {
    "defaultSize": "md",
    "defaultVariant": "ghost",
    "sizes": {
      "sm": { "padding": "4px 6px",  "fontSize": "0.9rem",  "height": "28px" },
      "md": { "padding": "6px 9px",  "fontSize": "1.1rem",  "height": "34px" },
      "lg": { "padding": "8px 10px", "fontSize": "1.3rem",  "height": "40px" }
    }
  },
  "input": {
    "defaultSize": "md",
    "defaultRadius": "6px"
  },
  "pagination": {
    "defaultPageSize": 25,
    "pageSizeOptions": [10, 25, 50, 100],
    "showPageSizeSelector": true,
    "showPageInfo": true
  },
  "skeleton": {
    "animationDuration": "1.5s",
    "baseColor": "#e5e7eb",
    "highlightColor": "#f3f4f6"
  },
  "emptyState": {
    "defaultIcon": "bi-inbox",
    "defaultMessage": "No records found."
  },
  "alert": {
    "defaultDuration": 4000,
    "variants": ["success", "warning", "danger", "info"],
    "position": "top-right"
  }
}
