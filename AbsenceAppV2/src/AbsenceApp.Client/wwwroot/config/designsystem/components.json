  "badge": {
    "tokenFamily": "badge-status",
    "defaultVariant": "neutral",
    "variants": [
      "neutral",
      "primary",
      "success",
      "warning",
      "danger",
      "info"
    ]
  },

  "card": {
    "tokenFamily": "card",
    "defaultPadding": "16px",
    "defaultRadius": "8px",
    "defaultShadow": "xs",
    "showDivider": true
  },

  "sectionHeader": {
    "showDivider": true,
    "titleSize": "1rem",
    "subtitleSize": "0.875rem"
  },

  "icon": {
    "tokenFamily": "icon",
    "defaultLibrary": "bootstrap-icons",
    "defaultSize": "1rem",
    "sizes": {
      "xs":  "0.75rem",
      "sm":  "0.875rem",
      "md":  "1rem",
      "lg":  "1.25rem",
      "xl":  "1.5rem",
      "2xl": "2rem"
    }
  },

  "iconButton": {
    "tokenFamily": "icon-btn",
    "defaultSize": "md",
    "defaultVariant": "ghost",
    "sizes": {
      "sm": { "padding": "4px 6px", "fontSize": "0.9rem", "height": "28px" },
      "md": { "padding": "6px 9px", "fontSize": "1.1rem", "height": "34px" },
      "lg": { "padding": "8px 10px", "fontSize": "1.3rem", "height": "40px" }
    }
  },

  "input": {
    "tokenFamily": "form-field",
    "defaultSize": "md",
    "defaultRadius": "6px"
  },

  "formShell": {
    "tokenFamily": "form-shell",
    "defaultPadding": "16px",
    "showActions": true
  },

  "table": {
    "tokenFamily": "table",
    "defaultPageSize": 25,
    "pageSizeOptions": [10, 25, 50, 100],
    "showPageSizeSelector": true,
    "showPageInfo": true
  },

  "navHeader": {
    "tokenFamily": "nav-header",
    "showLogo": true,
    "showNotifications": true,
    "showUserMenu": true
  },

  "navSidebar": {
    "tokenFamily": "nav-sidebar",
    "defaultWidth": "230px",
    "collapsedWidth": "52px",
    "showScrollbar": true
  },

  "chart": {
    "tokenFamily": "chart",
    "defaultType": "line",
    "defaultTheme": "light",
    "showLegend": true,
    "showGrid": true
  },

  "pagination": {
    "defaultPageSize": 25,
    "pageSizeOptions": [10, 25, 50, 100],
    "showPageSizeSelector": true,
    "showPageInfo": true
  },

  "skeleton": {
    "animationDuration": "1.5s",
    "baseColor": "#e5e7eb",
    "highlightColor": "#f3f4f6"
  },

  "emptyState": {
    "defaultIcon": "bi-inbox",
    "defaultMessage": "No records found."
  },

  "alert": {
    "tokenFamily": "alert",
    "defaultDuration": 4000,
    "variants": [
      "success",
      "warning",
      "danger",
      "info"
    ],
    "position": "top-right"
  },

  "buttons": {
