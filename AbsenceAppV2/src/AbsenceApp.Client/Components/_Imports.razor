@* ===========================================================================
   File        : _Imports.razor
   Namespace   : AbsenceApp.Client.Components
   Author      : Michael
   Version     : 1.3.0
   Created     : 2026-03-13
   Updated     : 2026-03-25
   ---------------------------------------------------------------------------
   Purpose     : Global using directives for all Razor components in the
                 Components/ folder. These imports provide shared access to
                 core application namespaces used by reusable UI components.
                 This file intentionally excludes V2 page-level namespaces
                 (Framework.V2, PageTemplates, etc.) to keep Components
                 independent and reusable across Modules and Pages.
   ---------------------------------------------------------------------------
   Changes     :
     - 1.0.0  2026-03-13  Initial implementation.
     - 1.1.0  2026-03-23  Added PageTemplatesV2 namespace.
     - 1.2.0  2026-03-24  Updated namespaces after folder renames:
                          - PageTemplatesV2 → PageTemplates
                          - LayoutV2 merged into Layout
                          - TableV2 → Table
                          - FrameworkV2 → Framework
                          - ModulesV2 → Modules
     - 1.3.0  2026-03-25  Removed V2 page-level imports to maintain proper
                          separation of concerns. Components now reference
                          only shared UI and application namespaces.
   ---------------------------------------------------------------------------
   Notes       :
     - Blazor automatically processes this file; do not add markup or
       directives other than @using, @inject, and similar non-render items.
     - Keep this file focused on shared component dependencies only.
   ===========================================================================
*@

@* =========================================================================
   Framework and BCL usings — ASP.NET Core and .NET runtime namespaces
   ========================================================================= *@
@using System.Net.Http
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components.Routing
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.AspNetCore.Components.Web.Virtualization
@using Microsoft.JSInterop

@* =========================================================================
   Application usings — AbsenceApp-specific namespaces
   ========================================================================= *@
@using AbsenceApp.Client
@using AbsenceApp.Client.Services
@using AbsenceApp.Client.Components
@using AbsenceApp.Client.Components.Layout
@using AbsenceApp.Client.Components.PageTemplates
@using AbsenceApp.Client.Shared
@using AbsenceApp.Core.Interfaces
@using AbsenceApp.Core.Navigation
@using AbsenceApp.Core.ViewModels
@using AbsenceApp.Core.DTOs
