@using AbsenceApp.Client.Services
@inject AppStateService AppState
@implements IDisposable

@* =========================================================================
   Section: Full breadcrumb trail (Menu > Submenu)
   ========================================================================= *@
@if (AppState.Breadcrumb.Count > 1)
{
    <nav aria-label="Breadcrumb" class="dsv2-breadcrumb">
        <span class="dsv2-breadcrumb__trail">
            @string.Join(" > ", AppState.Breadcrumb)
        </span>
    </nav>
}

@code {
    protected override void OnInitialized() => AppState.OnChange += StateHasChanged;
    public void Dispose() => AppState.OnChange -= StateHasChanged;
}
