@* ===========================================================================
   File        : BaseLayoutV2.razor
   Namespace   : AbsenceApp.Client.Components.LayoutV2
   Author      : Michael
   Version     : 1.1.0
   Created     : 2026-03-23
   Updated     : 2026-03-23
   ---------------------------------------------------------------------------
   Purpose     : Base layout for all V2 pages. Provides the universal shell
                 including SidebarV2, HeaderV2, BreadcrumbV2, and a single
                 main content container where page content is rendered via
                 @Body (Blazor's built-in layout content placeholder).
   ---------------------------------------------------------------------------
   Changes     :
     - 1.1.0  2026-03-23  Added required ChildContent parameter to support
                          component-wrapped usage and prevent runtime error:
                          "Object ... does not have a property matching the
                          name 'ChildContent'."
     - 1.0.0  2026-03-23  Initial creation of the V2 base layout structure.
   ---------------------------------------------------------------------------
   Notes       :
     - All V2 pages will eventually inherit from this layout.
     - Padding, spacing, and global settings integration will be added in
       later steps.
     - LayoutComponentBase automatically exposes @Body, but ChildContent must
       be explicitly declared if the layout is ever used as a component.
   ===========================================================================
*@

@inherits LayoutComponentBase

@* =========================================================================
   Section: Layout structure
   ========================================================================= *@

<SidebarV2 />

<div class="v2-content-area">

    <HeaderV2 />

    <BreadcrumbV2 />

    <main class="v2-main">
        <div class="v2-page-container">
            @Body
        </div>
    </main>

</div>

@* =========================================================================
   Section: Parameters
   - ChildContent is required if this layout is ever used as a component
     wrapper rather than only via @layout.
   ========================================================================= *@
@code {
    [Parameter]
    public RenderFragment? ChildContent { get; set; }
}
