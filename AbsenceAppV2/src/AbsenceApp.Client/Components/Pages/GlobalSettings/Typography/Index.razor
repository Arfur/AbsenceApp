@* ===========================================================================
   File        : Index.razor
   Namespace   : AbsenceApp.Client.Components.Pages.GlobalSettings.Typography
   Route       : /global-settings/typography
   Author      : Michael
   Version     : 1.0.0
   Created     : 2026-03-26
   ---------------------------------------------------------------------------
   Purpose     : Global Settings — Typography configuration page.
                 Displays a hard-coded preview of the current typography
                 settings via IDesignSystemService. No editing. No JSON loading.
   ---------------------------------------------------------------------------
   Changes     :
     - 1.0.0  2026-03-26  Initial implementation (Phase 1 placeholder).
   ===========================================================================
*@

@page "/global-settings/typography"
@layout AbsenceApp.Client.Framework.Layouts.GlobalSettingsLayout
@using AbsenceApp.Client.Services.DesignSystem
@using AbsenceApp.Client.Components.Templates
@inject IDesignSystemService DesignSystem

<BlankPageTemplate PageTitle="Typography — Global Settings">
    <ChildContent>
        <p class="gs-preview-label">Current preview</p>
        <p class="gs-preview-value">@DesignSystem.GetTypographyPreview()</p>
        <UnderConstructionTemplate PageTitle="Editing coming in Phase 2" />
    </ChildContent>
</BlankPageTemplate>
