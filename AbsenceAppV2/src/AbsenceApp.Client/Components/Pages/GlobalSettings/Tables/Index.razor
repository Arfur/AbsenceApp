@* ===========================================================================
   File        : Index.razor
   Namespace   : AbsenceApp.Client.Components.Pages.GlobalSettings.Tables
   Route       : /globalsettings/tables
   Author      : Michael
   Version     : 1.1.0
   Created     : 2026-03-26
   Updated     : 2026-03-27
   ---------------------------------------------------------------------------
   Purpose     : Global Settings — Tables configuration page.
                 Displays a hard-coded preview of the current table style
                 via IDesignSystemService. No editing. No JSON loading.
   ---------------------------------------------------------------------------
   Changes     :
     - 1.0.0  2026-03-26  Initial implementation (Phase 1 placeholder).
     - 1.1.0  2026-03-27  Fix: renamed PageTitle parameter to Title (correct
                          TablePageTemplate parameter). PageTitle is not a
                          recognised parameter on TablePageTemplate and caused
                          a runtime crash when navigating to /global-settings/tables.
   ===========================================================================
*@

@page "/globalsettings/tables"
@layout AbsenceApp.Client.Framework.Layouts.GlobalSettingsLayout
@using AbsenceApp.Client.Services.DesignSystem
@using AbsenceApp.Client.Components.Templates
@inject IDesignSystemService DesignSystem

<TablePageTemplate Title="Tables — Global Settings"
                   Subtitle="Current table style preview">
    <TableContent>
        <p class="gs-preview-value">@DesignSystem.GetTablePreview()</p>
        <UnderConstructionTemplate PageTitle="Editing coming in Phase 2" />
    </TableContent>
</TablePageTemplate>
