@* ===========================================================================
   File        : Index.razor
   Namespace   : AbsenceApp.Client.Components.Pages.GlobalSettings.Buttons.Edit
   Route       : /global-settings/buttons/edit
   Author      : Michael
   Version     : 1.0.0
   Created     : 2026-05-12
   Updated     : 2026-05-12
   ---------------------------------------------------------------------------
   Purpose     : Global Settings — Buttons design-token editor.
                 Accordion variant selector on the left; live token editor +
                 preview on the right. Edits are validated in the ViewModel,
                 saved to the DesignTokens table via DesignTokenApiServiceV2,
                 and applied instantly through the global CSS injector.
                 Moved from /global-settings/buttons in Phase C.
   ---------------------------------------------------------------------------
   Changes     :
     - 1.0.0  2026-05-12  Phase C: moved from Buttons/Index.razor to
                          Buttons/Edit/Index.razor. Route updated to
                          /global-settings/buttons/edit. No logic changes.
   ===========================================================================
*@

@page "/global-settings/buttons/edit"
@layout AbsenceApp.Client.Framework.Layouts.GlobalSettingsLayout
@namespace AbsenceApp.Client.Components.Pages.GlobalSettings.Buttons.Edit
@using AbsenceApp.Client.ViewModels.V2
@using AbsenceApp.Data.Models
@inject ButtonsEditorViewModelV2 ViewModel
@implements IDisposable

<div class="gs-template gs-template--blank">

    <div class="gs-template__header">
        <h1 class="gs-template__title">Buttons — Token Editor</h1>
        <p class="gs-template__subtitle">
            Select a variant to edit its design token values.
            Changes are saved to the database and applied instantly via the CSS injector.
        </p>
    </div>

    <div class="gs-template__body">

        @if (!ViewModel.IsLoaded)
        {
            <p class="bep-placeholder">Loading tokens…</p>
        }
        else
        {
            <div class="bep-layout">

                @* ── LEFT: Accordion variant selector ──────────────────────── *@
                <div class="bep-left">

                    @* ── Fill Variants ── *@
                    <div class="bep-accordion">
                        <button type="button" class="bep-accordion__toggle"
                                aria-expanded="@_openSections.Contains("fill")"
                                aria-controls="bep-grid-fill"
                                @onclick='() => ToggleSection("fill")'>
                            <span>Fill Variants</span>
                            <i class="bi bi-chevron-down bep-chevron @(_openSections.Contains("fill") ? "bep-chevron--open" : "")"></i>
                        </button>
                        @if (_openSections.Contains("fill"))
                        {
                            <div id="bep-grid-fill" class="bep-btn-grid">
                                @foreach (var kv in FillVariants)
                                {
                                    var vKey = kv.Key;
                                    <button type="button"
                                            role="radio"
                                            aria-checked="@(ViewModel.SelectedVariant == vKey)"
                                            class="dsv2-btn dsv2-btn--@vKey bep-btn @(ViewModel.SelectedVariant == vKey ? "bep-btn--selected" : "")"
                                            @onclick="() => SelectVariantAsync(vKey)">
                                        @kv.Value
                                    </button>
                                }
                            </div>
                        }
                    </div>

                    @* ── Outline Variants ── *@
                    <div class="bep-accordion">
                        <button type="button" class="bep-accordion__toggle"
                                aria-expanded="@_openSections.Contains("outline")"
                                aria-controls="bep-grid-outline"
                                @onclick='() => ToggleSection("outline")'>
                            <span>Outline Variants</span>
                            <i class="bi bi-chevron-down bep-chevron @(_openSections.Contains("outline") ? "bep-chevron--open" : "")"></i>
                        </button>
                        @if (_openSections.Contains("outline"))
                        {
                            <div id="bep-grid-outline" class="bep-btn-grid">
                                @foreach (var kv in OutlineVariants)
                                {
                                    var oKey = "outline-" + kv.Key;
                                    <button type="button"
                                            role="radio"
                                            aria-checked="@(ViewModel.SelectedVariant == oKey)"
                                            class="dsv2-btn dsv2-btn--outline-@kv.Key bep-btn @(ViewModel.SelectedVariant == oKey ? "bep-btn--selected" : "")"
                                            @onclick="() => SelectVariantAsync(oKey)">
                                        @kv.Value
                                    </button>
                                }
                            </div>
                        }
                    </div>

                    @* ── Size &amp; Structure ── *@
                    <div class="bep-accordion">
                        <button type="button" class="bep-accordion__toggle"
                                aria-expanded="@_openSections.Contains("structural")"
                                aria-controls="bep-grid-structural"
                                @onclick='() => ToggleSection("structural")'>
                            <span>Size &amp; Structure</span>
                            <i class="bi bi-chevron-down bep-chevron @(_openSections.Contains("structural") ? "bep-chevron--open" : "")"></i>
                        </button>
                        @if (_openSections.Contains("structural"))
                        {
                            <div id="bep-grid-structural" class="bep-btn-grid">
                                <button type="button"
                                        role="radio"
                                        aria-checked="@(ViewModel.SelectedVariant == "structural")"
                                        class="dsv2-btn dsv2-btn--secondary bep-btn @(ViewModel.SelectedVariant == "structural" ? "bep-btn--selected" : "")"
                                        @onclick='() => SelectVariantAsync("structural")'>
                                    Base Structure
                                </button>
                            </div>
                        }
                    </div>

                    @* ── States ── *@
                    <div class="bep-accordion">
                        <button type="button" class="bep-accordion__toggle"
                                aria-expanded="@_openSections.Contains("states")"
                                aria-controls="bep-grid-states"
                                @onclick='() => ToggleSection("states")'>
                            <span>States</span>
                            <i class="bi bi-chevron-down bep-chevron @(_openSections.Contains("states") ? "bep-chevron--open" : "")"></i>
                        </button>
                        @if (_openSections.Contains("states"))
                        {
                            <div id="bep-grid-states" class="bep-btn-grid">
                                <button type="button"
                                        role="radio"
                                        aria-checked="@(ViewModel.SelectedVariant == "disabled")"
                                        class="dsv2-btn dsv2-btn--secondary bep-btn @(ViewModel.SelectedVariant == "disabled" ? "bep-btn--selected" : "")"
                                        @onclick='() => SelectVariantAsync("disabled")'>
                                    Disabled
                                </button>
                            </div>
                        }
                    </div>

                </div>

                @* ── RIGHT: Token editor panel ─────────────────────────────── *@
                <div class="bep-right">

                    @if (ViewModel.SelectedVariant is null)
                    {
                        <p class="bep-placeholder">← Select a variant to edit its design tokens.</p>
                    }
                    else
                    {
                        @* Panel header *@
                        <div class="bep-panel-header">
                            <h2 class="bep-variant-label">
                                @GetVariantLabel(ViewModel.SelectedVariant)
                            </h2>
                            @if (ViewModel.SelectedVariant != "structural")
                            {
                                @* Live preview button — inline style built from EditBuffer *@
                                <button type="button"
                                        class="dsv2-btn bep-preview-btn"
                                        style="@PreviewStyle">
                                    Preview
                                </button>
                            }
                        </div>

                        @* Variant info strip *@
                        <div class="bep-variant-info">
                            <span class="bep-variant-info__class">.dsv2-btn--@ViewModel.SelectedVariant</span>
                            <span class="bep-variant-info__count">@ViewModel.VisibleTokens.Count() tokens</span>
                        </div>

                        @* Token rows *@
                        @if (!ViewModel.VisibleTokens.Any())
                        {
                            <p class="bep-placeholder bep-placeholder--sm">
                                No tokens are seeded for this variant yet.
                            </p>
                        }
                        else
                        {
                            @foreach (var token in ViewModel.VisibleTokens)
                            {
                                var cssVar  = token.CssVariable;
                                var editVal = ViewModel.EditBuffer.TryGetValue(cssVar, out var ev) ? ev : token.DefaultValue;
                                var hasErr  = ViewModel.Errors.ContainsKey(cssVar);

                                <div @key="token.Id" class="bep-token-row">
                                    <label class="bep-token-row__label" for="@cssVar">
                                        @TokenLabel(token.TokenKey)
                                    </label>
                                    <div class="bep-token-row__input-wrap">
                                        @if (token.Category == "color")
                                        {
                                            <span class="bep-swatch" style="background:@editVal" aria-hidden="true"></span>
                                        }
                                        <input id="@cssVar"
                                               type="text"
                                               class="bep-token-row__input @(hasErr ? "bep-token-row__input--error" : "")"
                                               value="@editVal"
                                               @oninput="@(e => ViewModel.SetTokenValue(cssVar, e.Value?.ToString() ?? string.Empty))" />
                                    </div>
                                    <span class="bep-token-row__code">@cssVar</span>
                                    @if (ViewModel.Errors.ContainsKey(cssVar))
                                    {
                                        <p class="bep-token-row__error" role="alert">@ViewModel.Errors[cssVar]</p>
                                    }
                                </div>
                            }

                            @* Footer actions *@
                            <div class="bep-actions">
                                <button type="button"
                                        class="dsv2-btn dsv2-btn--primary"
                                        aria-busy="@ViewModel.IsSaving"
                                        @onclick="SaveAsync"
                                        disabled="@(!ViewModel.IsDirty || ViewModel.IsSaving || ViewModel.Errors.Any())">
                                    @(ViewModel.IsSaving ? "Saving…" : "Save Changes")
                                </button>
                                <button type="button"
                                        class="dsv2-btn dsv2-btn--secondary"
                                        @onclick="ResetAsync"
                                        disabled="@ViewModel.IsSaving">
                                    Reset to Defaults
                                </button>
                                @if (!string.IsNullOrWhiteSpace(ViewModel.SaveMessage))
                                {
                                    <span class="bep-save-message">@ViewModel.SaveMessage</span>
                                }
                            </div>
                        }
                    }

                </div>

            </div>
        }

    </div>

</div>

@code {

    // =========================================================================
    // Accordion state (component-local)
    // =========================================================================

    private readonly HashSet<string> _openSections = ["fill"];

    private static readonly Dictionary<string, string> FillVariants = new()
    {
        ["primary"]   = "Primary",
        ["secondary"] = "Secondary",
        ["success"]   = "Success",
        ["danger"]    = "Danger",
        ["warning"]   = "Warning",
        ["info"]      = "Info",
    };

    private static readonly Dictionary<string, string> OutlineVariants = new()
    {
        ["primary"]   = "Outline Primary",
        ["secondary"] = "Outline Secondary",
        ["success"]   = "Outline Success",
        ["danger"]    = "Outline Danger",
        ["warning"]   = "Outline Warning",
        ["info"]      = "Outline Info",
    };

    private static readonly Dictionary<string, string> VariantLabels = new()
    {
        ["primary"]           = "Primary Variant",
        ["secondary"]         = "Secondary Variant",
        ["success"]           = "Success Variant",
        ["danger"]            = "Danger Variant",
        ["warning"]           = "Warning Variant",
        ["info"]              = "Info Variant",
        ["outline-primary"]   = "Outline Primary",
        ["outline-secondary"] = "Outline Secondary",
        ["outline-success"]   = "Outline Success",
        ["outline-danger"]    = "Outline Danger",
        ["outline-warning"]   = "Outline Warning",
        ["outline-info"]      = "Outline Info",
        ["structural"]        = "Structural Tokens",
        ["disabled"]          = "Disabled State",
    };

    // =========================================================================
    // Lifecycle
    // =========================================================================

    protected override async Task OnInitializedAsync()
    {
        ViewModel.StateChanged += StateHasChanged;
        await ViewModel.InitialiseAsync();
    }

    public void Dispose()
    {
        ViewModel.StateChanged -= StateHasChanged;
    }

    // =========================================================================
    // Variant label helper
    // =========================================================================

    private string GetVariantLabel(string? variant) =>
        variant is null ? string.Empty
        : VariantLabels.TryGetValue(variant, out var label) ? label : variant;

    // =========================================================================
    // Accordion toggle
    // =========================================================================

    private async Task ToggleSection(string section)
    {
        if (!_openSections.Remove(section)) _openSections.Add(section);
        await InvokeAsync(StateHasChanged);
    }

    // =========================================================================
    // Variant selection
    // =========================================================================

    private async Task SelectVariantAsync(string variant)
    {
        ViewModel.SelectVariant(variant);
        await Task.CompletedTask;
    }

    // =========================================================================
    // Save / Reset
    // =========================================================================

    private async Task SaveAsync()  => await ViewModel.SaveAsync();
    private async Task ResetAsync() => await ViewModel.ResetToDefaultsAsync();

    // =========================================================================
    // Live preview style (built from EditBuffer on every render)
    // =========================================================================

    private string PreviewStyle
    {
        get
        {
            var variant = ViewModel.SelectedVariant;
            if (variant is null || variant == "structural") return string.Empty;

            var buf = ViewModel.EditBuffer;
            var sb  = new System.Text.StringBuilder();

            // Variant-specific colour tokens
            if (buf.TryGetValue($"--ds-btn-{variant}-bg",     out var bg))     sb.Append($"background:{bg};");
            if (buf.TryGetValue($"--ds-btn-{variant}-text",   out var text))   sb.Append($"color:{text};");
            if (buf.TryGetValue($"--ds-btn-{variant}-border", out var border)) sb.Append($"border-color:{border};");

            // Structural tokens (always applied)
            if (buf.TryGetValue("--ds-btn-border-radius", out var radius))   sb.Append($"border-radius:{radius};");
            if (buf.TryGetValue("--ds-btn-font-size",     out var fontSize)) sb.Append($"font-size:{fontSize};");
            if (buf.TryGetValue("--ds-btn-padding-y", out var py) &&
                buf.TryGetValue("--ds-btn-padding-x", out var px))
                sb.Append($"padding:{py} {px};");

            return sb.ToString();
        }
    }

    // =========================================================================
    // Token label helper
    // =========================================================================

    private static string TokenLabel(string tokenKey) => tokenKey switch
    {
        _ when tokenKey.EndsWith("-hover-bg", StringComparison.Ordinal) => "Hover Background",
        _ when tokenKey.EndsWith("-bg",       StringComparison.Ordinal) => "Background",
        _ when tokenKey.EndsWith("-text",     StringComparison.Ordinal) => "Text Colour",
        _ when tokenKey.EndsWith("-border",   StringComparison.Ordinal) => "Border Colour",
        "border-radius" => "Border Radius",
        "font-size"     => "Font Size",
        "padding-y"     => "Padding Y (vertical)",
        "padding-x"     => "Padding X (horizontal)",
        _               => tokenKey,
    };
}
