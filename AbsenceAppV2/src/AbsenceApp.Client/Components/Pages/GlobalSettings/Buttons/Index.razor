@* ===========================================================================
   File        : Index.razor
   Namespace   : AbsenceApp.Client.Components.Pages.GlobalSettings.Buttons
   Route       : /globalsettings/buttons
   Author      : Michael
   Version     : 3.0.0
   Created     : 2026-03-26
   Updated     : 2026-05-12
   ---------------------------------------------------------------------------
   Purpose     : Global Settings — Buttons showcase page (KI-Admin style).
                 Displays all button variants as static live demos using the
                 ButtonDemoCard component. Each card has an independently
                 toggled code-snippet section. No token logic or DB writes.
                 Token editing is at /global-settings/buttons/edit.
   ---------------------------------------------------------------------------
   Changes     :
     - 1.0.0  2026-03-26  Initial implementation (Phase 1 placeholder).
     - 2.0.0  2026-05-12  Phase B: token editor (moved to /edit in Phase C).
     - 3.0.0  2026-05-12  Phase C: KI-Admin-style demo layout with 12 card
                          sections. No token logic. Static demo only.
   =========================================================================== *@

@page "/globalsettings/buttons"
@layout AbsenceApp.Client.Framework.Layouts.GlobalSettingsLayout
@namespace AbsenceApp.Client.Components.Pages.GlobalSettings.Buttons
@using AbsenceApp.Client.Shared.Components.DesignSystem

<div class="kbp-page">

    <!-- 1. Basic Buttons -->
    <ButtonDemoCard Title="Basic Buttons" CodeSnippet="@_basicCode">
        <DemoContent>
            <button type="button" class="dsv2-btn dsv2-btn--primary">Primary</button>
            <button type="button" class="dsv2-btn dsv2-btn--secondary">Secondary</button>
            <button type="button" class="dsv2-btn dsv2-btn--success">Success</button>
            <button type="button" class="dsv2-btn dsv2-btn--danger">Danger</button>
            <button type="button" class="dsv2-btn dsv2-btn--warning">Warning</button>
            <button type="button" class="dsv2-btn dsv2-btn--info">Info</button>
            <button type="button" class="dsv2-btn dsv2-btn--light">Light</button>
            <button type="button" class="dsv2-btn dsv2-btn--dark">Dark</button>
            <button type="button" class="dsv2-btn dsv2-btn--link">Link</button>
        </DemoContent>
    </ButtonDemoCard>

    <!-- 2. Outline Buttons -->
    <ButtonDemoCard Title="Outline Buttons" CodeSnippet="@_outlineCode">
        <DemoContent>
            <button type="button" class="dsv2-btn dsv2-btn--outline-primary">Primary</button>
            <button type="button" class="dsv2-btn dsv2-btn--outline-secondary">Secondary</button>
            <button type="button" class="dsv2-btn dsv2-btn--outline-success">Success</button>
            <button type="button" class="dsv2-btn dsv2-btn--outline-danger">Danger</button>
            <button type="button" class="dsv2-btn dsv2-btn--outline-warning">Warning</button>
            <button type="button" class="dsv2-btn dsv2-btn--outline-info">Info</button>
            <button type="button" class="dsv2-btn dsv2-btn--outline-light">Light</button>
            <button type="button" class="dsv2-btn dsv2-btn--outline-dark">Dark</button>
            <button type="button" class="dsv2-btn dsv2-btn--link">Link</button>
        </DemoContent>
    </ButtonDemoCard>

    <!-- 3. Light Buttons -->
    <ButtonDemoCard Title="Light Buttons" CodeSnippet="@_lightCode">
        <DemoContent>
            <button type="button" class="dsv2-btn dsv2-btn--light kbp-light-primary">Primary</button>
            <button type="button" class="dsv2-btn dsv2-btn--light kbp-light-secondary">Secondary</button>
            <button type="button" class="dsv2-btn dsv2-btn--light kbp-light-success">Success</button>
            <button type="button" class="dsv2-btn dsv2-btn--light kbp-light-danger">Danger</button>
            <button type="button" class="dsv2-btn dsv2-btn--light kbp-light-warning">Warning</button>
            <button type="button" class="dsv2-btn dsv2-btn--light kbp-light-info">Info</button>
        </DemoContent>
    </ButtonDemoCard>

    <!-- 4. Icon Buttons -->
    <ButtonDemoCard Title="Icon Buttons" CodeSnippet="@_iconCode">
        <DemoContent>
            <button type="button" class="dsv2-btn dsv2-btn--primary">
                <i class="bi bi-download"></i> Primary
            </button>
            <button type="button" class="dsv2-btn dsv2-btn--secondary">
                <i class="bi bi-triangle"></i> Secondary
            </button>
            <button type="button" class="dsv2-btn dsv2-btn--outline-primary">
                <i class="bi bi-download"></i> Primary
            </button>
            <button type="button" class="dsv2-btn dsv2-btn--outline-secondary">
                <i class="bi bi-triangle"></i> Secondary
            </button>
            <button type="button" class="dsv2-btn dsv2-btn--light kbp-light-primary">
                <i class="bi bi-download"></i> Primary
            </button>
            <button type="button" class="dsv2-btn dsv2-btn--light">
                <i class="bi bi-triangle"></i> Secondary
            </button>
        </DemoContent>
    </ButtonDemoCard>

    <!-- 5. Radius Buttons -->
    <ButtonDemoCard Title="Radius Buttons" CodeSnippet="@_radiusCode">
        <DemoContent>
            <button type="button" class="dsv2-btn dsv2-btn--primary kbp-pill">
                <i class="bi bi-download"></i> Primary
            </button>
            <button type="button" class="dsv2-btn dsv2-btn--secondary kbp-pill">
                <i class="bi bi-triangle"></i> Secondary
            </button>
            <button type="button" class="dsv2-btn dsv2-btn--outline-primary kbp-pill">
                <i class="bi bi-download"></i> Primary
            </button>
            <button type="button" class="dsv2-btn dsv2-btn--outline-secondary kbp-pill">
                <i class="bi bi-triangle"></i> Secondary
            </button>
            <button type="button" class="dsv2-btn dsv2-btn--light kbp-light-primary kbp-pill">
                <i class="bi bi-download"></i> Primary
            </button>
            <button type="button" class="dsv2-btn dsv2-btn--light kbp-pill">
                <i class="bi bi-triangle"></i> Secondary
            </button>
        </DemoContent>
    </ButtonDemoCard>

    <!-- 6. Social Buttons -->
    <ButtonDemoCard Title="Social Buttons" CodeSnippet="@_socialCode">
        <DemoContent>
            <button type="button" class="dsv2-btn kbp-social kbp-social--facebook">
                <i class="bi bi-facebook"></i> Facebook
            </button>
            <button type="button" class="dsv2-btn kbp-social kbp-social--twitter">
                <i class="bi bi-twitter-x"></i> Twitter
            </button>
            <button type="button" class="dsv2-btn kbp-social kbp-social--pinterest">
                <i class="bi bi-pinterest"></i> Pinterest
            </button>
            <button type="button" class="dsv2-btn kbp-social kbp-social--linkedin">
                <i class="bi bi-linkedin"></i> Linkedin
            </button>
            <button type="button" class="dsv2-btn kbp-social kbp-social--reddit">
                <i class="bi bi-reddit"></i> Reddit
            </button>
            <button type="button" class="dsv2-btn kbp-social kbp-social--twitter">
                <i class="bi bi-twitter-x"></i> Twitter
            </button>
        </DemoContent>
    </ButtonDemoCard>

    <!-- 7. Disabled Buttons -->
    <ButtonDemoCard Title="Disable Buttons" CodeSnippet="@_disableCode">
        <DemoContent>
            <button type="button" class="dsv2-btn dsv2-btn--primary" disabled>
                <i class="bi bi-download"></i> Primary
            </button>
            <button type="button" class="dsv2-btn dsv2-btn--secondary" disabled>
                <i class="bi bi-triangle"></i> Secondary
            </button>
            <button type="button" class="dsv2-btn dsv2-btn--outline-primary" disabled>
                <i class="bi bi-download"></i> Primary
            </button>
            <button type="button" class="dsv2-btn dsv2-btn--outline-secondary" disabled>
                <i class="bi bi-triangle"></i> Secondary
            </button>
            <button type="button" class="dsv2-btn dsv2-btn--light kbp-light-primary" disabled>
                <i class="bi bi-download"></i> Primary
            </button>
            <button type="button" class="dsv2-btn dsv2-btn--light" disabled>
                <i class="bi bi-triangle"></i> Secondary
            </button>
        </DemoContent>
    </ButtonDemoCard>

    <!-- 8. Active Buttons -->
    <ButtonDemoCard Title="Active Buttons" CodeSnippet="@_activeCode">
        <DemoContent>
            <button type="button" class="dsv2-btn dsv2-btn--primary active">
                <i class="bi bi-download"></i> Primary
            </button>
            <button type="button" class="dsv2-btn dsv2-btn--secondary active">
                <i class="bi bi-triangle"></i> Secondary
            </button>
            <button type="button" class="dsv2-btn dsv2-btn--outline-primary active">
                <i class="bi bi-download"></i> Primary
            </button>
            <button type="button" class="dsv2-btn dsv2-btn--outline-secondary active">
                <i class="bi bi-triangle"></i> Secondary
            </button>
            <button type="button" class="dsv2-btn dsv2-btn--light kbp-light-primary active">
                <i class="bi bi-download"></i> Primary
            </button>
            <button type="button" class="dsv2-btn dsv2-btn--light active">
                <i class="bi bi-triangle"></i> Secondary
            </button>
        </DemoContent>
    </ButtonDemoCard>

    <!-- 9. Loading Buttons -->
    <ButtonDemoCard Title="Loading Buttons" CodeSnippet="@_loadingCode">
        <DemoContent>
            <button type="button" class="dsv2-btn dsv2-btn--primary kbp-loading" disabled>
                <span class="kbp-spinner"></span> Loading...
            </button>
            <button type="button" class="dsv2-btn dsv2-btn--secondary kbp-loading" disabled>
                <span class="kbp-spinner"></span> Wait...
            </button>
            <button type="button" class="dsv2-btn dsv2-btn--success kbp-loading kbp-loading--icon-only" disabled>
                <span class="kbp-spinner"></span>
            </button>
            <button type="button" class="dsv2-btn dsv2-btn--danger kbp-loading kbp-loading--icon-only" disabled>
                <span class="kbp-spinner kbp-spinner--stop"></span>
            </button>
            <button type="button" class="dsv2-btn dsv2-btn--outline-primary kbp-loading" disabled>
                <span class="kbp-spinner"></span> Loading...
            </button>
            <button type="button" class="dsv2-btn dsv2-btn--outline-secondary kbp-loading" disabled>
                <span class="kbp-spinner"></span> Wait...
            </button>
            <button type="button" class="dsv2-btn dsv2-btn--outline-success kbp-loading kbp-loading--icon-only" disabled>
                <span class="kbp-spinner"></span>
            </button>
            <button type="button" class="dsv2-btn dsv2-btn--outline-danger kbp-loading kbp-loading--icon-only" disabled>
                <span class="kbp-spinner kbp-spinner--stop"></span>
            </button>
        </DemoContent>
    </ButtonDemoCard>

    <!-- 10. Block Buttons -->
    <ButtonDemoCard Title="Block Buttons" CodeSnippet="@_blockCode">
        <DemoContent>
            <div class="kbp-block-row">
                <button type="button" class="dsv2-btn dsv2-btn--primary kbp-block">Primary</button>
                <button type="button" class="dsv2-btn dsv2-btn--secondary kbp-block">Secondary</button>
                <button type="button" class="dsv2-btn dsv2-btn--success kbp-block">Success</button>
            </div>
        </DemoContent>
    </ButtonDemoCard>

    <!-- 11. Button Sizes -->
    <ButtonDemoCard Title="Button Sizes" CodeSnippet="@_sizesCode">
        <DemoContent>
            <button type="button" class="dsv2-btn dsv2-btn--primary dsv2-btn--lg">Large</button>
            <button type="button" class="dsv2-btn dsv2-btn--primary">Default</button>
            <button type="button" class="dsv2-btn dsv2-btn--primary dsv2-btn--sm">Small</button>
            <button type="button" class="dsv2-btn dsv2-btn--outline-secondary dsv2-btn--lg">Large</button>
            <button type="button" class="dsv2-btn dsv2-btn--outline-secondary">Default</button>
            <button type="button" class="dsv2-btn dsv2-btn--outline-secondary dsv2-btn--sm">Small</button>
        </DemoContent>
    </ButtonDemoCard>

    <!-- 12. Button Groups -->
    <ButtonDemoCard Title="Button Groups" CodeSnippet="@_groupCode">
        <DemoContent>
            <div class="kbp-btn-group" role="group">
                <button type="button" class="dsv2-btn dsv2-btn--primary kbp-group-btn">Left</button>
                <button type="button" class="dsv2-btn dsv2-btn--primary kbp-group-btn">Middle</button>
                <button type="button" class="dsv2-btn dsv2-btn--primary kbp-group-btn">Right</button>
            </div>
            <div class="kbp-btn-group" role="group">
                <button type="button" class="dsv2-btn dsv2-btn--outline-secondary kbp-group-btn">Left</button>
                <button type="button" class="dsv2-btn dsv2-btn--outline-secondary kbp-group-btn">Middle</button>
                <button type="button" class="dsv2-btn dsv2-btn--outline-secondary kbp-group-btn">Right</button>
            </div>
            <div class="kbp-btn-group" role="group">
                <button type="button" class="dsv2-btn dsv2-btn--success kbp-group-btn">1</button>
                <button type="button" class="dsv2-btn dsv2-btn--success kbp-group-btn">2</button>
                <button type="button" class="dsv2-btn dsv2-btn--success kbp-group-btn">3</button>
                <button type="button" class="dsv2-btn dsv2-btn--success kbp-group-btn">4</button>
            </div>
        </DemoContent>
    </ButtonDemoCard>

</div>
