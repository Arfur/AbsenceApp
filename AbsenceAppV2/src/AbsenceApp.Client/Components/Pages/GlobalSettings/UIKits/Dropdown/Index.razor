@* ===========================================================================
   File        : Index.razor
   Namespace   : AbsenceApp.Client.Components.Pages.GlobalSettings.UIKits.Dropdown
    Author      : GitHub Copilot (Refactored by Michael + Copilot)
    Version     : 5.4.0
   Created     : 2026-05-19
   Updated     : 2026-05-21
   ---------------------------------------------------------------------------
   Purpose     : Dropdown UI Kit page using the same architecture as the
                 Buttons page: data‑driven groups, variant selection,
                 accordion CSS editor, and live preview.
   ---------------------------------------------------------------------------
   Changes     :
    - 5.4.0  2026-05-21  Phase 2.2 strict corrective cycle: revalidated and
                     retained preview payload hydration before interactive
                     trigger/toggle execution paths.
    - 5.3.0  2026-05-21  Phase 2.2 corrective cycle: preserved preview-first
                     selection flow across single, split primary, and split
                     toggle interactions for deterministic payload updates.
    - 5.2.0  2026-05-21  Phase 2.1 visual regression recovery: ensured split
                     primary action clicks also hydrate selected preview payload
                     before interaction, preserving callback consistency.
    - 5.1.0  2026-05-21  Ensured trigger/toggle clicks explicitly refresh
                     selected variant preview CSS while preserving
                     template-level selection callbacks.
    - 5.0.0  2026-05-21  Rewired page to template-level UiKitsGroup item
                     contract (Items + OnItemSelectedKeyChanged +
                     ItemTemplate), removing page-owned selected-state
                     rendering logic.
     - 4.1.0  2026-05-21  Added @using AbsenceApp.Client.Shared.Templates.UIKits
                          after migrating UiKitsPage/UiKitsGroup to new namespace.
     - 4.0.0  2026-05-20  Migrated page layout to use UiKitsPage/UiKitsGroup template.
   =========================================================================== *@

@page "/globalsettings/ui-kits/dropdown"
@using AbsenceApp.Client.Shared.Templates.UIKits
@layout AbsenceApp.Client.Framework.Layouts.GlobalSettingsLayout
@namespace AbsenceApp.Client.Components.Pages.GlobalSettings.UIKits.Dropdown
@using AbsenceApp.Client.Framework.PageTemplates
@using System.Linq

@if (_isLoading)
{
    <div class="ddp-loading">Loading dropdown sets…</div>
}
else if (!string.IsNullOrWhiteSpace(_initError))
{
    <div class="ddp-init-error">@_initError</div>
}
else
{
    <UiKitsPage>

        @* ── Single Button & Link Dropdown ────────────────────────────── *@
        <UiKitsGroup Id="dd-group-single"
                     Title="@_groups[0].GroupTitle"
                     IsAccordionOpen="@_groups[0].AccordionOpen"
                     IsAccordionOpenChanged="EventCallback.Factory.Create<bool>(this, _ => OnToggleAccordion(_groups[0]))"
                     Items="@(_groups[0].Variants.Select(v => new UiKitsGroup.UiKitsDemoItem(v.Key, v.Label, v.PreviewCssClass, null)).ToList())"
                     OnItemSelectedKeyChanged="EventCallback.Factory.Create<string>(this, key => OnSelectedVariantChanged(_groups[0], key))"
                     IsEditing="@_groups[0].IsEditing"
                     OnEdit="EventCallback.Factory.Create(this, () => OnEditSaveClickedAsync(_groups[0]))"
                     EditorText="@_groups[0].EditorText"
                     EditorTextChanged="EventCallback.Factory.Create<string>(this, v => OnEditorInput(_groups[0], v))"
                     IsSaving="@_groups[0].IsSaving"
                     OnSave="EventCallback.Factory.Create(this, () => OnEditSaveClickedAsync(_groups[0]))"
                     OnCancel="EventCallback.Factory.Create(this, () => OnCancelClicked(_groups[0]))"
                     PreviewCss="@_groups[0].PreviewCss"
                     StatusMessage="@_groups[0].StatusMessage"
                     StatusIsError="@_groups[0].StatusIsError">
            <ItemTemplate Context="ctx">
                <div class="ddp-dropdown @ctx.Item.CssClass">
                    <button type="button"
                            class="ddp-trigger"
                            @onclick="() => { var selected = _groups[0].Variants.First(v => v.Key == ctx.Item.Key); OnSelectedVariantChanged(_groups[0], selected.Key); OnDropdownClicked(_groups[0], selected); }">
                        @ctx.Item.Label
                        <i class="bi bi-chevron-down"></i>
                    </button>
                    @if (_groups[0].OpenMenuForVariant == ctx.Item.Key)
                    {
                        <ul class="ddp-menu ddp-menu--open">
                            <li class="ddp-item">Action</li>
                            <li class="ddp-item">Another action</li>
                            <li class="ddp-item">Something else</li>
                        </ul>
                    }
                </div>
            </ItemTemplate>
        </UiKitsGroup>

        @* ── Split Button Dropdowns ────────────────────────────────────── *@
        <UiKitsGroup Id="dd-group-split"
                     Title="@_groups[1].GroupTitle"
                     IsAccordionOpen="@_groups[1].AccordionOpen"
                     IsAccordionOpenChanged="EventCallback.Factory.Create<bool>(this, _ => OnToggleAccordion(_groups[1]))"
                     Items="@(_groups[1].Variants.Select(v => new UiKitsGroup.UiKitsDemoItem(v.Key, v.Label, v.PreviewCssClass, null)).ToList())"
                     OnItemSelectedKeyChanged="EventCallback.Factory.Create<string>(this, key => OnSelectedVariantChanged(_groups[1], key))"
                     IsEditing="@_groups[1].IsEditing"
                     OnEdit="EventCallback.Factory.Create(this, () => OnEditSaveClickedAsync(_groups[1]))"
                     EditorText="@_groups[1].EditorText"
                     EditorTextChanged="EventCallback.Factory.Create<string>(this, v => OnEditorInput(_groups[1], v))"
                     IsSaving="@_groups[1].IsSaving"
                     OnSave="EventCallback.Factory.Create(this, () => OnEditSaveClickedAsync(_groups[1]))"
                     OnCancel="EventCallback.Factory.Create(this, () => OnCancelClicked(_groups[1]))"
                     PreviewCss="@_groups[1].PreviewCss"
                     StatusMessage="@_groups[1].StatusMessage"
                     StatusIsError="@_groups[1].StatusIsError">
            <ItemTemplate Context="ctx">
                <div class="ddp-split @ctx.Item.CssClass">
                    <button type="button"
                            class="ddp-split-btn"
                            @onclick="() => { var selected = _groups[1].Variants.First(v => v.Key == ctx.Item.Key); OnSelectedVariantChanged(_groups[1], selected.Key); }">
                        @ctx.Item.Label
                    </button>
                    <button type="button"
                            class="ddp-split-toggle"
                            @onclick="() => { var selected = _groups[1].Variants.First(v => v.Key == ctx.Item.Key); OnSelectedVariantChanged(_groups[1], selected.Key); OnSplitDropdownClicked(_groups[1], selected); }">
                        <i class="bi bi-chevron-down"></i>
                    </button>
                    @if (_groups[1].OpenMenuForVariant == ctx.Item.Key)
                    {
                        <ul class="ddp-menu ddp-menu--open">
                            <li class="ddp-item">Action</li>
                            <li class="ddp-item">Another Action</li>
                            <li class="ddp-item">Something Else</li>
                        </ul>
                    }
                </div>
            </ItemTemplate>
        </UiKitsGroup>

        @* ── Directional Dropdowns ─────────────────────────────────────── *@
        <UiKitsGroup Id="dd-group-directional"
                     Title="@_groups[2].GroupTitle"
                     IsAccordionOpen="@_groups[2].AccordionOpen"
                     IsAccordionOpenChanged="EventCallback.Factory.Create<bool>(this, _ => OnToggleAccordion(_groups[2]))"
                     Items="@(_groups[2].Variants.Select(v => new UiKitsGroup.UiKitsDemoItem(v.Key, v.Label, v.PreviewCssClass, null)).ToList())"
                     OnItemSelectedKeyChanged="EventCallback.Factory.Create<string>(this, key => OnSelectedVariantChanged(_groups[2], key))"
                     IsEditing="@_groups[2].IsEditing"
                     OnEdit="EventCallback.Factory.Create(this, () => OnEditSaveClickedAsync(_groups[2]))"
                     EditorText="@_groups[2].EditorText"
                     EditorTextChanged="EventCallback.Factory.Create<string>(this, v => OnEditorInput(_groups[2], v))"
                     IsSaving="@_groups[2].IsSaving"
                     OnSave="EventCallback.Factory.Create(this, () => OnEditSaveClickedAsync(_groups[2]))"
                     OnCancel="EventCallback.Factory.Create(this, () => OnCancelClicked(_groups[2]))"
                     PreviewCss="@_groups[2].PreviewCss"
                     StatusMessage="@_groups[2].StatusMessage"
                     StatusIsError="@_groups[2].StatusIsError">
            <ItemTemplate Context="ctx">
                <div class="ddp-dropdown @ctx.Item.CssClass">
                    <button type="button"
                            class="ddp-trigger"
                            @onclick="() => { var selected = _groups[2].Variants.First(v => v.Key == ctx.Item.Key); OnSelectedVariantChanged(_groups[2], selected.Key); OnDropdownClicked(_groups[2], selected); }">
                        @ctx.Item.Label
                        <i class="bi bi-chevron-down"></i>
                    </button>
                    @if (_groups[2].OpenMenuForVariant == ctx.Item.Key)
                    {
                        <ul class="ddp-menu ddp-menu--open">
                            <li class="ddp-item">Action</li>
                            <li class="ddp-item">Another action</li>
                            <li class="ddp-item">Something else</li>
                        </ul>
                    }
                </div>
            </ItemTemplate>
        </UiKitsGroup>

    </UiKitsPage>
}
