                     EditorText="@_iconState.EditorText"
                     EditorTextChanged="EventCallback.Factory.Create<string>(this, v => OnEditorInput(_iconState, v))"
                     IsSaving="@_iconState.IsSaving"
                     OnSave="EventCallback.Factory.Create(this, () => OnEditSaveClickedAsync(_iconState))"
                     OnCancel="EventCallback.Factory.Create(this, () => OnCancelClicked(_iconState))"
                     PreviewCss="@_iconState.PreviewCss"
                     StatusMessage="@_iconState.StatusMessage"
                     StatusIsError="@_iconState.StatusIsError">
            <DemoContent>
                @if (!string.IsNullOrWhiteSpace(_iconState.PreviewCss)) { <style>@_iconState.PreviewCss</style> }
                <div class="btp-icon-row">
                    <button type="button"
                            class="dsv2-btn dsv2-btn--primary @(_iconState.SelectedVariantKey == "icon-1" ? "btp-btn--selected" : string.Empty)"
                            @onclick='() => OnSelectedVariantChanged(_iconState, "icon-1")'>
                        <i class="bi bi-download"></i>
                    </button>
                    <button type="button"
                            class="dsv2-btn dsv2-btn--secondary @(_iconState.SelectedVariantKey == "icon-2" ? "btp-btn--selected" : string.Empty)"
                            @onclick='() => OnSelectedVariantChanged(_iconState, "icon-2")'>
                        <i class="bi bi-bell"></i>
                    </button>
                    <button type="button"
                            class="dsv2-btn dsv2-btn--outline-primary @(_iconState.SelectedVariantKey == "icon-3" ? "btp-btn--selected" : string.Empty)"
                            @onclick='() => OnSelectedVariantChanged(_iconState, "icon-3")'>
                        <i class="bi bi-gear"></i>
                    </button>
                    <button type="button"
                            class="dsv2-btn dsv2-btn--outline-secondary @(_iconState.SelectedVariantKey == "icon-4" ? "btp-btn--selected" : string.Empty)"
                            @onclick='() => OnSelectedVariantChanged(_iconState, "icon-4")'>
                        <i class="bi bi-alarm"></i>
                    </button>
                    <button type="button"
                            class="dsv2-btn dsv2-btn--soft-primary @(_iconState.SelectedVariantKey == "icon-5" ? "btp-btn--selected" : string.Empty)"
                            @onclick='() => OnSelectedVariantChanged(_iconState, "icon-5")'>
                        <i class="bi bi-camera"></i>
                    </button>
                    <button type="button"
                            class="dsv2-btn dsv2-btn--soft-secondary @(_iconState.SelectedVariantKey == "icon-6" ? "btp-btn--selected" : string.Empty)"
                            @onclick='() => OnSelectedVariantChanged(_iconState, "icon-6")'>
                        <i class="bi bi-image"></i>
                    </button>
                </div>
            </DemoContent>
        </UiKitsGroup>

