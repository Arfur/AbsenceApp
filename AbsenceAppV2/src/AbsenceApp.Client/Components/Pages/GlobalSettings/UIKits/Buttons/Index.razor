            Header: SECTION
        ─────────────────────────────────────────────────────────────── *@
        <UiKitsGroup Id="btn-group-social"
                     Title="@_socialState.GroupTitle"
                     IsAccordionOpen="@_socialState.AccordionOpen"
                     IsAccordionOpenChanged="EventCallback.Factory.Create<bool>(this, _ => OnToggleAccordion(_socialState))"
                     IsEditing="@_socialState.IsEditing"
                     OnEdit="EventCallback.Factory.Create(this, () => OnEditSaveClickedAsync(_socialState))"
                     EditorText="@_socialState.EditorText"
                     EditorTextChanged="EventCallback.Factory.Create<string>(this, v => OnEditorInput(_socialState, v))"
                     IsSaving="@_socialState.IsSaving"
                     OnSave="EventCallback.Factory.Create(this, () => OnEditSaveClickedAsync(_socialState))"
                     OnCancel="EventCallback.Factory.Create(this, () => OnCancelClicked(_socialState))"
                     PreviewCss="@_socialState.PreviewCss"
                     StatusMessage="@_socialState.StatusMessage"
                     StatusIsError="@_socialState.StatusIsError">
            <DemoContent>
                @if (!string.IsNullOrWhiteSpace(_socialState.PreviewCss)) { <style>@_socialState.PreviewCss</style> }
                @foreach (var variant in _socialState.Variants)
                {
                    var selected = IsSelected(_socialState, variant);
                    <button type="button"
                            class="@variant.PreviewCssClass @(selected ? "btp-btn--selected" : string.Empty)"
                            aria-label="@variant.Label"
                            @onclick="() => OnSelectedVariantChanged(_socialState, variant.Key)">
                        @if (variant.Key == "social-facebook")      { <i class="bi bi-facebook" aria-hidden="true"></i> }
                        else if (variant.Key == "social-twitter")   { <i class="bi bi-twitter" aria-hidden="true"></i> }
                        else if (variant.Key == "social-instagram") { <i class="bi bi-instagram" aria-hidden="true"></i> }
                        else if (variant.Key == "social-reddit")    { <i class="bi bi-reddit" aria-hidden="true"></i> }
                        else if (variant.Key == "social-whatsapp")  { <i class="bi bi-whatsapp" aria-hidden="true"></i> }
                        else if (variant.Key == "social-linkedin")  { <i class="bi bi-linkedin" aria-hidden="true"></i> }
                        else if (variant.Key == "social-telegram")  { <i class="bi bi-telegram" aria-hidden="true"></i> }
                        else if (variant.Key == "social-youtube")   { <i class="bi bi-youtube" aria-hidden="true"></i> }
                        else if (variant.Key == "social-behance")   { <i class="bi bi-behance" aria-hidden="true"></i> }
                        else if (variant.Key == "social-dribbble")  { <i class="bi bi-dribbble" aria-hidden="true"></i> }
                        else                                         { <i class="bi bi-snapchat" aria-hidden="true"></i> }
                    </button>
                }
            </DemoContent>
        </UiKitsGroup>

