@* ===========================================================================
   File        : Index.razor
   Namespace   : AbsenceApp.Client.Components.Pages.GlobalSettings.UIKits.Buttons
   Author      : GitHub Copilot
    Version     : 8.0.0
   Created     : 2026-03-30
   Updated     : 2026-05-21
   ---------------------------------------------------------------------------
   Purpose     : Buttons3 UX layout with full Ki-Admin parity (one set per row).
                 - Accordion cards
                 - Real button variant selectors
                 - CSS code panel with Edit / Save, Cancel, Preview flow
                 - All sections collapsed by default
   ---------------------------------------------------------------------------
   Changes     :
    - 8.0.0  2026-05-21  Rewired page to template-level UiKitsGroup item
                     contract (Items + OnItemSelectedKeyChanged +
                     ItemTemplate), removing page-owned selected-state
                     rendering logic.
     - 7.1.0  2026-05-21  Added @using AbsenceApp.Client.Shared.Templates.UIKits
                          after migrating UiKitsPage/UiKitsGroup to new namespace.
     - 7.0.1  2026-05-20  Corrected header metadata: updated Version and Changes entry;
                           preserved original Author value; no functional code changes.
     - 7.0.0  2026-05-20  Refactored page layout to use UiKitsPage/UiKitsGroup template.
   =========================================================================== *@

@layout AbsenceApp.Client.Framework.Layouts.GlobalSettingsLayout
@page "/globalsettings/ui-kits/buttons"
@using AbsenceApp.Client.Shared.Templates.UIKits
@using AbsenceApp.Client.Components.DesignSystem
@using AbsenceApp.Client.Framework.PageTemplates
@using AbsenceApp.Client.Framework.Layout
@using System.Linq

@if (_isLoading)
{
    <div class="btp-loading">Loading button</div>
}
else if (!string.IsNullOrWhiteSpace(_initError))
{
    <div class="btp-init-error">@_initError</div>
}
else
{
    <UiKitsPage>
        <ChildContent>
        @* ───────────────────────────────────────────────────────────────
            Header: SECTION
        ─────────────────────────────────────────────────────────────── *@
        <UiKitsGroup Id="btn-group-basic"
                     Title="@_basicState.GroupTitle"
                     AccordionOpen="@_basicState.AccordionOpen"
                     AccordionOpenChanged="EventCallback.Factory.Create<bool>(this, _ => OnToggleAccordion(_basicState))"
                     Items="@(_basicState.Variants.Select(v => new UiKitsGroup.UiKitsDemoItem(v.Key, v.Label, string.Concat("dsv2-btn ", v.PreviewCssClass).Trim())).ToList())"
                     OnItemSelectedKeyChanged="EventCallback.Factory.Create<string>(this, key => OnSelectedVariantChanged(_basicState, key))"
                     IsEditing="@_basicState.IsEditing"
                     OnEdit="EventCallback.Factory.Create(this, () => OnEditSaveClickedAsync(_basicState))"
                     EditorText="@_basicState.EditorText"
                     EditorTextChanged="EventCallback.Factory.Create<string>(this, v => OnEditorInput(_basicState, v))"
                     IsSaving="@_basicState.IsSaving"
                     OnSave="EventCallback.Factory.Create(this, () => OnEditSaveClickedAsync(_basicState))"
                     OnCancel="EventCallback.Factory.Create(this, () => OnCancelClicked(_basicState))"
                     PreviewCss="@_basicState.PreviewCss"
                     StatusMessage="@_basicState.StatusMessage"
                     StatusIsError="@_basicState.StatusIsError" />

        @* ───────────────────────────────────────────────────────────────
            Header: SECTION
        ─────────────────────────────────────────────────────────────── *@
        <UiKitsGroup Id="btn-group-outline"
                     Title="@_outlineState.GroupTitle"
                     IsAccordionOpen="@_outlineState.AccordionOpen"
                     IsAccordionOpenChanged="EventCallback.Factory.Create<bool>(this, _ => OnToggleAccordion(_outlineState))"
                     Items="@(_outlineState.Variants.Select(v => new UiKitsGroup.UiKitsDemoItem(v.Key, v.Label, string.Concat("dsv2-btn ", v.PreviewCssClass).Trim())).ToList())"
                     OnItemSelectedKeyChanged="EventCallback.Factory.Create<string>(this, key => OnSelectedVariantChanged(_outlineState, key))"
                     IsEditing="@_outlineState.IsEditing"
                     OnEdit="EventCallback.Factory.Create(this, () => OnEditSaveClickedAsync(_outlineState))"
                     EditorText="@_outlineState.EditorText"
                     EditorTextChanged="EventCallback.Factory.Create<string>(this, v => OnEditorInput(_outlineState, v))"
                     IsSaving="@_outlineState.IsSaving"
                     OnSave="EventCallback.Factory.Create(this, () => OnEditSaveClickedAsync(_outlineState))"
                     OnCancel="EventCallback.Factory.Create(this, () => OnCancelClicked(_outlineState))"
                     PreviewCss="@_outlineState.PreviewCss"
                     StatusMessage="@_outlineState.StatusMessage"
                     StatusIsError="@_outlineState.StatusIsError" />

        @* ───────────────────────────────────────────────────────────────
            Header: SECTION
        ─────────────────────────────────────────────────────────────── *@
        <UiKitsGroup Id="btn-group-soft"
                     Title="@_softState.GroupTitle"
                     IsAccordionOpen="@_softState.AccordionOpen"
                     IsAccordionOpenChanged="EventCallback.Factory.Create<bool>(this, _ => OnToggleAccordion(_softState))"
                     Items="@(_softState.Variants.Select(v => new UiKitsGroup.UiKitsDemoItem(v.Key, v.Label, string.Concat("dsv2-btn ", v.PreviewCssClass).Trim())).ToList())"
                     OnItemSelectedKeyChanged="EventCallback.Factory.Create<string>(this, key => OnSelectedVariantChanged(_softState, key))"
                     IsEditing="@_softState.IsEditing"
                     OnEdit="EventCallback.Factory.Create(this, () => OnEditSaveClickedAsync(_softState))"
                     EditorText="@_softState.EditorText"
                     EditorTextChanged="EventCallback.Factory.Create<string>(this, v => OnEditorInput(_softState, v))"
                     IsSaving="@_softState.IsSaving"
                     OnSave="EventCallback.Factory.Create(this, () => OnEditSaveClickedAsync(_softState))"
                     OnCancel="EventCallback.Factory.Create(this, () => OnCancelClicked(_softState))"
                     PreviewCss="@_softState.PreviewCss"
                     StatusMessage="@_softState.StatusMessage"
                     StatusIsError="@_softState.StatusIsError" />

        @* ───────────────────────────────────────────────────────────────
            Header: SECTION
        ─────────────────────────────────────────────────────────────── *@
        <UiKitsGroup Id="btn-group-icon"
                     Title="@_iconState.GroupTitle"
                     IsAccordionOpen="@_iconState.AccordionOpen"
                     IsAccordionOpenChanged="EventCallback.Factory.Create<bool>(this, _ => OnToggleAccordion(_iconState))"
                     Items="@(_iconState.Variants.Select(v => new UiKitsGroup.UiKitsDemoItem(v.Key, v.Label, v.PreviewCssClass)).ToList())"
                     OnItemSelectedKeyChanged="EventCallback.Factory.Create<string>(this, key => OnSelectedVariantChanged(_iconState, key))"
                     IsEditing="@_iconState.IsEditing"
                     OnEdit="EventCallback.Factory.Create(this, () => OnEditSaveClickedAsync(_iconState))"
                     EditorText="@_iconState.EditorText"
                     EditorTextChanged="EventCallback.Factory.Create<string>(this, v => OnEditorInput(_iconState, v))"
                     IsSaving="@_iconState.IsSaving"
                     OnSave="EventCallback.Factory.Create(this, () => OnEditSaveClickedAsync(_iconState))"
                     OnCancel="EventCallback.Factory.Create(this, () => OnCancelClicked(_iconState))"
                     PreviewCss="@_iconState.PreviewCss"
                     StatusMessage="@_iconState.StatusMessage"
                     StatusIsError="@_iconState.StatusIsError">
            <ItemTemplate Context="ctx">
                <button type="button" class="dsv2-btn @ctx.Item.CssClass">
                    @if (ctx.Item.Key == "icon-1") { <i class="bi bi-download"></i> }
                    else if (ctx.Item.Key == "icon-2") { <i class="bi bi-bell"></i> }
                    else if (ctx.Item.Key == "icon-3") { <i class="bi bi-gear"></i> }
                    else if (ctx.Item.Key == "icon-4") { <i class="bi bi-alarm"></i> }
                    else if (ctx.Item.Key == "icon-5") { <i class="bi bi-camera"></i> }
                    else { <i class="bi bi-image"></i> }
                </button>
            </ItemTemplate>
        </UiKitsGroup>

        @* ───────────────────────────────────────────────────────────────
            Header: SECTION
        ─────────────────────────────────────────────────────────────── *@
        <UiKitsGroup Id="btn-group-social"
                     Title="@_socialState.GroupTitle"
                     IsAccordionOpen="@_socialState.AccordionOpen"
                     IsAccordionOpenChanged="EventCallback.Factory.Create<bool>(this, _ => OnToggleAccordion(_socialState))"
                     Items="@(_socialState.Variants.Select(v => new UiKitsGroup.UiKitsDemoItem(v.Key, v.Label, v.PreviewCssClass)).ToList())"
                     OnItemSelectedKeyChanged="EventCallback.Factory.Create<string>(this, key => OnSelectedVariantChanged(_socialState, key))"
                     IsEditing="@_socialState.IsEditing"
                     OnEdit="EventCallback.Factory.Create(this, () => OnEditSaveClickedAsync(_socialState))"
                     EditorText="@_socialState.EditorText"
                     EditorTextChanged="EventCallback.Factory.Create<string>(this, v => OnEditorInput(_socialState, v))"
                     IsSaving="@_socialState.IsSaving"
                     OnSave="EventCallback.Factory.Create(this, () => OnEditSaveClickedAsync(_socialState))"
                     OnCancel="EventCallback.Factory.Create(this, () => OnCancelClicked(_socialState))"
                     PreviewCss="@_socialState.PreviewCss"
                     StatusMessage="@_socialState.StatusMessage"
                     StatusIsError="@_socialState.StatusIsError">
            <ItemTemplate Context="ctx">
                <button type="button" class="@ctx.Item.CssClass" aria-label="@ctx.Item.Label">
                    @if (ctx.Item.Key == "social-facebook") { <i class="bi bi-facebook" aria-hidden="true"></i> }
                    else if (ctx.Item.Key == "social-twitter") { <i class="bi bi-twitter" aria-hidden="true"></i> }
                    else if (ctx.Item.Key == "social-instagram") { <i class="bi bi-instagram" aria-hidden="true"></i> }
                    else if (ctx.Item.Key == "social-reddit") { <i class="bi bi-reddit" aria-hidden="true"></i> }
                    else if (ctx.Item.Key == "social-whatsapp") { <i class="bi bi-whatsapp" aria-hidden="true"></i> }
                    else if (ctx.Item.Key == "social-linkedin") { <i class="bi bi-linkedin" aria-hidden="true"></i> }
                    else if (ctx.Item.Key == "social-telegram") { <i class="bi bi-telegram" aria-hidden="true"></i> }
                    else if (ctx.Item.Key == "social-youtube") { <i class="bi bi-youtube" aria-hidden="true"></i> }
                    else if (ctx.Item.Key == "social-behance") { <i class="bi bi-behance" aria-hidden="true"></i> }
                    else if (ctx.Item.Key == "social-dribbble") { <i class="bi bi-dribbble" aria-hidden="true"></i> }
                    else { <i class="bi bi-snapchat" aria-hidden="true"></i> }
                </button>
            </ItemTemplate>
        </UiKitsGroup>

        @* ───────────────────────────────────────────────────────────────
            Header: SECTION
        ─────────────────────────────────────────────────────────────── *@
        <UiKitsGroup Id="btn-group-radius"
                     Title="@_radiusState.GroupTitle"
                     IsAccordionOpen="@_radiusState.AccordionOpen"
                     IsAccordionOpenChanged="EventCallback.Factory.Create<bool>(this, _ => OnToggleAccordion(_radiusState))"
                     Items="@(_radiusState.Variants.Select(v => new UiKitsGroup.UiKitsDemoItem(v.Key, v.Label, v.PreviewCssClass)).ToList())"
                     OnItemSelectedKeyChanged="EventCallback.Factory.Create<string>(this, key => OnSelectedVariantChanged(_radiusState, key))"
                     IsEditing="@_radiusState.IsEditing"
                     OnEdit="EventCallback.Factory.Create(this, () => OnEditSaveClickedAsync(_radiusState))"
                     EditorText="@_radiusState.EditorText"
                     EditorTextChanged="EventCallback.Factory.Create<string>(this, v => OnEditorInput(_radiusState, v))"
                     IsSaving="@_radiusState.IsSaving"
                     OnSave="EventCallback.Factory.Create(this, () => OnEditSaveClickedAsync(_radiusState))"
                     OnCancel="EventCallback.Factory.Create(this, () => OnCancelClicked(_radiusState))"
                     PreviewCss="@_radiusState.PreviewCss"
                     StatusMessage="@_radiusState.StatusMessage"
                     StatusIsError="@_radiusState.StatusIsError" />

        @* ───────────────────────────────────────────────────────────────
        Header: SECTION
        ─────────────────────────────────────────────────────────────── *@
        <UiKitsGroup Id="btn-group-active"
                     Title="@_activeState.GroupTitle"
                     IsAccordionOpen="@_activeState.AccordionOpen"
                     IsAccordionOpenChanged="EventCallback.Factory.Create<bool>(this, _ => OnToggleAccordion(_activeState))"
                     Items="@(_activeState.Variants.Select(v => new UiKitsGroup.UiKitsDemoItem(v.Key, v.Label, string.Concat("dsv2-btn ", v.PreviewCssClass).Trim())).ToList())"
                     OnItemSelectedKeyChanged="EventCallback.Factory.Create<string>(this, key => OnSelectedVariantChanged(_activeState, key))"
                     IsEditing="@_activeState.IsEditing"
                     OnEdit="EventCallback.Factory.Create(this, () => OnEditSaveClickedAsync(_activeState))"
                     EditorText="@_activeState.EditorText"
                     EditorTextChanged="EventCallback.Factory.Create<string>(this, v => OnEditorInput(_activeState, v))"
                     IsSaving="@_activeState.IsSaving"
                     OnSave="EventCallback.Factory.Create(this, () => OnEditSaveClickedAsync(_activeState))"
                     OnCancel="EventCallback.Factory.Create(this, () => OnCancelClicked(_activeState))"
                     PreviewCss="@_activeState.PreviewCss"
                     StatusMessage="@_activeState.StatusMessage"
                     StatusIsError="@_activeState.StatusIsError" />

        @* ───────────────────────────────────────────────────────────────
        Header: SECTION
        ─────────────────────────────────────────────────────────────── *@
        <UiKitsGroup Id="btn-group-disabled"
                     Title="@_disabledState.GroupTitle"
                     IsAccordionOpen="@_disabledState.AccordionOpen"
                     IsAccordionOpenChanged="EventCallback.Factory.Create<bool>(this, _ => OnToggleAccordion(_disabledState))"
                     Items="@(_disabledState.Variants.Select(v => new UiKitsGroup.UiKitsDemoItem(v.Key, v.Label, string.Concat("dsv2-btn ", v.PreviewCssClass).Trim())).ToList())"
                     OnItemSelectedKeyChanged="EventCallback.Factory.Create<string>(this, key => OnSelectedVariantChanged(_disabledState, key))"
                     IsEditing="@_disabledState.IsEditing"
                     OnEdit="EventCallback.Factory.Create(this, () => OnEditSaveClickedAsync(_disabledState))"
                     EditorText="@_disabledState.EditorText"
                     EditorTextChanged="EventCallback.Factory.Create<string>(this, v => OnEditorInput(_disabledState, v))"
                     IsSaving="@_disabledState.IsSaving"
                     OnSave="EventCallback.Factory.Create(this, () => OnEditSaveClickedAsync(_disabledState))"
                     OnCancel="EventCallback.Factory.Create(this, () => OnCancelClicked(_disabledState))"
                     PreviewCss="@_disabledState.PreviewCss"
                     StatusMessage="@_disabledState.StatusMessage"
                     StatusIsError="@_disabledState.StatusIsError" />

        @* ───────────────────────────────────────────────────────────────
        Header: SECTION
        ─────────────────────────────────────────────────────────────── *@
        <UiKitsGroup Id="btn-group-loading"
                     Title="@_loadingState.GroupTitle"
                     IsAccordionOpen="@_loadingState.AccordionOpen"
                     IsAccordionOpenChanged="EventCallback.Factory.Create<bool>(this, _ => OnToggleAccordion(_loadingState))"
                     Items="@(_loadingState.Variants.Select(v => new UiKitsGroup.UiKitsDemoItem(v.Key, v.Label, v.PreviewCssClass)).ToList())"
                     OnItemSelectedKeyChanged="EventCallback.Factory.Create<string>(this, key => OnSelectedVariantChanged(_loadingState, key))"
                     IsEditing="@_loadingState.IsEditing"
                     OnEdit="EventCallback.Factory.Create(this, () => OnEditSaveClickedAsync(_loadingState))"
                     EditorText="@_loadingState.EditorText"
                     EditorTextChanged="EventCallback.Factory.Create<string>(this, v => OnEditorInput(_loadingState, v))"
                     IsSaving="@_loadingState.IsSaving"
                     OnSave="EventCallback.Factory.Create(this, () => OnEditSaveClickedAsync(_loadingState))"
                     OnCancel="EventCallback.Factory.Create(this, () => OnCancelClicked(_loadingState))"
                     PreviewCss="@_loadingState.PreviewCss"
                     StatusMessage="@_loadingState.StatusMessage"
                     StatusIsError="@_loadingState.StatusIsError">
            <ItemTemplate Context="ctx">
                <button type="button" class="@ctx.Item.CssClass">
                    @if (ctx.Item.Key.Contains("pulse", StringComparison.OrdinalIgnoreCase) || ctx.Item.Key.Contains("danger", StringComparison.OrdinalIgnoreCase))
                    {
                        <span class="btp-pulse-loader" aria-hidden="true"></span>
                    }
                    else
                    {
                        <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                    }
                    <span>@ctx.Item.Label...</span>
                </button>
            </ItemTemplate>
        </UiKitsGroup>

        @* ───────────────────────────────────────────────────────────────
            Header: SECTION
        ─────────────────────────────────────────────────────────────── *@
        <UiKitsGroup Id="btn-group-block"
                     Title="@_blockState.GroupTitle"
                     IsAccordionOpen="@_blockState.AccordionOpen"
                     IsAccordionOpenChanged="EventCallback.Factory.Create<bool>(this, _ => OnToggleAccordion(_blockState))"
                     Items="@(_blockState.Variants.Select(v => new UiKitsGroup.UiKitsDemoItem(v.Key, v.Label, v.PreviewCssClass)).ToList())"
                     OnItemSelectedKeyChanged="EventCallback.Factory.Create<string>(this, key => OnSelectedVariantChanged(_blockState, key))"
                     IsEditing="@_blockState.IsEditing"
                     OnEdit="EventCallback.Factory.Create(this, () => OnEditSaveClickedAsync(_blockState))"
                     EditorText="@_blockState.EditorText"
                     EditorTextChanged="EventCallback.Factory.Create<string>(this, v => OnEditorInput(_blockState, v))"
                     IsSaving="@_blockState.IsSaving"
                     OnSave="EventCallback.Factory.Create(this, () => OnEditSaveClickedAsync(_blockState))"
                     OnCancel="EventCallback.Factory.Create(this, () => OnCancelClicked(_blockState))"
                     PreviewCss="@_blockState.PreviewCss"
                     StatusMessage="@_blockState.StatusMessage"
                     StatusIsError="@_blockState.StatusIsError" />

        @* ───────────────────────────────────────────────────────────────
            Header: SECTION
        ─────────────────────────────────────────────────────────────── *@
        <UiKitsGroup Id="btn-group-sizes"
                     Title="@_sizeState.GroupTitle"
                     IsAccordionOpen="@_sizeState.AccordionOpen"
                     IsAccordionOpenChanged="EventCallback.Factory.Create<bool>(this, _ => OnToggleAccordion(_sizeState))"
                     Items="@(_sizeState.Variants.Select(v => new UiKitsGroup.UiKitsDemoItem(v.Key, v.Label, string.Concat("dsv2-btn ", v.PreviewCssClass).Trim())).ToList())"
                     OnItemSelectedKeyChanged="EventCallback.Factory.Create<string>(this, key => OnSelectedVariantChanged(_sizeState, key))"
                     IsEditing="@_sizeState.IsEditing"
                     OnEdit="EventCallback.Factory.Create(this, () => OnEditSaveClickedAsync(_sizeState))"
                     EditorText="@_sizeState.EditorText"
                     EditorTextChanged="EventCallback.Factory.Create<string>(this, v => OnEditorInput(_sizeState, v))"
                     IsSaving="@_sizeState.IsSaving"
                     OnSave="EventCallback.Factory.Create(this, () => OnEditSaveClickedAsync(_sizeState))"
                     OnCancel="EventCallback.Factory.Create(this, () => OnCancelClicked(_sizeState))"
                     PreviewCss="@_sizeState.PreviewCss"
                     StatusMessage="@_sizeState.StatusMessage"
                     StatusIsError="@_sizeState.StatusIsError" />

        @* ───────────────────────────────────────────────────────────────
            Header: SECTION
        ─────────────────────────────────────────────────────────────── *@
        <UiKitsGroup Id="btn-group-groups"
                     Title="@_groupState.GroupTitle"
                     IsAccordionOpen="@_groupState.AccordionOpen"
                     IsAccordionOpenChanged="EventCallback.Factory.Create<bool>(this, _ => OnToggleAccordion(_groupState))"
                     Items="@(_groupState.Variants.Select(v => new UiKitsGroup.UiKitsDemoItem(v.Key, v.Label, v.PreviewCssClass)).ToList())"
                     OnItemSelectedKeyChanged="EventCallback.Factory.Create<string>(this, key => OnSelectedVariantChanged(_groupState, key))"
                     IsEditing="@_groupState.IsEditing"
                     OnEdit="EventCallback.Factory.Create(this, () => OnEditSaveClickedAsync(_groupState))"
                     EditorText="@_groupState.EditorText"
                     EditorTextChanged="EventCallback.Factory.Create<string>(this, v => OnEditorInput(_groupState, v))"
                     IsSaving="@_groupState.IsSaving"
                     OnSave="EventCallback.Factory.Create(this, () => OnEditSaveClickedAsync(_groupState))"
                     OnCancel="EventCallback.Factory.Create(this, () => OnCancelClicked(_groupState))"
                     PreviewCss="@_groupState.PreviewCss"
                     StatusMessage="@_groupState.StatusMessage"
                     StatusIsError="@_groupState.StatusIsError">
            <ItemTemplate Context="ctx">
                <div class="@ctx.Item.CssClass">
                    <button type="button" class="dsv2-btn">Active link</button>
                    <button type="button" class="dsv2-btn">Link</button>
                    <button type="button" class="dsv2-btn">Link</button>
                </div>
            </ItemTemplate>
        </UiKitsGroup>

        @* ───────────────────────────────────────────────────────────────
            Header: SECTION
        ─────────────────────────────────────────────────────────────── *@
        <UiKitsGroup Id="btn-group-action"
                     Title="@_actionState.GroupTitle"
                     IsAccordionOpen="@_actionState.AccordionOpen"
                     IsAccordionOpenChanged="EventCallback.Factory.Create<bool>(this, _ => OnToggleAccordion(_actionState))"
                     Items="@(_actionState.Variants.Select(v => new UiKitsGroup.UiKitsDemoItem(v.Key, v.Label, string.Concat("dsv2-btn ", v.PreviewCssClass).Trim())).ToList())"
                     OnItemSelectedKeyChanged="EventCallback.Factory.Create<string>(this, key => OnSelectedVariantChanged(_actionState, key))"
                     IsEditing="@_actionState.IsEditing"
                     OnEdit="EventCallback.Factory.Create(this, () => OnEditSaveClickedAsync(_actionState))"
                     EditorText="@_actionState.EditorText"
                     EditorTextChanged="EventCallback.Factory.Create<string>(this, v => OnEditorInput(_actionState, v))"
                     IsSaving="@_actionState.IsSaving"
                     OnSave="EventCallback.Factory.Create(this, () => OnEditSaveClickedAsync(_actionState))"
                     OnCancel="EventCallback.Factory.Create(this, () => OnCancelClicked(_actionState))"
                     PreviewCss="@_actionState.PreviewCss"
                     StatusMessage="@_actionState.StatusMessage"
                     StatusIsError="@_actionState.StatusIsError" />
        </ChildContent>
    </UiKitsPage>
}


