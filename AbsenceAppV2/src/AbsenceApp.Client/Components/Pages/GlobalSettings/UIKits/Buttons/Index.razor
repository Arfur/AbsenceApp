@* ===========================================================================
   File        : Index.razor
   Namespace   : AbsenceApp.Client.Components.Pages.GlobalSettings.UIKits.Buttons
    Author      : GitHub Copilot
    Version     : 8.4.0
   Created     : 2026-03-30
   Updated     : 2026-05-21
   ---------------------------------------------------------------------------
   Purpose     : Buttons3 UX layout with full Ki-Admin parity (one set per row).
                 - Accordion cards
                 - Real button variant selectors
                 - CSS code panel with Edit / Save, Cancel, Preview flow
                 - All sections collapsed by default
   ---------------------------------------------------------------------------
   Changes     :
    - 8.4.0  2026-05-21  Phase 2.2 strict corrective cycle: enforced
                     deterministic per-group render classes (no heuristic
                     tone/class inference), corrected icon/social/size
                     mappings, and kept all required groups on explicit
                     page-owned ItemTemplate markup.
    - 8.3.0  2026-05-21  Phase 2.2 corrective cycle: moved visual button groups
                     to page-owned ItemTemplate markup, removed tone-heuristic
                     class synthesis, and applied explicit per-group render
                     class payloads to prevent template fallback interference.
    - 8.2.0  2026-05-21  Phase 2.1 visual regression recovery: explicit
                     render-ready button class mapping for affected groups,
                     data-driven icon class payloads, and initial preview
                     hydration compatibility with template selection flow.
    - 8.1.0  2026-05-21  Restored full variant class lists, restored icon item
                     classes in ItemTemplate, and wired explicit preview
                     payload updates through OnItemSelectedKeyChanged.
    - 8.0.0  2026-05-21  Rewired page to template-level UiKitsGroup item
                     contract (Items + OnItemSelectedKeyChanged +
                     ItemTemplate), removing page-owned selected-state
                     rendering logic.
     - 7.1.0  2026-05-21  Added @using AbsenceApp.Client.Shared.Templates.UIKits
                          after migrating UiKitsPage/UiKitsGroup to new namespace.
     - 7.0.1  2026-05-20  Corrected header metadata: updated Version and Changes entry;
                           preserved original Author value; no functional code changes.
     - 7.0.0  2026-05-20  Refactored page layout to use UiKitsPage/UiKitsGroup template.
   =========================================================================== *@

@layout AbsenceApp.Client.Framework.Layouts.GlobalSettingsLayout
@page "/globalsettings/ui-kits/buttons"
@using AbsenceApp.Client.Shared.Templates.UIKits
@using AbsenceApp.Client.Components.DesignSystem
@using AbsenceApp.Client.Framework.PageTemplates
@using AbsenceApp.Client.Framework.Layout
@using System.Linq

@if (_isLoading)
{
    <div class="btp-loading">Loading button</div>
}
