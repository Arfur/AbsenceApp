@* ===========================================================================
   File        : Index.razor
   Author      : GitHub Copilot
   Version     : 6.1.0
   Created     : 2026-03-30
   Updated     : 18/05/2026
   Changes     : Phase 2 — Removed icon from Active/Disabled/Sizes default render;
                 loading case now uses btp-pulse-loader for pulse/danger variants.
   ---------------------------------------------------------------------------
   Purpose     : Buttons3 UX layout with full Ki-Admin parity (one set per row).
                 - Accordion cards
                 - Real button variant selectors
                 - CSS code panel with Edit / Save, Cancel, Preview flow
                 - All sections collapsed by default
   =========================================================================== *@

@page "/globalsettings/ui-kits/buttons"
@using AbsenceApp.Client.Components.DesignSystem

<div class="btp-page">
    <div class="btp-header">
        <h1>Buttons</h1>
        <p>UI Kits</p>
    </div>

    @if (_isLoading)
    {
        <div class="btp-loading">Loading button sets…</div>
    }
    else if (!string.IsNullOrWhiteSpace(_initError))
    {
        <div class="btp-init-error">@_initError</div>
    }
    else
    {
        @foreach (var state in GroupStates)
        {
            <section class="btp-group-card">
                <header class="btp-group-header">
                    <h2 class="btp-group-title">@state.GroupTitle</h2>
                    <button type="button"
                            class="btp-accordion-toggle @(state.AccordionOpen ? "btp-accordion-toggle--open" : string.Empty)"
                            title="Toggle CSS editor"
                            aria-label="Toggle CSS editor"
                            @onclick="() => OnToggleAccordion(state)">
                        &lt;/&gt;
                    </button>
                </header>

                <div id="btn-demo-@state.GroupKey" class="btp-demo-row">
                    @if (!string.IsNullOrWhiteSpace(state.PreviewCss))
                    {
                        <style>@state.PreviewCss</style>
                    }

                    @switch (state.GroupKey)
                    {
                        case "icon":
                            <div class="btp-icon-row">
                                <button type="button"
                                        class="dsv2-btn dsv2-btn--primary @(state.SelectedVariantKey == "icon-1" ? "btp-btn--selected" : string.Empty)"
                                        @onclick='() => OnSelectedVariantChanged(state, "icon-1")'>
                                    <i class="bi bi-download"></i>
                                </button>

                                <button type="button"
                                        class="dsv2-btn dsv2-btn--secondary @(state.SelectedVariantKey == "icon-2" ? "btp-btn--selected" : string.Empty)"
                                        @onclick='() => OnSelectedVariantChanged(state, "icon-2")'>
                                    <i class="bi bi-bell"></i>
                                </button>

                                <button type="button"
                                        class="dsv2-btn dsv2-btn--outline-primary @(state.SelectedVariantKey == "icon-3" ? "btp-btn--selected" : string.Empty)"
                                        @onclick='() => OnSelectedVariantChanged(state, "icon-3")'>
                                    <i class="bi bi-gear"></i>
                                </button>

                                <button type="button"
                                        class="dsv2-btn dsv2-btn--outline-secondary @(state.SelectedVariantKey == "icon-4" ? "btp-btn--selected" : string.Empty)"
                                        @onclick='() => OnSelectedVariantChanged(state, "icon-4")'>
                                    <i class="bi bi-alarm"></i>
                                </button>

                                <button type="button"
                                        class="dsv2-btn dsv2-btn--soft-primary @(state.SelectedVariantKey == "icon-5" ? "btp-btn--selected" : string.Empty)"
                                        @onclick='() => OnSelectedVariantChanged(state, "icon-5")'>
                                    <i class="bi bi-camera"></i>
                                </button>

                                <button type="button"
                                        class="dsv2-btn dsv2-btn--soft-secondary @(state.SelectedVariantKey == "icon-6" ? "btp-btn--selected" : string.Empty)"
                                        @onclick='() => OnSelectedVariantChanged(state, "icon-6")'>
                                    <i class="bi bi-image"></i>
                                </button>
                            </div>
                            break;

                        case "radius":
                            @foreach (var variant in state.Variants)
                            {
                                var selected = IsSelected(state, variant);
                                <button type="button"
                                        class="@variant.PreviewCssClass @(selected ? "btp-btn--selected" : string.Empty)"
                                        @onclick="() => OnSelectedVariantChanged(state, variant.Key)">
                                    @variant.Label
                                </button>
                            }
                            break;

                        case "social":
                            @foreach (var variant in state.Variants)
                            {
                                var selected = IsSelected(state, variant);
                                <button type="button"
                                        class="@variant.PreviewCssClass @(selected ? "btp-btn--selected" : string.Empty)"
                                        aria-label="@variant.Label"
                                        @onclick="() => OnSelectedVariantChanged(state, variant.Key)">
                                    @if (variant.Key == "social-facebook")
                                    {
                                        <i class="bi bi-facebook" aria-hidden="true"></i>
                                    }
                                    else if (variant.Key == "social-twitter")
                                    {
                                        <i class="bi bi-twitter" aria-hidden="true"></i>
                                    }
                                    else if (variant.Key == "social-instagram")
                                    {
                                        <i class="bi bi-instagram" aria-hidden="true"></i>
                                    }
                                    else if (variant.Key == "social-reddit")
                                    {
                                        <i class="bi bi-reddit" aria-hidden="true"></i>
                                    }
                                    else if (variant.Key == "social-whatsapp")
                                    {
                                        <i class="bi bi-whatsapp" aria-hidden="true"></i>
                                    }
                                    else if (variant.Key == "social-linkedin")
                                    {
                                        <i class="bi bi-linkedin" aria-hidden="true"></i>
                                    }
                                    else if (variant.Key == "social-telegram")
                                    {
                                        <i class="bi bi-telegram" aria-hidden="true"></i>
                                    }
                                    else if (variant.Key == "social-youtube")
                                    {
                                        <i class="bi bi-youtube" aria-hidden="true"></i>
                                    }
                                    else if (variant.Key == "social-behance")
                                    {
                                        <i class="bi bi-behance" aria-hidden="true"></i>
                                    }
                                    else if (variant.Key == "social-dribbble")
                                    {
                                        <i class="bi bi-dribbble" aria-hidden="true"></i>
                                    }
                                    else
                                    {
                                        <i class="bi bi-snapchat" aria-hidden="true"></i>
                                    }
                                </button>
                            }
                            break;

                        case "loading":
                            @foreach (var variant in state.Variants)
                            {
                                var selected = IsSelected(state, variant);
                                <button type="button"
                                        class="@variant.PreviewCssClass @(selected ? "btp-btn--selected" : string.Empty)"
                                        @onclick="() => OnSelectedVariantChanged(state, variant.Key)">
                                    @if (variant.Key.Contains("pulse", StringComparison.OrdinalIgnoreCase) || variant.Key.Contains("danger", StringComparison.OrdinalIgnoreCase))
                                    {
                                        <span class="btp-pulse-loader" aria-hidden="true"></span>
                                    }
                                    else
                                    {
                                        <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                                    }
                                    <span>@variant.Label...</span>
                                </button>
                            }
                            break;

                        case "block":
                            @foreach (var variant in state.Variants)
                            {
                                var selected = IsSelected(state, variant);
                                <button type="button"
                                        class="@variant.PreviewCssClass @(selected ? "btp-btn--selected" : string.Empty)"
                                        @onclick="() => OnSelectedVariantChanged(state, variant.Key)">
                                    @variant.Label
                                </button>
                            }
                            break;

                        case "groups":
                            @foreach (var variant in state.Variants)
                            {
                                var selected = IsSelected(state, variant);
                                <div class="@variant.PreviewCssClass @(selected ? "btp-btn--selected" : string.Empty)">
                                    <button type="button" class="dsv2-btn" @onclick="() => OnSelectedVariantChanged(state, variant.Key)">Active link</button>
                                    <button type="button" class="dsv2-btn" @onclick="() => OnSelectedVariantChanged(state, variant.Key)">Link</button>
                                    <button type="button" class="dsv2-btn" @onclick="() => OnSelectedVariantChanged(state, variant.Key)">Link</button>
                                </div>
                            }
                            break;

                        case "nested":
                            @foreach (var variant in state.Variants)
                            {
                                var selected = IsSelected(state, variant);
                                <div class="@variant.PreviewCssClass @(selected ? "btp-btn--selected" : string.Empty)">
                                    <button type="button" class="dsv2-btn" @onclick="() => OnSelectedVariantChanged(state, variant.Key)">1</button>
                                    <button type="button" class="dsv2-btn" @onclick="() => OnSelectedVariantChanged(state, variant.Key)">2</button>
                                    <button type="button" class="dsv2-btn" @onclick="() => OnSelectedVariantChanged(state, variant.Key)">
                                        Dropdown <i class="bi bi-chevron-down" aria-hidden="true"></i>
                                    </button>
                                </div>
                            }
                            break;

                        case "checkradio":
                            @foreach (var variant in state.Variants)
                            {
                                var selected = IsSelected(state, variant);
                                <div class="@variant.PreviewCssClass @(selected ? "btp-btn--selected" : string.Empty)">
                                    @if (variant.Key == "checkbox-line")
                                    {
                                        <button type="button" class="dsv2-btn" @onclick="() => OnSelectedVariantChanged(state, variant.Key)">Checkbox 1</button>
                                        <button type="button" class="dsv2-btn" @onclick="() => OnSelectedVariantChanged(state, variant.Key)">Checkbox 2</button>
                                        <button type="button" class="dsv2-btn" @onclick="() => OnSelectedVariantChanged(state, variant.Key)">Checkbox 3</button>
                                    }
                                    else if (variant.Key == "radio-line")
                                    {
                                        <button type="button" class="dsv2-btn" @onclick="() => OnSelectedVariantChanged(state, variant.Key)">Radio 1</button>
                                        <button type="button" class="dsv2-btn" @onclick="() => OnSelectedVariantChanged(state, variant.Key)">Radio 2</button>
                                        <button type="button" class="dsv2-btn" @onclick="() => OnSelectedVariantChanged(state, variant.Key)">Radio 3</button>
                                    }
                                    else
                                    {
                                        <button type="button" class="dsv2-btn" @onclick="() => OnSelectedVariantChanged(state, variant.Key)">1</button>
                                        <button type="button" class="dsv2-btn" @onclick="() => OnSelectedVariantChanged(state, variant.Key)">2</button>
                                        <button type="button" class="dsv2-btn" @onclick="() => OnSelectedVariantChanged(state, variant.Key)">3</button>
                                        <button type="button" class="dsv2-btn" @onclick="() => OnSelectedVariantChanged(state, variant.Key)">4</button>
                                        <button type="button" class="dsv2-btn" @onclick="() => OnSelectedVariantChanged(state, variant.Key)">8</button>
                                    }
                                </div>
                            }
                            break;

                        case "vertical":
                            @foreach (var variant in state.Variants)
                            {
                                var selected = IsSelected(state, variant);
                                <div class="@variant.PreviewCssClass @(selected ? "btp-btn--selected" : string.Empty)">
                                    @if (variant.Key == "vertical-radio")
                                    {
                                        <button type="button" class="dsv2-btn" @onclick="() => OnSelectedVariantChanged(state, variant.Key)">Radio 1</button>
                                        <button type="button" class="dsv2-btn" @onclick="() => OnSelectedVariantChanged(state, variant.Key)">Radio 2</button>
                                        <button type="button" class="dsv2-btn" @onclick="() => OnSelectedVariantChanged(state, variant.Key)">Radio 3</button>
                                    }
                                    else
                                    {
                                        <button type="button" class="dsv2-btn" @onclick="() => OnSelectedVariantChanged(state, variant.Key)">Button</button>
                                        <button type="button" class="dsv2-btn" @onclick="() => OnSelectedVariantChanged(state, variant.Key)">Button</button>
                                        <button type="button" class="dsv2-btn" @onclick="() => OnSelectedVariantChanged(state, variant.Key)">
                                            @(variant.Key == "vertical-solid" || variant.Key == "vertical-soft" ? "Dropdown" : "Button")
                                            @if (variant.Key == "vertical-solid" || variant.Key == "vertical-soft")
                                            {
                                                <i class="bi bi-chevron-down" aria-hidden="true"></i>
                                            }
                                        </button>
                                    }
                                </div>
                            }
                            break;

                        default:
                            @foreach (var variant in state.Variants)
                            {
                                var selected = IsSelected(state, variant);
                                <button type="button"
                                        class="dsv2-btn @variant.PreviewCssClass @(selected ? "btp-btn--selected" : string.Empty)"
                                        @onclick="() => OnSelectedVariantChanged(state, variant.Key)">
                                    @variant.Label
                                </button>
                            }
                            break;
                    }
                </div>

                @if (state.AccordionOpen)
                {
                    <div class="btp-accordion-panel">
                        <textarea class="btp-editor @(state.IsEditing ? "btp-editor--active" : string.Empty)"
                                  readonly="@(!state.IsEditing)"
                                  value="@state.EditorText"
                                  @oninput="(e => OnEditorInput(state, e.Value?.ToString() ?? string.Empty))"></textarea>

                        <div class="btp-action-row">
                            <button type="button"
                                    class="btp-btn-edit"
                                    disabled="@state.IsSaving"
                                    @onclick="() => OnEditSaveClickedAsync(state)">
                                @(state.IsEditing ? (state.IsSaving ? "Saving..." : "Save") : "Edit")
                            </button>

                            @if (state.IsEditing)
                            {
                                <button type="button"
                                        class="btp-btn-cancel"
                                        @onclick="() => OnCancelClicked(state)">
                                    Cancel
                                </button>

                                <button type="button"
                                        class="btp-btn-preview"
                                        @onclick="() => OnPreviewClicked(state)">
                                    Preview
                                </button>
                            }
                        </div>

                        @if (!string.IsNullOrWhiteSpace(state.StatusMessage))
                        {
                            <div class="btp-status @(state.StatusIsError ? "btp-status--error" : "btp-status--success")">
                                @state.StatusMessage
                            </div>
                        }
                    </div>
                }
            </section>
            
        }
    }
</div>
