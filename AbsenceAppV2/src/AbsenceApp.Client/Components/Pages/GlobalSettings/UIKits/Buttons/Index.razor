@layout AbsenceApp.Client.Framework.Layouts.GlobalSettingsLayout
@page "/globalsettings/ui-kits/buttons"
@using AbsenceApp.Client.Shared.Templates.UIKits
@using AbsenceApp.Client.Components.DesignSystem
@using AbsenceApp.Client.Framework.PageTemplates
@using AbsenceApp.Client.Framework.Layout

@if (_isLoading)
{
    <div class="btp-loading">Loading button</div>
}
else if (!string.IsNullOrWhiteSpace(_initError))
{
    <div class="btp-init-error">@_initError</div>
}
else
{
    <UiKitsPage>
        <ChildContent>
        @* ───────────────────────────────────────────────────────────────
            Header: SECTION
        ─────────────────────────────────────────────────────────────── *@
        <UiKitsGroup Id="btn-group-basic"
                     Title="@_basicState.GroupTitle"
                     AccordionOpen="@_basicState.AccordionOpen"
                     AccordionOpenChanged="EventCallback.Factory.Create<bool>(this, _ => OnToggleAccordion(_basicState))"
                     IsEditing="@_basicState.IsEditing"
                     OnEdit="EventCallback.Factory.Create(this, () => OnEditSaveClickedAsync(_basicState))"
                     EditorText="@_basicState.EditorText"
                     EditorTextChanged="EventCallback.Factory.Create<string>(this, v => OnEditorInput(_basicState, v))"
                     IsSaving="@_basicState.IsSaving"
                     OnSave="EventCallback.Factory.Create(this, () => OnEditSaveClickedAsync(_basicState))"
                     OnCancel="EventCallback.Factory.Create(this, () => OnCancelClicked(_basicState))"
                     PreviewCss="@_basicState.PreviewCss"
                     StatusMessage="@_basicState.StatusMessage"
                     StatusIsError="@_basicState.StatusIsError">
            <DemoContent>
                @if (!string.IsNullOrWhiteSpace(_basicState.PreviewCss)) { <style>@_basicState.PreviewCss</style> }
                @foreach (var variant in _basicState.Variants)
                {
                    var selected = IsSelected(_basicState, variant);
                    <button type="button"
                            class="dsv2-btn @variant.PreviewCssClass @(selected ? "btp-btn--selected" : string.Empty)"
                            @onclick="() => OnSelectedVariantChanged(_basicState, variant.Key)">
                        @variant.Label
                    </button>
                }
            </DemoContent>
        </UiKitsGroup>

