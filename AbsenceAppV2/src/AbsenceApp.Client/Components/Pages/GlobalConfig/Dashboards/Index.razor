@* ===========================================================================
   File        : Index.razor (Global Config — Dashboards)
   Namespace   : AbsenceApp.Client.Components.Pages.GlobalConfig.Dashboards
   Route       : /global-config/dashboards
   Author      : Michael
   Version     : 2.0.0
   Created     : 2026-03-27
   Updated     : 2026-03-28
   Changes :
     - 1.0.0  2026-03-27  Initial implementation.
     - 2.0.0  2026-03-28  Rebuilt with Ki-Admin card structure: KPI stats, activity feed, action buttons.
   ===========================================================================
*@

@page "/global-config/dashboards"
@layout AbsenceApp.Client.Framework.Layouts.BaseLayoutV2
@namespace AbsenceApp.Client.Components.Pages.GlobalConfig.Dashboards
@using AbsenceApp.Client.Framework.PageTemplates

<PageTemplateV2 PageTitleText="Dashboards">
    <ChildContent>
        <div class="gc-page">

            <!-- KPI Stat Cards -->
            <div class="gc-row">
                <div class="gc-col-full">
                    <div class="dsv2-card">
                        <div class="dsv2-card__header">
                            <h5 class="dsv2-card__title">KPI Stat Cards</h5>
                            <span class="dsv2-card__subtitle">Metric tiles used at the top of dashboard pages</span>
                        </div>
                        <div class="dsv2-card__body">
                            <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:1rem">
                                <div style="background:var(--v2-bg-subtle);border:1px solid var(--v2-border-color);border-radius:var(--v2-radius-base);border-left:4px solid var(--v2-color-primary);padding:1rem">
                                    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.5rem">
                                        <span style="font-size:0.75rem;font-weight:600;color:var(--v2-text-muted);text-transform:uppercase;letter-spacing:.04em">Total Students</span>
                                        <i class="bi bi-people-fill" style="font-size:1rem;color:var(--v2-color-primary)"></i>
                                    </div>
                                    <div style="font-size:1.75rem;font-weight:700;color:var(--v2-text-primary);line-height:1">1,284</div>
                                    <div style="font-size:0.75rem;color:var(--v2-color-success);margin-top:0.375rem"><i class="bi bi-arrow-up-short"></i> +12 this term</div>
                                </div>
                                <div style="background:var(--v2-bg-subtle);border:1px solid var(--v2-border-color);border-radius:var(--v2-radius-base);border-left:4px solid var(--v2-color-success);padding:1rem">
                                    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.5rem">
                                        <span style="font-size:0.75rem;font-weight:600;color:var(--v2-text-muted);text-transform:uppercase;letter-spacing:.04em">Attendance Rate</span>
                                        <i class="bi bi-graph-up-arrow" style="font-size:1rem;color:var(--v2-color-success)"></i>
                                    </div>
                                    <div style="font-size:1.75rem;font-weight:700;color:var(--v2-text-primary);line-height:1">94.7%</div>
                                    <div style="font-size:0.75rem;color:var(--v2-color-success);margin-top:0.375rem"><i class="bi bi-arrow-up-short"></i> +0.4% vs last week</div>
                                </div>
                                <div style="background:var(--v2-bg-subtle);border:1px solid var(--v2-border-color);border-radius:var(--v2-radius-base);border-left:4px solid var(--v2-color-warning);padding:1rem">
                                    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.5rem">
                                        <span style="font-size:0.75rem;font-weight:600;color:var(--v2-text-muted);text-transform:uppercase;letter-spacing:.04em">Absences Today</span>
                                        <i class="bi bi-person-x-fill" style="font-size:1rem;color:var(--v2-color-warning)"></i>
                                    </div>
                                    <div style="font-size:1.75rem;font-weight:700;color:var(--v2-text-primary);line-height:1">38</div>
                                    <div style="font-size:0.75rem;color:var(--v2-color-danger);margin-top:0.375rem"><i class="bi bi-arrow-down-short"></i> 8 unauthorised</div>
                                </div>
                                <div style="background:var(--v2-bg-subtle);border:1px solid var(--v2-border-color);border-radius:var(--v2-radius-base);border-left:4px solid var(--v2-color-info);padding:1rem">
                                    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.5rem">
                                        <span style="font-size:0.75rem;font-weight:600;color:var(--v2-text-muted);text-transform:uppercase;letter-spacing:.04em">Active Staff</span>
                                        <i class="bi bi-briefcase-fill" style="font-size:1rem;color:var(--v2-color-info)"></i>
                                    </div>
                                    <div style="font-size:1.75rem;font-weight:700;color:var(--v2-text-primary);line-height:1">86</div>
                                    <div style="font-size:0.75rem;color:var(--v2-text-muted);margin-top:0.375rem">2 on planned leave</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Activity Feed + Quick Actions -->
            <div class="gc-row">
                <div class="gc-col-half">
                    <div class="dsv2-card">
                        <div class="dsv2-card__header">
                            <h5 class="dsv2-card__title">Recent Activity Feed</h5>
                            <span class="dsv2-card__subtitle">Latest events listed chronologically</span>
                        </div>
                        <div class="dsv2-card__body--np">
                            <ul style="list-style:none;margin:0;padding:0">
                                <li style="display:flex;align-items:flex-start;gap:0.75rem;padding:0.75rem 1.25rem;border-bottom:1px solid var(--v2-border-color)">
                                    <div style="width:32px;height:32px;border-radius:50%;background:rgba(13,110,253,0.12);display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:2px">
                                        <i class="bi bi-person-check" style="color:var(--v2-color-primary);font-size:0.875rem"></i>
                                    </div>
                                    <div>
                                        <div style="font-size:0.8125rem;font-weight:500;color:var(--v2-text-primary)">Jane Smith marked attendance for 9A</div>
                                        <div style="font-size:0.75rem;color:var(--v2-text-muted);margin-top:2px">2 minutes ago</div>
                                    </div>
                                </li>
                                <li style="display:flex;align-items:flex-start;gap:0.75rem;padding:0.75rem 1.25rem;border-bottom:1px solid var(--v2-border-color)">
                                    <div style="width:32px;height:32px;border-radius:50%;background:rgba(220,53,69,0.12);display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:2px">
                                        <i class="bi bi-exclamation-circle" style="color:var(--v2-color-danger);font-size:0.875rem"></i>
                                    </div>
                                    <div>
                                        <div style="font-size:0.8125rem;font-weight:500;color:var(--v2-text-primary)">Priya Nair — unauthorised absence logged</div>
                                        <div style="font-size:0.75rem;color:var(--v2-text-muted);margin-top:2px">15 minutes ago</div>
                                    </div>
                                </li>
                                <li style="display:flex;align-items:flex-start;gap:0.75rem;padding:0.75rem 1.25rem;border-bottom:1px solid var(--v2-border-color)">
                                    <div style="width:32px;height:32px;border-radius:50%;background:rgba(25,135,84,0.12);display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:2px">
                                        <i class="bi bi-person-plus" style="color:var(--v2-color-success);font-size:0.875rem"></i>
                                    </div>
                                    <div>
                                        <div style="font-size:0.8125rem;font-weight:500;color:var(--v2-text-primary)">New student <strong>Oliver King</strong> added to Year 10</div>
                                        <div style="font-size:0.75rem;color:var(--v2-text-muted);margin-top:2px">1 hour ago</div>
                                    </div>
                                </li>
                                <li style="display:flex;align-items:flex-start;gap:0.75rem;padding:0.75rem 1.25rem">
                                    <div style="width:32px;height:32px;border-radius:50%;background:rgba(13,202,240,0.12);display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:2px">
                                        <i class="bi bi-gear" style="color:var(--v2-color-info);font-size:0.875rem"></i>
                                    </div>
                                    <div>
                                        <div style="font-size:0.8125rem;font-weight:500;color:var(--v2-text-primary)">Theme settings updated by Admin</div>
                                        <div style="font-size:0.75rem;color:var(--v2-text-muted);margin-top:2px">Yesterday at 4:30 pm</div>
                                    </div>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
                <div class="gc-col-half">
                    <div class="dsv2-card">
                        <div class="dsv2-card__header">
                            <h5 class="dsv2-card__title">Quick Action Buttons</h5>
                            <span class="dsv2-card__subtitle">Common primary actions surfaced on dashboard</span>
                        </div>
                        <div class="dsv2-card__body">
                            <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem">
                                <button style="display:flex;flex-direction:column;align-items:center;gap:0.5rem;padding:1rem;background:var(--v2-bg-subtle);border:1px solid var(--v2-border-color);border-radius:var(--v2-radius-base);cursor:pointer;transition:box-shadow .15s">
                                    <i class="bi bi-person-plus-fill" style="font-size:1.5rem;color:var(--v2-color-primary)"></i>
                                    <span style="font-size:0.8125rem;font-weight:600;color:var(--v2-text-primary)">Add Student</span>
                                </button>
                                <button style="display:flex;flex-direction:column;align-items:center;gap:0.5rem;padding:1rem;background:var(--v2-bg-subtle);border:1px solid var(--v2-border-color);border-radius:var(--v2-radius-base);cursor:pointer">
                                    <i class="bi bi-clipboard2-check-fill" style="font-size:1.5rem;color:var(--v2-color-success)"></i>
                                    <span style="font-size:0.8125rem;font-weight:600;color:var(--v2-text-primary)">Register</span>
                                </button>
                                <button style="display:flex;flex-direction:column;align-items:center;gap:0.5rem;padding:1rem;background:var(--v2-bg-subtle);border:1px solid var(--v2-border-color);border-radius:var(--v2-radius-base);cursor:pointer">
                                    <i class="bi bi-file-earmark-bar-graph" style="font-size:1.5rem;color:var(--v2-color-warning)"></i>
                                    <span style="font-size:0.8125rem;font-weight:600;color:var(--v2-text-primary)">Reports</span>
                                </button>
                                <button style="display:flex;flex-direction:column;align-items:center;gap:0.5rem;padding:1rem;background:var(--v2-bg-subtle);border:1px solid var(--v2-border-color);border-radius:var(--v2-radius-base);cursor:pointer">
                                    <i class="bi bi-gear-wide-connected" style="font-size:1.5rem;color:var(--v2-color-info)"></i>
                                    <span style="font-size:0.8125rem;font-weight:600;color:var(--v2-text-primary)">Settings</span>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Token Reference -->
            <div class="gc-row">
                <div class="gc-col-full">
                    <div class="dsv2-card">
                        <div class="dsv2-card__header">
                            <h5 class="dsv2-card__title">Design Tokens</h5>
                        </div>
                        <div class="dsv2-card__body">
                            <table class="gc-token-table">
                                <thead><tr><th class="gc-token-table__th">Token</th><th class="gc-token-table__th">Description</th></tr></thead>
                                <tbody>
                                    <tr><td class="gc-token-table__td gc-token-table__td--code">--v2-stat-card-border-w</td> <td class="gc-token-table__td">KPI card accent border width (4px)</td></tr>
                                    <tr><td class="gc-token-table__td gc-token-table__td--code">--v2-stat-card-bg</td>       <td class="gc-token-table__td">Stat card background (inherits --v2-bg-subtle)</td></tr>
                                    <tr><td class="gc-token-table__td gc-token-table__td--code">--v2-color-primary</td>      <td class="gc-token-table__td">Students metric accent</td></tr>
                                    <tr><td class="gc-token-table__td gc-token-table__td--code">--v2-color-success</td>      <td class="gc-token-table__td">Positive trend / attendance metric</td></tr>
                                    <tr><td class="gc-token-table__td gc-token-table__td--code">--v2-color-warning</td>      <td class="gc-token-table__td">Caution metric (absences)</td></tr>
                                    <tr><td class="gc-token-table__td gc-token-table__td--code">--v2-color-info</td>         <td class="gc-token-table__td">Neutral informational metric</td></tr>
                                    <tr><td class="gc-token-table__td gc-token-table__td--code">--v2-color-danger</td>       <td class="gc-token-table__td">Negative trend / alert state</td></tr>
                                    <tr><td class="gc-token-table__td gc-token-table__td--code">--v2-radius-base</td>        <td class="gc-token-table__td">Card and quick-action button radius</td></tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </ChildContent>
</PageTemplateV2>
