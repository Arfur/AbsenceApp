@page "/global-config/colours"
@layout AbsenceApp.Client.Framework.Layouts.BaseLayoutV2
@namespace AbsenceApp.Client.Components.Pages.GlobalConfig.Colours
@using AbsenceApp.Client.Framework.PageTemplates

<PageTemplateV2 PageTitleText="Colours">
    <ChildContent>
        <div class="gc-page">

            <!-- Semantic Colours -->
            <div class="gc-row">
                <div class="gc-col-full">
                    <div class="dsv2-card">
                        <div class="dsv2-card__header">
                            <h5 class="dsv2-card__title">Semantic Colours</h5>
                            <span class="dsv2-card__subtitle">Core brand and status colour tokens</span>
                        </div>
                        <div class="dsv2-card__body">
                            <div class="gc-colours-grid">
                                <div class="gc-swatch gc-swatch--primary">
                                    <span class="gc-swatch__label">Primary</span>
                                    <span class="gc-swatch__token">--v2-color-primary</span>
                                </div>
                                <div class="gc-swatch gc-swatch--secondary">
                                    <span class="gc-swatch__label">Secondary</span>
                                    <span class="gc-swatch__token">--v2-color-secondary</span>
                                </div>
                                <div class="gc-swatch gc-swatch--success">
                                    <span class="gc-swatch__label">Success</span>
                                    <span class="gc-swatch__token">--v2-color-success</span>
                                </div>
                                <div class="gc-swatch gc-swatch--danger">
                                    <span class="gc-swatch__label">Danger</span>
                                    <span class="gc-swatch__token">--v2-color-danger</span>
                                </div>
                                <div class="gc-swatch gc-swatch--warning">
                                    <span class="gc-swatch__label">Warning</span>
                                    <span class="gc-swatch__token">--v2-color-warning</span>
                                </div>
                                <div class="gc-swatch gc-swatch--info">
                                    <span class="gc-swatch__label">Info</span>
                                    <span class="gc-swatch__token">--v2-color-info</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Surface & Text colours -->
            <div class="gc-row">
                <div class="gc-col-half">
                    <div class="dsv2-card">
                        <div class="dsv2-card__header">
                            <h5 class="dsv2-card__title">Surface &amp; Background</h5>
                            <span class="dsv2-card__subtitle">Page, card and sidebar fills</span>
                        </div>
                        <div class="dsv2-card__body">
                            <div class="gc-colours-grid">
                                <div class="gc-swatch gc-swatch--bg-surface">
                                    <span class="gc-swatch__label">Surface</span>
                                    <span class="gc-swatch__token">--v2-bg-surface</span>
                                </div>
                                <div class="gc-swatch gc-swatch--bg-page">
                                    <span class="gc-swatch__label">Page</span>
                                    <span class="gc-swatch__token">--v2-bg-page</span>
                                </div>
                                <div class="gc-swatch gc-swatch--bg-subtle">
                                    <span class="gc-swatch__label">Subtle</span>
                                    <span class="gc-swatch__token">--v2-bg-subtle</span>
                                </div>
                                <div class="gc-swatch gc-swatch--bg-sidebar">
                                    <span class="gc-swatch__label">Sidebar</span>
                                    <span class="gc-swatch__token">--v2-bg-sidebar</span>
                                </div>
                                <div class="gc-swatch gc-swatch--bg-header">
                                    <span class="gc-swatch__label">Header</span>
                                    <span class="gc-swatch__token">--v2-bg-header</span>
                                </div>
                                <div class="gc-swatch gc-swatch--border">
                                    <span class="gc-swatch__label">Border</span>
                                    <span class="gc-swatch__token">--v2-border-color</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="gc-col-half">
                    <div class="dsv2-card">
                        <div class="dsv2-card__header">
                            <h5 class="dsv2-card__title">Text</h5>
                            <span class="dsv2-card__subtitle">Foreground colour hierarchy</span>
                        </div>
                        <div class="dsv2-card__body">
                            <div class="gc-colours-grid">
                                <div class="gc-swatch gc-swatch--text-primary">
                                    <span class="gc-swatch__label">Primary</span>
                                    <span class="gc-swatch__token">--v2-text-primary</span>
                                </div>
                                <div class="gc-swatch gc-swatch--text-secondary">
                                    <span class="gc-swatch__label">Secondary</span>
                                    <span class="gc-swatch__token">--v2-text-secondary</span>
                                </div>
                                <div class="gc-swatch gc-swatch--text-muted">
                                    <span class="gc-swatch__label">Muted</span>
                                    <span class="gc-swatch__token">--v2-text-muted</span>
                                </div>
                                <div class="gc-swatch gc-swatch--text-on-primary">
                                    <span class="gc-swatch__label">On Primary</span>
                                    <span class="gc-swatch__token">--v2-text-on-primary</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Token Reference -->
            <div class="gc-row">
                <div class="gc-col-full">
                    <div class="dsv2-card">
                        <div class="dsv2-card__header">
                            <h5 class="dsv2-card__title">Design Tokens</h5>
                        </div>
                        <div class="dsv2-card__body">
                            <table class="gc-token-table">
                                <thead>
                                    <tr>
                                        <th class="gc-token-table__th">Token</th>
                                        <th class="gc-token-table__th">Value</th>
                                        <th class="gc-token-table__th">Description</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr><td class="gc-token-table__td gc-token-table__td--code">--v2-color-primary</td>    <td class="gc-token-table__td">#0d6efd</td><td class="gc-token-table__td">Brand primary — blue</td></tr>
                                    <tr><td class="gc-token-table__td gc-token-table__td--code">--v2-color-secondary</td>  <td class="gc-token-table__td">#6c757d</td><td class="gc-token-table__td">Neutral secondary</td></tr>
                                    <tr><td class="gc-token-table__td gc-token-table__td--code">--v2-color-success</td>    <td class="gc-token-table__td">#198754</td><td class="gc-token-table__td">Positive / resolved</td></tr>
                                    <tr><td class="gc-token-table__td gc-token-table__td--code">--v2-color-danger</td>     <td class="gc-token-table__td">#dc3545</td><td class="gc-token-table__td">Critical / error</td></tr>
                                    <tr><td class="gc-token-table__td gc-token-table__td--code">--v2-color-warning</td>    <td class="gc-token-table__td">#ffc107</td><td class="gc-token-table__td">Caution / pending</td></tr>
                                    <tr><td class="gc-token-table__td gc-token-table__td--code">--v2-color-info</td>       <td class="gc-token-table__td">#0dcaf0</td><td class="gc-token-table__td">Informational</td></tr>
                                    <tr><td class="gc-token-table__td gc-token-table__td--code">--v2-bg-surface</td>       <td class="gc-token-table__td">#ffffff</td><td class="gc-token-table__td">Card / panel background</td></tr>
                                    <tr><td class="gc-token-table__td gc-token-table__td--code">--v2-bg-page</td>          <td class="gc-token-table__td">#f0f2f5</td><td class="gc-token-table__td">Page background</td></tr>
                                    <tr><td class="gc-token-table__td gc-token-table__td--code">--v2-border-color</td>     <td class="gc-token-table__td">#dee2e6</td><td class="gc-token-table__td">All borders</td></tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </ChildContent>
</PageTemplateV2>
