@page "/global-config/typography"
@layout AbsenceApp.Client.Framework.Layouts.BaseLayoutV2
@namespace AbsenceApp.Client.Components.Pages.GlobalConfig.Typography
@using AbsenceApp.Client.Framework.PageTemplates

<PageTemplateV2 PageTitleText="Typography">
    <ChildContent>
        <div class="gc-page">

            <!-- Heading Scale -->
            <div class="gc-row">
                <div class="gc-col-half">
                    <div class="dsv2-card">
                        <div class="dsv2-card__header">
                            <h5 class="dsv2-card__title">Heading Scale</h5>
                            <span class="dsv2-card__subtitle">h1 – h4 with token names</span>
                        </div>
                        <div class="dsv2-card__body">
                            <div class="gc-typo-list">
                                <div class="gc-typo-row">
                                    <span class="gc-typo-row__token">h1 / 2rem</span>
                                    <h1 style="margin:0;font-size:2rem;font-weight:700">Display Heading</h1>
                                </div>
                                <div class="gc-typo-row">
                                    <span class="gc-typo-row__token">h2 / 1.5rem</span>
                                    <h2 style="margin:0;font-size:1.5rem;font-weight:600">Section Heading</h2>
                                </div>
                                <div class="gc-typo-row">
                                    <span class="gc-typo-row__token">h3 / 1.25rem</span>
                                    <h3 style="margin:0;font-size:1.25rem;font-weight:600">Sub-section Heading</h3>
                                </div>
                                <div class="gc-typo-row">
                                    <span class="gc-typo-row__token">h4 / 1.0625rem</span>
                                    <h4 style="margin:0;font-size:1.0625rem;font-weight:600">Card Title</h4>
                                </div>
                                <div class="gc-typo-row">
                                    <span class="gc-typo-row__token">h5 / 0.9375rem</span>
                                    <h5 style="margin:0;font-size:0.9375rem;font-weight:600">Panel Heading</h5>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="gc-col-half">
                    <div class="dsv2-card">
                        <div class="dsv2-card__header">
                            <h5 class="dsv2-card__title">Body &amp; Label Text</h5>
                            <span class="dsv2-card__subtitle">Paragraph, caption, hint, code</span>
                        </div>
                        <div class="dsv2-card__body">
                            <div class="gc-typo-list">
                                <div class="gc-typo-row">
                                    <span class="gc-typo-row__token">base / 14px</span>
                                    <p style="margin:0;font-size:14px">The quick brown fox jumps over the lazy dog.</p>
                                </div>
                                <div class="gc-typo-row">
                                    <span class="gc-typo-row__token">sm / 12px</span>
                                    <p style="margin:0;font-size:12px">Small body — captions, help text, form hints.</p>
                                </div>
                                <div class="gc-typo-row">
                                    <span class="gc-typo-row__token">xs / 11px</span>
                                    <p style="margin:0;font-size:11px">Extra-small — badges, timestamps, status labels.</p>
                                </div>
                                <div class="gc-typo-row">
                                    <span class="gc-typo-row__token">muted text</span>
                                    <p style="margin:0;font-size:14px;color:var(--v2-text-muted)">Muted helper text for secondary information.</p>
                                </div>
                                <div class="gc-typo-row">
                                    <span class="gc-typo-row__token">monospace / code</span>
                                    <code style="font-size:13px">--v2-font-size-base: 14px</code>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Font Weights + Token Reference -->
            <div class="gc-row">
                <div class="gc-col-half">
                    <div class="dsv2-card">
                        <div class="dsv2-card__header">
                            <h5 class="dsv2-card__title">Font Weights</h5>
                        </div>
                        <div class="dsv2-card__body">
                            <div class="gc-typo-list">
                                <div class="gc-typo-row">
                                    <span class="gc-typo-row__token">400 / regular</span>
                                    <span style="font-weight:400;font-size:15px">Regular — default body text weight</span>
                                </div>
                                <div class="gc-typo-row">
                                    <span class="gc-typo-row__token">500 / medium</span>
                                    <span style="font-weight:500;font-size:15px">Medium — table cells, labels</span>
                                </div>
                                <div class="gc-typo-row">
                                    <span class="gc-typo-row__token">600 / semibold</span>
                                    <span style="font-weight:600;font-size:15px">Semibold — headings, nav items</span>
                                </div>
                                <div class="gc-typo-row">
                                    <span class="gc-typo-row__token">700 / bold</span>
                                    <span style="font-weight:700;font-size:15px">Bold — KPI values, emphasis</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="gc-col-half">
                    <div class="dsv2-card">
                        <div class="dsv2-card__header">
                            <h5 class="dsv2-card__title">Design Tokens</h5>
                        </div>
                        <div class="dsv2-card__body">
                            <table class="gc-token-table">
                                <thead>
                                    <tr>
                                        <th class="gc-token-table__th">Token</th>
                                        <th class="gc-token-table__th">Value</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr><td class="gc-token-table__td gc-token-table__td--code">--v2-font-sans</td>          <td class="gc-token-table__td">Inter, Segoe UI, Arial</td></tr>
                                    <tr><td class="gc-token-table__td gc-token-table__td--code">--v2-font-size-base</td>      <td class="gc-token-table__td">14px</td></tr>
                                    <tr><td class="gc-token-table__td gc-token-table__td--code">--v2-font-size-sm</td>        <td class="gc-token-table__td">12px</td></tr>
                                    <tr><td class="gc-token-table__td gc-token-table__td--code">--v2-font-size-xs</td>        <td class="gc-token-table__td">11px</td></tr>
                                    <tr><td class="gc-token-table__td gc-token-table__td--code">--v2-font-weight-regular</td> <td class="gc-token-table__td">400</td></tr>
                                    <tr><td class="gc-token-table__td gc-token-table__td--code">--v2-font-weight-semibold</td><td class="gc-token-table__td">600</td></tr>
                                    <tr><td class="gc-token-table__td gc-token-table__td--code">--v2-font-weight-bold</td>    <td class="gc-token-table__td">700</td></tr>
                                    <tr><td class="gc-token-table__td gc-token-table__td--code">--v2-line-height-base</td>    <td class="gc-token-table__td">1.5</td></tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </ChildContent>
</PageTemplateV2>
