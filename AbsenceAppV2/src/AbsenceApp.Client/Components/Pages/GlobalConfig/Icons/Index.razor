@* ===========================================================================
   File        : Index.razor (Global Config — Icons)
   Namespace   : AbsenceApp.Client.Components.Pages.GlobalConfig.Icons
   Route       : /global-config/icons
   Author      : Michael
   Version     : 2.0.0
   Created     : 2026-03-27
   Updated     : 2026-03-28
   Changes :
     - 1.0.0  2026-03-27  Initial implementation.
     - 2.0.0  2026-03-28  Rebuilt with Ki-Admin card structure: icon grid, sizes, token reference.
   ===========================================================================
*@

@page "/global-config/icons"
@layout AbsenceApp.Client.Framework.Layouts.BaseLayoutV2
@namespace AbsenceApp.Client.Components.Pages.GlobalConfig.Icons
@using AbsenceApp.Client.Framework.PageTemplates

<PageTemplateV2 PageTitleText="Icons">
    <ChildContent>
        <div class="gc-page">

            <!-- Icon Grid -->
            <div class="gc-row">
                <div class="gc-col-full">
                    <div class="dsv2-card">
                        <div class="dsv2-card__header">
                            <h5 class="dsv2-card__title">Bootstrap Icons — Common Set</h5>
                            <span class="dsv2-card__subtitle">All icons used across AbsenceApp V2 UI. Hover to see class name.</span>
                        </div>
                        <div class="dsv2-card__body">
                            <div style="display:flex;flex-wrap:wrap;gap:0.5rem">
                                @{
                                    var icons = new string[]
                                    {
                                        "bi-house-fill","bi-house",
                                        "bi-people-fill","bi-people",
                                        "bi-person-fill","bi-person",
                                        "bi-person-plus-fill","bi-person-plus",
                                        "bi-person-check-fill","bi-person-check",
                                        "bi-person-x-fill","bi-person-x",
                                        "bi-clipboard2-check-fill","bi-clipboard2-check",
                                        "bi-clipboard2-pulse","bi-clipboard2",
                                        "bi-calendar-check-fill","bi-calendar-check",
                                        "bi-calendar3","bi-calendar-event",
                                        "bi-graph-up-arrow","bi-bar-chart-fill",
                                        "bi-pie-chart-fill","bi-pie-chart",
                                        "bi-search","bi-funnel-fill",
                                        "bi-filter","bi-sliders",
                                        "bi-gear-wide-connected","bi-gear-fill",
                                        "bi-gear","bi-wrench-adjustable",
                                        "bi-shield-fill-check","bi-shield-check",
                                        "bi-lock-fill","bi-unlock-fill",
                                        "bi-bell-fill","bi-bell",
                                        "bi-envelope-fill","bi-envelope",
                                        "bi-file-earmark-text","bi-file-earmark-bar-graph",
                                        "bi-file-earmark-pdf","bi-folder2-open",
                                        "bi-pencil-fill","bi-pencil-square",
                                        "bi-trash3-fill","bi-trash3",
                                        "bi-plus-circle-fill","bi-plus-lg",
                                        "bi-dash-circle","bi-x-circle-fill",
                                        "bi-check-circle-fill","bi-check-lg",
                                        "bi-exclamation-triangle-fill","bi-exclamation-circle-fill",
                                        "bi-info-circle-fill","bi-question-circle-fill",
                                        "bi-arrow-left","bi-arrow-right",
                                        "bi-arrow-up","bi-arrow-down",
                                        "bi-chevron-left","bi-chevron-right",
                                        "bi-chevron-double-left","bi-chevron-double-right",
                                        "bi-box-arrow-right","bi-box-arrow-in-right",
                                        "bi-list","bi-grid-fill",
                                        "bi-table","bi-layout-text-sidebar-reverse",
                                        "bi-moon-fill","bi-sun-fill",
                                        "bi-brightness-high-fill","bi-palette-fill",
                                        "bi-tags-fill","bi-tag",
                                        "bi-briefcase-fill","bi-building",
                                        "bi-bank","bi-diagram-3-fill",
                                        "bi-star-fill","bi-star",
                                        "bi-heart-fill","bi-hand-thumbs-up-fill",
                                        "bi-clock-fill","bi-stopwatch-fill",
                                        "bi-wifi","bi-wifi-off",
                                        "bi-broadcast","bi-reception-4"
                                    };
                                    foreach (var icon in icons)
                                    {
                                        <div title="@icon" style="display:flex;flex-direction:column;align-items:center;gap:4px;padding:0.5rem;min-width:72px;border:1px solid var(--v2-border-color);border-radius:var(--v2-radius-sm);background:var(--v2-bg-subtle);cursor:default">
                                            <i class="bi @icon" style="font-size:1.25rem;color:var(--v2-text-primary)"></i>
                                            <span style="font-size:0.6rem;color:var(--v2-text-muted);word-break:break-all;text-align:center;line-height:1.2">@icon.Replace("bi-","")</span>
                                        </div>
                                    }
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Size Demo + Token Reference -->
            <div class="gc-row">
                <div class="gc-col-half">
                    <div class="dsv2-card">
                        <div class="dsv2-card__header">
                            <h5 class="dsv2-card__title">Icon Sizes</h5>
                            <span class="dsv2-card__subtitle">Standard sizes used in the design system</span>
                        </div>
                        <div class="dsv2-card__body">
                            <div style="display:flex;flex-direction:column;gap:1rem">
                                <div style="display:flex;align-items:center;gap:1rem">
                                    <i class="bi bi-person-fill" style="font-size:0.75rem;color:var(--v2-text-secondary)"></i>
                                    <span style="font-size:0.8125rem;color:var(--v2-text-secondary)">0.75rem — XS — badge icons, inline labels</span>
                                </div>
                                <div style="display:flex;align-items:center;gap:1rem">
                                    <i class="bi bi-person-fill" style="font-size:1rem;color:var(--v2-text-secondary)"></i>
                                    <span style="font-size:0.8125rem;color:var(--v2-text-secondary)">1rem — SM — button icons, table row icons</span>
                                </div>
                                <div style="display:flex;align-items:center;gap:1rem">
                                    <i class="bi bi-person-fill" style="font-size:1.25rem;color:var(--v2-text-secondary)"></i>
                                    <span style="font-size:0.8125rem;color:var(--v2-text-secondary)">1.25rem — MD — sidebar icons, header icons</span>
                                </div>
                                <div style="display:flex;align-items:center;gap:1rem">
                                    <i class="bi bi-person-fill" style="font-size:1.5rem;color:var(--v2-text-secondary)"></i>
                                    <span style="font-size:0.8125rem;color:var(--v2-text-secondary)">1.5rem — LG — quick-action card icons</span>
                                </div>
                                <div style="display:flex;align-items:center;gap:1rem">
                                    <i class="bi bi-person-fill" style="font-size:2rem;color:var(--v2-text-secondary)"></i>
                                    <span style="font-size:0.8125rem;color:var(--v2-text-secondary)">2rem — XL — empty-state illustrations</span>
                                </div>
                                <div style="display:flex;align-items:center;gap:1rem">
                                    <i class="bi bi-person-fill" style="font-size:3rem;color:var(--v2-text-secondary)"></i>
                                    <span style="font-size:0.8125rem;color:var(--v2-text-secondary)">3rem — XXL — hero / splash icons</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="gc-col-half">
                    <div class="dsv2-card">
                        <div class="dsv2-card__header">
                            <h5 class="dsv2-card__title">Design Tokens</h5>
                        </div>
                        <div class="dsv2-card__body">
                            <table class="gc-token-table">
                                <thead><tr><th class="gc-token-table__th">Token</th><th class="gc-token-table__th">Description</th></tr></thead>
                                <tbody>
                                    <tr><td class="gc-token-table__td gc-token-table__td--code">--v2-icon-size-xs</td>  <td class="gc-token-table__td">0.75rem — inline / badge</td></tr>
                                    <tr><td class="gc-token-table__td gc-token-table__td--code">--v2-icon-size-sm</td>  <td class="gc-token-table__td">1rem — button / table</td></tr>
                                    <tr><td class="gc-token-table__td gc-token-table__td--code">--v2-icon-size-md</td>  <td class="gc-token-table__td">1.25rem — nav / header</td></tr>
                                    <tr><td class="gc-token-table__td gc-token-table__td--code">--v2-icon-size-lg</td>  <td class="gc-token-table__td">1.5rem — quick-action cards</td></tr>
                                    <tr><td class="gc-token-table__td gc-token-table__td--code">--v2-icon-size-xl</td>  <td class="gc-token-table__td">2rem — empty states</td></tr>
                                    <tr><td class="gc-token-table__td gc-token-table__td--code">--v2-icon-size-xxl</td> <td class="gc-token-table__td">3rem — hero illustrations</td></tr>
                                    <tr><td class="gc-token-table__td gc-token-table__td--code">--v2-text-primary</td>  <td class="gc-token-table__td">Default icon colour</td></tr>
                                    <tr><td class="gc-token-table__td gc-token-table__td--code">--v2-text-muted</td>    <td class="gc-token-table__td">Subdued / placeholder icons</td></tr>
                                    <tr><td class="gc-token-table__td gc-token-table__td--code">--v2-color-primary</td> <td class="gc-token-table__td">Accent icon colour (nav active)</td></tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </ChildContent>
</PageTemplateV2>
