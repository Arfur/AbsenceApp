   File        : Index.razor (Global Config — Spacing)
   Namespace   : AbsenceApp.Client.Components.Pages.GlobalConfig.Spacing
   Route       : /global-config/spacing
   Author      : Michael
   Version     : 2.0.0
   Created     : 2026-03-27
   Updated     : 2026-03-28
   Changes :
     - 1.0.0  2026-03-27  Initial implementation.
     - 2.0.0  2026-03-28  Rebuilt with Ki-Admin card structure: spacing scale, padding/margin demos, radii.
   ===========================================================================
*@

@page "/global-config/spacing"
@layout AbsenceApp.Client.Framework.Layouts.BaseLayoutV2
@namespace AbsenceApp.Client.Components.Pages.GlobalConfig.Spacing
@using AbsenceApp.Client.Framework.PageTemplates

<PageTemplateV2 PageTitleText="Spacing">
    <ChildContent>
        <div class="gc-page">

            <!-- Spacing Scale -->
            <div class="gc-row">
                <div class="gc-col-full">
                    <div class="dsv2-card">
                        <div class="dsv2-card__header">
                            <h5 class="dsv2-card__title">Spacing Scale</h5>
                            <span class="dsv2-card__subtitle">Design system spacing tokens — 4px base unit</span>
                        </div>
                        <div class="dsv2-card__body">
                            <div style="display:flex;flex-direction:column;gap:0.625rem">
                                @{
                                    var steps = new (string Token, string Px, string Rem)[]
                                    {
                                        ("--v2-space-1", "4px",  "0.25rem"),
                                        ("--v2-space-2", "8px",  "0.5rem"),
                                        ("--v2-space-3", "12px", "0.75rem"),
                                        ("--v2-space-4", "16px", "1rem"),
                                        ("--v2-space-5", "20px", "1.25rem"),
                                        ("--v2-space-6", "24px", "1.5rem"),
                                        ("--v2-space-8", "32px", "2rem"),
                                        ("--v2-space-10","40px", "2.5rem"),
                                        ("--v2-space-12","48px", "3rem"),
                                        ("--v2-space-16","64px", "4rem"),
                                    };
                                    foreach (var s in steps)
                                    {
                                        <div style="display:flex;align-items:center;gap:1rem">
                                            <code style="width:130px;flex-shrink:0;font-size:0.75rem;color:var(--v2-color-primary)">@s.Token</code>
                                            <div style="height:20px;width:@s.Px;background:var(--v2-color-primary);opacity:.7;border-radius:2px;flex-shrink:0"></div>
                                            <span style="font-size:0.75rem;color:var(--v2-text-muted);min-width:60px">@s.Px</span>
                                            <span style="font-size:0.75rem;color:var(--v2-text-muted)">@s.Rem</span>
                                        </div>
                                    }
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Padding Demo + Margin Demo -->
            <div class="gc-row">
                <div class="gc-col-half">
                    <div class="dsv2-card">
                        <div class="dsv2-card__header">
                            <h5 class="dsv2-card__title">Padding Demo</h5>
                            <span class="dsv2-card__subtitle">Visualising interior space around content</span>
                        </div>
                        <div class="dsv2-card__body">
                            <div style="display:flex;flex-direction:column;gap:0.75rem">
                                <div style="background:rgba(13,110,253,0.08);border:2px dashed var(--v2-color-primary);border-radius:var(--v2-radius-sm);padding:4px;display:inline-flex">
                                    <div style="background:var(--v2-bg-surface);border:1px solid var(--v2-border-color);border-radius:var(--v2-radius-sm);padding:4px">
                                        <span style="font-size:0.75rem;color:var(--v2-text-muted)">p-1 — 4px</span>
                                    </div>
                                </div>
                                <div style="background:rgba(13,110,253,0.08);border:2px dashed var(--v2-color-primary);border-radius:var(--v2-radius-sm);padding:8px;display:inline-flex">
                                    <div style="background:var(--v2-bg-surface);border:1px solid var(--v2-border-color);border-radius:var(--v2-radius-sm);padding:8px">
                                        <span style="font-size:0.75rem;color:var(--v2-text-muted)">p-2 — 8px</span>
                                    </div>
                                </div>
                                <div style="background:rgba(13,110,253,0.08);border:2px dashed var(--v2-color-primary);border-radius:var(--v2-radius-sm);padding:16px;display:inline-flex">
                                    <div style="background:var(--v2-bg-surface);border:1px solid var(--v2-border-color);border-radius:var(--v2-radius-sm);padding:16px">
                                        <span style="font-size:0.75rem;color:var(--v2-text-muted)">p-4 — 16px (card body standard)</span>
                                    </div>
                                </div>
                                <div style="background:rgba(13,110,253,0.08);border:2px dashed var(--v2-color-primary);border-radius:var(--v2-radius-sm);padding:24px;display:inline-flex">
                                    <div style="background:var(--v2-bg-surface);border:1px solid var(--v2-border-color);border-radius:var(--v2-radius-sm);padding:24px">
                                        <span style="font-size:0.75rem;color:var(--v2-text-muted)">p-6 — 24px (page section gap)</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="gc-col-half">
                    <div class="dsv2-card">
                        <div class="dsv2-card__header">
                            <h5 class="dsv2-card__title">Border Radii</h5>
                            <span class="dsv2-card__subtitle">Rounded corner tokens used across components</span>
                        </div>
                        <div class="dsv2-card__body">
                            <div style="display:flex;flex-direction:column;gap:1rem">
                                <div style="display:flex;align-items:center;gap:1rem">
                                    <div style="width:64px;height:40px;background:var(--v2-color-primary);opacity:.8;border-radius:0px"></div>
                                    <div>
                                        <code style="font-size:0.75rem;color:var(--v2-color-primary)">--v2-radius-none</code>
                                        <span style="font-size:0.75rem;color:var(--v2-text-muted);margin-left:0.5rem">0px</span>
                                    </div>
                                </div>
                                <div style="display:flex;align-items:center;gap:1rem">
                                    <div style="width:64px;height:40px;background:var(--v2-color-primary);opacity:.8;border-radius:4px"></div>
                                    <div>
                                        <code style="font-size:0.75rem;color:var(--v2-color-primary)">--v2-radius-sm</code>
                                        <span style="font-size:0.75rem;color:var(--v2-text-muted);margin-left:0.5rem">4px — inputs, buttons</span>
                                    </div>
                                </div>
                                <div style="display:flex;align-items:center;gap:1rem">
                                    <div style="width:64px;height:40px;background:var(--v2-color-primary);opacity:.8;border-radius:8px"></div>
                                    <div>
                                        <code style="font-size:0.75rem;color:var(--v2-color-primary)">--v2-radius-base</code>
                                        <span style="font-size:0.75rem;color:var(--v2-text-muted);margin-left:0.5rem">8px — cards, panels</span>
                                    </div>
                                </div>
                                <div style="display:flex;align-items:center;gap:1rem">
                                    <div style="width:64px;height:40px;background:var(--v2-color-primary);opacity:.8;border-radius:16px"></div>
                                    <div>
                                        <code style="font-size:0.75rem;color:var(--v2-color-primary)">--v2-radius-lg</code>
                                        <span style="font-size:0.75rem;color:var(--v2-text-muted);margin-left:0.5rem">16px — modals, drawers</span>
                                    </div>
                                </div>
                                <div style="display:flex;align-items:center;gap:1rem">
                                    <div style="width:64px;height:40px;background:var(--v2-color-primary);opacity:.8;border-radius:999px"></div>
                                    <div>
                                        <code style="font-size:0.75rem;color:var(--v2-color-primary)">--v2-radius-pill</code>
                                        <span style="font-size:0.75rem;color:var(--v2-text-muted);margin-left:0.5rem">999px — badges, chips</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Token Reference -->
            <div class="gc-row">
                <div class="gc-col-full">
                    <div class="dsv2-card">
                        <div class="dsv2-card__header">
                            <h5 class="dsv2-card__title">Design Tokens</h5>
                        </div>
                        <div class="dsv2-card__body">
                            <table class="gc-token-table">
                                <thead><tr><th class="gc-token-table__th">Token</th><th class="gc-token-table__th">Value</th><th class="gc-token-table__th">Usage</th></tr></thead>
                                <tbody>
                                    <tr><td class="gc-token-table__td gc-token-table__td--code">--v2-space-1</td>    <td class="gc-token-table__td">4px</td>   <td class="gc-token-table__td">Fine detail spacing, icon gaps</td></tr>
                                    <tr><td class="gc-token-table__td gc-token-table__td--code">--v2-space-2</td>    <td class="gc-token-table__td">8px</td>   <td class="gc-token-table__td">Inline element gaps</td></tr>
                                    <tr><td class="gc-token-table__td gc-token-table__td--code">--v2-space-4</td>    <td class="gc-token-table__td">16px</td>  <td class="gc-token-table__td">Card body padding, list item gap</td></tr>
                                    <tr><td class="gc-token-table__td gc-token-table__td--code">--v2-space-6</td>    <td class="gc-token-table__td">24px</td>  <td class="gc-token-table__td">Section gap, page gutter</td></tr>
                                    <tr><td class="gc-token-table__td gc-token-table__td--code">--v2-space-8</td>    <td class="gc-token-table__td">32px</td>  <td class="gc-token-table__td">Page top padding, large section gap</td></tr>
                                    <tr><td class="gc-token-table__td gc-token-table__td--code">--v2-radius-sm</td>  <td class="gc-token-table__td">4px</td>   <td class="gc-token-table__td">Inputs, buttons, badges</td></tr>
                                    <tr><td class="gc-token-table__td gc-token-table__td--code">--v2-radius-base</td><td class="gc-token-table__td">8px</td>   <td class="gc-token-table__td">Cards, panels, dropdowns</td></tr>
                                    <tr><td class="gc-token-table__td gc-token-table__td--code">--v2-radius-lg</td>  <td class="gc-token-table__td">16px</td>  <td class="gc-token-table__td">Modals, drawers, overlays</td></tr>
                                    <tr><td class="gc-token-table__td gc-token-table__td--code">--v2-radius-pill</td><td class="gc-token-table__td">999px</td> <td class="gc-token-table__td">Pills, status dots, round avatars</td></tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </ChildContent>
</PageTemplateV2>
