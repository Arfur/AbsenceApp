@* ===========================================================================
   File        : Index.razor (Global Config — Tabs)
   Namespace   : AbsenceApp.Client.Components.Pages.GlobalConfig.Tabs
   Route       : /global-config/tabs | /global-settings/tabs
   Author      : Michael
   Version     : 1.0.0
   Created     : 2026-05-11
   Updated     : 2026-05-11
   ---------------------------------------------------------------------------
   Purpose     : Global Config — Tabs demo page.
                 Ki-Admin–style card layout. Demonstrates the indicator-style
                 upv2-tab-* classes used by ProfileTabsV2. Shows active,
                 inactive and disabled tab states with design token reference.
   ---------------------------------------------------------------------------
   Changes     :
     - 1.0.0  2026-05-11  Initial creation. Three demo cards: Active Tab,
                          Inactive Tab, Full Strip Preview.
   ===========================================================================
*@

@page "/global-config/tabs"
@page "/global-settings/tabs"
@layout AbsenceApp.Client.Framework.Layouts.BaseLayoutV2
@namespace AbsenceApp.Client.Components.Pages.GlobalConfig.Tabs
@using AbsenceApp.Client.Framework.PageTemplates

<PageTemplateV2 PageTitleText="Tabs">
    <ChildContent>
        <div class="gc-page">

            <!-- Active Tab State -->
            <div class="gc-row">
                <div class="gc-col-half">
                    <div class="dsv2-card">
                        <div class="dsv2-card__header">
                            <h5 class="dsv2-card__title">Active Tab</h5>
                            <span class="dsv2-card__subtitle">4px Corporate Blue bottom indicator via box-shadow inset</span>
                        </div>
                        <div class="dsv2-card__body">
                            <div class="upv2-tab-bar" role="tablist" style="position:relative;top:auto;z-index:auto;">
                                <button type="button" role="tab" class="upv2-tab-btn upv2-tab-btn--active" aria-selected="true">
                                    <i class="bi bi-person" aria-hidden="true"></i>
                                    <span>Basic Info</span>
                                </button>
                            </div>
                            <table class="gc-token-table" style="margin-top:1rem;">
                                <thead>
                                    <tr><th>Token</th><th>Value</th></tr>
                                </thead>
                                <tbody>
                                    <tr><td><code>--ds-tab-active-color</code></td><td>var(--ds-color-accent) — #2563eb</td></tr>
                                    <tr><td><code>--ds-tab-active-weight</code></td><td>var(--ds-font-semibold) — 600</td></tr>
                                    <tr><td><code>--ds-tab-active-border-color</code></td><td>var(--ds-color-accent) — #2563eb</td></tr>
                                    <tr><td><code>--ds-tab-active-border-width</code></td><td>4px</td></tr>
                                    <tr><td><code>--ds-tab-bg</code></td><td>var(--ds-color-surface-raised) — #ffffff</td></tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- Inactive Tab State -->
                <div class="gc-col-half">
                    <div class="dsv2-card">
                        <div class="dsv2-card__header">
                            <h5 class="dsv2-card__title">Inactive Tab</h5>
                            <span class="dsv2-card__subtitle">1px light-grey bottom indicator, slate grey label</span>
                        </div>
                        <div class="dsv2-card__body">
                            <div class="upv2-tab-bar" role="tablist" style="position:relative;top:auto;z-index:auto;">
                                <button type="button" role="tab" class="upv2-tab-btn" aria-selected="false">
                                    <i class="bi bi-telephone" aria-hidden="true"></i>
                                    <span>Contacts</span>
                                </button>
                            </div>
                            <table class="gc-token-table" style="margin-top:1rem;">
                                <thead>
                                    <tr><th>Token</th><th>Value</th></tr>
                                </thead>
                                <tbody>
                                    <tr><td><code>--ds-tab-inactive-color</code></td><td>var(--ds-color-gray-500) — #6b7280</td></tr>
                                    <tr><td><code>--ds-tab-inactive-weight</code></td><td>var(--ds-font-medium) — 500</td></tr>
                                    <tr><td><code>--ds-tab-inactive-border-color</code></td><td>var(--ds-color-gray-200) — #e5e7eb</td></tr>
                                    <tr><td><code>--ds-tab-inactive-border-width</code></td><td>1px</td></tr>
                                    <tr><td><code>--ds-tab-bg</code></td><td>var(--ds-color-surface-raised) — #ffffff</td></tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Full Strip Preview -->
            <div class="gc-row">
                <div class="gc-col-full">
                    <div class="dsv2-card">
                        <div class="dsv2-card__header">
                            <h5 class="dsv2-card__title">Full Strip Preview</h5>
                            <span class="dsv2-card__subtitle">Active, inactive, hover and disabled states in context</span>
                        </div>
                        <div class="dsv2-card__body">
                            <div class="upv2-tab-bar" role="tablist" style="position:relative;top:auto;z-index:auto;">
                                <button type="button" role="tab" class="upv2-tab-btn upv2-tab-btn--active" aria-selected="true">
                                    <i class="bi bi-person" aria-hidden="true"></i>
                                    <span>Basic Info</span>
                                </button>
                                <button type="button" role="tab" class="upv2-tab-btn" aria-selected="false">
                                    <i class="bi bi-telephone" aria-hidden="true"></i>
                                    <span>Contacts</span>
                                </button>
                                <button type="button" role="tab" class="upv2-tab-btn" aria-selected="false">
                                    <i class="bi bi-diagram-3" aria-hidden="true"></i>
                                    <span>Classes</span>
                                </button>
                                <button type="button" role="tab" class="upv2-tab-btn upv2-tab-btn--disabled" aria-selected="false" disabled>
                                    <i class="bi bi-laptop" aria-hidden="true"></i>
                                    <span>Devices</span>
                                </button>
                            </div>
                            <table class="gc-token-table" style="margin-top:1rem;">
                                <thead>
                                    <tr><th>Token</th><th>Value</th></tr>
                                </thead>
                                <tbody>
                                    <tr><td><code>--ds-tab-hover-bg</code></td><td>var(--ds-color-accent-subtle) — #eff6ff</td></tr>
                                    <tr><td><code>--ds-tab-hover-color</code></td><td>var(--ds-color-accent) — #2563eb</td></tr>
                                    <tr><td><code>--ds-tab-hover-border-color</code></td><td>var(--ds-color-accent-light) — #dbeafe</td></tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </ChildContent>
</PageTemplateV2>
