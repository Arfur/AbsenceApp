@* ===========================================================================
   File        : AppHost.razor
   Namespace   : AbsenceApp.Client.Components
   Author      : Michael
   Version     : 4.1.0
   Created     : 2026-03-23
   Updated     : 2026-04-05
   ---------------------------------------------------------------------------
   Purpose     : Root Blazor component for the MAUI BlazorWebView.
                 Renders a branded SplashScreenV2 for 1 500 ms while the app
                 initialises, then reveals the router inside a GLOBAL ERROR
                 BOUNDARY so that ALL unhandled exceptions — including
                 layout-level failures in SidebarV2, HeaderV2, BreadcrumbV2,
                 and page components — are caught and shown as a styled
                 fallback rather than a blank screen or raw exception dump.
                 Injects EntitlementsService at the root of the Blazor tree so
                 layouts and pages can perform permission checks.
   ---------------------------------------------------------------------------
   Notes       :
     - Registered as the RootComponent in MainPage.xaml.
     - Index.razor (route "/") redirects to /login on startup.
     - BaseLayoutV2 acts as the auth guard for all authenticated pages.
   ---------------------------------------------------------------------------
   Changes     :
     - 1.0.0  2026-03-23  Initial implementation.
     - 2.0.0  2026-03-24  Removed BaseLayoutV2 wrapper (Routes was swallowed).
     - 2.1.0  2026-03-24  Added @using AbsenceApp.Client for <Routes /> resolution.
     - 3.0.0  2026-03-27  Section A fix: wrapped <Routes /> with
                          GlobalErrorBoundaryV2 so all unhandled exceptions are
                          caught globally, logged, and shown as a styled fallback.
     - 4.0.0  2026-03-28  Phase 4 fix: added SplashScreenV2 shown for 1 500 ms
                          on first load before the router is revealed. Restores
                          the branded loading experience that was missing in V2.
     - 4.1.0  2026-04-05  Injected EntitlementsService at the Blazor root so
                          layouts and pages can evaluate permissions.
   ===========================================================================
*@
@using AbsenceApp.Client
@using AbsenceApp.Client.Framework.Layouts
@using AbsenceApp.Client.Services

@inject EntitlementsService Entitlements

<!-- =========================================================
     Section: SPLASH SCREEN
     Shown for 1 500 ms on first load as a branded loading
     experience before the shell and router are revealed.
     ========================================================= -->
@if (_showSplash)
{
    <SplashScreenV2 />
}
else
{
    <!-- =========================================================
         Section: GLOBAL ERROR BOUNDARY
         Wraps the entire router so all unhandled exceptions —
         including layout-level failures — are caught, logged, and
         shown as a styled fallback rather than a blank screen.
         ========================================================= -->
    <GlobalErrorBoundaryV2>
        <Routes />
    </GlobalErrorBoundaryV2>
}

@code {
    private bool _showSplash = true;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Task.Delay(1500);
            _showSplash = false;
            StateHasChanged();
        }
    }
}
