@* ===========================================================================
   File        : EmptyStateV2.razor
   Namespace   : AbsenceApp.Client.Components.TableV2
   Author      : Michael
   Version     : 1.0.0
   Created     : 2026-03-21
   Updated     : 2026-03-21
   ---------------------------------------------------------------------------
   Purpose     : V2 empty state component. Renders a centred icon, title, message, and optional action buttons. Used by TableV2 when Items is empty, and directly on empty pages.
   ---------------------------------------------------------------------------
   Changes     :
     - 1.0.0  2026-03-21  Initial implementation.
   ---------------------------------------------------------------------------
   Notes       :
     - Phase 4 component. No DI registration required.
   ===========================================================================
*@

@* =========================================================================
   Section: Empty state
   ========================================================================= *@
<div class="dsv2-empty-state @SizeClass">
    <div class="dsv2-empty-state__icon-wrap" aria-hidden="true">
        <i class="bi @Icon dsv2-empty-state__icon"></i>
    </div>

    <h2 class="dsv2-empty-state__title">@Title</h2>

    @if (!string.IsNullOrEmpty(Message))
    {
        <p class="dsv2-empty-state__message">@Message</p>
    }

    @if (ChildContent is not null)
    {
        <div class="dsv2-empty-state__actions">
            @ChildContent
        </div>
    }
</div>

@* =========================================================================
   Section: Parameters
   ========================================================================= *@
@code {
    [Parameter] public string Title { get; set; } = "No records found";
    [Parameter] public string Message { get; set; } = string.Empty;
    [Parameter] public string Icon { get; set; } = "bi-inbox";

    /// <summary>"sm" | "md" (default) | "lg"</summary>
    [Parameter] public string Size { get; set; } = "md";

    [Parameter] public RenderFragment? ChildContent { get; set; }

    private string SizeClass => Size switch
    {
        "sm" => "dsv2-empty-state--sm",
        "lg" => "dsv2-empty-state--lg",
        _    => string.Empty,
    };
}
