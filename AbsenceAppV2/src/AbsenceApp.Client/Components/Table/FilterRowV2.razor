@* ===========================================================================
   File        : FilterRowV2.razor
   Namespace   : AbsenceApp.Client.Components.TableV2
   Author      : Michael
   Version     : 1.0.0
   Created     : 2026-03-21
   Updated     : 2026-03-21
   ---------------------------------------------------------------------------
   Purpose     : V2 table filter row. Renders one text input per filterable visible column as a <tr> element inside <thead>. Emits a Dictionary<string,string> of active filter values on change.
   ---------------------------------------------------------------------------
   Changes     :
     - 1.0.0  2026-03-21  Initial implementation.
   ---------------------------------------------------------------------------
   Notes       :
     - Phase 4 component. No DI registration required.
   ===========================================================================
*@
@using AbsenceApp.Client.Models.TableV2

@* =========================================================================
   Section: Filter row
   ========================================================================= *@
<tr class="dsv2-filter-row" role="row" aria-label="Column filters">

    @* checkbox spacer *@
    @if (ShowCheckboxSpacer)
    {
        <td class="dsv2-filter-row__spacer"></td>
    }

    @foreach (var col in VisibleFilterableColumns)
    {
        <td class="dsv2-filter-row__cell dsv2-filter-row__cell--@col.Align @(col.HideOnMobile ? "dsv2-filter-row__cell--mobile-hidden" : "")"
            style="@(col.Width is not null ? $"width:{col.Width};min-width:{col.Width}" : "")">
            <input type="text"
                   class="dsv2-filter-row__input"
                   placeholder="@col.Label…"
                   value="@GetCurrentFilter(col.Key)"
                   @oninput="@(e => OnInputChanged(col.Key, e.Value?.ToString() ?? string.Empty))"
                   aria-label="Filter by @col.Label" />
        </td>
    }

    @* non-filterable visible columns still need spacer td cells *@
    @foreach (var col in VisibleNonFilterableColumns)
    {
        <td class="dsv2-filter-row__spacer"></td>
    }

    @* actions spacer *@
    @if (ShowActionsSpacer)
    {
        <td class="dsv2-filter-row__spacer"></td>
    }
</tr>

@* =========================================================================
   Section: Parameters and filter change handling
   ========================================================================= *@
@code {
    [Parameter] public List<TableColumnModel>? Columns { get; set; }
    [Parameter] public Dictionary<string, string> FilterValues { get; set; } = new();
    [Parameter] public bool ShowCheckboxSpacer { get; set; }
    [Parameter] public bool ShowActionsSpacer { get; set; }
    [Parameter] public EventCallback<Dictionary<string, string>> OnFilterChanged { get; set; }

    private IEnumerable<TableColumnModel> VisibleFilterableColumns =>
        Columns?.Where(c => c.Visible && c.Filterable).OrderBy(c => c.Order) ?? Enumerable.Empty<TableColumnModel>();

    private IEnumerable<TableColumnModel> VisibleNonFilterableColumns =>
        Columns?.Where(c => c.Visible && !c.Filterable).OrderBy(c => c.Order) ?? Enumerable.Empty<TableColumnModel>();

    private string GetCurrentFilter(string key) =>
        FilterValues.TryGetValue(key, out var v) ? v : string.Empty;

    private async Task OnInputChanged(string key, string value)
    {
        var updated = new Dictionary<string, string>(FilterValues);
        if (string.IsNullOrEmpty(value))
            updated.Remove(key);
        else
            updated[key] = value;

        await OnFilterChanged.InvokeAsync(updated);
    }
}
