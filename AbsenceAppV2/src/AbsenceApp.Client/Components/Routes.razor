@using AbsenceApp.Client.Framework.Layouts
@using AbsenceApp.Client.Services
@inject NavigationManager Nav
@inject AppStateService AppState
@implements IDisposable

<Router AppAssembly="@typeof(MauiProgram).Assembly">
    <Found Context="routeData">
        <ErrorBoundary>
            <ChildContent>
                <RouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayoutV2)" />
            </ChildContent>
            <ErrorContent Context="ex">
                @{ LogError(ex); }
                <div style="padding:2rem;font-family:monospace;color:red;background:white;position:fixed;top:0;left:0;right:0;bottom:0;overflow:auto;z-index:9999;">
                    <h2>Startup Error</h2>
                    <p><strong>@ex.GetType().FullName</strong></p>
                    <p>@ex.Message</p>
                    <pre style="white-space:pre-wrap;font-size:0.8rem;">@ex.ToString()</pre>
                </div>
            </ErrorContent>
        </ErrorBoundary>
    </Found>
    <NotFound>
        <p>Page not found.</p>
    </NotFound>
</Router>

@code {
    protected override void OnInitialized()
    {
        AppLog.TestWrite();
        AppLog.Write("Routes.razor", "OnInitialized",
            $"Router started. IsAuthenticated={AppState.IsAuthenticated} URI={Nav.Uri}");

        Nav.LocationChanged += OnLocationChanged;

        _ = InvokeAsync(() => CheckAuthRedirect(Nav.Uri, "OnInitialized"));
    }

    private void OnLocationChanged(object? sender,
        Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        AppLog.Write("Routes.razor", "OnLocationChanged",
            $"URI={e.Location} IsAuthenticated={AppState.IsAuthenticated}");

        _ = InvokeAsync(() => CheckAuthRedirect(e.Location, "LocationChanged"));
    }

    private void CheckAuthRedirect(string uri, string calledFrom = "")
    {
        var path = Nav.ToBaseRelativePath(uri);
        if (!path.StartsWith("/")) path = "/" + path;

        // ───────────────────────────────────────────────────────────────
        // MAUI Hybrid fix:
        // Ignore stale WebView navigation events to authenticated routes
        // when the user is not authenticated.
        // ALSO: force router back to /login so UI is correct.
        // ───────────────────────────────────────────────────────────────
        if (!AppState.IsAuthenticated &&
            path.StartsWith("/v2/", StringComparison.OrdinalIgnoreCase) &&
            !path.Equals("/login", StringComparison.OrdinalIgnoreCase))
        {
            AppLog.Write("Routes.razor", "CheckAuthRedirect",
                $"[from={calledFrom}] Ignoring stale MAUI WebView navigation to '{path}' while unauthenticated.");

            Nav.NavigateTo("/login", replace: true);
            return;
        }

        if (!AppState.IsAuthenticated &&
            !path.Equals("/login", StringComparison.OrdinalIgnoreCase))
        {
            AppLog.Write("Routes.razor", "CheckAuthRedirect",
                $"[from={calledFrom}] Unauthenticated access to '{path}' — redirecting to /login");

            Nav.NavigateTo("/login", replace: true);
        }
        else
        {
            AppLog.Write("Routes.razor", "CheckAuthRedirect",
                $"[from={calledFrom}] path='{path}' IsAuthenticated={AppState.IsAuthenticated} — no redirect");
        }
    }

    public void Dispose()
    {
        AppLog.Write("Routes.razor", "Dispose",
            $"Unsubscribing from Nav.LocationChanged. IsAuthenticated={AppState.IsAuthenticated}");
        Nav.LocationChanged -= OnLocationChanged;
    }

    static void LogError(Exception ex)
    {
        try
        {
            var dir  = @"C:\DevAbsence1\logs";
            var path = System.IO.Path.Combine(dir, "AbsenceApp_crash.log");
            System.IO.Directory.CreateDirectory(dir);
            System.IO.File.AppendAllText(path,
                $"[{DateTime.Now:HH:mm:ss}] ErrorBoundary: {ex}{Environment.NewLine}");
        }
        catch { }

        AppLog.Write("Routes.razor", "LogError",
            $"ErrorBoundary caught: {ex.GetType().Name}: {ex.Message}");
    }
}
