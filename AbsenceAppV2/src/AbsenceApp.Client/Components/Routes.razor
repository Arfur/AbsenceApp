@using AbsenceApp.Client.Framework.Layouts
@using AbsenceApp.Client.Services
@inject NavigationManager Nav
@inject AppStateService AppState
@implements IDisposable

<Router AppAssembly="@typeof(MauiProgram).Assembly">
    <Found Context="routeData">
        <ErrorBoundary>
            <ChildContent>
                <RouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayoutV2)" />
            </ChildContent>
            <ErrorContent Context="ex">
                @{ LogError(ex); }
                <div style="padding:2rem;font-family:monospace;color:red;background:white;position:fixed;top:0;left:0;right:0;bottom:0;overflow:auto;z-index:9999;">
                    <h2>Startup Error</h2>
                    <p><strong>@ex.GetType().FullName</strong></p>
                    <p>@ex.Message</p>
                    <pre style="white-space:pre-wrap;font-size:0.8rem;">@ex.ToString()</pre>
                </div>
            </ErrorContent>
        </ErrorBoundary>
    </Found>
    <NotFound>
        <p>Page not found.</p>
    </NotFound>
</Router>

@code {
    // ── Auth guard ──────────────────────────────────────────────────────────
    // Runs on initial render and on every navigation to ensure unauthenticated
    // users are always sent to /login.  The guard skips the /login route itself
    // to prevent an infinite redirect loop.

    protected override void OnInitialized()
    {
        Nav.LocationChanged += OnLocationChanged;
        _ = InvokeAsync(() => CheckAuthRedirect(Nav.Uri));
    }

    private void OnLocationChanged(object? sender,
        Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        _ = InvokeAsync(() => CheckAuthRedirect(e.Location));
    }

    private void CheckAuthRedirect(string uri)
    {
        var path = Nav.ToBaseRelativePath(uri);
        if (!path.StartsWith("/")) path = "/" + path;

        if (!AppState.IsAuthenticated &&
            !path.Equals("/login", StringComparison.OrdinalIgnoreCase))
        {
            Nav.NavigateTo("/login", replace: true);
        }
    }

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
    }

    // ── Error boundary helper ────────────────────────────────────────────────

    static void LogError(Exception ex)
    {
        try
        {
            var path = System.IO.Path.Combine(
                Environment.GetFolderPath(Environment.SpecialFolder.Desktop),
                "AbsenceApp_crash.log");
            System.IO.File.AppendAllText(path,
                $"[{DateTime.Now:HH:mm:ss}] ErrorBoundary: {ex}{Environment.NewLine}");
        }
        catch { }
    }
}
