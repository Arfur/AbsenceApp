   ---------------------------------------------------------------------------
   Purpose     : Dashboard page template. Composes PageTemplateV2 and provides
                 a metric strip slot (row of DashboardCardV2 components) and a
                 main grid body for charts, summary tables, or activity feeds.
   ---------------------------------------------------------------------------
   Changes     :
     - 1.0.0  2026-03-21  Initial implementation.
     - 1.1.0  2026-03-23  Added @layout BaseLayoutV2 directive (Step 3).
   ---------------------------------------------------------------------------
   Notes       :
     - Phase 5 component. No DI registration required.
     - Now inherits BaseLayoutV2 for consistent V2 page structure.
   ===========================================================================
*@

@using AbsenceApp.Client.Components.PageTemplatesV2

@* =========================================================================
   Section: Dashboard page shell
   ========================================================================= *@
<PageTemplateV2 PageTitleText="@PageTitle">

    <ActionsContent>
        @ActionsContent
    </ActionsContent>

    <BodyContent>
        <div class="dsv2-dashboard-page">

            @if (MetricsContent is not null)
            {
                <div class="dsv2-dashboard-page__metrics">
                    @MetricsContent
                </div>
            }

            @if (BodyContent is not null)
            {
                <div class="@BodyClass()">
                    @BodyContent
                </div>
            }

        </div>
    </BodyContent>

</PageTemplateV2>

@* =========================================================================
   Section: Parameters and layout
   ========================================================================= *@
@code {
    // -------------------------------------------------------------------------
    // Parameters
    // -------------------------------------------------------------------------

    /// <summary>Page heading shown in the title bar.</summary>
    [Parameter] public string PageTitle { get; set; } = string.Empty;

    /// <summary>Action buttons in the title bar (e.g. Date-range picker, Export).</summary>
    [Parameter] public RenderFragment? ActionsContent { get; set; }

    /// <summary>Row of DashboardCardV2 metric/stat cards rendered at the top.</summary>
    [Parameter] public RenderFragment? MetricsContent { get; set; }

    /// <summary>Main body grid content (panels, charts, activity feeds).</summary>
    [Parameter] public RenderFragment? BodyContent { get; set; }

    /// <summary>Number of columns in the body grid (1–4). Default: 2.</summary>
    [Parameter] public int BodyColumns { get; set; } = 2;

    // -------------------------------------------------------------------------
    // Helpers
    // -------------------------------------------------------------------------

    private string BodyClass() =>
        "dsv2-dashboard-page__body dsv2-dashboard-page__body--cols-" + BodyColumns;
}
