@* ===========================================================================
   File        : SettingsItemV2.razor
   Namespace   : AbsenceApp.Client.Components.PageTemplatesV2
   Author      : Michael
   Version     : 1.1.0
   Created     : 2026-03-21
   Updated     : 2026-03-23
   ---------------------------------------------------------------------------
   Purpose     : Single settings row rendered inside a SettingsGroupV2.
                 Left side: icon, label, description.
                 Right side: BodyContent (toggle, dropdown, input, etc.)
                 or HintText. Accepts a SettingsItemModel for configuration
                 or inline parameters.
   ---------------------------------------------------------------------------
   Changes     :
     - 1.0.0  2026-03-21  Initial implementation.
     - 1.1.0  2026-03-23  Header updated for Step 3 (no layout binding required).
   ---------------------------------------------------------------------------
   Notes       :
     - Phase 5 component. No DI registration required.
     - Not a page template — does not inherit BaseLayoutV2.
   ===========================================================================
*@

@using AbsenceApp.Client.Models.V2

@* =========================================================================
   Section: Settings item
   ========================================================================= *@
<div class="@ItemClass()" role="listitem">
    <div class="dsv2-settings-item__label-col">
        @if (Icon is not null)
        {
            <i class="bi @Icon dsv2-settings-item__icon" aria-hidden="true"></i>
        }
        <div class="dsv2-settings-item__text">
            <span class="dsv2-settings-item__label">
                @Label
                @if (!string.IsNullOrEmpty(BadgeText))
                {
                    <span class="dsv2-settings-item__badge">@BadgeText</span>
                }
            </span>
            @if (!string.IsNullOrEmpty(Description))
            {
                <span class="dsv2-settings-item__description">@Description</span>
            }
        </div>
    </div>

    <div class="dsv2-settings-item__control-col">
        @if (BodyContent is not null)
        {
            @BodyContent
        }
        else if (!string.IsNullOrEmpty(HintText))
        {
            <span class="dsv2-settings-item__hint">@HintText</span>
        }
    </div>
</div>

@* =========================================================================
   Section: Parameters
   ========================================================================= *@
@code {
    // -------------------------------------------------------------------------
    // Parameters
    // -------------------------------------------------------------------------
    [Parameter] public SettingsItemModel? Model { get; set; }
    [Parameter] public string Label { get; set; } = string.Empty;
    [Parameter] public string? Description { get; set; }
    [Parameter] public string? HintText { get; set; }
    [Parameter] public string? Icon { get; set; }
    [Parameter] public bool Disabled { get; set; } = false;
    [Parameter] public string? BadgeText { get; set; }
    [Parameter] public RenderFragment? BodyContent { get; set; }

    // -------------------------------------------------------------------------
    // Lifecycle
    // -------------------------------------------------------------------------
    protected override void OnParametersSet()
    {
        if (Model is not null)
        {
            if (string.IsNullOrEmpty(Label)) Label = Model.Label;
            Description ??= Model.Description;
            HintText    ??= Model.HintText;
            Icon        ??= Model.Icon;
            BadgeText   ??= Model.BadgeText;
            if (!Disabled) Disabled = Model.Disabled;
        }
    }

    private string ItemClass()
    {
        var cls = "dsv2-settings-item";
        if (Disabled) cls += " dsv2-settings-item--disabled";
        return cls;
    }
}
