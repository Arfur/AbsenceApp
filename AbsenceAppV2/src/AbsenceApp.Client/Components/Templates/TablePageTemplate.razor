@* ===========================================================================
   File        : TablePageTemplate.razor
   Namespace   : AbsenceApp.Client.Components.Templates
   Author      : AI Assistant
   Version     : 1.1.0
   Created     : 2026-03-26
   Updated     : 2026-03-27
   ---------------------------------------------------------------------------
   Purpose     : Table page content layout template. Provides a structured inner
                 layout for list/table pages inside the V2 shell. Exports seven
                 named regions as RenderFragment slots:

                   BreadcrumbContent  -- secondary in-content breadcrumb trail
                   FiltersContent     -- search box and filter controls
                   ToolbarContent     -- action buttons (Add, Export, etc.)
                   TableContent       -- the actual data table (TableV2 etc.)
                   PaginationContent  -- page controls (PaginationV2 etc.)

                 Each slot falls back to a static placeholder when not provided.
                 When IsEmpty=true AND TableContent is null, the EMPTY STATE
                 REGION renders instead of the placeholder table.

                 Intended to be composed inside PageTemplateV2ChildContent.
   ---------------------------------------------------------------------------
   Changes     :
     - 1.0.0  2026-03-26  Initial implementation (Phase 1 placeholder only).
     - 1.0.1  2026-03-26  Phase 3 Part 1: added HEADER / LAYOUT ROOT /
                          CONTENT REGION / PLACEHOLDER REGION section comments.
     - 1.1.0  2026-03-27  Phase 3 Part 1 of 2 (full implementation):
                          Added BREADCRUMB REGION, FILTERS REGION,
                          ACTIONS/TOOLBAR REGION, TABLE REGION with 5-row
                          placeholder, PAGINATION REGION, and EMPTY STATE
                          REGION. Replaced gs-template-* class prefix with
                          dsv2-tbl-tpl-* to avoid collision with other templates.
                          Added IsEmpty parameter. All regions use placeholder
                          content only -- no JSON, no dynamic data.
   ---------------------------------------------------------------------------
   Notes       :
     - DO NOT wire pages to this template yet (Phase 3 Part 2 scope).
     - BreadcrumbContent is a secondary in-content breadcrumb; the top-bar
       BreadcrumbV2 is rendered by BaseLayoutV2 and remains separate.
   ===========================================================================
*@

@namespace AbsenceApp.Client.Components.Templates

@* =========================
   SECTION: LAYOUT ROOT
   Column flex container wrapping all table page regions.
   ========================= *@
<div class="dsv2-tbl-tpl">

    @* =========================
       SECTION: HEADER REGION
       Optional title and sub-title for the table section. The outer
       PageTemplateV2 handles the main page title; this is a secondary header.
       ========================= *@
    @if (!string.IsNullOrWhiteSpace(Title) || !string.IsNullOrWhiteSpace(Subtitle))
    {
        <div class="dsv2-tbl-tpl__header">
            @if (!string.IsNullOrWhiteSpace(Title))
            {
                <h2 class="dsv2-tbl-tpl__title">@Title</h2>
            }
            @if (!string.IsNullOrWhiteSpace(Subtitle))
            {
                <p class="dsv2-tbl-tpl__subtitle">@Subtitle</p>
            }
        </div>
    }

    @* =========================
       SECTION: BREADCRUMB REGION
       Secondary in-content breadcrumb trail showing hierarchical location
       within the module. Falls back to a static placeholder.
       ========================= *@
    <div class="dsv2-tbl-tpl__breadcrumb">
        @if (BreadcrumbContent is not null)
        {
            @BreadcrumbContent
        }
        else
        {
            <nav class="dsv2-tbl-tpl__breadcrumb-nav" aria-label="Page breadcrumb">
                <span class="dsv2-tbl-tpl__breadcrumb-item">Home</span>
                <i class="bi bi-chevron-right dsv2-tbl-tpl__breadcrumb-sep" aria-hidden="true"></i>
                <span class="dsv2-tbl-tpl__breadcrumb-item">Section</span>
                <i class="bi bi-chevron-right dsv2-tbl-tpl__breadcrumb-sep" aria-hidden="true"></i>
                <span class="dsv2-tbl-tpl__breadcrumb-current">All Records</span>
            </nav>
        }
    </div>

    @* =========================
       SECTION: FILTERS REGION
       Search input and filter controls rendered above the table.
       Falls back to a static placeholder filter bar.
       ========================= *@
    <div class="dsv2-tbl-tpl__filters">
        @if (FiltersContent is not null)
        {
            @FiltersContent
        }
        else
        {
            <div class="dsv2-tbl-tpl__search-box">
                <i class="bi bi-search dsv2-tbl-tpl__search-icon" aria-hidden="true"></i>
                <span class="dsv2-tbl-tpl__search-placeholder">Search records&hellip;</span>
            </div>
            <div class="dsv2-tbl-tpl__filter-chips">
                <span class="dsv2-tbl-tpl__chip dsv2-tbl-tpl__chip--active">All</span>
                <span class="dsv2-tbl-tpl__chip">Active</span>
                <span class="dsv2-tbl-tpl__chip">Inactive</span>
            </div>
        }
    </div>

    @* =========================
       SECTION: ACTIONS / TOOLBAR REGION
       Primary action buttons (Add New, Export, etc.) above the table.
       Falls back to placeholder disabled buttons.
       ========================= *@
    <div class="dsv2-tbl-tpl__toolbar">
        @if (ToolbarContent is not null)
        {
            @ToolbarContent
        }
        else
        {
            <button class="dsv2-tbl-tpl__action-btn dsv2-tbl-tpl__action-btn--primary"
                    type="button" disabled>
                <i class="bi bi-plus-circle" aria-hidden="true"></i>
                Add New
            </button>
            <button class="dsv2-tbl-tpl__action-btn dsv2-tbl-tpl__action-btn--secondary"
                    type="button" disabled>
                <i class="bi bi-download" aria-hidden="true"></i>
                Export
            </button>
        }
    </div>

    @* =========================
       SECTION: TABLE REGION
       Main data grid. Delegates to TableContent slot if provided.
       When IsEmpty=true and no TableContent, shows EMPTY STATE REGION.
       Otherwise renders the 5-row placeholder table.
       ========================= *@
    <div class="dsv2-tbl-tpl__table-wrap">
        @if (TableContent is not null)
        {
            @TableContent
        }
        else if (IsEmpty)
        {
            @* =========================
               SECTION: EMPTY STATE REGION
               Shown when the result set has no records.
               ========================= *@
            <div class="dsv2-tbl-tpl__empty" role="status">
                <i class="bi bi-inbox dsv2-tbl-tpl__empty-icon" aria-hidden="true"></i>
                <p class="dsv2-tbl-tpl__empty-title">No records found</p>
                <p class="dsv2-tbl-tpl__empty-sub">
                    Try adjusting your filters or add a new record to get started.
                </p>
            </div>
        }
        else
        {
            @* Placeholder table with 5 sample rows *@
            <table class="dsv2-tbl-tpl__table">
                <thead>
                    <tr>
                        <th class="dsv2-tbl-tpl__th">Name</th>
                        <th class="dsv2-tbl-tpl__th">Status</th>
                        <th class="dsv2-tbl-tpl__th">Created</th>
                        <th class="dsv2-tbl-tpl__th">Updated</th>
                        <th class="dsv2-tbl-tpl__th dsv2-tbl-tpl__th--actions">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <tr class="dsv2-tbl-tpl__tr">
                        <td class="dsv2-tbl-tpl__td">Sample Record A</td>
                        <td class="dsv2-tbl-tpl__td"><span class="dsv2-tbl-tpl__badge dsv2-tbl-tpl__badge--active">Active</span></td>
                        <td class="dsv2-tbl-tpl__td">01 Jan 2026</td>
                        <td class="dsv2-tbl-tpl__td">15 Mar 2026</td>
                        <td class="dsv2-tbl-tpl__td dsv2-tbl-tpl__td--actions">
                            <button class="dsv2-tbl-tpl__row-btn" type="button" disabled title="View">
                                <i class="bi bi-eye" aria-hidden="true"></i>
                            </button>
                        </td>
                    </tr>
                    <tr class="dsv2-tbl-tpl__tr">
                        <td class="dsv2-tbl-tpl__td">Sample Record B</td>
                        <td class="dsv2-tbl-tpl__td"><span class="dsv2-tbl-tpl__badge dsv2-tbl-tpl__badge--active">Active</span></td>
                        <td class="dsv2-tbl-tpl__td">10 Feb 2026</td>
                        <td class="dsv2-tbl-tpl__td">20 Mar 2026</td>
                        <td class="dsv2-tbl-tpl__td dsv2-tbl-tpl__td--actions">
                            <button class="dsv2-tbl-tpl__row-btn" type="button" disabled title="View">
                                <i class="bi bi-eye" aria-hidden="true"></i>
                            </button>
                        </td>
                    </tr>
                    <tr class="dsv2-tbl-tpl__tr">
                        <td class="dsv2-tbl-tpl__td">Sample Record C</td>
                        <td class="dsv2-tbl-tpl__td"><span class="dsv2-tbl-tpl__badge dsv2-tbl-tpl__badge--inactive">Inactive</span></td>
                        <td class="dsv2-tbl-tpl__td">05 Mar 2026</td>
                        <td class="dsv2-tbl-tpl__td">22 Mar 2026</td>
                        <td class="dsv2-tbl-tpl__td dsv2-tbl-tpl__td--actions">
                            <button class="dsv2-tbl-tpl__row-btn" type="button" disabled title="View">
                                <i class="bi bi-eye" aria-hidden="true"></i>
                            </button>
                        </td>
                    </tr>
                    <tr class="dsv2-tbl-tpl__tr">
                        <td class="dsv2-tbl-tpl__td">Sample Record D</td>
                        <td class="dsv2-tbl-tpl__td"><span class="dsv2-tbl-tpl__badge dsv2-tbl-tpl__badge--active">Active</span></td>
                        <td class="dsv2-tbl-tpl__td">12 Mar 2026</td>
                        <td class="dsv2-tbl-tpl__td">25 Mar 2026</td>
                        <td class="dsv2-tbl-tpl__td dsv2-tbl-tpl__td--actions">
                            <button class="dsv2-tbl-tpl__row-btn" type="button" disabled title="View">
                                <i class="bi bi-eye" aria-hidden="true"></i>
                            </button>
                        </td>
                    </tr>
                    <tr class="dsv2-tbl-tpl__tr">
                        <td class="dsv2-tbl-tpl__td">Sample Record E</td>
                        <td class="dsv2-tbl-tpl__td"><span class="dsv2-tbl-tpl__badge dsv2-tbl-tpl__badge--planned">Planned</span></td>
                        <td class="dsv2-tbl-tpl__td">20 Mar 2026</td>
                        <td class="dsv2-tbl-tpl__td">27 Mar 2026</td>
                        <td class="dsv2-tbl-tpl__td dsv2-tbl-tpl__td--actions">
                            <button class="dsv2-tbl-tpl__row-btn" type="button" disabled title="View">
                                <i class="bi bi-eye" aria-hidden="true"></i>
                            </button>
                        </td>
                    </tr>
                </tbody>
            </table>
        }
    </div>

    @* =========================
       SECTION: PAGINATION REGION
       Page navigation controls. Falls back to a placeholder bar.
       Hidden when IsEmpty=true and no content is provided.
       ========================= *@
    @if (PaginationContent is not null)
    {
        <div class="dsv2-tbl-tpl__pagination">
            @PaginationContent
        </div>
    }
    else if (!IsEmpty || TableContent is not null)
    {
        <div class="dsv2-tbl-tpl__pagination">
            <span class="dsv2-tbl-tpl__page-info">Showing 1 &ndash; 5 of 5 records</span>
            <div class="dsv2-tbl-tpl__page-btns">
                <button class="dsv2-tbl-tpl__page-btn" type="button" disabled>
                    <i class="bi bi-chevron-left" aria-hidden="true"></i>
                    Previous
                </button>
                <button class="dsv2-tbl-tpl__page-btn dsv2-tbl-tpl__page-btn--active"
                        type="button" aria-current="page">1</button>
                <button class="dsv2-tbl-tpl__page-btn" type="button" disabled>
                    Next
                    <i class="bi bi-chevron-right" aria-hidden="true"></i>
                </button>
            </div>
        </div>
    }

</div>

@code {
    // -------------------------------------------------------------------------
    // Parameters
    // -------------------------------------------------------------------------

    /// <summary>Optional secondary title for the table section.</summary>
    [Parameter] public string? Title { get; set; }

    /// <summary>Optional descriptive text below the section title.</summary>
    [Parameter] public string? Subtitle { get; set; }

    /// <summary>
    /// When true and no TableContent is provided, the EMPTY STATE REGION
    /// is shown in place of the placeholder table. Pagination is also hidden.
    /// </summary>
    [Parameter] public bool IsEmpty { get; set; } = false;

    /// <summary>BREADCRUMB REGION — secondary in-content breadcrumb trail.</summary>
    [Parameter] public RenderFragment? BreadcrumbContent { get; set; }

    /// <summary>FILTERS REGION — search and filter controls.</summary>
    [Parameter] public RenderFragment? FiltersContent { get; set; }

    /// <summary>ACTIONS/TOOLBAR REGION — primary action buttons.</summary>
    [Parameter] public RenderFragment? ToolbarContent { get; set; }

    /// <summary>TABLE REGION — the data grid component (e.g. TableV2).</summary>
    [Parameter] public RenderFragment? TableContent { get; set; }

    /// <summary>PAGINATION REGION — page navigation controls.</summary>
    [Parameter] public RenderFragment? PaginationContent { get; set; }
}