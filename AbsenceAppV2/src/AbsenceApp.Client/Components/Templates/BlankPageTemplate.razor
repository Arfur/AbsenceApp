@namespace AbsenceApp.Client.Components.Templates

@* =========================
   SECTION: LAYOUT ROOT
   ========================= *@
<div class="gs-template gs-template--blank">

    @* =========================
       SECTION: HEADER
       ========================= *@
    @if (!string.IsNullOrWhiteSpace(PageTitle))
    {
        <div class="gs-template__header">
            <h1 class="gs-template__title">@PageTitle</h1>
        </div>
    }

    @* =========================
       SECTION: CONTENT REGION
       ========================= *@
    <div class="gs-template__body">
        @if (ChildContent is not null)
        {
            @ChildContent
        }
        else
        {
            @* =========================
               SECTION: PLACEHOLDER REGION
               ========================= *@
            <p class="gs-template__placeholder-text">No content provided.</p>
        }
    </div>

</div>

@code {
    [Parameter] public string PageTitle { get; set; } = string.Empty;
    [Parameter] public RenderFragment? ChildContent { get; set; }
}
