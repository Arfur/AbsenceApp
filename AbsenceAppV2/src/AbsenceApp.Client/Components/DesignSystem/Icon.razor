@* ===========================================================================
   File        : Icon.razor
   Namespace   : AbsenceApp.Client.Components.DesignSystem
   Author      : Michael
   Version     : 1.0.0
   Created     : 2026-03-21
   Updated     : 2026-03-21
   ---------------------------------------------------------------------------
   Purpose     : Reusable icon component backed by Bootstrap Icons. Renders a <i class="bi bi-{Name}"> element with configurable size, colour, and ARIA label.
   ---------------------------------------------------------------------------
   Changes     :
     - 1.0.0  2026-03-21  Initial implementation.
   ---------------------------------------------------------------------------
   Notes       :
     - Phase 2 component. No DI registration required.
   ===========================================================================
*@

@* =========================================================================
   Section: Icon element
   ========================================================================= *@
<i class="@CssClass" aria-label="@AriaLabel" aria-hidden="@(string.IsNullOrEmpty(AriaLabel) ? "true" : null)" title="@Title"></i>

@* =========================================================================
   Section: Parameters and CSS class builder
   ========================================================================= *@
@code {
    /// <summary>Bootstrap Icons name without the "bi-" prefix. E.g. "person".</summary>
    [Parameter, EditorRequired] public string Name { get; set; } = string.Empty;

    /// <summary>Size variant: xs | sm | md (default) | lg | xl | 2xl, or a raw CSS size e.g. "1.5rem".</summary>
    [Parameter] public string Size { get; set; } = "md";

    /// <summary>Optional colour override — any valid CSS colour value.</summary>
    [Parameter] public string? Color { get; set; }

    /// <summary>Optional ARIA label. If empty the icon is decorative (aria-hidden).</summary>
    [Parameter] public string? AriaLabel { get; set; }

    /// <summary>Optional tooltip title.</summary>
    [Parameter] public string? Title { get; set; }

    /// <summary>Additional CSS classes to append.</summary>
    [Parameter] public string? Class { get; set; }

    private string CssClass => BuildClass();
    private string BuildClass()
    {
        var sizeClass = Size switch
        {
            "xs"  => "ds-icon--xs",
            "sm"  => "ds-icon--sm",
            "md"  => "ds-icon--md",
            "lg"  => "ds-icon--lg",
            "xl"  => "ds-icon--xl",
            "2xl" => "ds-icon--2xl",
            _     => ""  // raw CSS handled via style below
        };
        return string.Join(" ", new[] { "bi", $"bi-{Name}", "ds-icon", sizeClass, Class }
            .Where(c => !string.IsNullOrWhiteSpace(c)));
    }

    private string? InlineStyle => !IsNamedSize(Size)
        ? $"font-size:{Size};{(Color is not null ? $"color:{Color};" : "")}"
        : Color is not null ? $"color:{Color};" : null;

    private static bool IsNamedSize(string s)
        => s is "xs" or "sm" or "md" or "lg" or "xl" or "2xl";
}
