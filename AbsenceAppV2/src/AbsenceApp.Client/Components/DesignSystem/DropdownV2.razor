@* ===========================================================================
   File        : DropdownV2.razor
   Namespace   : AbsenceApp.Client.Components.DesignSystem
   Author      : Michael
   Version     : 1.0.0
   Created     : 2026-05-19
   Updated     : 2026-05-19
   ---------------------------------------------------------------------------
   Purpose     : Reusable dropdown component for the Phase 2 design system.
                 Renders a trigger button and a positioned menu container.
                 Open/close state is managed internally; clicking the
                 backdrop (outside the menu) closes it without JS interop.

                 Outputs wrapper classes:
                   dsv2-dropdown
                   dsv2-dropdown--{Variant}  (e.g. dsv2-dropdown--primary)
                   dsv2-dropdown--{Size}     (e.g. dsv2-dropdown--sm)

                 Styles defined in wwwroot/css/components/dropdown.css and
                 consume --ds-dropdown-* design tokens.
   ---------------------------------------------------------------------------
   Parameters:
     Label        — label shown on the trigger button (required)
     Icon         — optional Bootstrap icon class (e.g. "bi bi-download")
     ChildContent — RenderFragment slot for menu items
     Variant      — "primary" (default) | "secondary"
     Size         — "sm" | "md" (default) | "lg"
     Disabled     — disables the trigger button
     Title        — optional tooltip for the trigger button
   ---------------------------------------------------------------------------
   Notes       :
     - No .razor.css companion — styles live in the global dropdown.css.
     - Outside-click dismissal uses a transparent backdrop div; no JS interop.
   ===========================================================================
*@

@namespace AbsenceApp.Client.Components.DesignSystem

@if (_open)
{
    <div class="dsv2-dropdown-backdrop" @onclick="Close" aria-hidden="true"></div>
}

<div class="@_wrapperClass">

    <button type="button"
            class="dsv2-dropdown__trigger"
            title="@Title"
            disabled="@Disabled"
            aria-expanded="@_open"
            aria-haspopup="menu"
            @onclick="Toggle"
            @onclick:stopPropagation="true">
        @if (!string.IsNullOrEmpty(Icon))
        {
            <i class="@Icon" aria-hidden="true"></i>
        }
        <span>@Label</span>
    </button>

    @if (_open)
    {
        <div class="dsv2-dropdown__menu" role="menu">
            @ChildContent
        </div>
    }

</div>

@code {

    [Parameter, EditorRequired] public string Label          { get; set; } = string.Empty;
    [Parameter] public string           Icon         { get; set; } = string.Empty;
    [Parameter] public RenderFragment?  ChildContent { get; set; }
    [Parameter] public string           Variant      { get; set; } = "primary";
    [Parameter] public string           Size         { get; set; } = "md";
    [Parameter] public bool             Disabled     { get; set; } = false;
    [Parameter] public string?          Title        { get; set; }

    private bool _open;

    private void Toggle() => _open = !_open;
    private void Close()  => _open = false;

    private string _wrapperClass =>
        $"dsv2-dropdown dsv2-dropdown--{Variant} dsv2-dropdown--{Size}";
}
