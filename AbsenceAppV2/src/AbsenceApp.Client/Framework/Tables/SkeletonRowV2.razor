@* ===========================================================================
   File        : SkeletonRowV2.razor
   Namespace   : AbsenceApp.Client.Components.TableV2
   Author      : Michael
   Version     : 1.0.0
   Created     : 2026-03-21
   Updated     : 2026-03-21
   ---------------------------------------------------------------------------
   Purpose     : V2 table skeleton loading row. Renders a <tr> of animated shimmer placeholder cells to be shown while real data is loading. ColumnCount controls how many cells are rendered.
   ---------------------------------------------------------------------------
   Changes     :
     - 1.0.0  2026-03-21  Initial implementation.
   ---------------------------------------------------------------------------
   Notes       :
     - Phase 4 component. No DI registration required.
   ===========================================================================
*@

@* =========================================================================
   Section: Skeleton row
   ========================================================================= *@
<tr class="dsv2-skeleton-row" aria-hidden="true">
    @for (int i = 0; i < ColumnCount; i++)
    {
        <td class="dsv2-skeleton-row__cell">
            <span class="dsv2-skeleton-row__shimmer"></span>
        </td>
    }
</tr>

@* =========================================================================
   Section: Parameters
   ========================================================================= *@
@code {
    /// <summary>Number of skeleton cells to render — should match the visible column count.</summary>
    [Parameter] public int ColumnCount { get; set; } = 5;
}
