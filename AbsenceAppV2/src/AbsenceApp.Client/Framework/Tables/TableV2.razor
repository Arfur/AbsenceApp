@* ===========================================================================
   File        : TableV2.razor
   Namespace   : AbsenceApp.Client.Components.TableV2
   Author      : Michael
   Version     : 1.0.0
   Created     : 2026-03-21
   Updated     : 2026-03-21
   ---------------------------------------------------------------------------
   Purpose     : V2 generic data table component. Renders a configurable, sortable, filterable, paginated table using strongly-typed TableColumnModel definitions. Composes FilterRowV2, InlineActionsV2, SkeletonRowV2, EmptyStateV2, and PaginationV2. TItem is the row data type.
   ---------------------------------------------------------------------------
   Changes     :
     - 1.0.0  2026-03-21  Initial implementation.
   ---------------------------------------------------------------------------
   Notes       :
     - Phase 4 component. No DI registration required.
   ===========================================================================
*@
@typeparam TItem
@using AbsenceApp.Client.Models.TableV2

@* =========================================================================
   Section: Table wrapper
   ========================================================================= *@
<div class="dsv2-table-wrapper">

@* =========================================================================
   Section: Toolbar: search + filter toggle + column settings
   ========================================================================= *@
    @if (ShowToolbar)
    {
        <div class="dsv2-table-toolbar">
            @if (ShowSearch)
            {
                <SearchBarV2 Value="@SearchValue"
                             Placeholder="@SearchPlaceholder"
                             ValueChanged="@OnSearchChanged"
                             class="dsv2-table-toolbar__search" />
            }

            <div class="dsv2-table-toolbar__actions">
                @if (ToolbarActionsContent is not null)
                {
                    @ToolbarActionsContent
                }

                @if (ShowFilterToggle && Columns is not null && Columns.Any(c => c.Filterable && c.Visible))
                {
                    <button type="button"
                            class="@FilterToggleBtnClass()"
                            @onclick="ToggleFilterRow"
                            title="@FilterToggleBtnTitle()">
                        <i class="bi bi-funnel" aria-hidden="true"></i>
                        <span>Filter</span>
                    </button>
                }
            </div>
        </div>
    }

@* =========================================================================
   Section: Horizontal scroll wrapper
   ========================================================================= *@
    <div class="dsv2-table-scroll">
        <table class="dsv2-table" aria-label="@AriaLabel">
            <thead class="dsv2-table__head">
                @* =========================================================================
   Section: Column headers
   ========================================================================= *@
                <tr class="dsv2-table__head-row">
                    @if (SelectionMode == TableSelectionMode.Multi)
                    {
                        <th class="dsv2-table__th dsv2-table__th--checkbox" scope="col">
                            <input type="checkbox"
                                   class="dsv2-table__checkbox"
                                   checked="@AllSelected"
                                   @onchange="ToggleSelectAll"
                                   aria-label="Select all rows" />
                        </th>
                    }

                    @foreach (var col in VisibleColumns)
                    {
                        <th class="@ThClass(col)"
                            scope="col"
                            style="@ThStyle(col)">
                            @if (col.Sortable)
                            {
                                <button type="button"
                                        class="@SortBtnClass(col.Key)"
                                        @onclick="@(() => OnColumnSort(col.Key))">
                                    @if (!string.IsNullOrEmpty(col.Icon))
                                    {
                                        <i class="bi @col.Icon dsv2-table__col-icon" aria-hidden="true"></i>
                                    }
                                    <span>@col.Label</span>
                                    <i class="bi @SortIconClass(col.Key) dsv2-table__sort-icon"
                                       aria-hidden="true"></i>
                                </button>
                            }
                            else
                            {
                                <span class="dsv2-table__col-label">
                                    @if (!string.IsNullOrEmpty(col.Icon))
                                    {
                                        <i class="bi @col.Icon dsv2-table__col-icon" aria-hidden="true"></i>
                                    }
                                    @col.Label
                                </span>
                            }
                        </th>
                    }

                    @if (RowActionsContent is not null)
                    {
                        <th class="dsv2-table__th dsv2-table__th--actions" scope="col" aria-label="Actions"></th>
                    }
                </tr>

@* =========================================================================
   Section: Filter row
   ========================================================================= *@
                @if (_showFilterRow && Columns is not null)
                {
                    <FilterRowV2 Columns="@Columns"
                                 FilterValues="@_filterValues"
                                 ShowCheckboxSpacer="@(SelectionMode == TableSelectionMode.Multi)"
                                 ShowActionsSpacer="@(RowActionsContent is not null)"
                                 OnFilterChanged="@HandleColumnFilterChanged" />
                }
            </thead>

            <tbody class="dsv2-table__body">
                @if (IsLoading)
                {
                    @for (int i = 0; i < LoadingRowCount; i++)
                    {
                        <SkeletonRowV2 ColumnCount="@(VisibleColumns.Count() + (SelectionMode == TableSelectionMode.Multi ? 1 : 0) + (RowActionsContent is not null ? 1 : 0))" />
                    }
                }
                else if (!PagedItems.Any())
                {
                    <tr class="dsv2-table__empty-row">
                        <td colspan="@TotalColumnCount" class="dsv2-table__empty-cell">
                            <EmptyStateV2 Title="@EmptyTitle"
                                          Message="@EmptyMessage"
                                          Icon="@EmptyIcon">
                                @EmptyActionsContent
                            </EmptyStateV2>
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var item in PagedItems)
                    {
                        var isSelected = _selectedItems.Contains(item);
                        <tr class="@RowClass(item, isSelected)"
                            @onclick="@(() => HandleRowClick(item))">

                            @if (SelectionMode == TableSelectionMode.Multi)
                            {
                                <td class="dsv2-table__td dsv2-table__td--checkbox">
                                    <input type="checkbox"
                                           class="dsv2-table__checkbox"
                                           checked="@isSelected"
                                           @onchange="@(() => ToggleRowSelection(item))"
                                           @onclick:stopPropagation="true"
                                           aria-label="Select row" />
                                </td>
                            }

                            @if (RowTemplate is not null)
                            {
                                @RowTemplate(item)
                            }
                            else
                            {
                                @* Fallback: display raw .ToString() per visible column *@
                                @foreach (var col in VisibleColumns)
                                {
                                    <td class="@TdClass(col)">
                                        @GetCellValue(item, col)
                                    </td>
                                }
                            }

                            @if (RowActionsContent is not null)
                            {
                                <td class="dsv2-table__td dsv2-table__td--actions" @onclick:stopPropagation="true">
                                    <InlineActionsV2>
                                        @RowActionsContent(item)
                                    </InlineActionsV2>
                                </td>
                            }
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

@* =========================================================================
   Section: Pagination footer
   ========================================================================= *@
    @if (ShowPagination && TotalCount > 0)
    {
        <PaginationV2 CurrentPage="@CurrentPage"
                      PageSize="@PageSize"
                      TotalCount="@TotalCount"
                      PageSizeOptions="@PageSizeOptions"
                      ShowPageSizeSelector="@ShowPageSizeSelector"
                      OnPageChanged="@OnPageChangedInternal"
                      OnPageSizeChanged="@OnPageSizeChangedInternal" />
    }
</div>

@code {
    // -------------------------------------------------------------------------
    // Data parameters
    // -------------------------------------------------------------------------
    /// <summary>Column definitions. If null, falls back to Keys of the first row item.</summary>
    [Parameter] public List<TableColumnModel>? Columns { get; set; }

    /// <summary>The full data set to display. ClientSide: pagination applied here.</summary>
    [Parameter] public IEnumerable<TItem> Items { get; set; } = [];

    /// <summary>Total row count for server-side pagination. 0 = use Items.Count().</summary>
    [Parameter] public int TotalCount { get; set; }

    // -------------------------------------------------------------------------

    // State parameters

    // -------------------------------------------------------------------------
    [Parameter] public bool IsLoading { get; set; }
    [Parameter] public int LoadingRowCount { get; set; } = 5;

    // -------------------------------------------------------------------------

    // Sort parameters

    // -------------------------------------------------------------------------
    [Parameter] public string? SortColumn { get; set; }
    [Parameter] public bool SortAscending { get; set; } = true;
    [Parameter] public EventCallback<(string Column, bool Ascending)> OnSortChanged { get; set; }

    // -------------------------------------------------------------------------

    // Search parameters

    // -------------------------------------------------------------------------
    [Parameter] public bool ShowSearch { get; set; } = true;
    [Parameter] public string SearchValue { get; set; } = string.Empty;
    [Parameter] public string SearchPlaceholder { get; set; } = "Search…";
    [Parameter] public EventCallback<string> OnSearchChanged { get; set; }

    // -------------------------------------------------------------------------

    // Filter parameters

    // -------------------------------------------------------------------------
    [Parameter] public bool ShowFilterToggle { get; set; } = true;
    [Parameter] public EventCallback<Dictionary<string, string>> OnFilterChanged { get; set; }

    // -------------------------------------------------------------------------

    // Pagination parameters

    // -------------------------------------------------------------------------
    [Parameter] public bool ShowPagination { get; set; } = true;
    [Parameter] public int CurrentPage { get; set; } = 1;
    [Parameter] public int PageSize { get; set; } = 25;
    [Parameter] public int[] PageSizeOptions { get; set; } = [10, 25, 50, 100];
    [Parameter] public bool ShowPageSizeSelector { get; set; } = true;
    [Parameter] public EventCallback<int> OnPageChanged { get; set; }
    [Parameter] public EventCallback<int> OnPageSizeChanged { get; set; }

    // -------------------------------------------------------------------------

    // Selection parameters

    // -------------------------------------------------------------------------
    [Parameter] public TableSelectionMode SelectionMode { get; set; } = TableSelectionMode.None;
    [Parameter] public EventCallback<HashSet<TItem>> OnSelectionChanged { get; set; }

    // -------------------------------------------------------------------------

    // Empty-state parameters

    // -------------------------------------------------------------------------
    [Parameter] public string EmptyTitle { get; set; } = "No records found";
    [Parameter] public string EmptyMessage { get; set; } = "Try adjusting your filters or search terms.";
    [Parameter] public string EmptyIcon { get; set; } = "bi-inbox";
    [Parameter] public RenderFragment? EmptyActionsContent { get; set; }

    // -------------------------------------------------------------------------

    // Render fragments

    // -------------------------------------------------------------------------
    /// <summary>Custom row template. Receives TItem; must render &lt;td&gt; cells.</summary>
    [Parameter] public RenderFragment<TItem>? RowTemplate { get; set; }

    /// <summary>Inline action buttons rendered in the last column per row.</summary>
    [Parameter] public RenderFragment<TItem>? RowActionsContent { get; set; }

    /// <summary>Additional toolbar buttons placed beside the search box.</summary>
    [Parameter] public RenderFragment? ToolbarActionsContent { get; set; }

    // -------------------------------------------------------------------------

    // Toolbar

    // -------------------------------------------------------------------------
    [Parameter] public bool ShowToolbar { get; set; } = true;

    // -------------------------------------------------------------------------

    // Event callbacks

    // -------------------------------------------------------------------------
    [Parameter] public EventCallback<TItem> OnRowClick { get; set; }

    // -------------------------------------------------------------------------

    // Accessibility

    // -------------------------------------------------------------------------
    [Parameter] public string AriaLabel { get; set; } = "Data table";

    // -------------------------------------------------------------------------

    // Private state

    // -------------------------------------------------------------------------
    private bool _showFilterRow = false;
    private Dictionary<string, string> _filterValues = new();
    private HashSet<TItem> _selectedItems = new();

    private IEnumerable<TableColumnModel> VisibleColumns =>
        Columns?.Where(c => c.Visible).OrderBy(c => c.Order) ?? Enumerable.Empty<TableColumnModel>();

    private int TotalColumnCount =>
        VisibleColumns.Count()
        + (SelectionMode == TableSelectionMode.Multi ? 1 : 0)
        + (RowActionsContent is not null ? 1 : 0);

    private bool AllSelected =>
        PagedItems.Any() && PagedItems.All(i => _selectedItems.Contains(i));

    private IEnumerable<TItem> PagedItems
    {
        get
        {
            // Client-side pagination (TotalCount == 0 means caller passed full Items)
            if (TotalCount > 0) return Items; // server-side: caller provides paged data
            var skip = (CurrentPage - 1) * PageSize;
            return Items.Skip(skip).Take(PageSize);
        }
    }

    private int EffectiveTotalCount => TotalCount > 0 ? TotalCount : Items.Count();

    // -------------------------------------------------------------------------

    // Handlers

    // -------------------------------------------------------------------------
    private async Task OnColumnSort(string key)
    {
        bool ascending = SortColumn == key ? !SortAscending : true;
        await OnSortChanged.InvokeAsync((key, ascending));
    }

    private void ToggleFilterRow() => _showFilterRow = !_showFilterRow;

    private async Task HandleColumnFilterChanged(Dictionary<string, string> filters)
    {
        _filterValues = filters;
        await OnFilterChanged.InvokeAsync(filters);
    }

    private async Task HandleRowClick(TItem item)
    {
        if (SelectionMode == TableSelectionMode.Single)
        {
            _selectedItems.Clear();
            _selectedItems.Add(item);
            await OnSelectionChanged.InvokeAsync(_selectedItems);
        }
        await OnRowClick.InvokeAsync(item);
    }

    private async Task ToggleRowSelection(TItem item)
    {
        if (!_selectedItems.Remove(item))
            _selectedItems.Add(item);
        await OnSelectionChanged.InvokeAsync(_selectedItems);
    }

    private async Task ToggleSelectAll()
    {
        if (AllSelected)
            foreach (var item in PagedItems) _selectedItems.Remove(item);
        else
            foreach (var item in PagedItems) _selectedItems.Add(item);

        await OnSelectionChanged.InvokeAsync(_selectedItems);
    }

    private async Task OnPageChangedInternal(int page) => await OnPageChanged.InvokeAsync(page);
    private async Task OnPageSizeChangedInternal(int size) => await OnPageSizeChanged.InvokeAsync(size);

    // Minimal reflection-free fallback cell renderer
    private static string GetCellValue(TItem item, TableColumnModel col)
    {
        if (item is null) return string.Empty;
        var prop = item.GetType().GetProperty(col.Key);
        return prop?.GetValue(item)?.ToString() ?? string.Empty;
    }

    // -------------------------------------------------------------------------

    // CSS class helpers (avoid inner double-quotes inside HTML attributes)

    // -------------------------------------------------------------------------
    private string FilterToggleBtnClass() =>
        _showFilterRow
            ? "dsv2-table-toolbar__btn dsv2-table-toolbar__btn--active"
            : "dsv2-table-toolbar__btn";

    private string FilterToggleBtnTitle() =>
        _showFilterRow ? "Hide filters" : "Show filters";

    private static string ThClass(TableColumnModel col) =>
        col.HideOnMobile
            ? $"dsv2-table__th dsv2-table__th--{col.Align} dsv2-table__th--mobile-hidden"
            : $"dsv2-table__th dsv2-table__th--{col.Align}";

    private static string ThStyle(TableColumnModel col)
    {
        var w = col.Width ?? ResolveColumnWidth(col);
        return w is not null ? $"width:{w}" : string.Empty;
    }

    /// <summary>
    /// Returns a CSS width string based on WidthHint, then DataType, then null (browser distributes).
    /// </summary>
    private static string? ResolveColumnWidth(TableColumnModel col) =>
        col.WidthHint switch
        {
            "narrow"  => "80px",
            "wide"    => "20%",
            "actions" => "120px",
            null => col.DataType switch
            {
                "bool"     => "80px",
                "badge"    => "90px",
                "number"   => "80px",
                "date"     => "110px",
                "datetime" => "140px",
                "actions"  => "120px",
                _          => null   // "string" / default: let table fill remaining space
            },
            _ => null
        };

    private string SortBtnClass(string colKey) =>
        SortColumn == colKey
            ? "dsv2-table__sort-btn dsv2-table__sort-btn--active"
            : "dsv2-table__sort-btn";

    private string SortIconClass(string colKey) =>
        SortColumn == colKey
            ? (SortAscending ? "bi-sort-up" : "bi-sort-down")
            : "bi-arrow-down-up";

    private string RowClass(TItem item, bool isSelected)
    {
        var cls = "dsv2-table__row";
        if (isSelected) cls += " dsv2-table__row--selected";
        if (OnRowClick.HasDelegate) cls += " dsv2-table__row--clickable";
        return cls;
    }

    private static string TdClass(TableColumnModel col) =>
        col.HideOnMobile
            ? $"dsv2-table__td dsv2-table__td--{col.Align} dsv2-table__td--mobile-hidden"
            : $"dsv2-table__td dsv2-table__td--{col.Align}";

    /// <summary>Row-selection mode for TableV2.</summary>
    public enum TableSelectionMode { None, Single, Multi }
}
