@* ===========================================================================
   File        : GlobalSettingsLayout.razor
   Namespace   : AbsenceApp.Client.Framework.Layouts
   Author      : Michael
   Version     : 1.0.0
   Created     : 2026-03-29
   ---------------------------------------------------------------------------
   Purpose     : Layout for all Global Settings pages (/global-settings/*).
                 Mirrors the Ki-Admin structure of BaseLayoutV2 but is kept
                 as a separate layout so Global Settings pages are never
                 accidentally wrapped by the main app layout.
                 SidebarV2 automatically switches to Global Settings mode
                 when the current route starts with /global-settings/.
   ---------------------------------------------------------------------------
   Notes       :
     - All Global Settings pages must declare @layout GlobalSettingsLayout.
     - Do NOT use BaseLayoutV2 for Global Settings pages.
   ===========================================================================
*@

@namespace AbsenceApp.Client.Framework.Layouts
@inherits LayoutComponentBase
@using AbsenceApp.Client.Services
@inject AppStateService AppState
@implements IDisposable

<div class="v2-layout-root @(AppState.DarkMode ? "dark" : "")">

    @* Sidebar — SidebarV2 auto-detects /global-settings/ and loads
       the Global Settings menu instead of the main application menu. *@
    <SidebarV2 />

    <div class="v2-content-area">

        <HeaderV2 />
        <BreadcrumbV2 />

        <main class="v2-main">
            <div class="v2-page-container">
                @Body
            </div>
        </main>

        <footer class="v2-footer">
            <span>&copy; 2026 AbsenceApp — All rights reserved.</span>
        </footer>

    </div>

</div>

@code {
    protected override void OnInitialized()
    {
        AppState.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        AppState.OnChange -= StateHasChanged;
    }
}
