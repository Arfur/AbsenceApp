@* ===========================================================================
   File        : GlobalSettingsLayout.razor
   Namespace   : AbsenceApp.Client.Framework.Layouts
   Author      : Michael
   Version     : 1.2.0
   Created     : 2026-03-29
   Updated     : 2026-07-02
   ---------------------------------------------------------------------------
   Purpose     : Layout for all Global Settings pages (/globalsettings/*).
                 Mirrors the Ki-Admin structure of BaseLayoutV2 but is kept
                 as a separate layout so Global Settings pages are never
                 accidentally wrapped by the main app layout.
                 SidebarV2 automatically switches to Global Settings mode
                 when the current route starts with /globalsettings/.
   ---------------------------------------------------------------------------
   Notes       :
     - All Global Settings pages must declare @layout GlobalSettingsLayout.
     - Do NOT use BaseLayoutV2 for Global Settings pages.
   Changes     :
     - 1.0.0  2026-03-29  Initial implementation.
     - 1.1.0  2026-04-13  E8 — removed <BreadcrumbV2 />. BreadcrumbV2 is
                          replaced by HeaderV3 which renders inside each
                          page’s PageTemplateV2.
     - 1.2.0  2026-07-02  Added <DesignTokenStyleInjectorV2 /> to ensure
                          dynamic CSS tokens are injected for Global Settings
                          pages, enabling Buttons accordion CSS preview.
   ===========================================================================
*@

@namespace AbsenceApp.Client.Framework.Layouts
@inherits LayoutComponentBase
@using AbsenceApp.Client.Services
@using AbsenceApp.Client.Framework.Layout
@using AbsenceApp.Client.Shared.Components

@inject AppStateService AppState
@implements IDisposable

<div class="v2-layout-root @(AppState.DarkMode ? "dark" : "")">

    <SidebarV2 />

    <div class="v2-content-area">

        <HeaderV2 />

        <main class="v2-main">
            <div class="v2-page-container">
                <PageHeaderV2 />

                <DesignTokenStyleInjectorV2 />

                @Body
            </div>
        </main>

        <footer class="v2-footer">
            <span>&copy; 2026 AbsenceApp — All rights reserved.</span>
        </footer>

    </div>

</div>

@code {
    protected override void OnInitialized()
    {
        Console.WriteLine("[DBG] GlobalSettingsLayout.OnInitialized — subscribing to AppState.OnChange");
        AppState.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        Console.WriteLine("[DBG] GlobalSettingsLayout.Dispose — unsubscribing from AppState.OnChange");
        AppState.OnChange -= StateHasChanged;
    }
}
