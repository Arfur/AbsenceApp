@* ===========================================================================
   File        : BaseLayoutV2.razor
   Namespace   : AbsenceApp.Client.Framework.Layouts
   Author      : Michael
   Version     : 6.1.0
   Created     : 2026-03-23
   Updated     : 2026-04-07
   ---------------------------------------------------------------------------
   Purpose     : Base layout for all V2 pages. Provides the universal shell
                 including SidebarV2, HeaderV2, BreadcrumbV2, a scrollable
                 main content area, and a fixed footer.
                 Sidebar, header, breadcrumb, and footer are hidden when the
                 user is not authenticated, so the Login page renders as a
                 clean centred full-screen card inside the same layout.
                 Applies the `dark` CSS class to the root div when dark mode
                 is active so all CSS custom property overrides in app.css
                 and the token files cascade down to every child component.
                 Sidebar visibility is determined by the API via
                 GET /api/features/allowed?key=ui.sidebar. The API evaluates
                 dbo.fn_IsFeatureAllowed and is the sole authority.
   ---------------------------------------------------------------------------
   Changes     :
     - 1.0.0  2026-03-23  Initial creation.
     - 1.1.0  2026-03-23  Added ChildContent parameter.
     - 1.2.0  2026-03-26  Moved to Framework/Layouts; corrected namespace.
     - 1.3.0  2026-03-26  Phase 3 Part 1: added v2-layout-root wrapper,
                          auth-conditional sidebar/header/breadcrumb,
                          IDisposable subscription to AppState.OnChange.
     - 1.4.0  2026-03-27  Phase 3 Part 2: dark class, v2-main--auth, v2-footer.
     - 1.4.1  2026-03-27  Phase 3 Shell Fix: confirmed layout structure is
                          correct. SidebarV2 is a direct child of v2-layout-root
                          (flex row) so HeaderV2 spans the full content column.
                          No markup changes — version bump confirms review.
     - 1.5.0  2026-03-27  Phase 3 Part 2 — Login flash fix: added _isInitializing
                          guard so a spinner overlay shows for the first render
                          cycle, preventing the brief flicker of the auth layout
                          before AppState is fully hydrated.
     - 1.6.0  2026-04-05  Injected EntitlementsService and applied entitlement-
                          driven visibility to the sidebar.
     - 2.0.0  2026-04-06  Option A: replaced EntitlementsService.Has() with
                          FeaturePermissionApiServiceV2.IsAllowedAsync().
     - 3.0.0  2026-04-06  MAUI render fix attempt: moved permission resolution
                          into OnAfterRenderAsync(firstRender).
     - 4.0.0  2026-04-06  Correct MAUI lifecycle fix: removed OnInitializedAsync,
                          resolved permissions in OnAfterRenderAsync where the
                          WebView render pipeline is active.
     - 4.1.0  2026-04-06  Fixed layout not re-rendering on AppState changes by
                          marshalling StateHasChanged onto the Blazor dispatcher
                          via InvokeAsync. Prevents silent UI stalls in MAUI
                          Blazor Hybrid when AppState.OnChange fires off-thread.
     - 5.0.0  2026-04-06  Logging migration: replaced all Console.WriteLine calls
                          with AppLog.Write. Added AppLog.Write hooks to
                          OnInitialized and OnAppStateChanged.
     - 6.0.0  2026-04-07  ROOT CAUSE FIX (Bug 2 — Login.razor recreated
                          mid-DoLogin): @Body is now always rendered inside
                          the same structural position
                          (v2-content-area > main > div.v2-page-container)
                          regardless of AppState.IsAuthenticated.
     - 6.1.0  2026-04-07  Debug instrumentation: added AppLog.Write calls to
                          OnAfterRenderAsync non-firstRender path, Dispose,
                          and enhanced OnAfterRenderAsync/OnAppStateChanged
                          to include CurrentUserId, _sidebarAllowed,
                          _isInitializing, and the IsAuthenticated&&sidebarAllowed
                          condition result at every state-change event.
   ---------------------------------------------------------------------------
   Notes       :
     - `dark` class in app.css overrides all V1 CSS custom properties.
     - V2 token files reference V1 properties, so dark mode cascades fully.
     - ChildContent retained for backward compatibility; only @Body is used.
     - @Body is ALWAYS at v2-content-area > main > div.v2-page-container.
       Login.razor (which uses this layout) renders inside v2-page-container
       in both auth and non-auth states. If the login card alignment is
       affected, add CSS: .v2-main--auth .v2-page-container { max-width: none;
       padding: 0; display: flex; justify-content: center; align-items: center; }
   ===========================================================================
*@

@namespace AbsenceApp.Client.Framework.Layouts
@inherits LayoutComponentBase
@using AbsenceApp.Client.Services
@inject AppStateService AppState
@inject AbsenceApp.Client.Services.ApiV2.Modules.FeaturePermissionApiServiceV2 FeaturePermissions
@implements IDisposable

@if (_isInitializing)
{
    <div class="v2-app-loader" role="status" aria-label="Loading AbsenceApp">
        <div class="v2-app-loader__ring"></div>
    </div>
}
else
{
<div class="v2-layout-root @(AppState.DarkMode ? "dark" : "")">

    @if (AppState.IsAuthenticated && _sidebarAllowed)
    {
        <SidebarV2 />
    }

    <div class="v2-content-area">

        @* Header and breadcrumb visible only when authenticated *@
        @if (AppState.IsAuthenticated)
        {
            <HeaderV2 />
            <BreadcrumbV2 />
        }

        @* @Body is ALWAYS inside main > div.v2-page-container regardless of
           auth state. This is the critical structural fix: Login.razor was
           previously being torn down and recreated when IsAuthenticated
           changed because @Body moved between two different DOM branches.
           Keeping @Body at the same tree position prevents that recreation. *@
        <main class="@(AppState.IsAuthenticated ? "v2-main" : "v2-main v2-main--auth")">
            <div class="v2-page-container">
                @Body
            </div>
        </main>

        @if (AppState.IsAuthenticated)
        {
            <footer class="v2-footer">
                <span>&copy; 2026 AbsenceApp — All rights reserved.</span>
            </footer>
        }

    </div>

</div>
}

@code {
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    private bool _isInitializing = true;
    private bool _sidebarAllowed = false;

    protected override void OnInitialized()
    {
        AppLog.Write("BaseLayoutV2.razor", "OnInitialized",
            $"Subscribing to AppState.OnChange. IsAuthenticated={AppState.IsAuthenticated}");
        AppState.OnChange += OnAppStateChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            AppLog.Write("BaseLayoutV2.razor", "OnAfterRenderAsync",
                $"firstRender=true — IsAuthenticated={AppState.IsAuthenticated} CurrentUserId={AppState.CurrentUserId} _isInitializing={_isInitializing} — resolving ui.sidebar permission");
            _sidebarAllowed = await FeaturePermissions.IsAllowedAsync("ui.sidebar");
            _isInitializing = false;
            AppLog.Write("BaseLayoutV2.razor", "OnAfterRenderAsync",
                $"sidebarAllowed={_sidebarAllowed} IsAuthenticated={AppState.IsAuthenticated} CurrentUserId={AppState.CurrentUserId} — (IsAuthenticated && sidebarAllowed)={AppState.IsAuthenticated && _sidebarAllowed} — calling StateHasChanged");
            StateHasChanged();
        }
        else
        {
            AppLog.Write("BaseLayoutV2.razor", "OnAfterRenderAsync",
                $"firstRender=false (non-first render) — _isInitializing={_isInitializing} _sidebarAllowed={_sidebarAllowed} IsAuthenticated={AppState.IsAuthenticated} CurrentUserId={AppState.CurrentUserId} — permission NOT re-checked");
        }
    }

    private void OnAppStateChanged()
    {
        AppLog.Write("BaseLayoutV2.razor", "OnAppStateChanged",
            $"AppState changed. IsAuthenticated={AppState.IsAuthenticated} CurrentUserId={AppState.CurrentUserId} _sidebarAllowed={_sidebarAllowed} _isInitializing={_isInitializing} — sidebarWillRender={(AppState.IsAuthenticated && _sidebarAllowed)} — invoking StateHasChanged");
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        AppLog.Write("BaseLayoutV2.razor", "Dispose",
            $"Unsubscribing from AppState.OnChange. IsAuthenticated={AppState.IsAuthenticated} _sidebarAllowed={_sidebarAllowed} _isInitializing={_isInitializing}");
        AppState.OnChange -= OnAppStateChanged;
    }
}
