@* ===========================================================================
   File        : HeaderV2.razor
   Namespace   : AbsenceApp.Client.Components.LayoutV2
   Author      : Michael
   Version     : 1.1.0
   Created     : 2026-03-21
   Updated     : 2026-03-27
   ---------------------------------------------------------------------------
   Purpose     : V2 top navigation header. Provides logo zone, sidebar toggle, optional search slot, dark-mode toggle, and notification bell. Parallel to V1 NavBar.razor; does NOT modify or replace it.
   ---------------------------------------------------------------------------
   Changes     :
     - 1.0.0  2026-03-21  Initial implementation.
   ---------------------------------------------------------------------------
   Notes       :
     - Phase 3 component. Requires AppStateService.
   ===========================================================================
*@
@using AbsenceApp.Client.Services
@inject AppStateService AppState
@implements IDisposable

<header class="dsv2-header" role="banner">
    @* =========================================================================
   Section: Logo zone
   ========================================================================= *@
    <div class="dsv2-header__logo-zone">
        <a href="/v2/dashboard" class="dsv2-header__logo-link" aria-label="AbsenceApp home">
            <i class="bi bi-calendar-check-fill dsv2-header__logo-icon" aria-hidden="true"></i>
            <span class="dsv2-header__logo-text">AbsenceApp</span>
        </a>
    </div>

@* =========================================================================
   Section: Centre zone — sidebar toggle + optional search
   ========================================================================= *@
    <div class="dsv2-header__centre">
        <button class="dsv2-header__icon-btn"
                title="Toggle sidebar"
                aria-label="Toggle sidebar"
                @onclick="AppState.ToggleSidebar">
            <i class="bi bi-list" aria-hidden="true"></i>
        </button>

        @if (SearchContent is not null)
        {
            <div class="dsv2-header__search-slot">
                @SearchContent
            </div>
        }
        else if (ShowDefaultSearch)
        {
            <div class="dsv2-header__search">
                <i class="bi bi-search" aria-hidden="true"></i>
                <input type="search"
                       placeholder="@SearchPlaceholder"
                       aria-label="Global search"
                       @bind="_searchValue"
                       @bind:event="oninput"
                       @onkeydown="HandleSearchKey" />
            </div>
        }
    </div>

@* =========================================================================
   Section: Right zone — actions
   ========================================================================= *@
    <div class="dsv2-header__right">
        @if (ActionsContent is not null)
        {
            @ActionsContent
        }

        @* Dark mode toggle *@
        <button class="dsv2-header__icon-btn"
                title="@(AppState.DarkMode ? "Switch to light mode" : "Switch to dark mode")"
                aria-label="@(AppState.DarkMode ? "Switch to light mode" : "Switch to dark mode")"
                @onclick="AppState.ToggleDarkMode">
            <i class="bi @(AppState.DarkMode ? "bi-sun" : "bi-moon")" aria-hidden="true"></i>
        </button>

        @* Notifications *@
        <button class="dsv2-header__icon-btn dsv2-header__notif-btn"
                title="Notifications"
                aria-label="Notifications (@AppState.UnreadCount unread)">
            <i class="bi bi-bell" aria-hidden="true"></i>
            @if (AppState.UnreadCount > 0)
            {
                <span class="dsv2-header__notif-badge" aria-live="polite">@AppState.UnreadCount</span>
            }
        </button>
    </div>
</header>

@code {
    /// <summary>Whether to show the default search input in the centre zone.</summary>
    [Parameter] public bool ShowDefaultSearch { get; set; } = true;

    /// <summary>Placeholder text for the default search input.</summary>
    [Parameter] public string SearchPlaceholder { get; set; } = "Search pages, students, staff…";

    /// <summary>Optional slot to replace the default search with custom content.</summary>
    [Parameter] public RenderFragment? SearchContent { get; set; }

    /// <summary>Optional slot for additional action buttons in the right zone.</summary>
    [Parameter] public RenderFragment? ActionsContent { get; set; }

    /// <summary>Fires when the user presses Enter in the default search input.</summary>
    [Parameter] public EventCallback<string> OnSearch { get; set; }

    private string _searchValue = string.Empty;

    protected override void OnInitialized()
    {
        AppState.OnChange += StateHasChanged;
    }

    private async Task HandleSearchKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && OnSearch.HasDelegate)
            await OnSearch.InvokeAsync(_searchValue);
    }

    public void Dispose() => AppState.OnChange -= StateHasChanged;
}
