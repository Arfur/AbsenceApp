@* ===========================================================================
   File        : HeaderV2.razor
   Namespace   : AbsenceApp.Client.Components.LayoutV2
   Author      : Michael
   Version     : 2.3.0
   Created     : 2026-03-21
   Updated     : 2026-04-12
   ---------------------------------------------------------------------------
   Purpose     : V2 top navigation header. Provides logo zone, sidebar toggle,
                 optional search slot, dark-mode toggle, message icon with
                 unread badge, notification bell with unread badge, and a user
                 identity cluster (avatar + username + role) with an anchored
                 dropdown menu. Parallel to V1 NavBar.razor; does NOT modify
                 or replace it.
   ---------------------------------------------------------------------------
   Changes     :
     - 1.0.0  2026-03-21  Initial implementation.
     - 1.1.0  2026-03-27  Phase 3 stabilisation; search and actions slots.
     - 2.0.0  2026-04-05  Phase 3 Header Nav Identity & Messaging parity:
                          added user identity cluster (avatar + username +
                          role) with anchored dropdown (Profile Details,
                          Settings, Log Out). Added message icon with badge
                          and conditional dropdown. Upgraded notification
                          bell with conditional dropdown. Added full-screen
                          transparent overlay for outside-click dismiss.
                          Role sourced dynamically via AppState.UserRole,
                          which is set at login from AuthService using
                          RoleTypes.DisplayName from the database.
     - 2.1.0  2026-04-05  Phase 3 messaging enablement.
     - 2.2.0  2026-04-07  Debug instrumentation: added AppLog.Write to
                          OnInitialized, Dispose, ToggleUser, ToggleMsg,
                          ToggleNotif, CloseAll, and HandleLogout.
     - 2.3.0  2026-04-12  E30: Messages dropdown uses avatar row layout with
                          sender initials and cycling colours. Notifications
                          dropdown uses icon row layout. User menu updated to
                          match design reference: orange header showing
                          username, items My Profile / Task / Message /
                          Account Settings / Log Out. DEV debug role label
                          removed. Dropdown z-index fixed (260) so dropdowns
                          appear above the transparent overlay (240).
   ---------------------------------------------------------------------------
   Notes       :
     - Phase 3 component. Requires AppStateService.
     - Role is NOT hardcoded: AppState.UserRole is populated at login from
       AuthService.LoginAsync → RoleTypes.DisplayName (database lookup).
       Fallback “Admin”/“Staff” strings only execute when the DB has no
       matching RoleType row for the authenticated user’s role_type_id.
   ===========================================================================
*@
@using AbsenceApp.Client.Services
@inject AppStateService AppState
@inject NavigationManager Nav
@implements IDisposable

@* Transparent full-screen overlay — intercepts outside clicks to close all open menus *@
@if (_userOpen || _msgOpen || _notifOpen)
{
    <div class="dsv2-header__overlay" @onclick="CloseAll"></div>
}

<header class="dsv2-header" role="banner">
    @* =========================================================================
   Section: Logo zone
   ========================================================================= *@
    <div class="dsv2-header__logo-zone">
        <a href="/v2/dashboard" class="dsv2-header__logo-link" aria-label="AbsenceApp home">
            <i class="bi bi-calendar-check-fill dsv2-header__logo-icon" aria-hidden="true"></i>
            <span class="dsv2-header__logo-text">AbsenceApp</span>
        </a>
    </div>

@* =========================================================================
   Section: Centre zone — sidebar toggle + optional search
   ========================================================================= *@
    <div class="dsv2-header__centre">
        <button class="dsv2-header__icon-btn"
                title="Toggle sidebar"
                aria-label="Toggle sidebar"
                @onclick="AppState.ToggleSidebar">
            <i class="bi bi-list" aria-hidden="true"></i>
        </button>

        @if (SearchContent is not null)
        {
            <div class="dsv2-header__search-slot">
                @SearchContent
            </div>
        }
        else if (ShowDefaultSearch)
        {
            <div class="dsv2-header__search">
                <i class="bi bi-search" aria-hidden="true"></i>
                <input type="search"
                       placeholder="@SearchPlaceholder"
                       aria-label="Global search"
                       @bind="_searchValue"
                       @bind:event="oninput"
                       @onkeydown="HandleSearchKey" />
            </div>
        }
    </div>

@* =========================================================================
   Section: Right zone — dark mode / messages / notifications / user cluster
   ========================================================================= *@
    <div class="dsv2-header__right">
        @if (ActionsContent is not null)
        {
            @ActionsContent
        }

        @* Dark mode toggle *@
        <button class="dsv2-header__icon-btn"
                title="@(AppState.DarkMode ? "Switch to light mode" : "Switch to dark mode")"
                aria-label="@(AppState.DarkMode ? "Switch to light mode" : "Switch to dark mode")"
                @onclick="AppState.ToggleDarkMode">
            <i class="bi @(AppState.DarkMode ? "bi-sun" : "bi-moon")" aria-hidden="true"></i>
        </button>

        @* Messages — badge shown when unread > 0; dropdown opens only when count > 0 *@
        <div class="dsv2-header__dd-wrap">
            <button class="dsv2-header__icon-btn"
                    title="Messages (@AppState.UnreadMessagesCount unread)"
                    aria-label="Messages (@AppState.UnreadMessagesCount unread)"
                    aria-expanded="@_msgOpen"
                    @onclick="ToggleMsg">
                <i class="bi bi-envelope" aria-hidden="true"></i>
                @if (AppState.UnreadMessagesCount > 0)
                {
                    <span class="dsv2-header__notif-badge" aria-live="polite">@AppState.UnreadMessagesCount</span>
                }
            </button>
            @if (_msgOpen)
            {
                <div class="dsv2-header__dropdown dsv2-header__dropdown--msgs">
                    <div class="dsv2-header__dd-hdr-coloured dsv2-header__dd-hdr-coloured--msgs">
                        <span class="dsv2-header__dd-hdr-count">@AppState.UnreadMessagesCount.ToString("D2")</span>
                        <span class="dsv2-header__dd-hdr-label">Messages</span>
                    </div>
                    @foreach (var (m, mi) in AppState.UnreadMessages.Select((x, i) => (x, i)))
                    {
                        <div class="dsv2-header__dd-item dsv2-header__dd-item--row">
                            <span class="dsv2-header__dd-sender-avatar" style="background:@GetAvatarColor(mi)">
                                @GetInitial(m.SenderName)
                            </span>
                            <div class="dsv2-header__dd-item-content">
                                <div class="dsv2-header__dd-item-row1">
                                    <span class="dsv2-header__dd-item-title">@m.SenderName</span>
                                    <span class="dsv2-header__dd-item-time">@m.CreatedAt.ToString("HH:mm")</span>
                                </div>
                                <span class="dsv2-header__dd-item-preview">@m.Preview</span>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        @* Notifications — badge shown when unread > 0; dropdown opens only when count > 0 *@
        <div class="dsv2-header__dd-wrap">
            <button class="dsv2-header__icon-btn dsv2-header__notif-btn"
                    title="Notifications (@AppState.UnreadNotificationsCount unread)"
                    aria-label="Notifications (@AppState.UnreadNotificationsCount unread)"
                    aria-expanded="@_notifOpen"
                    @onclick="ToggleNotif">
                <i class="bi bi-bell" aria-hidden="true"></i>
                @if (AppState.UnreadNotificationsCount > 0)
                {
                    <span class="dsv2-header__notif-badge" aria-live="polite">@AppState.UnreadNotificationsCount</span>
                }
            </button>
            @if (_notifOpen)
            {
                <div class="dsv2-header__dropdown dsv2-header__dropdown--notifs">
                    <div class="dsv2-header__dd-hdr-coloured dsv2-header__dd-hdr-coloured--notifs">
                        <span class="dsv2-header__dd-hdr-count">@AppState.UnreadNotificationsCount.ToString("D2")</span>
                        <span class="dsv2-header__dd-hdr-label">Notifications</span>
                    </div>
                    @foreach (var (n, ni) in AppState.UnreadNotifications.Select((x, i) => (x, i)))
                    {
                        <div class="dsv2-header__dd-item dsv2-header__dd-item--row">
                            <span class="dsv2-header__dd-notif-icon" style="background:@GetAvatarColor(ni)">
                                <i class="bi bi-bell-fill" aria-hidden="true"></i>
                            </span>
                            <div class="dsv2-header__dd-item-content">
                                <span class="dsv2-header__dd-item-title">@n.Title</span>
                                <span class="dsv2-header__dd-item-time">@n.CreatedAt.ToString("HH:mm dd MMM")</span>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        @* User identity cluster: avatar + username + role — opens anchored dropdown menu *@
        <div class="dsv2-header__dd-wrap dsv2-header__user-wrap">
            <button class="dsv2-header__user-btn"
                    type="button"
                    aria-label="User menu for @(AppState.UserName ?? "user")"
                    aria-expanded="@_userOpen"
                    aria-haspopup="menu"
                    @onclick="ToggleUser">
                <span class="dsv2-header__user-avatar" aria-hidden="true">
                    @(string.IsNullOrWhiteSpace(AppState.UserName)
                        ? "?"
                        : AppState.UserName[0].ToString().ToUpper())
                </span>
                <span class="dsv2-header__user-info">
                    <span class="dsv2-header__user-name">
                        @(!string.IsNullOrWhiteSpace(AppState.UserName) ? AppState.UserName : "Unknown")
                    </span>
                    <span class="dsv2-header__user-role">
                        @(!string.IsNullOrWhiteSpace(AppState.UserRole) ? AppState.UserRole : "Role not set")
                    </span>
                </span>
            </button>
            @if (_userOpen)
            {
                <ul class="dsv2-header__dropdown dsv2-header__dropdown--user" role="menu">
                    <li role="none" class="dsv2-header__dd-user-hdr">
                        <span class="dsv2-header__dd-user-hdr-name">
                            @(!string.IsNullOrWhiteSpace(AppState.UserName) ? AppState.UserName : "Unknown")
                        </span>
                        <span class="dsv2-header__dd-user-hdr-role">
                            @(!string.IsNullOrWhiteSpace(AppState.UserRole) ? AppState.UserRole : "Role not set")
                        </span>
                    </li>
                    <li role="none">
                        <a class="dsv2-header__dd-link" href="/v2/settings" role="menuitem" @onclick="CloseAll">
                            <i class="bi bi-person" aria-hidden="true"></i>
                            My Profile
                        </a>
                    </li>
                    <li role="none">
                        <a class="dsv2-header__dd-link" href="/v2/settings" role="menuitem" @onclick="CloseAll">
                            <i class="bi bi-list-task" aria-hidden="true"></i>
                            Task
                        </a>
                    </li>
                    <li role="none">
                        <a class="dsv2-header__dd-link" href="/v2/messages" role="menuitem" @onclick="CloseAll">
                            <i class="bi bi-envelope" aria-hidden="true"></i>
                            Message
                        </a>
                    </li>
                    <li role="none">
                        <a class="dsv2-header__dd-link" href="/v2/settings" role="menuitem" @onclick="CloseAll">
                            <i class="bi bi-gear" aria-hidden="true"></i>
                            Account Settings
                        </a>
                    </li>
                    <li class="dsv2-header__dd-divider" role="separator"></li>
                    <li role="none">
                        <button class="dsv2-header__dd-link dsv2-header__dd-link--danger"
                                type="button"
                                role="menuitem"
                                @onclick="HandleLogout">
                            <i class="bi bi-box-arrow-right" aria-hidden="true"></i>
                            Log Out
                        </button>
                    </li>
                </ul>
            }
        </div>
    </div>
</header>

@code {
    // ── Parameters ────────────────────────────────────────────────────────────────────────────
    /// <summary>Whether to show the default search input in the centre zone.</summary>
    [Parameter] public bool ShowDefaultSearch { get; set; } = true;

    /// <summary>Placeholder text for the default search input.</summary>
    [Parameter] public string SearchPlaceholder { get; set; } = "Search pages, students, staff…";

    /// <summary>Optional slot to replace the default search with custom content.</summary>
    [Parameter] public RenderFragment? SearchContent { get; set; }

    /// <summary>Optional slot for additional action buttons in the right zone.</summary>
    [Parameter] public RenderFragment? ActionsContent { get; set; }

    /// <summary>Fires when the user presses Enter in the default search input.</summary>
    [Parameter] public EventCallback<string> OnSearch { get; set; }

    // ── Demo data removed: HeaderV2 now binds directly to AppState.UnreadMessages
    // and AppState.UnreadNotifications populated at login from the database.
    // See Login.razor DoLogin() → IMessageService + INotificationService → AppState.SetMessagingData()

    // ── Dropdown open / close state ──────────────────────────────────────────────────────
    private bool _userOpen;
    private bool _msgOpen;
    private bool _notifOpen;

    private void ToggleUser()
    {
        AppLog.Write("HeaderV2.razor", "ToggleUser",
            $"_userOpen={!_userOpen} UserName='{AppState.UserName}' UserRole='{AppState.UserRole}'");
        _userOpen  = !_userOpen;
        _msgOpen   = false;
        _notifOpen = false;
    }

    private void ToggleMsg()
    {
        AppLog.Write("HeaderV2.razor", "ToggleMsg",
            $"UnreadMessagesCount={AppState.UnreadMessagesCount} — {(AppState.UnreadMessagesCount <= 0 ? "skipped (no messages)" : $"_msgOpen={!_msgOpen}")}");
        if (AppState.UnreadMessagesCount <= 0) return;
        _msgOpen   = !_msgOpen;
        _userOpen  = false;
        _notifOpen = false;
    }

    private void ToggleNotif()
    {
        AppLog.Write("HeaderV2.razor", "ToggleNotif",
            $"UnreadNotificationsCount={AppState.UnreadNotificationsCount} — {(AppState.UnreadNotificationsCount <= 0 ? "skipped (no notifications)" : $"_notifOpen={!_notifOpen}")}");
        if (AppState.UnreadNotificationsCount <= 0) return;
        _notifOpen = !_notifOpen;
        _userOpen  = false;
        _msgOpen   = false;
    }

    private void CloseAll()
    {
        AppLog.Write("HeaderV2.razor", "CloseAll",
            $"Closing all dropdowns. _userOpen={_userOpen} _msgOpen={_msgOpen} _notifOpen={_notifOpen}");
        _userOpen  = false;
        _msgOpen   = false;
        _notifOpen = false;
    }

    private void HandleLogout()
    {
        AppLog.Write("HeaderV2.razor", "HandleLogout",
            $"Logging out. UserName='{AppState.UserName}' IsAuthenticated={AppState.IsAuthenticated}");
        CloseAll();
        AppState.AuthLogout();
        Nav.NavigateTo("/login");
    }

    // ── Avatar / icon colour helpers ────────────────────────────────────────────────────
    private static readonly string[] _avatarColors =
    {
        "#20c997", // teal
        "#f59e0b", // amber
        "#3b82f6", // blue
        "#ef4444", // red
        "#8b5cf6"  // purple
    };

    private static string GetAvatarColor(int index) =>
        _avatarColors[index % _avatarColors.Length];

    private static string GetInitial(string name) =>
        string.IsNullOrWhiteSpace(name) ? "?" : name[0].ToString().ToUpper();

    // ── Search ─────────────────────────────────────────────────────────────────────────────
    private string _searchValue = string.Empty;

    // ── Lifecycle ───────────────────────────────────────────────────────────────────────
    protected override void OnInitialized()
    {
        AppLog.Write("HeaderV2.razor", "OnInitialized",
            $"IsAuthenticated={AppState.IsAuthenticated} UserName='{AppState.UserName}' UserRole='{AppState.UserRole}' UnreadMessages={AppState.UnreadMessagesCount} UnreadNotifications={AppState.UnreadNotificationsCount}");
        AppState.OnChange += StateHasChanged;
    }

    private async Task HandleSearchKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && OnSearch.HasDelegate)
            await OnSearch.InvokeAsync(_searchValue);
    }

    public void Dispose()
    {
        AppLog.Write("HeaderV2.razor", "Dispose",
            $"Unsubscribing from AppState.OnChange. IsAuthenticated={AppState.IsAuthenticated}");
        AppState.OnChange -= StateHasChanged;
    }
}
