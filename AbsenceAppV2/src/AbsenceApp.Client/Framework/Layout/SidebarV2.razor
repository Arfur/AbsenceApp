@*
===============================================================================
   File        : SidebarV2.razor
   Author      : Michael
   Version     : 6.1.0
   Created     : 2026-03-21
   Updated     : 2026-04-07
   ---------------------------------------------------------------------------
   Purpose     : V2 collapsible sidebar. Loads navigation categories from
                 the API via NavigationServiceV2. Renders category section
                 headers and accordion menu groups. When the current route
                 starts with /global-settings/, loads the Global Settings
                 groups from NavigationServiceV2 and shows a 'Back to Main
                 Menu' link.

                 The client performs no role checks, entitlement checks, or
                 menu filtering. The API is the sole authority for content.
   ---------------------------------------------------------------------------
   Changes     :
     - 1.0.0  2026-03-21  Initial implementation.
     - 1.1.0  2026-03-25  Confirmed as dedicated V2 sidebar.
     - 1.2.0  2026-03-26  Added menu switching for /global-settings/ routes.
     - 1.3.0  2026-03-26  Phase 3 Part 1: fixed OnLocationChanged.
     - 1.4.0  2026-03-27  Phase 3 Part 2: various active-route improvements.
     - 1.6.0  2026-03-28  Phase 4 Fix: removed hardcoded special cases.
     - 1.6.1  2026-03-29  Fixed invalid GetMenuGroupsAsync call.
     - 1.6.2  2026-03-29  Fixed MenuItemModel.Title rendering.
     - 1.7.0  2026-03-29  Added _loadError and try/catch in LoadMenuAsync.
     - 1.8.0  2026-04-05  Removed user panel from sidebar.
     - 1.9.0  2026-04-05  Added EntitlementsService injection + gate.
     - 2.0.0  2026-04-06  Option A: removed EntitlementsService injection
                          and ui.global-settings gate. API is now
                          authoritative for menu content. Sidebar renders
                          exactly what NavigationServiceV2 returns.
     - 3.0.0  2026-04-06  Schema alignment: replaced all item.Href with
                          item.Route and group.Items[0].Href with group.Route.
                          Removed item.Status badge and item.Description title
                          attribute (not in DB schema). Replaced group.Flat
                          flag with Items.Count == 0 derivation. Updated
                          GroupIsActive, AutoOpenGroup, ComputeRouteMatch,
                          and HandleGroupClick accordingly.
     - 4.0.0  2026-04-06  MAUI render fix: added await InvokeAsync(StateHasChanged)
                          at the end of OnInitializedAsync so the sidebar
                          renders after LoadMenuAsync completes. Without this,
                          MAUI Blazor Hybrid does not reliably fire the
                          automatic post-OnInitializedAsync re-render when the
                          EF Core DB call continuation runs on a thread-pool
                          thread, leaving the sidebar permanently in the
                          "Loading..." state until an incidental UI event
                          triggers a render.
     - 5.0.0  2026-04-06  MAUI render fix (correct approach): moved ALL async
                          menu loading from OnInitializedAsync to
                          OnAfterRenderAsync(firstRender guard). InvokeAsync
                          (StateHasChanged) from the continuation of an EF Core
                          await inside OnInitializedAsync does not reliably
                          wake the MAUI WebView render pump (confirmed by user
                          testing: no change observed from v4). StateHasChanged
                          called from OnAfterRenderAsync IS reliable because
                          the WebView render pipeline is already active at that
                          point. Added Console.WriteLine timestamps for
                          diagnosis. Added _loadPending guard to prevent
                          repeated loads on subsequent re-renders.
   - 6.0.0  2026-04-06  Logging migration: replaced all Console.WriteLine calls
                          with AppLog.Write. Added AppLog.Write hooks to
                          OnLocationChanged, HandleGroupClick, and Dispose.
   - 6.1.0  2026-04-07  Debug instrumentation: enhanced OnInitialized with
                          AppState.IsAuthenticated and _loadPending. Added
                          _loadPending=false early-exit log in OnAfterRenderAsync.
                          Enhanced OnAfterRenderAsync, LoadMenuAsync, and
                          OnLocationChanged with flags and state values.
   ---------------------------------------------------------------------------
   Notes       :
     - Must only be used in V2 layouts (BaseLayoutV2).
     - Sidebar collapse state is provided by AppStateService.
===============================================================================
*@

@using AbsenceApp.Client.Services
@using AbsenceApp.Client.Models.V2
@inject NavigationServiceV2 NavService
@inject AppStateService AppState
@inject NavigationManager Nav
@implements IDisposable

<aside class="@SidebarClass" aria-label="Main navigation">

    @* =========================
       SECTION: Navigation
       ========================= *@
    <nav class="dsv2-sidebar__nav">

        @if (_isSuperAdminMenu)
        {
            @* =========================
               SECTION: Back to Main Menu
               Link rendered only in superadmin mode so users can
               navigate back to the normal sidebar without browser back.
               ========================= *@
            <a class="dsv2-sidebar__back-link" href="/v2/dashboard"
               title="@(AppState.SidebarCollapsed ? "Main Menu" : null)">
                <i class="bi bi-arrow-left-circle dsv2-sidebar__item-icon"></i>
                @if (!AppState.SidebarCollapsed)
                {
                    <span class="dsv2-sidebar__item-label">Main Menu</span>
                }
            </a>

            @* =========================
               SECTION: Global Settings menu content
               Rendered unconditionally — the API is authoritative for
               what appears here. No client-side entitlement checks.
               ========================= *@
            @if (_loadError is not null)
            {
                @* Visible error — never silently blank *@
                <div class="dsv2-sidebar__error">
                    <i class="bi bi-exclamation-triangle"></i>
                    @if (!AppState.SidebarCollapsed)
                    {
                        <span>Menu failed to load</span>
                    }
                </div>
            }
            else if (_superAdminGroups is null || _superAdminGroups.Count == 0)
            {
                @* Visible empty state — never silently blank *@
                <div class="dsv2-sidebar__loading">
                    <i class="bi bi-inbox"></i>
                    @if (!AppState.SidebarCollapsed) { <span>No menu items</span> }
                </div>
            }
            else
            {
                @* Global Config accordion groups *@
                @RenderGroups(_superAdminGroups)
            }
        }
        else if (_loadError is not null)
        {
            @* Visible error placeholder for main menu load failure *@
            <div class="dsv2-sidebar__error">
                <i class="bi bi-exclamation-triangle"></i>
                @if (!AppState.SidebarCollapsed) { <span>Menu failed to load</span> }
            </div>
        }
        else if (_menuCategories is not null)
        {
            @* Normal menu: category headers → groups *@
            @foreach (var cat in _menuCategories)
            {
                @if (!string.IsNullOrWhiteSpace(cat.Category) && !AppState.SidebarCollapsed)
                {
                    <div class="dsv2-sidebar__category-label">@cat.Category</div>
                }
                @RenderGroups(cat.Groups)
            }
        }
        else
        {
            @* Loading state *@
            <div class="dsv2-sidebar__loading">
                <i class="bi bi-arrow-clockwise"></i>
                @if (!AppState.SidebarCollapsed) { <span>Loading…</span> }
            </div>
        }

    </nav>
</aside>

@* =========================
   SECTION: Group rendering helper
   Renders a list of groups as accordion buttons + optional submenus.
   ========================= *@
@code {
    private RenderFragment RenderGroups(IEnumerable<MenuGroupModel> groups) =>
        __builder =>
        {
            foreach (var group in groups)
            {
                var isOpen   = _openGroup == group.Group;
                var isActive = GroupIsActive(group);

                if (group.Items.Count == 0)
                {
                    @* Leaf menu node with its own route — render as a direct navigation link *@
                    var flatActive = ItemIsActive(group.Route);
                    __builder.OpenElement(0, "a");
                    __builder.AddAttribute(1, "href", group.Route);
                    __builder.AddAttribute(2, "class",
                        "dsv2-sidebar__group-btn dsv2-sidebar__group-btn--flat " +
                        (flatActive ? "dsv2-sidebar__group-btn--active" : ""));
                    __builder.AddAttribute(3, "title",
                        AppState.SidebarCollapsed ? group.Group : null);
                    __builder.OpenElement(4, "i");
                    __builder.AddAttribute(5, "class", "bi " + group.Icon + " dsv2-sidebar__item-icon");
                    __builder.CloseElement();
                    if (!AppState.SidebarCollapsed)
                    {
                        __builder.OpenElement(6, "span");
                        __builder.AddAttribute(7, "class", "dsv2-sidebar__item-label");
                        __builder.AddContent(8, group.Group);
                        __builder.CloseElement();
                    }
                    __builder.CloseElement();
                }
                else
                {
                    @* Accordion group: toggle button + submenu *@
                    __builder.OpenElement(0, "button");
                    __builder.AddAttribute(1, "class",
                        "dsv2-sidebar__group-btn " +
                        (isActive ? "dsv2-sidebar__group-btn--active" : "") + " " +
                        (isOpen   ? "dsv2-sidebar__group-btn--open"   : ""));
                    __builder.AddAttribute(2, "onclick",
                        EventCallback.Factory.Create(this, () => HandleGroupClick(group)));
                    __builder.AddAttribute(3, "title",
                        AppState.SidebarCollapsed ? group.Group : null);
                    __builder.OpenElement(4, "i");
                    __builder.AddAttribute(5, "class", "bi " + group.Icon + " dsv2-sidebar__item-icon");
                    __builder.CloseElement();
                    if (!AppState.SidebarCollapsed)
                    {
                        __builder.OpenElement(6, "span");
                        __builder.AddAttribute(7, "class", "dsv2-sidebar__item-label");
                        __builder.AddContent(8, group.Group);
                        __builder.CloseElement();
                        __builder.OpenElement(9, "i");
                        __builder.AddAttribute(10, "class", "bi bi-chevron-right dsv2-sidebar__chevron");
                        __builder.CloseElement();
                    }
                    __builder.CloseElement(); // button

                    if (isOpen && !AppState.SidebarCollapsed)
                    {
                        __builder.OpenElement(11, "div");
                        __builder.AddAttribute(12, "class", "dsv2-sidebar__submenu");
                        foreach (var item in group.Items)
                        {
                            var active = ItemIsActive(item.Route);
                            __builder.OpenElement(13, "a");
                            __builder.AddAttribute(14, "href", item.Route);
                            __builder.AddAttribute(15, "class",
                                "dsv2-sidebar__sublink " +
                                (active ? "dsv2-sidebar__sublink--active" : ""));
                            __builder.OpenElement(16, "i");
                            __builder.AddAttribute(17, "class", "bi " + item.Icon + " dsv2-sidebar__item-icon");
                            __builder.CloseElement();
                            __builder.OpenElement(18, "span");
                            __builder.AddAttribute(19, "class", "dsv2-sidebar__item-label");
                            __builder.AddContent(20, item.Title);
                            __builder.CloseElement();
                            __builder.CloseElement(); // a
                        }
                        __builder.CloseElement(); // div.submenu
                    }
                }
            }
        };
}

@code {
    // -------------------------------------------------------------------------
    // State
    // -------------------------------------------------------------------------
    private List<MenuCategoryModel>? _menuCategories;   // normal menu
    private List<MenuGroupModel>?    _superAdminGroups; // global-settings flat groups
    private bool   _isSuperAdminMenu;
    private string? _loadError;  // non-null when last menu load threw
    private string  _openGroup  = string.Empty;
    private string currentPath = string.Empty;
    /// <summary>True when the current path exactly equals at least one menu item href.</summary>
    private bool   _anyExactRouteMatch;
    /// <summary>
    /// True until the first OnAfterRenderAsync loads the menu.
    /// Prevents re-loading on every subsequent render cycle.
    /// </summary>
    private bool   _loadPending = true;

    private IEnumerable<MenuGroupModel> EffectiveGroups =>
        _isSuperAdminMenu
            ? (_superAdminGroups ?? [])
            : (_menuCategories?.SelectMany(c => c.Groups) ?? []);

    // -------------------------------------------------------------------------
    // Lifecycle
    // -------------------------------------------------------------------------

    protected override void OnInitialized()
    {
        AppState.OnChange += StateHasChanged;
        Nav.LocationChanged += OnLocationChanged;
        currentPath = GetCleanPath(Nav.Uri);
        // No async menu loading here. MAUI Blazor Hybrid does not reliably
        // flush the WebView render queue when StateHasChanged is called from
        // the continuation of an awaited DB call inside OnInitializedAsync.
        // Menu loading is deferred to OnAfterRenderAsync (see below), where
        // the WebView render pipeline is already active and StateHasChanged
        // produces an immediate visual update.
        AppLog.Write("SidebarV2.razor", "OnInitialized",
            $"Setup complete. path='{currentPath}' IsAuthenticated={AppState.IsAuthenticated} _loadPending={_loadPending} _menuCategories={((_menuCategories is null) ? "null" : _menuCategories.Count.ToString())}");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // _loadPending is true exactly once: the first time the component is
        // mounted. Setting it false before the await prevents re-entry on the
        // re-render that StateHasChanged() below will trigger.
        if (!_loadPending)
        {
            AppLog.Write("SidebarV2.razor", "OnAfterRenderAsync",
                $"_loadPending=false — skipping (already loaded). _menuCategories={((_menuCategories is null) ? "null" : _menuCategories.Count.ToString())} _isSuperAdminMenu={_isSuperAdminMenu} _loadError='{_loadError ?? "none"}'");
            return;
        }
        _loadPending = false;

        AppLog.Write("SidebarV2.razor", "OnAfterRenderAsync",
            $"Starting menu load for path='{currentPath}' IsAuthenticated={AppState.IsAuthenticated}");
        await LoadMenuAsync(currentPath);
        ComputeRouteMatch();
        AutoOpenGroup();
        AppLog.Write("SidebarV2.razor", "OnAfterRenderAsync",
            $"Menu load done. categories={_menuCategories?.Count ?? 0} "
            + $"superAdminGroups={_superAdminGroups?.Count ?? 0} "
            + $"_openGroup='{_openGroup}' _anyExactRouteMatch={_anyExactRouteMatch} "
            + $"loadError='{_loadError ?? "none"}' — calling StateHasChanged");
        // StateHasChanged from OnAfterRenderAsync is reliable in MAUI Blazor
        // Hybrid because the WebView render pipeline is active at this point.
        StateHasChanged();
    }

    private void OnLocationChanged(
        object? sender,
        Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        var newPath = GetCleanPath(e.Location);
        AppLog.Write("SidebarV2.razor", "OnLocationChanged",
            $"path changed '{currentPath}' → '{newPath}' IsAuthenticated={AppState.IsAuthenticated} _menuCategories={((_menuCategories is null) ? "null" : _menuCategories.Count.ToString())}");
        currentPath = newPath;
        _ = InvokeAsync(async () =>
        {
            await LoadMenuAsync(currentPath);
            ComputeRouteMatch();
            AutoOpenGroup();
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        AppLog.Write("SidebarV2.razor", "Dispose",
            "Unsubscribing from AppState.OnChange and Nav.LocationChanged");
        AppState.OnChange -= StateHasChanged;
        Nav.LocationChanged -= OnLocationChanged;
    }

    // -------------------------------------------------------------------------
    // Menu loading
    // -------------------------------------------------------------------------

    private async Task LoadMenuAsync(string path)
    {
        _isSuperAdminMenu = path.Equals("/global-settings", StringComparison.OrdinalIgnoreCase)
            || path.StartsWith("/global-settings/", StringComparison.OrdinalIgnoreCase);
        _loadError = null;

        AppLog.Write("SidebarV2.razor", "LoadMenuAsync",
            $"ENTER path='{path}' _isSuperAdminMenu={_isSuperAdminMenu} IsAuthenticated={AppState.IsAuthenticated} CurrentUserId={AppState.CurrentUserId}");

        try
        {
            if (_isSuperAdminMenu)
            {
                _superAdminGroups = await NavService.GetGlobalSettingsMenuGroupsAsync();
                _menuCategories   = null;
                AppLog.Write("SidebarV2.razor", "LoadMenuAsync",
                    $"SuperAdmin groups loaded = {_superAdminGroups?.Count ?? 0}");
            }
            else
            {
                AppLog.Write("SidebarV2.razor", "LoadMenuAsync",
                    "Requesting main menu categories");
                _menuCategories   = await NavService.GetMenuCategoriesAsync();
                _superAdminGroups = null;
                AppLog.Write("SidebarV2.razor", "LoadMenuAsync",
                    $"Categories received = {_menuCategories?.Count ?? 0}");
            }
            AppLog.Write("SidebarV2.razor", "LoadMenuAsync", "Menu bound to UI");
        }
        catch (Exception ex)
        {
            _loadError = ex.Message;
            AppLog.Write("SidebarV2.razor", "LoadMenuAsync",
                $"ERROR {ex.GetType().Name}: {ex.Message}");
        }
    }

    // -------------------------------------------------------------------------
    // Group expand / navigation
    // -------------------------------------------------------------------------

    private void HandleGroupClick(MenuGroupModel group)
    {
        // Toggle accordion: one group open at a time.
        bool isOpening = _openGroup != group.Group;
        _openGroup = isOpening ? group.Group : string.Empty;
        AppLog.Write("SidebarV2.razor", "HandleGroupClick",
            $"group='{group.Group}' isOpening={isOpening}");

        // When opening a new group, navigate to its first item so the
        // default sub-menu entry is automatically highlighted via
        // route-based active detection.
        if (isOpening && group.Items.Count > 0)
        {
            Nav.NavigateTo(group.Items[0].Route);
        }
    }

    /// <summary>Expand the first group whose items contain the current path.</summary>
    private void AutoOpenGroup()
    {
        var match = EffectiveGroups.FirstOrDefault(g =>
            g.Items.Any(i => ItemIsActive(i.Route)));
        if (match is not null)
            _openGroup = match.Group;
    }

    // -------------------------------------------------------------------------
    // Active-route helpers
    // -------------------------------------------------------------------------

    /// <summary>
    /// A group is active when any of its items matches the current path.
    /// </summary>
    private bool GroupIsActive(MenuGroupModel group) =>
        group.Items.Count > 0
            ? group.Items.Any(i => ItemIsActive(i.Route))
            : ItemIsActive(group.Route);

    /// <summary>
    /// Caches whether any menu item's href EXACTLY equals the current path.
    /// Must be called after each menu load and after each navigation.
    /// </summary>
    private void ComputeRouteMatch()
    {
        _anyExactRouteMatch =
            EffectiveGroups
                .SelectMany(g => g.Items)
                .Any(i => currentPath.Equals(i.Route, StringComparison.OrdinalIgnoreCase))
            || EffectiveGroups
                .Where(g => g.Items.Count == 0)
                .Any(g => currentPath.Equals(g.Route, StringComparison.OrdinalIgnoreCase));
    }

    /// <summary>
    /// An item is active when:
    ///   • (preferred) Its href exactly equals the current path.
    ///   • (fallback)  The current path starts with href + "/" — used to
    ///                 highlight a parent item for un-listed sub-pages
    ///                 (e.g. /v2/students/123 highlights "All Students" at /v2/students).
    ///
    /// When ANY item in the menu exactly matches the current path, ONLY
    /// exact matches are used. This prevents sibling routes such as
    /// /v2/dashboard from incorrectly matching /v2/dashboard/safeguarding
    /// via the StartsWith prefix rule.
    /// </summary>
    private bool ItemIsActive(string href)
    {
        if (_anyExactRouteMatch)
            return currentPath.Equals(href, StringComparison.OrdinalIgnoreCase);

        return href.Length > 1 &&
               currentPath.StartsWith(href + "/", StringComparison.OrdinalIgnoreCase);
    }

    // -------------------------------------------------------------------------
    // Helpers
    // -------------------------------------------------------------------------

    private string GetCleanPath(string uri)
    {
        var path = Nav.ToBaseRelativePath(uri);
        if (!path.StartsWith("/")) path = "/" + path;
        // Strip query string and fragment.
        var q = path.IndexOf('?');
        if (q >= 0) path = path[..q];
        var h = path.IndexOf('#');
        if (h >= 0) path = path[..h];
        return path;
    }

    private string SidebarClass => string.Join(" ", new[]
    {
        "dsv2-sidebar",
        AppState.SidebarCollapsed ? "dsv2-sidebar--collapsed" : null
    }.Where(c => c is not null));
}
