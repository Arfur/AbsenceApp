@*
===============================================================================
   File        : SidebarV2.razor
   Author      : Michael
   Version     : 7.1.0
   Created     : 2026-03-21
   Updated     : 2026-04-14
   ---------------------------------------------------------------------------
   Purpose     : V2 collapsible sidebar. Loads navigation categories from
                 the API via NavigationServiceV2. Renders category section
                 headers and accordion menu groups. When the current route
                 starts with /global-settings/, loads the Global Settings
                 groups from NavigationServiceV2 and shows a 'Back to Main
                 Menu' link.

                 The client performs no role checks, entitlement checks, or
                 menu filtering. The API is the sole authority for content.
   ---------------------------------------------------------------------------
   Changes     :
     - 1.0.0  2026-03-21  Initial implementation.
     - 1.1.0  2026-03-25  Confirmed as dedicated V2 sidebar.
     - 1.2.0  2026-03-26  Added menu switching for /global-settings/ routes.
     - 1.3.0  2026-03-26  Phase 3 Part 1: fixed OnLocationChanged.
     - 1.4.0  2026-03-27  Phase 3 Part 2: various active-route improvements.
     - 1.6.0  2026-03-28  Phase 4 Fix: removed hardcoded special cases.
     - 1.6.1  2026-03-29  Fixed invalid GetMenuGroupsAsync call.
     - 1.6.2  2026-03-29  Fixed MenuItemModel.Title rendering.
     - 1.7.0  2026-03-29  Added _loadError and try/catch in LoadMenuAsync.
     - 1.8.0  2026-04-05  Removed user panel from sidebar.
     - 1.9.0  2026-04-05  Added EntitlementsService injection + gate.
     - 2.0.0  2026-04-06  Removed EntitlementsService; API authoritative.
     - 3.0.0  2026-04-06  Schema alignment: Route, Status, Description.
     - 4.0.0  2026-04-06  MAUI render fix: InvokeAsync(StateHasChanged).
     - 5.0.0  2026-04-06  Correct MAUI fix: moved loading to OnAfterRenderAsync.
     - 6.0.0  2026-04-06  Logging migration to AppLog.Write.
     - 6.1.0  2026-04-07  Debug instrumentation improvements.
     - 6.2.0  2026-04-07  Disabled URL-based switching.
     - 6.3.0  2026-04-08  Added RestoreMainMenuRequested + switching in click.
     - 6.4.0  2026-04-08  Schema expansion: IsFlat, Description, Status.
     - 6.5.0  2026-04-10  FIXED Global Settings switching logic. Replaced
                          hardcoded route checks with StartsWith("/global-settings")
                          to support all global-settings pages. Added SECTION
                          banners for major blocks.
     - 6.7.0  2026-04-12  Removed auto-navigate to first submenu on group
                          expand. Accordion now only opens/closes; main content
                          does not change until a submenu link is clicked
                          (E6 Issue 2a).
                          Removed "Main Menu" back link from global-settings
                          sidebar — exit handled by OnLocationChanged (2a).
                          Replaced flat _superAdminGroups with categorised
                          _superAdminCategories; renders section headers in
                          global-settings mode (2b).
     - 6.9.0  2026-04-13  E8 three-fix batch:
                          (1) Group-button highlight fix: isActive now also
                          checks _openGroup == group.Group so the opened group
                          always shows --active even when no submenu is
                          selected (addresses Issue 1 — group highlight
                          broken after switching groups).
                          (2) Home / group-root navigation fix: ComputeRouteMatch
                          and AutoOpenGroup now include a Pass-3 group-root
                          prefix check (mirrors PageHeaderV2.UpdateAsync) so
                          navigating to a group root path (e.g. /v2/dashboard)
                          correctly opens and highlights that group without
                          hardcoding any route name.
                          (3) Removed literal 'ACTIVE' status badge: status
                          badges are now suppressed when item.Status=='ACTIVE'
                          so only meaningful badges (e.g. BETA, NEW) appear.
     - 7.1.0  2026-04-15  Issue 1: HandleGroupClick no longer collapses an
                          already-open group — clicking an active group is a
                          no-op (preferred no-collapse behaviour).
                          Issue 2: dual-highlight (open accordion + flat active
                          link) preserved — AutoOpenGroup Pass 1 never matches
                          flat items so _openGroup is unchanged for flat
                          navigation. Verified working after Issue 1 fix.
                          Issue 6: ComputeRouteMatch Pass 3 now stores the
                          first matching item's route in _groupRootFirstItemRoute.
                          ItemIsActive returns true for that route when at a
                          group-root URL, making the "|" indicator appear on
                          the first sublink after logo/home navigation.
                          leaving global-settings via the logo/home link.
                          OnLocationChanged now detects the global→main
                          transition, reads the last saved route from
                          AppStateService, and redirects there instead of
                          landing on /v2/dashboard. If no saved route differs
                          from the destination, /v2/dashboard is used as
                          normal fallback.
     - 6.8.0  2026-04-10  Fixed stale submenu highlight (E7 Issue 1).
                          In HandleGroupClick, after toggling _openGroup,
                          reset currentPath to string.Empty and
                          _anyExactRouteMatch to false so that no submenu
                          appears highlighted until the user navigates to one.
                          The opened group still shows the --open style.
   ---------------------------------------------------------------------------
   Notes       :
     - Must only be used in V2 layouts (BaseLayoutV2).
     - Sidebar collapse state is provided by AppStateService.
===============================================================================
*@

@using AbsenceApp.Client.Services
@using AbsenceApp.Client.Models.V2
@inject NavigationServiceV2 NavService
@inject AppStateService AppState
@inject NavigationManager Nav
@implements IDisposable

<aside class="@SidebarClass" aria-label="Main navigation">

    @* =========================
       SECTION: Navigation root
       Decides which menu to render: main menu, global-settings menu, or error/loading.
       ========================= *@
    <nav class="dsv2-sidebar__nav">

        @if (_isSuperAdminMenu)
        {
            @* =========================
               SECTION: Global Settings menu content
               Renders groups returned by the API for global-settings mode.
               ========================= *@
            @if (_loadError is not null)
            {
                <div class="dsv2-sidebar__error">
                    <i class="bi bi-exclamation-triangle"></i>
                    @if (!AppState.SidebarCollapsed)
                    {
                        <span>Menu failed to load</span>
                    }
                </div>
            }
            else if (_superAdminCategories is null || _superAdminCategories.Count == 0)
            {
                <div class="dsv2-sidebar__loading">
                    <i class="bi bi-inbox"></i>
                    @if (!AppState.SidebarCollapsed) { <span>No menu items</span> }
                </div>
            }
            else
            {
                @foreach (var cat in _superAdminCategories)
                {
                    @if (!string.IsNullOrWhiteSpace(cat.Category) && !AppState.SidebarCollapsed)
                    {
                        <div class="dsv2-sidebar__category-label">@cat.Category</div>
                    }
                    @RenderGroups(cat.Groups)
                }
            }
        }
        else if (_loadError is not null)
        {
            <div class="dsv2-sidebar__error">
                <i class="bi bi-exclamation-triangle"></i>
                @if (!AppState.SidebarCollapsed) { <span>Menu failed to load</span> }
            </div>
        }
        else if (_menuCategories is not null)
        {
            @foreach (var cat in _menuCategories)
            {
                @if (!string.IsNullOrWhiteSpace(cat.Category) && !AppState.SidebarCollapsed
                     && !string.Equals(cat.Category, "MAIN SIDEBAR", StringComparison.OrdinalIgnoreCase))
                {
                    <div class="dsv2-sidebar__category-label">@cat.Category</div>
                }
                @RenderGroups(cat.Groups)
            }
        }
        else
        {
            <div class="dsv2-sidebar__loading">
                <i class="bi bi-arrow-clockwise"></i>
                @if (!AppState.SidebarCollapsed) { <span>Loading…</span> }
            </div>
        }

    </nav>
</aside>

@* =========================
   SECTION: Group rendering helper
   Renders accordion groups and flat links for both main and global menus.
   ========================= *@
@code {
    private RenderFragment RenderGroups(IEnumerable<MenuGroupModel> groups) =>
        __builder =>
        {
            foreach (var group in groups)
            {
                var isOpen   = _openGroup == group.Group;
                var isActive = GroupIsActive(group);

                if (group.IsFlat || group.Items.Count == 0)
                {
                    var flatActive = ItemIsActive(group.Route);
                    __builder.OpenElement(0, "a");
                    __builder.AddAttribute(1, "href", group.Route);
                    __builder.AddAttribute(2, "class",
                        "dsv2-sidebar__group-btn dsv2-sidebar__group-btn--flat " +
                        (flatActive ? "dsv2-sidebar__group-btn--active" : ""));
                    __builder.AddAttribute(3, "title",
                        AppState.SidebarCollapsed ? group.Group : null);
                    __builder.OpenElement(4, "i");
                    __builder.AddAttribute(5, "class", "bi " + group.Icon + " dsv2-sidebar__item-icon");
                    __builder.CloseElement();
                    if (!AppState.SidebarCollapsed)
                    {
                        __builder.OpenElement(6, "span");
                        __builder.AddAttribute(7, "class", "dsv2-sidebar__item-label");
                        __builder.AddContent(8, group.Group);
                        __builder.CloseElement();
                    }
                    __builder.CloseElement();
                }
                else
                {
                    __builder.OpenElement(0, "button");
                    __builder.AddAttribute(1, "class",
                        "dsv2-sidebar__group-btn " +
                        (isActive || isOpen ? "dsv2-sidebar__group-btn--active" : "") + " " +
                        (isOpen             ? "dsv2-sidebar__group-btn--open"   : ""));
                    __builder.AddAttribute(2, "onclick",
                        EventCallback.Factory.Create(this, () => HandleGroupClick(group)));
                    __builder.AddAttribute(3, "title",
                        AppState.SidebarCollapsed ? group.Group : null);
                    __builder.OpenElement(4, "i");
                    __builder.AddAttribute(5, "class", "bi " + group.Icon + " dsv2-sidebar__item-icon");
                    __builder.CloseElement();
                    if (!AppState.SidebarCollapsed)
                    {
                        __builder.OpenElement(6, "span");
                        __builder.AddAttribute(7, "class", "dsv2-sidebar__item-label");
                        __builder.AddContent(8, group.Group);
                        __builder.CloseElement();
                        __builder.OpenElement(9, "i");
                        __builder.AddAttribute(10, "class", "bi bi-chevron-right dsv2-sidebar__chevron");
                        __builder.CloseElement();
                    }
                    __builder.CloseElement();

                    if (isOpen && !AppState.SidebarCollapsed)
                    {
                        __builder.OpenElement(11, "div");
                        __builder.AddAttribute(12, "class", "dsv2-sidebar__submenu");
                        foreach (var item in group.Items)
                        {
                            var active = ItemIsActive(item.Route);
                            __builder.OpenElement(13, "a");
                            __builder.AddAttribute(14, "href", item.Route);
                            __builder.AddAttribute(15, "class",
                                "dsv2-sidebar__sublink " +
                                (active ? "dsv2-sidebar__sublink--active" : ""));
                            if (!string.IsNullOrEmpty(item.Description))
                                __builder.AddAttribute(16, "title", item.Description);
                            __builder.OpenElement(17, "i");
                            __builder.AddAttribute(18, "class", "bi " + item.Icon + " dsv2-sidebar__item-icon");
                            __builder.CloseElement();
                            __builder.OpenElement(19, "span");
                            __builder.AddAttribute(20, "class", "dsv2-sidebar__item-label");
                            __builder.AddContent(21, item.Title);
                            __builder.CloseElement();
                            // Only show non-trivial status badges (skip "ACTIVE" which is the default state)
                            if (!string.IsNullOrEmpty(item.Status) &&
                                !string.Equals(item.Status, "ACTIVE", StringComparison.OrdinalIgnoreCase))
                            {
                                __builder.OpenElement(22, "span");
                                __builder.AddAttribute(23, "class", "dsv2-sidebar__status-badge");
                                __builder.AddContent(24, item.Status);
                                __builder.CloseElement();
                            }
                            __builder.CloseElement();
                        }
                        __builder.CloseElement();
                    }
                }
            }
        };
}

@* =========================
   SECTION: State
   Holds menu data, UI state, and mode flags for main vs global-settings.
   ========================= *@
@code {
    private List<MenuCategoryModel>? _menuCategories;
    private List<MenuCategoryModel>? _superAdminCategories;
    private bool   _isSuperAdminMenu;
    private string? _loadError;
    private string  _openGroup              = string.Empty;
    private string  currentPath             = string.Empty;
    private bool    _anyExactRouteMatch;
    // Issue 6: when at a group-root URL (e.g. /v2/dashboard), store the first
    // item's route so ItemIsActive can highlight it instead of showing nothing.
    private string  _groupRootFirstItemRoute = string.Empty;
    private bool    _loadPending = true;

    private IEnumerable<MenuGroupModel> EffectiveGroups =>
        _isSuperAdminMenu
            ? (_superAdminCategories?.SelectMany(c => c.Groups) ?? [])
            : (_menuCategories?.SelectMany(c => c.Groups) ?? []);
}

@* =========================
   SECTION: Lifecycle
   Handles initialization, first-render loading, and route-change updates.
   ========================= *@
@code {
    protected override void OnInitialized()
    {
        AppState.OnChange += HandleAppStateChanged;
        Nav.LocationChanged += OnLocationChanged;
        currentPath = GetCleanPath(Nav.Uri);

        AppLog.Write("SidebarV2.razor", "OnInitialized",
            $"Setup complete. path='{currentPath}' IsAuthenticated={AppState.IsAuthenticated} _loadPending={_loadPending}");
    }

    private void HandleAppStateChanged()
    {
        if (AppState.RestoreMainMenuRequested)
        {
            var (route, openGroup) = AppState.GetLastMainMenuState();
            _openGroup = openGroup;
            currentPath = route;

            AppState.ClearRestoreMainMenuRequest();
            Nav.NavigateTo(route);
            StateHasChanged();
            return;
        }

        StateHasChanged();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_loadPending)
        {
            AppLog.Write("SidebarV2.razor", "OnAfterRenderAsync",
                $"_loadPending=false — skipping. _isSuperAdminMenu={_isSuperAdminMenu}");
            return;
        }
        _loadPending = false;

        // Initialise sidebar mode from the path so that an app launched directly
        // on a global-settings page (or resumed there) shows the correct menu.
        _isSuperAdminMenu = currentPath.StartsWith("/global-settings", StringComparison.OrdinalIgnoreCase);
        AppLog.Write("SidebarV2.razor", "OnAfterRenderAsync",
            $"Starting menu load for path='{currentPath}' _isSuperAdminMenu={_isSuperAdminMenu}");
        await LoadMenuAsync(currentPath);
        ComputeRouteMatch();
        AutoOpenGroup();

        AppLog.Write("SidebarV2.razor", "OnAfterRenderAsync",
            $"Menu load done. categories={_menuCategories?.Count ?? 0} superAdminCategories={_superAdminCategories?.Count ?? 0}");

        StateHasChanged();
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        var newPath = GetCleanPath(e.Location);
        AppLog.Write("SidebarV2.razor", "OnLocationChanged",
            $"path changed '{currentPath}' → '{newPath}'");

        // Auto-detect sidebar mode from the destination path.
        // This handles flat link clicks, submenu <a> clicks, back-button navigation,
        // and direct URL entry — all cases where HandleGroupClick is not invoked.
        var shouldBeGlobal = newPath.StartsWith("/global-settings", StringComparison.OrdinalIgnoreCase);
        if (!_isSuperAdminMenu && shouldBeGlobal)
        {
            // Transitioning from main menu into global-settings.
            // currentPath still holds the pre-navigation value here — save it.
            AppState.SetLastMainMenuState(currentPath, _openGroup);
            _isSuperAdminMenu = true;
        }
        else if (_isSuperAdminMenu && !shouldBeGlobal)
        {
            // Transitioning out of global-settings back to the main app.
            _isSuperAdminMenu = false;
            // Restore the page that was active before entering global-settings,
            // so that clicking the logo/home icon while in global-settings always
            // returns the user to their previous page rather than /v2/dashboard.
            var (savedRoute, savedGroup) = AppState.GetLastMainMenuState();
            if (!string.IsNullOrEmpty(savedRoute) &&
                !savedRoute.Equals(newPath, StringComparison.OrdinalIgnoreCase))
            {
                _ = InvokeAsync(() =>
                {
                    _openGroup  = savedGroup;
                    currentPath = savedRoute;
                    StateHasChanged();
                    Nav.NavigateTo(savedRoute);
                });
                return; // Skip /v2/dashboard processing; second OnLocationChanged handles the rest.
            }
        }

        currentPath = newPath;

        _ = InvokeAsync(async () =>
        {
            await LoadMenuAsync(currentPath);
            ComputeRouteMatch();
            AutoOpenGroup();
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        AppLog.Write("SidebarV2.razor", "Dispose",
            "Unsubscribing from AppState.OnChange and Nav.LocationChanged");
        AppState.OnChange -= HandleAppStateChanged;
        Nav.LocationChanged -= OnLocationChanged;
    }
}

@* =========================
   SECTION: Menu loading
   Loads either the main menu or global-settings menu based on mode flag.
   ========================= *@
@code {
    private async Task LoadMenuAsync(string path)
    {
        _loadError = null;

        AppLog.Write("SidebarV2.razor", "LoadMenuAsync",
            $"ENTER path='{path}' _isSuperAdminMenu={_isSuperAdminMenu}");

        try
        {
            if (_isSuperAdminMenu)
            {
                _superAdminCategories = await NavService.GetGlobalSettingsCategoriesAsync();
                _menuCategories       = null;
                AppLog.Write("SidebarV2.razor", "LoadMenuAsync",
                    $"SuperAdmin categories loaded = {_superAdminCategories?.Count ?? 0}");
            }
            else
            {
                _menuCategories       = await NavService.GetMenuCategoriesAsync();
                _superAdminCategories = null;
                AppLog.Write("SidebarV2.razor", "LoadMenuAsync",
                    $"Categories received = {_menuCategories?.Count ?? 0}");
            }
        }
        catch (Exception ex)
        {
            _loadError = ex.Message;
            AppLog.Write("SidebarV2.razor", "LoadMenuAsync",
                $"ERROR {ex.GetType().Name}: {ex.Message}");
        }
    }
}

@* =========================
   SECTION: Group expand / navigation
   Handles accordion toggling and switching into global-settings mode.
   ========================= *@
@code {
    private void HandleGroupClick(MenuGroupModel group)
    {
        // FIXED: Global Settings switching logic
        if (group.Route?.StartsWith("/global-settings", StringComparison.OrdinalIgnoreCase) == true)
        {
            AppState.SetLastMainMenuState(currentPath, _openGroup);

            _isSuperAdminMenu = true;
            _openGroup = string.Empty;
            currentPath = "/global-settings/dashboard";

            _ = InvokeAsync(async () =>
            {
                await LoadMenuAsync(currentPath);
                ComputeRouteMatch();
                AutoOpenGroup();
                Nav.NavigateTo("/global-settings/dashboard");
                StateHasChanged();
            });

            return;
        }

        // Issue 1 fix: clicking an already-open group must not collapse it or
        // remove its highlight (preferred: no-collapse behaviour).
        if (_openGroup == group.Group)
        {
            AppLog.Write("SidebarV2.razor", "HandleGroupClick",
                $"group='{group.Group}' already open — no-op");
            return;
        }

        _openGroup = group.Group;

        // Opening a different group: clear stale submenu highlight so no
        // sub-link appears selected until the user navigates to one.
        currentPath = string.Empty;
        _anyExactRouteMatch = false;
        _groupRootFirstItemRoute = string.Empty;

        AppLog.Write("SidebarV2.razor", "HandleGroupClick",
            $"group='{group.Group}' opened");
    }

    private void AutoOpenGroup()
    {
        // Pass 1: a submenu item is explicitly active.
        var match = EffectiveGroups.FirstOrDefault(g =>
            g.Items.Any(i => ItemIsActive(i.Route)));
        if (match is not null)
        {
            _openGroup = match.Group;
            return;
        }

        // Pass 3 (group-root): current path is the root of a group's items
        // (e.g. /v2/dashboard for the Dashboard group whose items start
        // with /v2/dashboard/). Open that group so the accordion expands.
        if (currentPath.Length > 1)
        {
            var root = EffectiveGroups.FirstOrDefault(g =>
                g.Items.Any(i =>
                    i.Route.Length > currentPath.Length &&
                    i.Route[currentPath.Length] == '/' &&
                    i.Route.StartsWith(currentPath, StringComparison.OrdinalIgnoreCase)));
            if (root is not null)
                _openGroup = root.Group;
        }
    }
}

@* =========================
   SECTION: Active-route helpers
   Determines which items/groups are active based on the current path.
   ========================= *@
@code {
    private bool GroupIsActive(MenuGroupModel group) =>
        group.Items.Count > 0
            ? group.Items.Any(i => ItemIsActive(i.Route))
            : ItemIsActive(group.Route);

    private void ComputeRouteMatch()
    {
        _groupRootFirstItemRoute = string.Empty;

        // Pass 1: exact item or flat-group match.
        _anyExactRouteMatch =
            EffectiveGroups
                .SelectMany(g => g.Items)
                .Any(i => currentPath.Equals(i.Route, StringComparison.OrdinalIgnoreCase))
            || EffectiveGroups
                .Where(g => g.Items.Count == 0)
                .Any(g => currentPath.Equals(g.Route, StringComparison.OrdinalIgnoreCase));

        // Pass 3 (group-root): treat a path that is the common root of a group's
        // items as an active context so that the group button can be highlighted.
        // e.g. /v2/dashboard is the root of Dashboard items at /v2/dashboard/*
        // Also store the first item's route for Issue 6: highlight it so the "|"
        // indicator appears on the first sublink when arriving at a group root.
        if (!_anyExactRouteMatch && currentPath.Length > 1)
        {
            var rootGroup = EffectiveGroups.FirstOrDefault(g =>
                g.Items.Any(i =>
                    i.Route.Length > currentPath.Length &&
                    i.Route[currentPath.Length] == '/' &&
                    i.Route.StartsWith(currentPath, StringComparison.OrdinalIgnoreCase)));
            if (rootGroup is not null)
            {
                _anyExactRouteMatch = true;
                _groupRootFirstItemRoute = rootGroup.Items
                    .FirstOrDefault(i =>
                        i.Route.Length > currentPath.Length &&
                        i.Route[currentPath.Length] == '/' &&
                        i.Route.StartsWith(currentPath, StringComparison.OrdinalIgnoreCase))
                    ?.Route ?? string.Empty;
            }
        }
    }

    private bool ItemIsActive(string href)
    {
        if (_anyExactRouteMatch)
        {
            if (currentPath.Equals(href, StringComparison.OrdinalIgnoreCase))
                return true;
            // Issue 6: when at a group root (e.g. /v2/dashboard), highlight the
            // first sublink so the "|" indicator appears after logo navigation.
            if (!string.IsNullOrEmpty(_groupRootFirstItemRoute) &&
                href.Equals(_groupRootFirstItemRoute, StringComparison.OrdinalIgnoreCase))
                return true;
            return false;
        }

        return href.Length > 1 &&
               currentPath.StartsWith(href + "/", StringComparison.OrdinalIgnoreCase);
    }
}

@* =========================
   SECTION: Helpers
   Utility methods for path cleaning and CSS class generation.
   ========================= *@
@code {
    private string GetCleanPath(string uri)
    {
        var path = Nav.ToBaseRelativePath(uri);
        if (!path.StartsWith("/"))
            path = "/" + path;

        // Strip query string.
        var q = path.IndexOf('?');
        if (q >= 0)
            path = path[..q];

        // Strip fragment.
        var h = path.IndexOf('#');
        if (h >= 0)
            path = path[..h];

        return path;
    }

    private string SidebarClass => string.Join(" ", new[]
    {
        "dsv2-sidebar",
        AppState.SidebarCollapsed ? "dsv2-sidebar--collapsed" : null
    }.Where(c => c is not null));
}
