@* ===========================================================================
   File        : MainLayoutV2.razor
   Namespace   : AbsenceApp.Client.Framework.Layouts
   Author      : Michael
   Version     : 1.9.0
   Created     : 2026-03-29
   Updated     : 2026-04-13
   ---------------------------------------------------------------------------
   Purpose     : Root layout component for all authenticated V2 pages.
                 Composes HeaderV2, SidebarV2, BreadcrumbV2, the main @Body
                 content area, and a copyright footer into the full V2 app
                 shell. Login and other unauthenticated routes share this
                 layout — the sidebar and header are hidden by an auth
                 conditional so the login card renders as a clean centred
                 full-screen form.

                 Mirrors the structure of V1 MainLayout.razor while using the
                 V2 Ki-Admin design-system components (HeaderV2, SidebarV2,
                 BreadcrumbV2) and V2 CSS custom properties.
   ---------------------------------------------------------------------------
   Notes       :
     - Auth redirect: Routes.razor is the SOLE auth guard. This layout does
       NOT redirect to /login — doing so created a second, duplicate redirect
       source that caused spurious LocationChanged events and the startup
       navigation loop seen in the diagnostic log.
     - @Body is always rendered inside the SAME structural position
       (v2-content-area > main > @Body) regardless of auth state. This
       prevents Blazor from tearing down and recreating the page component
       when IsAuthenticated changes. Only the header/footer/sidebar are
       conditionally shown around the stable @Body location.
   ---------------------------------------------------------------------------
   Changes     :
     - 1.0.0  2026-03-29  Initial implementation. Canonical V2 root layout.
     - 1.1.0  2026-03-29  Diagnostic instrumentation to verify layout wiring.
     - 1.2.0  2026-03-29  Temporary removal of sidebar auth gate to isolate
                          AppState.IsAuthenticated timing issue.
     - 1.3.0  2026-03-29  Restored production layout behaviour. Sidebar and
                          header are again gated by AppState.IsAuthenticated.
                          Diagnostic artefacts removed. Layout contract
                          stabilised; auth state fix to follow in
                          AppStateService.
     - 1.4.0  2026-04-06  Fixed layout not re-rendering after login by invoking
                          StateHasChanged on the Blazor dispatcher when
                          AppState changes. Ensures SidebarV2 mounts
                          immediately once IsAuthenticated becomes true.
     - 1.5.0  2026-04-06  Diagnostic logging: added AppLog.Write hooks to
                          OnInitialized, OnAfterRenderAsync, OnAppStateChanged,
                          and Dispose.
     - 1.6.0  2026-04-07  Forced final render boundary after initialisation
                          to guarantee MAUI window repaint after auth change.
     - 1.7.0  2026-04-07  ROOT CAUSE FIX (Bug 1 — dual redirect): removed
                          Nav.NavigateTo('/login') from OnAfterRenderAsync.
                          ROOT CAUSE FIX (Bug 2 — @Body stability).
     - 1.9.0  2026-04-13  E8 — removed <BreadcrumbV2 /> from the auth
                          conditional block. BreadcrumbV2 is replaced by
                          HeaderV3 which renders inside PageTemplateV2.
     - 1.8.0  2026-04-07  Debug instrumentation: added AppLog.Write to
                          OnParametersSet, non-firstRender OnAfterRenderAsync
                          path. Enhanced OnAppStateChanged with _isInitializing
                          flag and sidebarWillRender evaluation. Enhanced
                          OnAfterRenderAsync firstRender with SidebarV2
                          mount-condition evaluation.
   ===========================================================================
*@

@namespace AbsenceApp.Client.Framework.Layouts
@inherits LayoutComponentBase
@using AbsenceApp.Client.Services
@using AbsenceApp.Client.Framework.Layout
@inject AppStateService AppState
@implements IDisposable

@* =========================================================================
   SECTION: INIT LOADER
   ========================================================================= *@
@if (_isInitializing)
{
    <div class="v2-app-loader" role="status" aria-label="Loading AbsenceApp">
        <div class="v2-app-loader__ring"></div>
    </div>
}
else
{
<div class="v2-layout-root @(AppState.DarkMode ? "dark" : "")">

    @if (AppState.IsAuthenticated)
    {
        <SidebarV2 />
    }

    <div class="v2-content-area">

        @* Header visible only when authenticated *@
        @if (AppState.IsAuthenticated)
        {
            <HeaderV2 />
        }

        @* @Body is ALWAYS inside main > div.v2-page-container regardless of
           auth state. This structural stability prevents Blazor from tearing
           down and recreating the current page component when IsAuthenticated
           changes. Only the CSS class on <main> changes conditionally. *@
        <main class="@(AppState.IsAuthenticated ? "v2-main" : "v2-main v2-main--auth")">
            <div class="v2-page-container">
                @Body
            </div>
        </main>

        @if (AppState.IsAuthenticated)
        {
            <footer class="v2-footer">
                <span>&copy; 2026 AbsenceApp — All rights reserved.</span>
            </footer>
        }

    </div>

</div>
}

@* =========================================================================
   SECTION: CODE-BEHIND
   ========================================================================= *@
@code {
    private bool _isInitializing = true;

    protected override void OnInitialized()
    {
        AppLog.Write("MainLayoutV2.razor", "OnInitialized",
            $"Subscribing to AppState.OnChange. IsAuthenticated={AppState.IsAuthenticated}");
        AppState.OnChange += OnAppStateChanged;
    }

    protected override void OnParametersSet()
    {
        AppLog.Write("MainLayoutV2.razor", "OnParametersSet",
            $"Parameters set. IsAuthenticated={AppState.IsAuthenticated} _isInitializing={_isInitializing}");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            AppLog.Write("MainLayoutV2.razor", "OnAfterRenderAsync",
                $"firstRender=true. IsAuthenticated={AppState.IsAuthenticated}. Clearing _isInitializing. sidebarWillRender={AppState.IsAuthenticated} (SidebarV2 is mounted when IsAuthenticated=true)");
            _isInitializing = false;

            // Routes.razor is the sole auth guard.
            // This layout does NOT redirect to /login.
            if (!AppState.IsAuthenticated)
                AppLog.Write("MainLayoutV2.razor", "OnAfterRenderAsync",
                    "Not authenticated. Waiting for Routes.razor guard to redirect.");

            StateHasChanged();
        }
        else
        {
            AppLog.Write("MainLayoutV2.razor", "OnAfterRenderAsync",
                $"firstRender=false (non-first render). IsAuthenticated={AppState.IsAuthenticated} _isInitializing={_isInitializing}");
        }

        await Task.CompletedTask;
    }

    private void OnAppStateChanged()
    {
        AppLog.Write("MainLayoutV2.razor", "OnAppStateChanged",
            $"AppState changed. IsAuthenticated={AppState.IsAuthenticated} _isInitializing={_isInitializing} — sidebarWillRender={(!_isInitializing && AppState.IsAuthenticated)} — invoking StateHasChanged");
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        AppLog.Write("MainLayoutV2.razor", "Dispose",
            "Unsubscribing from AppState.OnChange");
        AppState.OnChange -= OnAppStateChanged;
    }
}
