@* ===========================================================================
   File        : BreadcrumbV2.razor
   Namespace   : AbsenceApp.Client.Components.LayoutV2
   Author      : AI Assistant
   Version     : 1.2.0
   Created     : 2026-03-21
   Updated     : 2026-03-27
   ---------------------------------------------------------------------------
   Purpose     : Route-aware breadcrumb bar. Subscribes to
                 NavigationManager.LocationChanged, calls NavigationServiceV2
                 to resolve the active menu category, group, and item from the
                 current URL, then displays a two-part bar:

                   LEFT  — category name (e.g. "PEOPLE", "CONFIGURATION")
                   RIGHT — group > current item (e.g. "Students > All Students")

                 This replaces the v1.0.0 approach where each page manually
                 called AppState.SetBreadcrumb(), which caused stale labels
                 to persist when navigating between pages.
   ---------------------------------------------------------------------------
   Changes     :
     - 1.0.0  2026-03-21  Initial implementation: reads from AppState.Breadcrumb.
     - 1.1.0  2026-03-27  Phase 3 Shell Fix: complete redesign. Now subscribes
                          to NavigationManager.LocationChanged and resolves
                          category / group / item from NavigationServiceV2.
                          Two-part layout: left = category, right = group > item.
                          Handles both the normal menu and the superadmin
                          (/global-settings/*) menu.
     - 1.2.0  2026-03-27  Phase 3 Issue Fixes:
                          (a) Reset all labels to empty at the START of
                              UpdateAsync so stale values never persist when
                              the new path matches nothing.
                          (b) Two-pass item search: Pass 1 checks EXACT match
                              across all items; Pass 2 (prefix/StartsWith)
                              only runs if no exact match was found. This stops
                              sibling items (e.g. /v2/dashboard) from stealing
                              the match for /v2/dashboard/safeguarding via the
                              prefix rule.
   ---------------------------------------------------------------------------
   Notes       :
     - No [Parameter] public slots — component is self-contained.
     - AppStateService no longer needed here; removed from injection.
   ===========================================================================
*@

@using AbsenceApp.Client.Services
@using AbsenceApp.Client.Models.V2
@inject NavigationServiceV2 NavService
@inject NavigationManager Nav
@implements IDisposable

@* =========================
   SECTION: BREADCRUMB BAR
   Two-part: LEFT = category, RIGHT = group > page
   ========================= *@
<div class="dsv2-breadcrumb">

    @* LEFT: category label (e.g. "PEOPLE") *@
    @if (!string.IsNullOrEmpty(_categoryLabel))
    {
        <span class="dsv2-breadcrumb__category">@_categoryLabel</span>
    }

    @* RIGHT: nav trail (e.g. "Students > All Students") *@
    <div class="dsv2-breadcrumb__trail">
        @if (!string.IsNullOrEmpty(_groupLabel))
        {
            <span class="dsv2-breadcrumb__segment">@_groupLabel</span>
            @if (!string.IsNullOrEmpty(_itemLabel))
            {
                <i class="bi bi-chevron-right dsv2-breadcrumb__sep" aria-hidden="true"></i>
                <span class="dsv2-breadcrumb__current">@_itemLabel</span>
            }
        }
        else if (!string.IsNullOrEmpty(_categoryLabel))
        {
            <span class="dsv2-breadcrumb__current">@_categoryLabel</span>
        }
    </div>

</div>
@code {
    // -----------------------------------------------------------------------
    // State
    // -----------------------------------------------------------------------
    private string _categoryLabel = string.Empty;
    private string _groupLabel    = string.Empty;
    private string _itemLabel     = string.Empty;

    // -----------------------------------------------------------------------
    // Lifecycle
    // -----------------------------------------------------------------------

    protected override async Task OnInitializedAsync()
    {
        Nav.LocationChanged += OnLocationChanged;
        await UpdateAsync(Nav.Uri);
    }

    private void OnLocationChanged(
        object? sender,
        Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        _ = InvokeAsync(async () =>
        {
            await UpdateAsync(e.Location);
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
    }

    // -----------------------------------------------------------------------
    // Route resolution
    // -----------------------------------------------------------------------

    /// <summary>
    /// Resolves the current URI to category/group/item labels using a two-pass
    /// search: exact match first, prefix fallback second.
    /// Resets all labels at the start so stale text never shows.
    /// </summary>
    private async Task UpdateAsync(string uri)
    {
        // Reset labels before every resolution to prevent stale display.
        _categoryLabel = string.Empty;
        _groupLabel    = string.Empty;
        _itemLabel     = string.Empty;

        var path = GetCleanPath(uri);

        // ---- Superadmin / Global Settings (/global-settings/*) ----------------
        if (path.StartsWith("/global-settings/", StringComparison.OrdinalIgnoreCase))
        {
            var groups = await NavService.GetGlobalSettingsMenuGroupsAsync();

            // Pass 1: exact match
            foreach (var group in groups)
            {
                foreach (var item in group.Items)
                {
                    if (path.Equals(item.Href, StringComparison.OrdinalIgnoreCase))
                    {
                        _categoryLabel = group.Group;
                        _groupLabel    = item.Title;
                        _itemLabel     = "Global Settings";
                        return;
                    }
                }
            }

            // Pass 2: prefix match (sub-pages of listed items)
            foreach (var group in groups)
            {
                foreach (var item in group.Items)
                {
                    if (item.Href.Length > 1 &&
                        path.StartsWith(item.Href + "/", StringComparison.OrdinalIgnoreCase))
                    {
                        _categoryLabel = group.Group;
                        _groupLabel    = item.Title;
                        _itemLabel     = "Global Settings";
                        return;
                    }
                }
            }

            // Fallback: at /global-settings/ root or unknown sub-path
            _categoryLabel = "Configuration";
            _groupLabel    = "Global Settings";
            return;
        }

        // ---- Normal menu -------------------------------------------------------
        var categories = await NavService.GetMenuCategoriesAsync();

        // Pass 1: exact match across every item
        foreach (var cat in categories)
        {
            foreach (var group in cat.Groups)
            {
                foreach (var item in group.Items)
                {
                    if (path.Equals(item.Href, StringComparison.OrdinalIgnoreCase))
                    {
                        _categoryLabel = string.IsNullOrEmpty(cat.Category)
                            ? group.Group : cat.Category;
                        _groupLabel = group.Group;
                        _itemLabel  = item.Title;
                        return;
                    }
                }

                // Flat group exact match
                if (group.Flat && group.Items.Count > 0 &&
                    path.Equals(group.Items[0].Href, StringComparison.OrdinalIgnoreCase))
                {
                    _categoryLabel = string.IsNullOrEmpty(cat.Category)
                        ? group.Group : cat.Category;
                    _groupLabel = group.Group;
                    return;
                }
            }
        }

        // Pass 2: prefix match (for un-listed sub-pages, e.g. /v2/students/123)
        foreach (var cat in categories)
        {
            foreach (var group in cat.Groups)
            {
                foreach (var item in group.Items)
                {
                    if (item.Href.Length > 1 &&
                        path.StartsWith(item.Href + "/", StringComparison.OrdinalIgnoreCase))
                    {
                        _categoryLabel = string.IsNullOrEmpty(cat.Category)
                            ? group.Group : cat.Category;
                        _groupLabel = group.Group;
                        _itemLabel  = item.Title;
                        return;
                    }
                }
            }
        }

        // No match -- labels remain empty (reset at top of this method).
    }

    private string GetCleanPath(string uri)
    {
        var path = Nav.ToBaseRelativePath(uri);
        if (!path.StartsWith("/")) path = "/" + path;
        var q = path.IndexOf('?');
        if (q >= 0) path = path[..q];
        var h = path.IndexOf('#');
        if (h >= 0) path = path[..h];
        return path;
    }
}