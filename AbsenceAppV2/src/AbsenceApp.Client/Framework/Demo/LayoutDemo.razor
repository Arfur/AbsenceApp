@* ===========================================================================
   File        : LayoutDemo.razor
   Namespace   : AbsenceApp.Client.FrameworkV2.Demo
   Author      : Michael
   Version     : 1.1.0
   Created     : 2026-03-21
   Updated     : 2026-03-23
   ---------------------------------------------------------------------------
   Purpose     : Demo page for FrameworkV2 layout and page template components.
                 Route: /v2/demo/layout
                 No Absence-specific module dependencies.
   ---------------------------------------------------------------------------
   Changes     :
     - 1.0.0  2026-03-21  Initial implementation.
     - 1.1.0  2026-03-23  Wrapped content in PageTemplateV2 to restore V2 chrome
                           (header, sidebar) after MainLayoutV2 was made body-only.
   ---------------------------------------------------------------------------
   Notes       :
     None.
   ===========================================================================
*@
@page "/v2/demo/layout"
@layout AbsenceApp.Client.Components.Layout.MainLayoutV2
@using AbsenceApp.Client.Components.DesignSystem

<PageTemplateV2 PageTitleText="Layout Demo">
<BodyContent>
<div class="dsv2-demo-page">

    <SectionHeader Title="Layout &amp; Page Template Demo"
                   Icon="bi-layout-sidebar"
                   Subtitle="Overview of FrameworkV2 layout components and page templates" />

    @* =========================================================================
   Section: Layout components info
   ========================================================================= *@
    <section class="dsv2-demo-section">
        <h3 class="dsv2-demo-heading">Layout Shell Components</h3>
        <p>The following layout components compose the application shell. They are used in <code>MainLayout.razor</code> and are not rendered stand-alone on this page to avoid nesting conflicts.</p>

        <div class="dsv2-demo-row dsv2-demo-row--wrap">
            <Card Title="HeaderV2">
                <p>Top application bar. Renders branding, nav actions, and user menu.</p>
                <p><Icon Name="bi-file-earmark-code" Size="sm" /> <code>Components/LayoutV2/HeaderV2.razor</code></p>
            </Card>
            <Card Title="SidebarV2">
                <p>Collapsible side navigation. Driven by <code>NavigationServiceV2</code> and <code>menu.json</code>.</p>
                <p><Icon Name="bi-file-earmark-code" Size="sm" /> <code>Components/LayoutV2/SidebarV2.razor</code></p>
            </Card>
            <Card Title="BreadcrumbV2">
                <p>Contextual breadcrumb trail. Reads route metadata from <code>NavigationServiceV2</code>.</p>
                <p><Icon Name="bi-file-earmark-code" Size="sm" /> <code>Components/LayoutV2/BreadcrumbV2.razor</code></p>
            </Card>
            <Card Title="ScrollSpyV2">
                <p>Tracks in-page anchors as the user scrolls. Highlights the current visible section in side navigation.</p>
                <p><Icon Name="bi-file-earmark-code" Size="sm" /> <code>Components/LayoutV2/ScrollSpyV2.razor</code></p>
            </Card>
        </div>
    </section>

    @* =========================================================================
   Section: Page templates info
   ========================================================================= *@
    <section class="dsv2-demo-section">
        <h3 class="dsv2-demo-heading">Page Template Components</h3>
        <p>FrameworkV2 ships 12 standardized page templates. Each handles a common UI layout pattern.</p>

        <div class="dsv2-demo-row dsv2-demo-row--wrap">
            @foreach (var t in _templates)
            {
                <Card Title="@t.Name" Hoverable="true">
                    <p>@t.Description</p>
                    <p><Icon Name="bi-file-earmark-code" Size="sm" /> <code>@t.File</code></p>
                </Card>
            }
        </div>
    </section>

</div>
</BodyContent>
</PageTemplateV2>

@code {
    private record TemplateInfo(string Name, string Description, string File);

    private readonly List<TemplateInfo> _templates = new()
    {
        new("DetailPageTemplateV2",    "Read-only detail view with labeled sections.",          "PageTemplatesV2/DetailPageTemplateV2.razor"),
        new("FormPageTemplateV2",      "Editable form with validation and submit/cancel.",      "PageTemplatesV2/FormPageTemplateV2.razor"),
        new("ListPageTemplateV2",      "Searchable, filterable list or table page.",            "PageTemplatesV2/ListPageTemplateV2.razor"),
        new("DashboardPageTemplateV2", "Dashboard with metric cards and summary panels.",       "PageTemplatesV2/DashboardPageTemplateV2.razor"),
        new("SettingsPageTemplateV2",  "Grouped settings with toggle and input items.",         "PageTemplatesV2/SettingsPageTemplateV2.razor"),
        new("EmptyStatePageTemplateV2","Placeholder page for empty or no-data states.",         "PageTemplatesV2/EmptyStatePageTemplateV2.razor"),
        new("ErrorPageTemplateV2",     "Standardized error page with code and message.",        "PageTemplatesV2/ErrorPageTemplateV2.razor"),
        new("ConfirmDialogTemplateV2", "Modal-style confirmation prompt.",                      "PageTemplatesV2/ConfirmDialogTemplateV2.razor"),
        new("WizardPageTemplateV2",    "Multi-step wizard with step indicator.",                "PageTemplatesV2/WizardPageTemplateV2.razor"),
        new("ProfilePageTemplateV2",   "User profile display with avatar and attributes.",      "PageTemplatesV2/ProfilePageTemplateV2.razor"),
        new("ReportPageTemplateV2",    "Data report with filter bar and export actions.",       "PageTemplatesV2/ReportPageTemplateV2.razor"),
        new("SplitDetailTemplateV2",   "Master-detail split-panel layout.",                    "PageTemplatesV2/SplitDetailTemplateV2.razor"),
    };
}
