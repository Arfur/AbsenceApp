   Created     : 2026-03-21
   Updated     : 2026-05-20
   ---------------------------------------------------------------------------
   Purpose     : V2 base page template. A layout component (no @page directive)
                 that composes HeaderV2, SidebarV2, BreadcrumbV2, and a main
                 content area with configurable render-fragment slots. Reads
                 dark-mode and sidebar-collapse state from AppStateService.
   ---------------------------------------------------------------------------
   Changes     :
     - 1.0.0  2026-03-21  Initial implementation.
     - 1.0.1  2026-03-25  Removed invalid @using AbsenceApp.Client.Components.LayoutV2.
     - 1.1.0  2026-03-25  Corrected namespace to AbsenceApp.Client.Framework.PageTemplates
                          after restoring file to Framework/PageTemplates folder.
     - 3.1.0  2026-04-13  E8 follow-up: renamed HeaderV3 → PageHeaderV2.
                          Updated <HeaderV3> to <PageHeaderV2> and all
                          related comments. No behavioural change.
     - 3.0.0  2026-04-13  E8 — BreadcrumbV2 replacement. Removed title-row
                          (h1 + actions) in favour of HeaderV3 which renders
                          a two-row page header (resolved title + breadcrumb
                          path) with the ActionsContent slot forwarded to it.
                          PageTitle and PageTitleText parameters are retained
                          as no-ops for backward compatibility.
     - 2.0.0  2026-03-27  Phase 3 Part 2 — Shell deduplication fix.
                          BREAKING: Removed the duplicate Sidebar, Header, and
                          Breadcrumb slots from PageTemplateV2. BaseLayoutV2
                          already renders SidebarV2, HeaderV2, BreadcrumbV2.
                          Having them again inside @Body produced a double shell
                          (two sidebars, two headers) and the 'wide grey container
                          box' defect. PageTemplateV2 now renders ONLY the
                          page title row (title + actions) and the inner content
                          area — making it a true sub-shell composable within
                          BaseLayoutV2's @Body slot.
                          Removed: SidebarContent, HeaderContent, BreadcrumbContent
                          slots, AppState subscription, grid CSS.
                          Kept: PageTitle, PageTitleText, ActionsContent,
                          ChildContent, FooterContent.
     - 3.1.1  2026-05-20  Header comment update: updated Version and Updated
                          fields; clarified PageHeaderV2 comment and ensured
                          ActionsContent forwarding note is explicit.
   ---------------------------------------------------------------------------
   Notes       :
     - Phase 3 component. Requires AppStateService.
     - Framework-level primitive used by all V2 pages.
   ===========================================================================
*@

@namespace AbsenceApp.Client.Framework.PageTemplates
@using AbsenceApp.Client.Framework.Layout

@* =========================
   SECTION: PAGE INNER WRAPPER
   Simple column layout. BaseLayoutV2 owns Sidebar + Header (top nav bar).
   This component adds the two-row page header (PageHeaderV2) and inner content area.
   ========================= *@
<div class="dsv2-page-inner">

    @* =========================
       SECTION: PAGE HEADER
       Two-row header: Row 1 = resolved title + actions, Row 2 = nav path.
       PageHeaderV2 is self-contained — it resolves title from the active route
       via NavigationServiceV2. ActionsContent slot is forwarded here.
       ========================= *@
    <PageHeaderV2 ActionsContent="@ActionsContent" />

    @* =========================
       SECTION: CONTENT AREA
       Inner content placeholder; callers pass DashboardPageTemplate,
       TableV2, TablePageTemplate etc. via ChildContent.
       ========================= *@
    <div class="dsv2-page-inner__content">
        @ChildContent
    </div>

    @* =========================
       SECTION: FOOTER (optional)
       Rendered only when FooterContent is provided.
       ========================= *@
    @if (FooterContent is not null)
    {
        <footer class="dsv2-page-inner__footer">
            @FooterContent
        </footer>
    }

</div>

@code {
    // -------------------------------------------------------------------------
    // Parameters — shell slots (SidebarContent / HeaderContent /
    // BreadcrumbContent removed in v2.0.0; BaseLayoutV2 owns those).
    // -------------------------------------------------------------------------

    /// <summary>Custom title render fragment (overrides PageTitleText).</summary>
    [Parameter] public RenderFragment? PageTitle { get; set; }

    /// <summary>Plain-text page title rendered as an h1.</summary>
    [Parameter] public string? PageTitleText { get; set; }

    /// <summary>Right-aligned action buttons / chips in the title row.</summary>
    [Parameter] public RenderFragment? ActionsContent { get; set; }

    /// <summary>Primary inner content (table template, dashboard grid, etc.).</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }

    /// <summary>Optional footer strip below the content area.</summary>
    [Parameter] public RenderFragment? FooterContent { get; set; }
}
