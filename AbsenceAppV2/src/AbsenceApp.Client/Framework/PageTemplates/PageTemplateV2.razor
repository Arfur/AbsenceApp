@* ===========================================================================
   File        : PageTemplateV2.razor
   Namespace   : AbsenceApp.Client.Components.PageTemplatesV2
   Author      : Michael
   Version     : 1.0.0
   Created     : 2026-03-21
   Updated     : 2026-03-21
   ---------------------------------------------------------------------------
   Purpose     : V2 base page template. A layout component (no @page directive) that composes HeaderV2, SidebarV2, BreadcrumbV2, and a main content area with configurable render-fragment slots. Reads dark-mode and sidebar-collapse state from AppStateService.
   ---------------------------------------------------------------------------
   Changes     :
     - 1.0.0  2026-03-21  Initial implementation.
   ---------------------------------------------------------------------------
   Notes       :
     - Phase 3 component. Requires AppStateService.
   ===========================================================================
*@
@namespace AbsenceApp.Client.FrameworkV2.PageTemplates.Internal
@using AbsenceApp.Client.Services
@using AbsenceApp.Client.Components.DesignSystem
@using AbsenceApp.Client.Components.LayoutV2
@inject AppStateService AppState
@implements IDisposable

<div class="dsv2-page-shell @(_isDark ? "dsv2-page-shell--dark" : "") @(_sidebarCollapsed ? "dsv2-page-shell--sidebar-collapsed" : "")"
     data-theme="@(_isDark ? "dark" : "light")">

@* =========================================================================
   Section: Sidebar
   ========================================================================= *@
    <aside class="dsv2-page-shell__sidebar">
        @if (SidebarContent is not null)
        {
            @SidebarContent
        }
        else
        {
            <SidebarV2 />
        }
    </aside>

@* =========================================================================
   Section: Main column
   ========================================================================= *@
    <div class="dsv2-page-shell__main">

@* =========================================================================
   Section: Header
   ========================================================================= *@
        <header class="dsv2-page-shell__header">
            @if (HeaderContent is not null)
            {
                @HeaderContent
            }
            else
            {
                <HeaderV2 />
            }
        </header>

@* =========================================================================
   Section: Sub-header (breadcrumb + page title + actions)
   ========================================================================= *@
        <div class="dsv2-page-shell__subheader">
            <div class="dsv2-page-shell__breadcrumb">
                @if (BreadcrumbContent is not null)
                {
                    @BreadcrumbContent
                }
                else
                {
                    <BreadcrumbV2 />
                }
            </div>

            @if (PageTitle is not null || PageTitleText is not null)
            {
                <div class="dsv2-page-shell__title-row">
                    @if (PageTitle is not null)
                    {
                        @PageTitle
                    }
                    else
                    {
                        <h1 class="dsv2-page-shell__page-title">@PageTitleText</h1>
                    }

                    @if (ActionsContent is not null)
                    {
                        <div class="dsv2-page-shell__actions">
                            @ActionsContent
                        </div>
                    }
                </div>
            }
        </div>

@* =========================================================================
   Section: Scrollable content area
   ========================================================================= *@
        <main class="dsv2-page-shell__content" id="dsv2-main-content">
            @ChildContent
        </main>

@* =========================================================================
   Section: Optional footer
   ========================================================================= *@
        @if (FooterContent is not null)
        {
            <footer class="dsv2-page-shell__footer">
                @FooterContent
            </footer>
        }
    </div>
</div>

@code {
    // -------------------------------------------------------------------------
    // Render-fragment slots
    // -------------------------------------------------------------------------
    /// <summary>Custom sidebar content. Defaults to SidebarV2.</summary>
    [Parameter] public RenderFragment? SidebarContent { get; set; }

    /// <summary>Custom header content. Defaults to HeaderV2.</summary>
    [Parameter] public RenderFragment? HeaderContent { get; set; }

    /// <summary>Custom breadcrumb content. Defaults to BreadcrumbV2 reading AppStateService.</summary>
    [Parameter] public RenderFragment? BreadcrumbContent { get; set; }

    /// <summary>Custom page title render fragment (overrides PageTitleText).</summary>
    [Parameter] public RenderFragment? PageTitle { get; set; }

    /// <summary>Simple string page title rendered as &lt;h1&gt;. Ignored if PageTitle is set.</summary>
    [Parameter] public string? PageTitleText { get; set; }

    /// <summary>Action buttons or controls placed to the right of the page title.</summary>
    [Parameter] public RenderFragment? ActionsContent { get; set; }

    /// <summary>Main page content.</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }

    /// <summary>Optional footer content.</summary>
    [Parameter] public RenderFragment? FooterContent { get; set; }

    // -------------------------------------------------------------------------

    // State

    // -------------------------------------------------------------------------
    private bool _isDark;
    private bool _sidebarCollapsed;

    protected override void OnInitialized()
    {
        _isDark = AppState.DarkMode;
        _sidebarCollapsed = AppState.SidebarCollapsed;
        AppState.OnChange += OnAppStateChanged;
    }

    private void OnAppStateChanged()
    {
        _isDark = AppState.DarkMode;
        _sidebarCollapsed = AppState.SidebarCollapsed;
        InvokeAsync(StateHasChanged);
    }

    public void Dispose() => AppState.OnChange -= OnAppStateChanged;
}
