@* ===========================================================================
   File        : FormFooterV2.razor
   Namespace   : AbsenceApp.Client.Components.PageTemplatesV2
   Author      : Michael
   Version     : 1.0.0
   Created     : 2026-03-21
   Updated     : 2026-03-21
   ---------------------------------------------------------------------------
   Purpose     : Sticky footer bar for FormPageV2. Contains a primary submit button and a secondary cancel button. Supports a loading/busy state on the submit button and renders optional ChildContent for extra controls (e.g. Delete button on edit forms).
   ---------------------------------------------------------------------------
   Changes     :
     - 1.0.0  2026-03-21  Initial implementation.
   ---------------------------------------------------------------------------
   Notes       :
     - Phase 5 component. No DI registration required.
   ===========================================================================
*@

@* =========================================================================
   Section: Form footer
   ========================================================================= *@
<footer class="dsv2-form-footer">
    <div class="dsv2-form-footer__start">
        @ChildContent
    </div>
    <div class="dsv2-form-footer__end">
        @if (OnCancel.HasDelegate)
        {
            <button type="button"
                    class="dsv2-form-footer__btn dsv2-form-footer__btn--cancel"
                    disabled="@IsBusy"
                    @onclick="OnCancel">
                <i class="bi bi-x-lg" aria-hidden="true"></i>
                @CancelLabel
            </button>
        }
        <button type="submit"
                class="@SubmitBtnClass()"
                disabled="@(IsBusy || IsDisabled)"
                @onclick="OnSubmit">
            @if (IsBusy)
            {
                <span class="dsv2-form-footer__spinner" role="status"
                      aria-label="Saving…"></span>
                <span>@BusyLabel</span>
            }
            else
            {
                <i class="bi bi-check-lg" aria-hidden="true"></i>
                <span>@SubmitLabel</span>
            }
        </button>
    </div>
</footer>

@namespace AbsenceApp.Client.FrameworkV2.PageTemplates.Internal

@* =========================================================================
   Section: Parameters and busy state
   ========================================================================= *@
@code {
    // -------------------------------------------------------------------------
    // Parameters
    // -------------------------------------------------------------------------
    /// <summary>Label for the primary submit button. Default: "Save".</summary>
    [Parameter] public string SubmitLabel { get; set; } = "Save";

    /// <summary>Label shown on the submit button while busy. Default: "Saving…".</summary>
    [Parameter] public string BusyLabel { get; set; } = "Saving\u2026";

    /// <summary>Label for the cancel button. Default: "Cancel".</summary>
    [Parameter] public string CancelLabel { get; set; } = "Cancel";

    /// <summary>When true, shows a spinner inside the submit button and disables all buttons.</summary>
    [Parameter] public bool IsBusy { get; set; } = false;

    /// <summary>When true, disables the submit button even when not busy (e.g. form is invalid).</summary>
    [Parameter] public bool IsDisabled { get; set; } = false;

    /// <summary>Callback invoked when the submit button is clicked.</summary>
    [Parameter] public EventCallback OnSubmit { get; set; }

    /// <summary>Callback invoked when the cancel button is clicked. If not set the cancel button is hidden.</summary>
    [Parameter] public EventCallback OnCancel { get; set; }

    /// <summary>Optional extra controls rendered on the left side of the footer (e.g. Delete button).</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }

    // -------------------------------------------------------------------------

    // Helpers

    // -------------------------------------------------------------------------
    private string SubmitBtnClass()
    {
        var cls = "dsv2-form-footer__btn dsv2-form-footer__btn--submit";
        if (IsBusy) cls += " dsv2-form-footer__btn--busy";
        return cls;
    }
}
