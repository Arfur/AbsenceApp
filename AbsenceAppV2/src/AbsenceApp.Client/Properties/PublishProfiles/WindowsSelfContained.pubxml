<?xml version="1.0" encoding="utf-8"?>
<!--
===========================================================================
  File        : WindowsSelfContained.pubxml
  Project     : AbsenceApp.Client
  Purpose     : Publish profile for self-contained Windows x64 release build.
                Produces an unpackaged folder deploymentin
                bin\Publish\windows-x64\ containing the EXE and all
                required runtimes — no MSIX / Store packaging.

  Usage (from repo root):
    dotnet publish src\AbsenceApp.Client\AbsenceApp.Client.csproj \
      /p:PublishProfile=WindowsSelfContained -v q

  Output: src\AbsenceApp.Client\bin\Publish\windows-x64\
===========================================================================
-->
<Project ToolsVersion="4.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>AnyCPU</Platform>
    <PublishDir>bin\Publish\windows-x64\</PublishDir>
    <TargetFramework>net8.0-windows10.0.19041.0</TargetFramework>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <WindowsPackageType>None</WindowsPackageType>
    <PublishReadyToRun>false</PublishReadyToRun>
    <TrimmerRootDescriptor />
  </PropertyGroup>
</Project>
