@* ===========================================================================
   File        : DesignTokenStyleInjectorV2.razor
   Namespace   : AbsenceApp.Client.Shared.Components
   Author      : Michael
   Version     : 1.0.0
   Created     : 2026-05-12
   Updated     : 2026-05-12
   ---------------------------------------------------------------------------
   Purpose     : Injects a <style id="ds-token-overrides"> element into the
                 document containing the runtime CSS :root { } override block
                 generated by DesignTokenApiServiceV2.

                 Placed once at the top of MainLayoutV2.razor so the generated
                 custom properties are available globally for any component that
                 references a --ds-* variable.

                 Subscribes to DesignTokenApiServiceV2.OnTokensChanged so the
                 style block is automatically refreshed when an admin updates
                 token values at runtime (Phase 3+).
   ---------------------------------------------------------------------------
   Changes     :
     - 1.0.0  2026-05-12  Initial creation (Phase A — Design Token System).
   ---------------------------------------------------------------------------
   Notes       :
     - No .razor.css companion file — this component renders a single <style>
       element and has no scoped CSS requirements.
     - MarkupString is used intentionally: the CSS string is built from trusted
       DB values under admin control and does not accept external user input.
     - IAsyncDisposable: unsubscribes from OnTokensChanged on disposal to
       prevent memory leaks when the layout is torn down.
   ===========================================================================
*@

@namespace AbsenceApp.Client.Shared.Components
@using AbsenceApp.Client.Services.ApiV2.Modules
@inject DesignTokenApiServiceV2 TokenService
@implements IAsyncDisposable

<style id="ds-token-overrides">@((MarkupString)_css)</style>

@code {
    private string _css = string.Empty;

    // -------------------------------------------------------------------------
    // Lifecycle
    // -------------------------------------------------------------------------

    protected override async Task OnInitializedAsync()
    {
        TokenService.OnTokensChanged += HandleTokensChanged;
        _css = await TokenService.GetGeneratedCssAsync();
    }

    // -------------------------------------------------------------------------
    // Event handler — refreshes CSS when tokens are updated at runtime
    // -------------------------------------------------------------------------

    private void HandleTokensChanged()
    {
        _ = InvokeAsync(async () =>
        {
            _css = await TokenService.GetGeneratedCssAsync();
            StateHasChanged();
        });
    }

    // -------------------------------------------------------------------------
    // IAsyncDisposable
    // -------------------------------------------------------------------------

    public ValueTask DisposeAsync()
    {
        TokenService.OnTokensChanged -= HandleTokensChanged;
        return ValueTask.CompletedTask;
    }
}
