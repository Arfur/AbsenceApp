@* ===========================================================================
   File        : ButtonDemoCard.razor
   Namespace   : AbsenceApp.Client.Shared.Components.DesignSystem
   Author      : Michael
   Version     : 1.4.0
   Created     : 2026-05-12
   Updated     : 2026-05-13
   ---------------------------------------------------------------------------
   Purpose     : Reusable KI-Admin-style demo card for button showcase pages.
                 Renders a titled card with two sections:
                   Section A — always-visible live demo row (DemoContent slot)
                   Section B — accordion with code snippet + actions

                 Each card independently manages its own open/closed state
                 via a private _open boolean. No parent state coordination.
   ---------------------------------------------------------------------------
   Parameters  :
     Title         (string)          — card heading text
     DemoContent   (RenderFragment)  — live demo buttons rendered in Section A
     CodeSnippet   (string)          — HTML markup shown in Section B code block
   ---------------------------------------------------------------------------
   Changes     :
     - 1.0.0  2026-05-12  Initial creation (Phase C — Buttons demo layout).
     - 1.1.0  2026-05-12  Added AppLog.Write instrumentation to debug toggle.
     - 1.2.0  2026-05-12  Added page/card/toggle console debugs.
     - 1.3.0  2026-05-12  FIXED: Removed native onclick which was overriding
                          Blazor's @onclick, preventing Toggle() from firing.
     - 1.4.0  2026-05-13  Removed visible debug output; switched to ILogger
                          for diagnostics and kept AppLog.Write for audit.
   ===========================================================================
*@

@namespace AbsenceApp.Client.Shared.Components.DesignSystem
@using AbsenceApp.Client.Services
@using Microsoft.Extensions.Logging
@inject Microsoft.Extensions.Logging.ILogger<ButtonDemoCard> Logger

<div class="kbp-card">

    @* ── Card header: title (left) + toggle icon (right) ── *@
    <div class="kbp-card__header">
        <h3 class="kbp-card__title">@Title</h3>

        <button type="button"
                class="kbp-card__toggle @(_open ? "kbp-card__toggle--active" : "")"
                title="@(_open ? "Hide code" : "Show code")"
                aria-expanded="@_open"
                @onclick="OnToggleClicked">
            <i class="bi bi-code-slash" aria-hidden="true"></i>
        </button>
    </div>

    @* Debug UI removed from visual output. Use Logger for diagnostics. *@

    @* ── Section A: live demo area ── *@
    <div class="kbp-section-a">
        <div class="kbp-btn-row">
            @DemoContent
        </div>
    </div>

    @* ── Section B: accordion content ── *@
    @if (_open)
    {
        <div class="kbp-divider" aria-hidden="true"></div>

        <div class="kbp-section-b">

            <div class="kbp-code-actions">
                <a href="/globalsettings/buttons/edit"
                   class="dsv2-btn dsv2-btn--primary dsv2-btn--sm">
                    <i class="bi bi-pencil-square"></i>
                    Edit Tokens
                </a>

                <button type="button"
                        class="dsv2-btn dsv2-btn--secondary dsv2-btn--sm"
                        @onclick="Toggle">
                    <i class="bi bi-x-lg"></i>
                    Collapse
                </button>
            </div>

            <pre class="kbp-code-block"><code>@CodeSnippet</code></pre>

        </div>
    }

</div>

@code {

    [Parameter, EditorRequired] public string          Title       { get; set; } = string.Empty;
    [Parameter, EditorRequired] public RenderFragment? DemoContent { get; set; }
    [Parameter]                 public string          CodeSnippet { get; set; } = string.Empty;

    private bool _open = false;

    private void OnToggleClicked()
    {
        Console.WriteLine($"[DBG] ButtonDemoCard.OnToggleClicked ENTER — Title='{Title}' _open_before={_open}");
        Logger.LogInformation("CLICK RECEIVED BY BLAZOR - ButtonDemoCard Toggle - Title={Title}", Title ?? "<no-title>");
        Toggle();
        Console.WriteLine($"[DBG] ButtonDemoCard.OnToggleClicked EXIT — Title='{Title}' _open_after={_open}");
    }

    protected override void OnInitialized()
    {
        Console.WriteLine($"[DBG] ButtonDemoCard.OnInitialized — Title='{Title}' DemoContent={DemoContent is not null} CodeSnippetLength={CodeSnippet?.Length ?? 0}");
        Logger.LogDebug("ButtonDemoCard.OnInitialized — Title='{Title}' DemoContent={HasDemo} CodeSnippetLength={Len}",
            Title, DemoContent is not null, CodeSnippet?.Length ?? 0);
    }

    protected override void OnParametersSet()
    {
        Console.WriteLine($"[DBG] ButtonDemoCard.OnParametersSet — Title='{Title}' _open={_open} DemoContent={DemoContent is not null}");
        Logger.LogDebug("ButtonDemoCard.OnParametersSet — Title='{Title}' _open={Open} DemoContent={HasDemo}",
            Title, _open, DemoContent is not null);
    }

    protected override void OnAfterRender(bool firstRender)
    {
        Console.WriteLine($"[DBG] ButtonDemoCard.OnAfterRender — Title='{Title}' firstRender={firstRender} _open={_open}");
        Logger.LogDebug("ButtonDemoCard.OnAfterRender — Title='{Title}' firstRender={First} _open={Open}",
            Title, firstRender, _open);
    }
    private void Toggle()
    {
        Console.WriteLine($"[DBG] ButtonDemoCard.Toggle ENTER — Title='{Title}' _open_before={_open}");
        Logger.LogInformation("ButtonDemoCard.Toggle ENTER — Title='{Title}' _open_before={Before}", Title, _open);

        _open = !_open;

        Console.WriteLine($"[DBG] ButtonDemoCard.Toggle EXIT — Title='{Title}' _open_after={_open}");
        Logger.LogInformation("ButtonDemoCard.Toggle EXIT — Title='{Title}' _open_after={After}", Title, _open);

        AppLog.Write("ButtonDemoCard", "Toggle",
            $"Title='{Title}', NewState={_open}");

        StateHasChanged();   // ← THE FIX
    }
}
