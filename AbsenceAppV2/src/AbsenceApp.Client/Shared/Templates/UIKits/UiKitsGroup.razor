@* ===========================================================================
   File        : UiKitsGroup.razor
   Namespace   : AbsenceApp.Client.Shared.Templates.UIKits
   Author      : Michael
    Version     : 1.2.0
   Created     : 2026-05-20
   Updated     : 2026-05-21
   ---------------------------------------------------------------------------
   Purpose     : Reusable UI Kits group component. Renders a titled card with a
                 demo area and an accordion that reveals a CSS preview and an
                 editor with Edit / Save / Cancel controls. State is owned by
                 the page's code-behind and passed in via parameters.
   ---------------------------------------------------------------------------
   Changes     :
     - 1.0.0  2026-05-20  Initial creation.
     - 1.1.0  2026-05-21  Moved to Shared/Templates/UIKits and namespace updated
                          to enable proper Blazor component discovery and scoped
                          CSS compilation.
        - 1.2.0  2026-05-21  Added template-level item contract, active selection,
                         and item-click callback to support generic click-to-
                         preview behavior across UI Kits pages.
   =========================================================================== *@

@* ===========================================================================
   SECTION: Overview
   Purpose: This component is intentionally layout-only. It exposes parameters
            for all interactive state so the page's Index.razor.cs retains
            ownership of business logic, persistence and token synthesis.
   =========================================================================== *@

@namespace AbsenceApp.Client.Shared.Templates.UIKits
@using Microsoft.AspNetCore.Components.Web

@* ---------------------------------------------------------------------------
   Markup: Card wrapper and header
   --------------------------------------------------------------------------- *@
<div class="uikits-group" role="region" aria-labelledby="@($"{Id}-title")">
    <div class="uikits-group__header">
        <div class="uikits-group__title-area">
            <div id="@($"{Id}-title")" class="uikits-group__title">@Title</div>

            @if (!string.IsNullOrWhiteSpace(Description))
            {
                <div class="uikits-group__desc">@Description</div>
            }
        </div>

        @* Accordion toggle: compact icon button positioned in header *@
        <button class="uikits-group__accordion-toggle"
                @onclick="ToggleAccordion"
                aria-expanded="@AccordionOpen"
                aria-controls="@($"{Id}-accordion")"
                title="@(AccordionOpen ? "Hide CSS" : "Show CSS")">
            <i class="bi bi-code-slash"></i>
        </button>
    </div>

    @* ---------------------------------------------------------------------------
       Body: demo area and accordion
       --------------------------------------------------------------------------- *@
    <div class="uikits-group__body">
        <div class="uikits-group__demo" aria-live="polite">
            @if (!string.IsNullOrWhiteSpace(PreviewCss))
            {
                <style>@PreviewCss</style>
            }

            @if (Items is { Count: > 0 })
            {
                @foreach (var item in Items)
                {
                    var isActive = string.Equals(_activeItemKey, item.Key, StringComparison.Ordinal);

                    <div class="uikits-group__item @(isActive ? "active" : string.Empty)"
                         @onclick="() => SelectItemAsync(item.Key)"
                         role="button"
                         tabindex="0"
                         aria-pressed="@isActive"
                         @onkeydown="(e) => OnItemKeyDownAsync(e, item.Key)">

                        @if (ItemTemplate is not null)
                        {
                            @ItemTemplate(new UiKitsDemoItemContext(item, isActive))
                        }
                        else
                        {
                            <button type="button"
                                    class="uikits-group__item-button @item.CssClass @(isActive ? "is-active" : string.Empty)">
                                @item.Label
                            </button>
                        }
                    </div>
                }
            }
            else
            {
                @DemoContent
            }
        </div>

        @* Accordion container: collapsed/expanded states handled via CSS class *@
        <div id="@($"{Id}-accordion")" class="uikits-group__accordion @(AccordionOpen ? "open" : "closed")">
            @* Display mode: show synthesised CSS and Edit button *@
            @if (!IsEditing)
            {
                <pre class="uikits-group__code" role="textbox" aria-readonly="true">@((MarkupString)PreviewCss)</pre>

                <div class="uikits-group__actions">
                    <button class="btn btn-edit" @onclick="OnEditClicked" aria-label="Edit CSS">Edit</button>
                </div>
            }
            else
            {
                @* Edit mode: textarea bound to EditorText via explicit oninput *@
                <textarea class="uikits-group__editor"
                          value="@EditorText"
                          @oninput="OnEditorInput"
                          aria-label="CSS editor"></textarea>

                <div class="uikits-group__actions">
                    <button class="btn btn-save" @onclick="OnSaveClicked" disabled="@IsSaving" aria-disabled="@IsSaving">Save</button>
                    <button class="btn btn-cancel" @onclick="OnCancelClicked" disabled="@IsSaving" aria-disabled="@IsSaving">Cancel</button>
                </div>
            }

            @* Status message area *@
            @if (!string.IsNullOrEmpty(StatusMessage))
            {
                <div class="uikits-group__status @(StatusIsError ? "error" : "success")" role="status">@StatusMessage</div>
            }
        </div>
    </div>
</div>

@* ===========================================================================
   SECTION: Component parameters
   Purpose: Parameters are intentionally explicit. The page must pass and bind
            its own state objects into these parameters. This component does
            not mutate state directly; it raises callbacks for the page to
            handle.
   =========================================================================== *@
@code {
    // ---------------------------------------------------------------------------
    // Identity
    // ---------------------------------------------------------------------------
    [Parameter] public string Id { get; set; } = Guid.NewGuid().ToString("N");

    // ---------------------------------------------------------------------------
    // Content
    // ---------------------------------------------------------------------------
    [Parameter, EditorRequired]
    public required string Title { get; set; } = default!;

    [Parameter]
    public string? Description { get; set; } = null;

    [Parameter] public string AccordionLabel { get; set; } = "CSS Preview";

    [Parameter]
    public RenderFragment? DemoContent { get; set; }

    [Parameter]
    public IReadOnlyList<UiKitsDemoItem> Items { get; set; } = Array.Empty<UiKitsDemoItem>();

    [Parameter]
    public string? InitialActiveItemKey { get; set; }

    [Parameter]
    public EventCallback<string> OnItemSelectedKeyChanged { get; set; }

    [Parameter]
    public RenderFragment<UiKitsDemoItemContext>? ItemTemplate { get; set; }

    // ---------------------------------------------------------------------------
    // Accordion state (controlled by page)
    // Note: primary property is AccordionOpen; provide aliases for legacy bindings
    // ---------------------------------------------------------------------------
    [Parameter] public bool AccordionOpen { get; set; }
    [Parameter] public EventCallback<bool> AccordionOpenChanged { get; set; }

    // Backwards-compatibility aliases: some pages still bind to IsAccordionOpen / IsAccordionOpenChanged
    [Parameter]
    public bool IsAccordionOpen
    {
        get => AccordionOpen;
        set => AccordionOpen = value;
    }

    [Parameter]
    public EventCallback<bool> IsAccordionOpenChanged
    {
        get => AccordionOpenChanged;
        set => AccordionOpenChanged = value;
    }

    // ---------------------------------------------------------------------------
    // Edit state (controlled by page)
    // ---------------------------------------------------------------------------
    [Parameter] public bool IsEditing { get; set; }
    [Parameter] public EventCallback OnEdit { get; set; }

    // Editor text: initialize to empty string to avoid nullable warnings
    [Parameter] public string EditorText { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> EditorTextChanged { get; set; }

    [Parameter] public bool IsSaving { get; set; }
    [Parameter] public EventCallback OnSave { get; set; }

    [Parameter] public EventCallback OnCancel { get; set; }

    // ---------------------------------------------------------------------------
    // Preview + status (read-only from the page)
    // ---------------------------------------------------------------------------
    [Parameter] public string PreviewCss { get; set; } = string.Empty;
    [Parameter] public string StatusMessage { get; set; } = string.Empty;
    [Parameter] public bool StatusIsError { get; set; }

    private string? _activeItemKey;
    private bool _itemStateInitialised;

    public sealed class UiKitsDemoItem
    {
        public UiKitsDemoItem()
        {
        }

        public UiKitsDemoItem(string key, string label, string? cssClass = null)
        {
            Key = key;
            Label = label;
            CssClass = cssClass;
        }

        public string Key { get; set; } = string.Empty;
        public string Label { get; set; } = string.Empty;
        public string? CssClass { get; set; }
    }

    public sealed class UiKitsDemoItemContext
    {
        public UiKitsDemoItemContext(UiKitsDemoItem item, bool isActive)
        {
            Item = item;
            IsActive = isActive;
        }

        public UiKitsDemoItem Item { get; }
        public bool IsActive { get; }
    }

    protected override void OnParametersSet()
    {
        if (Items is null || Items.Count == 0)
        {
            _activeItemKey = null;
            _itemStateInitialised = false;
            return;
        }

        if (!_itemStateInitialised)
        {
            _activeItemKey = ResolveInitialActiveKey();
            _itemStateInitialised = true;
            return;
        }

        if (!_ContainsItemKey(_activeItemKey))
        {
            _activeItemKey = ResolveInitialActiveKey();
        }
    }

    // ---------------------------------------------------------------------------
    // Local helpers: raise callbacks to the owning page
    // ---------------------------------------------------------------------------
    private async Task ToggleAccordion()
    {
        // Toggle accordion open state by invoking the bound EventCallback.
        await AccordionOpenChanged.InvokeAsync(!AccordionOpen);
    }

    private async Task OnEditClicked()
    {
        // Notify page to enter edit mode. Page should populate EditorText.
        await OnEdit.InvokeAsync();
    }

    private async Task OnSaveClicked()
    {
        // Notify page to save current EditorText. Page handles persistence.
        await OnSave.InvokeAsync();
    }

    private async Task OnCancelClicked()
    {
        // Notify page to cancel edit. Page should restore EditorText/PreviewCss.
        await OnCancel.InvokeAsync();
    }

    private Task OnEditorInput(ChangeEventArgs e)
    {
        // Propagate editor changes to parent via EventCallback<string>.
        var newText = e?.Value?.ToString() ?? string.Empty;
        return EditorTextChanged.InvokeAsync(newText);
    }

    private async Task SelectItemAsync(string key)
    {
        if (string.IsNullOrWhiteSpace(key))
        {
            return;
        }

        _activeItemKey = key;

        if (OnItemSelectedKeyChanged.HasDelegate)
        {
            await OnItemSelectedKeyChanged.InvokeAsync(key);
        }
    }

    private Task OnItemKeyDownAsync(KeyboardEventArgs e, string key)
    {
        if (e.Key is "Enter" or " ")
        {
            return SelectItemAsync(key);
        }

        return Task.CompletedTask;
    }

    private string ResolveInitialActiveKey()
    {
        if (!string.IsNullOrWhiteSpace(InitialActiveItemKey) && _ContainsItemKey(InitialActiveItemKey))
        {
            return InitialActiveItemKey;
        }

        return Items[0].Key;
    }

    private bool _ContainsItemKey(string? key)
    {
        if (string.IsNullOrWhiteSpace(key))
        {
            return false;
        }

        return Items.Any(i => string.Equals(i.Key, key, StringComparison.Ordinal));
    }
}
