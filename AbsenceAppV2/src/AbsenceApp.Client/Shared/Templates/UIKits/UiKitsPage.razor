@namespace AbsenceApp.Client.Shared.Templates.UIKits

@* ===========================================================================
   SECTION: Overview
   Purpose: Top-level wrapper for UI Kits pages. This component is intentionally
            minimal: it provides layout, spacing and a single ChildContent slot.
   Notes  : Do not include component-specific logic here. State and handlers
            remain in the page's code-behind (Index.razor.cs).
   =========================================================================== *@

<div class="uikits-page">
    @* ---------------------------------------------------------------------------
       Inner container: constrains width and stacks groups vertically
       --------------------------------------------------------------------------- *@
    <div class="uikits-page__container">
        @ChildContent
    </div>
</div>

@* ===========================================================================
   SECTION: Component parameters
   Purpose: Expose a single ChildContent parameter for page composition.
   =========================================================================== *@
@code {
    [Parameter]
    public RenderFragment ChildContent { get; set; } = default!;
}
