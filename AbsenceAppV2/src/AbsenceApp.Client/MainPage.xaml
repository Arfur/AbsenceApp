<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:AbsenceApp.Client"
             x:Class="AbsenceApp.Client.MainPage">

    <!--
    ===========================================================================
     File        : MainPage.xaml
     Namespace   : AbsenceApp.Client
     Author      : Michael
     Version     : 1.1.0
     Created     : 2026-03-13
     Updated     : 2026-03-23
    ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
     Purpose     : Single MAUI ContentPage that hosts the BlazorWebView.
                   Acts as the entry point for the Blazor Hybrid UI.
    ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
     Notes       :
       - BlazorWebView HostPage points to wwwroot/index.html.
       - The root Blazor component is responsible for applying the
         application layout (header, sidebar, footer) and routing.
    ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
     Changes     :
       - 1.1.0  2026-03-23  Updated RootComponent to use AppHost as the
                            Blazor entry point, restoring global layout
                            (header, sidebar, footer).
       - 1.0.0  2026-03-13  Initial implementation.
    ===========================================================================
    -->

    <!-- =========================================================
         Page layout — BlazorWebView fills the entire page
         ========================================================= -->
    <BlazorWebView x:Name="blazorWebView" HostPage="wwwroot/index.html">
        <BlazorWebView.RootComponents>
            <RootComponent Selector="#app"
                           ComponentType="{x:Type local:Components.AppHost}" />
        </BlazorWebView.RootComponents>
    </BlazorWebView>

</ContentPage>
