<?xml version="1.0" encoding="utf-8"?>
<manifest package="maui-application-id-placeholder" version="0.0.0" api-version="8" xmlns="http://tizen.org/ns/packages">
  <!--
  =============================================================================
  File        : tizen-manifest.xml
  Project     : AbsenceApp.Client
  Author      :
  Version     : 1.0.0
  Created     : 2026-03-13
  Updated     : 2026-03-13
  Purpose     : Tizen application manifest
  Description : Declares the Tizen application profile, UI entry point,
                label, icon, AOT preference metadata, and required internet
                privilege.
  Changes     : 1.0.0 — Initial
  Notes       : Placeholders are substituted by .NET MAUI build tooling.
                The Tizen target is disabled in the csproj by default; enable
                it only when the Tizen SDK is installed and configured.
  =============================================================================
  -->

  <!-- ===========================================================================
       Profile and UI application — entry point, label, icon, and AOT metadata
  =========================================================================== -->
  <profile name="common" />
  <ui-application appid="maui-application-id-placeholder" exec="AbsenceApp.Client.dll" multiple="false" nodisplay="false" taskmanage="true" type="dotnet" launch_mode="single">
    <label>maui-application-title-placeholder</label>
    <icon>maui-appicon-placeholder</icon>
    <metadata key="http://tizen.org/metadata/prefer_dotnet_aot" value="true" />
  </ui-application>

  <!-- ===========================================================================
       Privileges — internet access required for BlazorWebView content
  =========================================================================== -->
  <shortcut-list />
  <privileges>
    <privilege>http://tizen.org/privilege/internet</privilege>
  </privileges> 
  <dependencies />
  <provides-appdefined-privileges />
</manifest>