@* ===========================================================================
   File        : SectionHeader.razor
   Namespace   : AbsenceApp.Client.Components.DesignSystem
   Author      : Michael
   Version     : 1.0.0
   Created     : 2026-03-21
   Updated     : 2026-03-21
   ---------------------------------------------------------------------------
   Purpose     : Reusable section header with optional icon, subtitle, divider, and an actions slot (right-aligned child content).
   ---------------------------------------------------------------------------
   Changes     :
     - 1.0.0  2026-03-21  Initial implementation.
   ---------------------------------------------------------------------------
   Notes       :
     - Phase 2 component. No DI registration required.
   ===========================================================================
*@

@* =========================================================================
   Section: SectionHeader
   ========================================================================= *@
<div class="@ContainerClass">
    <div class="ds-section-header__left">
        @if (!string.IsNullOrEmpty(Icon))
        {
            <Icon Name="@Icon" Size="lg" Class="ds-section-header__icon" />
        }
        <div class="ds-section-header__text">
            <h2 class="ds-section-header__title">@Title</h2>
            @if (!string.IsNullOrEmpty(Subtitle))
            {
                <p class="ds-section-header__subtitle">@Subtitle</p>
            }
        </div>
    </div>

    @if (Actions is not null)
    {
        <div class="ds-section-header__actions">
            @Actions
        </div>
    }
</div>

@if (ShowDivider)
{
    <hr class="ds-section-header__divider" />
}

@* =========================================================================
   Section: Parameters and CSS class builder
   ========================================================================= *@
@code {
    /// <summary>Section title text.</summary>
    [Parameter, EditorRequired] public string Title { get; set; } = string.Empty;

    /// <summary>Optional subtitle / description below the title.</summary>
    [Parameter] public string? Subtitle { get; set; }

    /// <summary>Optional Bootstrap Icon name (without "bi-" prefix).</summary>
    [Parameter] public string? Icon { get; set; }

    /// <summary>Whether to render a divider below the header.</summary>
    [Parameter] public bool ShowDivider { get; set; } = true;

    /// <summary>Size variant: sm | md (default) | lg.</summary>
    [Parameter] public string Size { get; set; } = "md";

    /// <summary>Additional CSS classes for the container.</summary>
    [Parameter] public string? Class { get; set; }

    /// <summary>Right-aligned actions slot (buttons, links, etc.).</summary>
    [Parameter] public RenderFragment? Actions { get; set; }

    private string ContainerClass => string.Join(" ", new[]
    {
        "ds-section-header",
        $"ds-section-header--{Size}",
        Class
    }.Where(c => !string.IsNullOrWhiteSpace(c)));
}
