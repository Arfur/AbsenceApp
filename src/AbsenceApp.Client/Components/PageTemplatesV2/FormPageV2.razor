@* ===========================================================================
   File        : FormPageV2.razor
   Namespace   : AbsenceApp.Client.Components.PageTemplatesV2
   Author      : Michael
   Version     : 1.3.0
   Created     : 2026-03-21
   Updated     : 2026-03-24
   ---------------------------------------------------------------------------
   Purpose     : V2 form page template. Wraps PageTemplateV2 and provides a
                 structured layout for forms, including an optional back link,
                 validation summary, main body area, and a FormFooterV2 for
                 save/cancel actions.
   ---------------------------------------------------------------------------
   Changes     :
     - 1.0.0  2026-03-21  Initial implementation.
     - 1.1.0  2026-03-23  Added @layout BaseLayoutV2 directive (Step 3).
     - 1.2.0  2026-03-24  Added BackHref, BackLabel, SubmitLabel, BusyLabel,
                          CancelLabel, IsBusy, IsDisabled, OnSubmit, OnCancel,
                          FooterExtraContent parameters. Added FormFooterV2.
                          This fixes the startup crash when navigating to any
                          form page that passes these parameters.
     - 1.3.0  2026-03-24  FIXED: FormFooterV2 was receiving FooterExtraContent
                          as child content (mapped to ChildContent by Blazor
                          default). FormFooterV2 declares BodyContent, not
                          ChildContent. Converted to explicit attribute pass so
                          BodyContent="@FooterExtraContent" is set directly on
                          the self-closing tag. This eliminates the
                          InvalidOperationException on Add Student / Add Staff.
   ---------------------------------------------------------------------------
   Notes       :
     - Phase 5 component. No DI registration required.
   ===========================================================================
*@

@using AbsenceApp.Client.Components.PageTemplatesV2

@* =========================================================================
   Section: Form page shell
   ========================================================================= *@
<PageTemplateV2 PageTitleText="@PageTitle">

    <ActionsContent>
        @if (!string.IsNullOrEmpty(BackHref))
        {
            <a href="@BackHref" class="dsv2-form-page__back-link">
                <i class="bi bi-arrow-left" aria-hidden="true"></i>
                @(string.IsNullOrEmpty(BackLabel) ? "Back" : BackLabel)
            </a>
        }
        @ActionsContent
    </ActionsContent>

    <BodyContent>
        <div class="dsv2-form-page">

            @if (ValidationContent is not null)
            {
                <div class="dsv2-form-page__validation">
                    @ValidationContent
                </div>
            }

            @if (BodyContent is not null)
            {
                <div class="dsv2-form-page__sections">
                    @BodyContent
                </div>
            }

            <FormFooterV2 SubmitLabel="@SubmitLabel"
                          BusyLabel="@BusyLabel"
                          CancelLabel="@CancelLabel"
                          IsBusy="@IsBusy"
                          IsDisabled="@IsDisabled"
                          OnSubmit="OnSubmit"
                          OnCancel="OnCancel"
                          BodyContent="@FooterExtraContent" />

        </div>
    </BodyContent>

</PageTemplateV2>

@* =========================================================================
   Section: Parameters
   ========================================================================= *@
@code {
    // -------------------------------------------------------------------------
    // Page identity
    // -------------------------------------------------------------------------

    /// <summary>Page heading text displayed in the title bar.</summary>
    [Parameter] public string PageTitle { get; set; } = string.Empty;

    // -------------------------------------------------------------------------
    // Back navigation
    // -------------------------------------------------------------------------

    /// <summary>Optional href for the back navigation link shown in the actions bar.</summary>
    [Parameter] public string? BackHref { get; set; }

    /// <summary>Label for the back link. Defaults to "Back" when empty.</summary>
    [Parameter] public string? BackLabel { get; set; }

    // -------------------------------------------------------------------------
    // Content slots
    // -------------------------------------------------------------------------

    /// <summary>Extra action buttons shown alongside the back link.</summary>
    [Parameter] public RenderFragment? ActionsContent { get; set; }

    /// <summary>Validation summary or alert area shown above the form body.</summary>
    [Parameter] public RenderFragment? ValidationContent { get; set; }

    /// <summary>Main form body content (form fields, sections, etc.).</summary>
    [Parameter] public RenderFragment? BodyContent { get; set; }

    /// <summary>Optional extra controls for the left side of FormFooterV2 (e.g. Delete button).</summary>
    [Parameter] public RenderFragment? FooterExtraContent { get; set; }

    // -------------------------------------------------------------------------
    // FormFooterV2 pass-through parameters
    // -------------------------------------------------------------------------

    /// <summary>Submit button label. Default: "Save".</summary>
    [Parameter] public string SubmitLabel { get; set; } = "Save";

    /// <summary>Busy-state label on the submit button. Default: "Saving…".</summary>
    [Parameter] public string BusyLabel { get; set; } = "Saving\u2026";

    /// <summary>Cancel button label. Default: "Cancel".</summary>
    [Parameter] public string CancelLabel { get; set; } = "Cancel";

    /// <summary>Puts the submit button into a loading/busy state.</summary>
    [Parameter] public bool IsBusy { get; set; } = false;

    /// <summary>Disables the submit button.</summary>
    [Parameter] public bool IsDisabled { get; set; } = false;

    /// <summary>Callback for the submit button.</summary>
    [Parameter] public EventCallback OnSubmit { get; set; }

    /// <summary>Callback for the cancel button.</summary>
    [Parameter] public EventCallback OnCancel { get; set; }
}

