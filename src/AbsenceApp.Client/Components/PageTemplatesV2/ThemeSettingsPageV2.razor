@using AbsenceApp.Client.Components.PageTemplatesV2

@* =========================================================================
   Section: Theme settings page shell
   ========================================================================= *@
<PageTemplateV2 PageTitleText="@PageTitle">

    <ActionsContent>
        @ActionsContent
    </ActionsContent>

    <BodyContent>
        <div class="dsv2-theme-settings-page">

            @if (BodyContent is not null)
            {
                <div class="dsv2-theme-settings-page__body">
                    @BodyContent
                </div>
            }

        </div>
    </BodyContent>

</PageTemplateV2>

@* =========================================================================
   Section: Parameters
   ========================================================================= *@
@code {
    // -------------------------------------------------------------------------
    // Parameters
    // -------------------------------------------------------------------------

    /// <summary>Page heading text displayed in the title bar.</summary>
    [Parameter] public string PageTitle { get; set; } = string.Empty;

    /// <summary>Action buttons shown in the title bar (e.g. Save, Reset).</summary>
    [Parameter] public RenderFragment? ActionsContent { get; set; }

    /// <summary>Main theme settings content (ThemeSettingsSectionV2 components).</summary>
    [Parameter] public RenderFragment? BodyContent { get; set; }
}
