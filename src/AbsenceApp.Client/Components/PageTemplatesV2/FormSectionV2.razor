@* ===========================================================================
   File        : FormSectionV2.razor
   Namespace   : AbsenceApp.Client.Components.PageTemplatesV2
   Author      : Michael
   Version     : 1.1.0
   Created     : 2026-03-21
   Updated     : 2026-03-23
   ---------------------------------------------------------------------------
   Purpose     : Bordered group card for grouping form fields within
                 FormPageV2. Accepts a FormSectionModel for configuration or
                 inline parameters. Renders a header section (title, icon,
                 description) and a grid body for Blazor form field content.
   ---------------------------------------------------------------------------
   Changes     :
     - 1.0.0  2026-03-21  Initial implementation.
     - 1.1.0  2026-03-23  Header updated for Step 3 (no layout binding required).
   ---------------------------------------------------------------------------
   Notes       :
     - Phase 5 component. No DI registration required.
     - Not a page template — does not inherit BaseLayoutV2.
   ===========================================================================
*@

@using AbsenceApp.Client.Models.V2

@* =========================================================================
   Section: Form section
   ========================================================================= *@
<div class="@SectionClass()">
    <div class="dsv2-form-section__header">
        @if (Icon is not null)
        {
            <i class="bi @Icon dsv2-form-section__icon" aria-hidden="true"></i>
        }
        <div class="dsv2-form-section__header-text">
            <span class="dsv2-form-section__title">@Title</span>
            @if (!string.IsNullOrEmpty(Description))
            {
                <span class="dsv2-form-section__description">@Description</span>
            }
        </div>
    </div>

    <div class="dsv2-form-section__body dsv2-form-section__body--cols-@Columns">
        @BodyContent
    </div>
</div>

@* =========================================================================
   Section: Parameters
   ========================================================================= *@
@code {
    // -------------------------------------------------------------------------
    // Parameters
    // -------------------------------------------------------------------------
    [Parameter] public FormSectionModel? Model { get; set; }
    [Parameter] public string Title { get; set; } = string.Empty;
    [Parameter] public string? Icon { get; set; }
    [Parameter] public string? Description { get; set; }
    [Parameter] public int Columns { get; set; } = 2;
    [Parameter] public string? CssClass { get; set; }
    [Parameter] public RenderFragment? BodyContent { get; set; }

    // -------------------------------------------------------------------------
    // Lifecycle
    // -------------------------------------------------------------------------
    protected override void OnParametersSet()
    {
        if (Model is not null)
        {
            if (string.IsNullOrEmpty(Title)) Title = Model.Title;
            Icon        ??= Model.Icon;
            Description ??= Model.Description;
            Columns       = Model.Columns;
            CssClass    ??= Model.CssClass;
        }
    }

    private string SectionClass()
    {
        var cls = "dsv2-form-section";
        if (!string.IsNullOrEmpty(CssClass)) cls += " " + CssClass;
        return cls;
    }
}
