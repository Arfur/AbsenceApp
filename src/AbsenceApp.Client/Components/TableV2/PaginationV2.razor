@* ===========================================================================
   File        : PaginationV2.razor
   Namespace   : AbsenceApp.Client.Components.TableV2
   Author      : Michael
   Version     : 1.0.0
   Created     : 2026-03-21
   Updated     : 2026-03-21
   ---------------------------------------------------------------------------
   Purpose     : V2 pagination control. Shows first/prev/next/last buttons, a compact page-range display, optional page-size selector, and a Showing X-Y of Z record summary. Fully keyboard-accessible.
   ---------------------------------------------------------------------------
   Changes     :
     - 1.0.0  2026-03-21  Initial implementation.
   ---------------------------------------------------------------------------
   Notes       :
     - Phase 4 component. No DI registration required.
   ===========================================================================
*@

<nav class="dsv2-pagination" aria-label="Table pagination">

@* =========================================================================
   Section: Record summary
   ========================================================================= *@
    <span class="dsv2-pagination__summary" aria-live="polite" aria-atomic="true">
        @if (TotalCount == 0)
        {
            <span>No records</span>
        }
        else
        {
            <span>@RangeStart–@RangeEnd of @TotalCount</span>
        }
    </span>

@* =========================================================================
   Section: Page size selector
   ========================================================================= *@
    @if (ShowPageSizeSelector && PageSizeOptions is { Length: > 0 })
    {
        <label class="dsv2-pagination__size-label">
            <span class="dsv2-pagination__size-text">Rows</span>
            <select class="dsv2-pagination__size-select"
                    value="@PageSize"
                    @onchange="OnPageSizeSelectChanged"
                    aria-label="Rows per page">
                @foreach (var option in PageSizeOptions)
                {
                    <option value="@option" selected="@(option == PageSize)">@option</option>
                }
            </select>
        </label>
    }

@* =========================================================================
   Section: Navigation buttons
   ========================================================================= *@
    <div class="dsv2-pagination__nav" role="group" aria-label="Page navigation">
        <button type="button"
                class="dsv2-pagination__btn"
                @onclick="GoFirst"
                disabled="@(CurrentPage <= 1)"
                aria-label="First page"
                title="First page">
            <i class="bi bi-chevron-double-left" aria-hidden="true"></i>
        </button>

        <button type="button"
                class="dsv2-pagination__btn"
                @onclick="GoPrev"
                disabled="@(CurrentPage <= 1)"
                aria-label="Previous page"
                title="Previous page">
            <i class="bi bi-chevron-left" aria-hidden="true"></i>
        </button>

        @* Page numbers (compact window) *@
        @foreach (var pageNum in PageNumbers)
        {
            @if (pageNum == -1)
            {
                <span class="dsv2-pagination__ellipsis" aria-hidden="true">…</span>
            }
            else
            {
                <button type="button"
                        class="@PageBtnClass(pageNum)"
                        @onclick="@(() => GoToPage(pageNum))"
                        aria-label="Page @pageNum"
                        aria-current="@AriaCurrent(pageNum)">
                    @pageNum
                </button>
            }
        }

        <button type="button"
                class="dsv2-pagination__btn"
                @onclick="GoNext"
                disabled="@(CurrentPage >= TotalPages)"
                aria-label="Next page"
                title="Next page">
            <i class="bi bi-chevron-right" aria-hidden="true"></i>
        </button>

        <button type="button"
                class="dsv2-pagination__btn"
                @onclick="GoLast"
                disabled="@(CurrentPage >= TotalPages)"
                aria-label="Last page"
                title="Last page">
            <i class="bi bi-chevron-double-right" aria-hidden="true"></i>
        </button>
    </div>
</nav>

@code {
    [Parameter] public int CurrentPage { get; set; } = 1;
    [Parameter] public int PageSize { get; set; } = 25;
    [Parameter] public int TotalCount { get; set; }
    [Parameter] public int[] PageSizeOptions { get; set; } = [10, 25, 50, 100];
    [Parameter] public bool ShowPageSizeSelector { get; set; } = true;
    [Parameter] public EventCallback<int> OnPageChanged { get; set; }
    [Parameter] public EventCallback<int> OnPageSizeChanged { get; set; }

    private int TotalPages => PageSize > 0 ? (int)Math.Ceiling((double)TotalCount / PageSize) : 1;
    private int RangeStart => TotalCount == 0 ? 0 : (CurrentPage - 1) * PageSize + 1;
    private int RangeEnd => Math.Min(CurrentPage * PageSize, TotalCount);

    private IEnumerable<int> PageNumbers
    {
        get
        {
            // Compact window: show up to 7 page numbers with ellipsis
            const int window = 2;
            var pages = new List<int>();
            if (TotalPages <= 7)
            {
                for (int i = 1; i <= TotalPages; i++) pages.Add(i);
                return pages;
            }

            pages.Add(1);
            if (CurrentPage - window > 2) pages.Add(-1); // ellipsis

            for (int i = Math.Max(2, CurrentPage - window);
                     i <= Math.Min(TotalPages - 1, CurrentPage + window); i++)
                pages.Add(i);

            if (CurrentPage + window < TotalPages - 1) pages.Add(-1); // ellipsis
            pages.Add(TotalPages);

            return pages;
        }
    }

    private async Task GoFirst() => await GoToPage(1);
    private async Task GoPrev() => await GoToPage(CurrentPage - 1);
    private async Task GoNext() => await GoToPage(CurrentPage + 1);
    private async Task GoLast() => await GoToPage(TotalPages);

    private async Task GoToPage(int page)
    {
        if (page < 1 || page > TotalPages || page == CurrentPage) return;
        await OnPageChanged.InvokeAsync(page);
    }

    private async Task OnPageSizeSelectChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var size))
            await OnPageSizeChanged.InvokeAsync(size);
    }

    private string PageBtnClass(int page) =>
        page == CurrentPage
            ? "dsv2-pagination__btn dsv2-pagination__btn--page dsv2-pagination__btn--active"
            : "dsv2-pagination__btn dsv2-pagination__btn--page";

    private string? AriaCurrent(int page) => page == CurrentPage ? "page" : null;
}
