@* ===========================================================================
   File        : TableSettingsPageV2.razor
   Namespace   : AbsenceApp.Client.Components.TableV2
   Author      : Michael
   Version     : 1.1.0
   Created     : 2026-03-21
   Updated     : 2026-03-23
   ---------------------------------------------------------------------------
   Purpose     : V2 table settings page. Allows users to toggle column visibility and reorder columns for a specific table schema key. Uses TableSettingsViewModelV2 for state, TableConfigService for initial column data, and ScrollSpyV2 for section navigation.
   ---------------------------------------------------------------------------
   Changes     :
     - 1.0.0  2026-03-21  Initial implementation.
     - 1.1.0  2026-03-23  Wrapped content in PageTemplateV2 to restore V2 chrome
                           (header, sidebar) after MainLayoutV2 was made body-only.
   ---------------------------------------------------------------------------
   Notes       :
     - Phase 4 page.
     - Route(s): /v2/table-settings/{SchemaKey}
   ===========================================================================
*@
@page "/v2/table-settings/{SchemaKey}"
@layout AbsenceApp.Client.Components.Layout.MainLayoutV2
@using AbsenceApp.Client.Models.TableV2
@using AbsenceApp.Client.Services.TableV2
@using AbsenceApp.Client.ViewModels.V2
@inject TableConfigService TableConfig
@inject NavigationManager NavManager

<PageTemplateV2 PageTitleText="@PageShellTitle">
<BodyContent>
<PageTitle>Table Settings — @SchemaKey</PageTitle>

<div class="dsv2-tspage">

@* =========================================================================
   Section: Page header
   ========================================================================= *@
    <div class="dsv2-tspage__header">
        <button type="button" class="dsv2-tspage__back-btn" @onclick="GoBack" aria-label="Back">
            <i class="bi bi-arrow-left" aria-hidden="true"></i>
        </button>
        <div>
            <h1 class="dsv2-tspage__title">Column Settings</h1>
            <p class="dsv2-tspage__subtitle">Configure visibility and order for the <strong>@SchemaKey</strong> table.</p>
        </div>
    </div>

    @if (_isLoading)
    {
        <div class="dsv2-tspage__loading">
            <i class="bi bi-arrow-clockwise dsv2-tspage__spinner" aria-label="Loading…"></i>
        </div>
    }
    else if (_vm is not null)
    {
        @* =========================================================================
   Section: Toolbar
   ========================================================================= *@
        <div class="dsv2-tspage__toolbar">
            <button type="button" class="dsv2-tspage__btn dsv2-tspage__btn--secondary"
                    @onclick="_vm.ResetToDefaults">
                <i class="bi bi-arrow-counterclockwise" aria-hidden="true"></i>
                Reset to defaults
            </button>

            <div class="dsv2-tspage__toolbar-right">
                <button type="button" class="dsv2-tspage__btn dsv2-tspage__btn--secondary"
                        @onclick="Cancel">
                    Cancel
                </button>
                <button type="button"
                        class="@ApplyBtnClass()"
                        @onclick="Apply"
                        disabled="@(!_vm.HasChanges)">
                    <i class="bi bi-check2" aria-hidden="true"></i>
                    Apply
                </button>
            </div>
        </div>

@* =========================================================================
   Section: Column list
   ========================================================================= *@
        <section class="dsv2-tspage__section" id="tspage-columns">
            <h2 class="dsv2-tspage__section-title">
                <i class="bi bi-layout-three-columns" aria-hidden="true"></i>
                Columns
            </h2>
            <p class="dsv2-tspage__section-desc">
                Toggle visibility or drag to reorder. Columns marked as non-hideable cannot be hidden.
            </p>

            <ul class="dsv2-tspage__col-list" role="list" aria-label="Column list">
                @foreach (var col in _vm.WorkingColumns)
                {
                    <li class="@ColItemClass(col)"
                        aria-label="@col.Label column settings">

                        @* Drag handle (visual only — full DnD requires Phase 6 JS) *@
                        <span class="dsv2-tspage__drag-handle" aria-hidden="true">
                            <i class="bi bi-grip-vertical"></i>
                        </span>

                        @* Visibility toggle *@
                        <label class="dsv2-tspage__toggle" aria-label="Show @col.Label">
                            <input type="checkbox"
                                   class="dsv2-tspage__toggle-input"
                                   checked="@col.Visible"
                                   disabled="@(!col.Hideable)"
                                   @onchange="@(() => _vm.ToggleVisibility(col.Key))" />
                            <span class="dsv2-tspage__toggle-track"></span>
                        </label>

                        @* Column info *@
                        <div class="dsv2-tspage__col-info">
                            @if (!string.IsNullOrEmpty(col.Icon))
                            {
                                <i class="bi @col.Icon dsv2-tspage__col-icon" aria-hidden="true"></i>
                            }
                            <span class="dsv2-tspage__col-label">@col.Label</span>
                            @if (!col.Hideable)
                            {
                                <span class="dsv2-tspage__badge dsv2-tspage__badge--locked"
                                      title="This column cannot be hidden">Required</span>
                            }
                            @if (!string.IsNullOrEmpty(col.DataType) && col.DataType != "string")
                            {
                                <span class="dsv2-tspage__badge">@col.DataType</span>
                            }
                        </div>

                        @* Reorder buttons *@
                        @if (col.Reorderable)
                        {
                            <div class="dsv2-tspage__reorder">
                                <button type="button"
                                        class="dsv2-tspage__reorder-btn"
                                        @onclick="@(() => _vm.MoveLeft(col.Key))"
                                        aria-label="Move @col.Label left"
                                        title="Move left">
                                    <i class="bi bi-chevron-left" aria-hidden="true"></i>
                                </button>
                                <button type="button"
                                        class="dsv2-tspage__reorder-btn"
                                        @onclick="@(() => _vm.MoveRight(col.Key))"
                                        aria-label="Move @col.Label right"
                                        title="Move right">
                                    <i class="bi bi-chevron-right" aria-hidden="true"></i>
                                </button>
                            </div>
                        }
                    </li>
                }
            </ul>
        </section>

@* =========================================================================
   Section: Live preview count
   ========================================================================= *@
        <p class="dsv2-tspage__preview-info">
            <i class="bi bi-eye" aria-hidden="true"></i>
            @_vm.WorkingColumns.Count(c => c.Visible) of @_vm.WorkingColumns.Count columns visible
        </p>
    }
    else
    {
        <div class="dsv2-tspage__error">
            <i class="bi bi-exclamation-triangle" aria-hidden="true"></i>
            Could not load settings for schema <strong>@SchemaKey</strong>.
        </div>
    }
</div>
</BodyContent>
</PageTemplateV2>

@code {
    [Parameter] public string SchemaKey { get; set; } = "absences";

    private string PageShellTitle => $"Column Settings \u2014 {SchemaKey}";

    private TableSettingsViewModelV2? _vm;
    private bool _isLoading = true;

    protected override async Task OnParametersSetAsync()
    {
        _isLoading = true;
        var columns = await TableConfig.GetColumnsAsync(SchemaKey);
        _vm = new TableSettingsViewModelV2();
        _vm.Load(SchemaKey, columns);
        _isLoading = false;
    }

    private void Apply()
    {
        _vm?.Apply();
        // In Phase 5+ this will persist to user preferences.
        GoBack();
    }

    private void Cancel()
    {
        _vm?.Cancel();
        GoBack();
    }

    private void GoBack() => NavManager.NavigateTo("/");

    private string ApplyBtnClass() =>
        _vm is not null && _vm.HasChanges
            ? "dsv2-tspage__btn dsv2-tspage__btn--primary"
            : "dsv2-tspage__btn dsv2-tspage__btn--primary dsv2-tspage__btn--disabled";

    private static string ColItemClass(TableColumnModel col) =>
        col.Visible
            ? "dsv2-tspage__col-item"
            : "dsv2-tspage__col-item dsv2-tspage__col-item--hidden";
}
