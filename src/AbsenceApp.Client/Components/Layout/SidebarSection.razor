@* ===========================================================================
   File        : SidebarSection.razor
   Namespace   : AbsenceApp.Client.Components.Layout
   Author      : Michael
   Version     : 1.0.0
   Created     : 2026-03-17
   Updated     : 2026-03-17
   ---------------------------------------------------------------------------
   Purpose     : Visual section divider rendered in the sidebar navigation.
                 Displays an uppercase category label (e.g. "PEOPLE",
                 "ACADEMICS") to group related navigation items.
   ---------------------------------------------------------------------------
   Notes       :
     - The label is hidden when the sidebar is in collapsed (icon-only) mode
       to avoid overflowing the narrow sidebar width.
     - No interactive behaviour; purely presentational.
   ---------------------------------------------------------------------------
   Changes     :
     - 1.0.0  2026-03-17  Initial implementation.
   ===========================================================================
*@

@* =========================================================================
   Section: Section label — shown only when sidebar is expanded
   ========================================================================= *@
@if (!Collapsed)
{
    <div class="sidebar-section-label">@Label</div>
}

@* =========================================================================
   Section: Component parameters
   ========================================================================= *@
@code {
    [Parameter] public string Label     { get; set; } = "";
    [Parameter] public bool   Collapsed { get; set; }
}
