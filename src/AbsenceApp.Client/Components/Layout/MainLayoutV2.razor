@* ===========================================================================
   File        : MainLayoutV2.razor
   Namespace   : AbsenceApp.Client.Components.Layout
   Author      : Michael
   Version     : 1.0.0
   Created     : 2026-03-21
   Updated     : 2026-03-21
   ---------------------------------------------------------------------------
   Purpose     : Root layout for all V2 authenticated pages (/v2/* routes).
                 Composes HeaderV2 and SidebarV2 from FrameworkV2/Layouts into
                 the V2 app shell. Parallel to MainLayout.razor; does NOT
                 modify or replace it.
   ---------------------------------------------------------------------------
   Changes     :
     - 1.0.0  2026-03-21  Initial implementation.
   ---------------------------------------------------------------------------
   Notes       :
     - @layout MainLayoutV2 must be declared on every V2 module page so the
       router uses this shell instead of the V1 MainLayout.
     - HeaderV2 and SidebarV2 each subscribe to AppStateService.OnChange
       internally; no additional subscription is needed here.
     - Authentication redirect is preserved from V1 pattern.
===========================================================================
*@
@inherits LayoutComponentBase
@using AbsenceApp.Client.Services
@inject AppStateService AppState
@inject NavigationManager Nav
@implements IDisposable

@* =========================================================================
   Section: V2 layout wrapper — chrome (header, sidebar, main) is owned by
   PageTemplateV2, which every V2 page composes via StandardPageV2.
   This layout only provides the auth guard and the diagnostic badge.
   ========================================================================= *@


@Body

@* =========================================================================
   Section: Code-behind — AppStateService change subscription
   ========================================================================= *@
@code {
    protected override void OnInitialized()
    {
        AppState.OnChange += StateHasChanged;
        LayoutDiag("MainLayoutV2.OnInitialized — V2 layout is active");
    }

    public void Dispose() => AppState.OnChange -= StateHasChanged;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!AppState.IsAuthenticated)
            Nav.NavigateTo("/login", replace: true);

        await base.OnAfterRenderAsync(firstRender);
    }

    static void LayoutDiag(string msg)
    {
        try
        {
            var path = System.IO.Path.Combine(
                Environment.GetFolderPath(Environment.SpecialFolder.Desktop),
                "AbsenceApp_diag.log");
            System.IO.File.AppendAllText(path, $"[{DateTime.Now:HH:mm:ss.fff}] LAYOUT: {msg}\n");
        }
        catch { }
    }
}
