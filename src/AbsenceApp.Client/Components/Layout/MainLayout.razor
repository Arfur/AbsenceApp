@* ===========================================================================
   File        : MainLayout.razor
   Namespace   : AbsenceApp.Client.Components.Layout
   Author      : Michael
   Version     : 1.0.0
   Created     : 2026-03-17
   Updated     : 2026-03-17
   ---------------------------------------------------------------------------
   Purpose     : Root layout component for all authenticated pages.
                 Composes the NavBar, SideBar, page-header bar, main content
                 area (@Body), and AppFooter into the full app shell.
                 Subscribes to AppStateService.OnChange to re-render on
                 dark-mode and sidebar-collapse state changes.
   ---------------------------------------------------------------------------
   Notes       :
     - DarkMode toggling applies the "dark" CSS class to app-root, switching
       the colour scheme via CSS custom properties in app.css.
     - Breadcrumb segments are set by each page via AppState.SetBreadcrumb();
       the last segment is shown as the page title on the left.
     - IDisposable is implemented to unsubscribe OnChange and avoid memory
       leaks when the layout is torn down.
   ---------------------------------------------------------------------------
   Changes     :
     - 1.0.0  2026-03-17  Initial implementation.
   ===========================================================================
*@
@inherits LayoutComponentBase
@inject AppStateService AppState
@implements IDisposable

@* =========================================================================
   Section: App shell — dark/light root, navbar, sidebar, and content column
   ========================================================================= *@
<div class="app-root @(AppState.DarkMode ? "dark" : "light")">

    <NavBar />

    <div class="app-shell">
        <SideBar />

        <div class="app-content-column">

            @* =========================================================================
               Section: Page header bar — title left, breadcrumb trail right
               ========================================================================= *@
            <div class="page-header-bar">
                <span class="page-header-title">@AppState.Breadcrumb.LastOrDefault()</span>
                <span class="page-header-crumb">
                    @for (int i = 0; i < AppState.Breadcrumb.Count; i++)
                    {
                        var seg    = AppState.Breadcrumb[i];
                        var isLast = i == AppState.Breadcrumb.Count - 1;
                        if (i > 0) { <span class="phc-sep"> &ndash; </span> }
                        if (isLast)
                        {
                            <span class="phc-active">@seg</span>
                        }
                        else
                        {
                            <span class="phc-link">@seg</span>
                        }
                    }
                </span>
            </div>

            <main class="app-main">
                <div class="page-content-box">
                    @Body
                </div>
            </main>

            <AppFooter />

        </div>
    </div>

</div>

@* =========================================================================
   Section: Code-behind — AppStateService change subscription
   ========================================================================= *@
@code {
    protected override void OnInitialized() => AppState.OnChange += StateHasChanged;
    public void Dispose()                   => AppState.OnChange -= StateHasChanged;
}
