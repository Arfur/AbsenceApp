@* ===========================================================================
   File        : DashboardStudentActivityPage.razor
   Namespace   : AbsenceApp.Client.Components.Pages
   Route       : /dashboard/student-activity
   Author      : Michael
   Version     : 1.0.0
   Created     : 2026-03-17
   Updated     : 2026-03-17
   ---------------------------------------------------------------------------
   Purpose     : Student attendance trends dashboard showing KPI cards, a
                 weekly absence trend line chart, attendance code breakdown,
                 per-year-group bar chart, and persistent absence table.
   ---------------------------------------------------------------------------
   Notes       :
     - All data is currently static; replace with ViewModel bindings once
       a student attendance service layer is available.
     - The SVG trend chart is hand-coded; consider a charting component
       library when dynamic data is wired in.
   ---------------------------------------------------------------------------
   Changes     :
     - 1.0.0  2026-03-17  Initial implementation.
   ===========================================================================
*@
@page "/dashboard/student-activity"
@inject AppStateService AppState

@* =========================================================================
   Section: KPI cards — headline attendance metrics
   ========================================================================= *@
<div class="db-kpi-row">
        <div class="db-kpi-card kpi-green">
            <div class="kpi-icon-wrap"><i class="bi bi-check-circle"></i></div>
            <div class="kpi-text">
                <span class="kpi-value">94%</span>
                <span class="kpi-label">Attendance Today</span>
            </div>
        </div>
        <div class="db-kpi-card kpi-green">
            <div class="kpi-icon-wrap"><i class="bi bi-graph-up"></i></div>
            <div class="kpi-text">
                <span class="kpi-value">92%</span>
                <span class="kpi-label">Weekly Attendance</span>
            </div>
        </div>
        <div class="db-kpi-card kpi-orange">
            <div class="kpi-icon-wrap"><i class="bi bi-exclamation-triangle"></i></div>
            <div class="kpi-text">
                <span class="kpi-value">14</span>
                <span class="kpi-label">Persistent Absence</span>
            </div>
        </div>
        <div class="db-kpi-card kpi-red">
            <div class="kpi-icon-wrap"><i class="bi bi-shield-x"></i></div>
            <div class="kpi-text">
                <span class="kpi-value">7</span>
                <span class="kpi-label">Safeguarding Flags</span>
            </div>
        </div>
    </div>

@* =========================================================================
   Section: Weekly absence trend — SVG line chart for Mon–Fri
   ========================================================================= *@
<div class="db-card">
    <div class="db-card-title">Daily Absence Trend This Week</div>
    <svg class="db-trend-svg" height="120" viewBox="0 0 400 80">
        <line x1="0" y1="0"  x2="400" y2="0"  stroke="var(--border)" stroke-width="1"/>
        <line x1="0" y1="27" x2="400" y2="27" stroke="var(--border)" stroke-width="1"/>
        <line x1="0" y1="54" x2="400" y2="54" stroke="var(--border)" stroke-width="1"/>
        <line x1="0" y1="80" x2="400" y2="80" stroke="var(--border)" stroke-width="1"/>
        <defs>
            <linearGradient id="trendGrad" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%"   stop-color="#3b82f6" stop-opacity="0.25"/>
                <stop offset="100%" stop-color="#3b82f6" stop-opacity="0"/>
            </linearGradient>
        </defs>
        <polygon points="0,21 100,35 200,46 300,28 400,39 400,80 0,80" fill="url(#trendGrad)"/>
        <polyline points="0,21 100,35 200,46 300,28 400,39"
                  fill="none" stroke="#3b82f6" stroke-width="2.5" stroke-linejoin="round" stroke-linecap="round"/>
        <circle cx="0"   cy="21" r="4" fill="#3b82f6"/>
        <circle cx="100" cy="35" r="4" fill="#3b82f6"/>
        <circle cx="200" cy="46" r="4" fill="#3b82f6"/>
        <circle cx="300" cy="28" r="4" fill="#3b82f6"/>
        <circle cx="400" cy="39" r="4" fill="#3b82f6"/>
        <text x="0"   y="95" text-anchor="middle" font-size="10" fill="var(--text-muted)">Mon</text>
        <text x="100" y="95" text-anchor="middle" font-size="10" fill="var(--text-muted)">Tue</text>
        <text x="200" y="95" text-anchor="middle" font-size="10" fill="var(--text-muted)">Wed</text>
        <text x="300" y="95" text-anchor="middle" font-size="10" fill="var(--text-muted)">Thu</text>
        <text x="400" y="95" text-anchor="middle" font-size="10" fill="var(--text-muted)">Fri</text>
        <text x="0"   y="16" text-anchor="middle" font-size="10" fill="#2563eb" font-weight="700">22</text>
        <text x="100" y="30" text-anchor="middle" font-size="10" fill="#2563eb" font-weight="700">18</text>
        <text x="200" y="41" text-anchor="middle" font-size="10" fill="#2563eb" font-weight="700">15</text>
        <text x="300" y="23" text-anchor="middle" font-size="10" fill="#2563eb" font-weight="700">20</text>
        <text x="400" y="34" text-anchor="middle" font-size="10" fill="#2563eb" font-weight="700">17</text>
    </svg>
</div>

@* =========================================================================
   Section: Attendance code donut and year-group bar charts
   ========================================================================= *@
<div class="db-row-2col">
    <div class="db-card">
        <div class="db-card-title">Attendance Codes Today (450 pupils)</div>
        <div class="db-chart-area">
            <div class="donut-wrap" style="background: conic-gradient(#10b981 0% 93.33%, #3b82f6 93.33% 97.33%, #ef4444 97.33% 98%, #f59e0b 98% 100%)">
                <div class="donut-hole">
                    <span class="donut-total">450</span>
                    <span class="donut-sub">pupils</span>
                </div>
            </div>
            <div class="donut-legend">
                <div class="legend-item"><span class="legend-dot" style="background:#10b981"></span> Present &mdash; 420</div>
                <div class="legend-item"><span class="legend-dot" style="background:#3b82f6"></span> Auth Absence &mdash; 18</div>
                <div class="legend-item"><span class="legend-dot" style="background:#ef4444"></span> Unauth &mdash; 3</div>
                <div class="legend-item"><span class="legend-dot" style="background:#f59e0b"></span> Late &mdash; 9</div>
            </div>
        </div>
    </div>
    <div class="db-card">
        <div class="db-card-title">Absences by Year Group (this week)</div>
        <div class="db-bar-chart">
            <div class="bar-col">
                <span class="bar-val">3</span>
                <div class="bar-fill" style="height:60%"></div>
                <span class="bar-lbl">Yr 1</span>
            </div>
            <div class="bar-col">
                <span class="bar-val">5</span>
                <div class="bar-fill" style="height:100%"></div>
                <span class="bar-lbl">Yr 2</span>
            </div>
            <div class="bar-col">
                <span class="bar-val">4</span>
                <div class="bar-fill" style="height:80%"></div>
                <span class="bar-lbl">Yr 3</span>
            </div>
            <div class="bar-col">
                <span class="bar-val">2</span>
                <div class="bar-fill" style="height:40%"></div>
                <span class="bar-lbl">Yr 4</span>
            </div>
            <div class="bar-col">
                <span class="bar-val">3</span>
                <div class="bar-fill" style="height:60%"></div>
                <span class="bar-lbl">Yr 5</span>
            </div>
            <div class="bar-col">
                <span class="bar-val">1</span>
                <div class="bar-fill" style="height:20%"></div>
                <span class="bar-lbl">Yr 6</span>
            </div>
        </div>
    </div>
</div>

@* =========================================================================
   Section: Persistent absence table — students with attendance below 90%
   ========================================================================= *@
<div class="db-card">
    <div class="db-card-title">Persistent Absence Students (&lt;90% attendance)</div>
    <table class="db-table">
        <thead>
            <tr>
                <th>Student</th>
                <th>Attendance %</th>
                <th>Year</th>
                <th>Notes</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td>Liam Thornton</td>
                <td style="color:#dc2626;font-weight:700">78%</td>
                <td>Year 3A</td>
                <td>Referred to EWO</td>
            </tr>
            <tr>
                <td>Sophie Walsh</td>
                <td style="color:#dc2626;font-weight:700">82%</td>
                <td>Year 5B</td>
                <td>Medical exemption applied</td>
            </tr>
        </tbody>
    </table>
</div>

@* =========================================================================
   Section: Code-behind — breadcrumb initialisation
   ========================================================================= *@
@code {
    protected override void OnInitialized()
        => AppState.SetBreadcrumb("Dashboard", "Attendance & Trends");
}
