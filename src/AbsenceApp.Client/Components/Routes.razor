@* ===========================================================================
   File        : Routes.razor
   Namespace   : AbsenceApp.Client.Components
   Author      : Michael
   Version     : 2.0.0
   Created     : 2026-03-13
   Updated     : 2026-03-23
   ---------------------------------------------------------------------------
   Purpose     : Root Blazor router component.
                 Matches the current URL to a @page-decorated component and
                 renders it within the selected application shell.
                 Version 2.0.0 temporarily switches the DefaultLayout from
                 MainLayout (V1) to MainLayoutV2 (V2) for isolated testing of
                 the new design-system shell.
   ---------------------------------------------------------------------------
   Changes     :
     - 1.0.0  2026-03-13  Initial implementation.
     - 2.0.0  2026-03-23  Temporary full switch to MainLayoutV2 for V2 shell
                          testing. No other routing behaviour modified.
   ---------------------------------------------------------------------------
   Notes       :
     - AppAssembly is set to the assembly containing MauiProgram so Blazor
       scans the entire client assembly for @page components.
     - DefaultLayout now points to MainLayoutV2 for the duration of V2 testing.
       Revert to MainLayout to restore V1 behaviour.
   ===========================================================================
*@

@* =========================================================================
   Router — maps URLs to @page-decorated components using MainLayoutV2
   ========================================================================= *@
<Router AppAssembly="@typeof(MauiProgram).Assembly">
    <Found Context="routeData">
        <ErrorBoundary>
            <ChildContent>
                @* TEMPORARY: V2 SHELL ACTIVATION *@
                <RouteView RouteData="@routeData" DefaultLayout="@typeof(Layout.MainLayoutV2)" />
            </ChildContent>
            <ErrorContent Context="ex">
                @{ LogError(ex); }
                <div style="padding:2rem;font-family:monospace;color:red;background:white;position:fixed;top:0;left:0;right:0;bottom:0;overflow:auto;z-index:9999;">
                    <h2>Startup Error</h2>
                    <p><strong>@ex.GetType().FullName</strong></p>
                    <p>@ex.Message</p>
                    <pre style="white-space:pre-wrap;font-size:0.8rem;">@ex.ToString()</pre>
                </div>
            </ErrorContent>
        </ErrorBoundary>
    </Found>
    <NotFound>
        <p>Page not found.</p>
    </NotFound>
</Router>

@* =========================================================================
   Section: Code-behind — diagnostic error logger
   ========================================================================= *@
@code {
    static void LogError(Exception ex)
    {
        try
        {
            var path = System.IO.Path.Combine(
                Environment.GetFolderPath(Environment.SpecialFolder.Desktop),
                "AbsenceApp_crash.log");
            System.IO.File.AppendAllText(path,
                $"[{DateTime.Now:HH:mm:ss}] ErrorBoundary: {ex}{Environment.NewLine}");
        }
        catch { /* never throw from error logger */ }
    }
}
