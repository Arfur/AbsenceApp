@* ===========================================================================
   File        : ThemeSettingPageV2.razor
   Namespace   : AbsenceApp.Client.ModulesV2.Settings
   Author      : Michael
   Version     : 1.0.0
   Created     : 2026-03-24
   Updated     : 2026-03-24
   ---------------------------------------------------------------------------
   Purpose     : V2 Theme Settings page. Allows Super Admin users to customise
                 application colour theme and branding. Uses StandardPageV2
                 shell. Full implementation pending design-system phase.
   ---------------------------------------------------------------------------
   Changes     :
     - 1.0.0  2026-03-24  Initial implementation. Route /v2/settings/theme
                          added to match menu.json v4.0.0 (Live item).
   ---------------------------------------------------------------------------
   Notes       :
     - Route: /v2/settings/theme
     - Super Admin guard is applied via NavigationManager redirect.
   ===========================================================================
*@

@page "/v2/settings/theme"
@layout AbsenceApp.Client.Components.Layout.MainLayoutV2
@using AbsenceApp.Client.Components.PageTemplatesV2
@inject AppStateService AppState
@inject NavigationManager Nav

@* =========================================================================
   Section: Theme settings page
   ========================================================================= *@
<StandardPageV2 PageTitle="Theme Colours">

    <BodyContent>
        <div class="dsv2-placeholder">
            <i class="bi bi-palette dsv2-placeholder__icon" aria-hidden="true"></i>
            <h2 class="dsv2-placeholder__title">Theme Configuration</h2>
            <p class="dsv2-placeholder__message">
                Colour palette, typography, and branding customisation tools
                will be available here in an upcoming release.
            </p>
        </div>
    </BodyContent>

</StandardPageV2>

@* =========================================================================
   Section: Code-behind
   ========================================================================= *@
@code {
    protected override void OnInitialized()
    {
        AppState.SetBreadcrumb("Settings", "Theme Colours");

        if (AppState.UserRole != "Super Admin")
            Nav.NavigateTo("/v2/settings", replace: true);
    }
}
