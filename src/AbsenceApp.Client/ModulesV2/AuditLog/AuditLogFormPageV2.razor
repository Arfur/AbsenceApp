@* ===========================================================================
   File        : AuditLogFormPageV2.razor
   Namespace   : AbsenceApp.Client.ModulesV2.AuditLog
   Author      : Michael
   Version     : 1.0.0
   Created     : 2026-03-21
   Updated     : 2026-03-21
   ---------------------------------------------------------------------------
   Purpose     : V2 Audit Log view page ("form" stub). Read-only view displaying
                 a single audit log entry with a notice that entries are
                 immutable. Reuses AuditLogDetailViewModelV2.
   ---------------------------------------------------------------------------
   Changes     :
     - 1.0.0  2026-03-21  Initial implementation (Phase 7).
   ---------------------------------------------------------------------------
   Notes       :
     - Route: /v2/auditlog/{Id:long}/view
     - Register AuditLogDetailViewModelV2 as Scoped in Phase 10.
   ===========================================================================
*@

@page "/v2/auditlog/{Id:long}/view"
@layout AbsenceApp.Client.Components.Layout.MainLayoutV2
@using AbsenceApp.Client.Components.PageTemplatesV2
@using AbsenceApp.Client.ViewModels.V2
@inject AuditLogDetailViewModelV2 ViewModel
@inject AppStateService AppState

@* =========================================================================
   Section: Audit log form
   ========================================================================= *@
<DetailPageV2 PageTitle="@PageTitle"
              BackHref="/v2/auditlog"
              BackLabel="Audit Log">

    <BodyContent>
        <div class="dsv2-alert dsv2-alert--info" role="note">
            <i class="bi bi-lock" aria-hidden="true"></i>
            Audit logs are read-only records. They cannot be created or modified.
        </div>

        @if (ViewModel.IsLoading)
        {
            <p class="dsv2-loading-text">Loading�</p>
        }
        else if (ViewModel.Error is not null)
        {
            <div class="dsv2-alert dsv2-alert--danger" role="alert">@ViewModel.Error</div>
        }
        else if (ViewModel.Item is not null)
        {
            var entry = ViewModel.Item;

            <DetailSectionV2 Title="Audit Entry" Icon="bi-shield-check">
                <BodyContent>
                    <span class="dsv2-detail-label">Audit ID</span>
                    <span class="dsv2-detail-value">@entry.AuditId</span>

                    <span class="dsv2-detail-label">User ID</span>
                    <span class="dsv2-detail-value">@entry.UserId</span>

                    <span class="dsv2-detail-label">Action</span>
                    <span class="dsv2-detail-value">@entry.Action</span>

                    <span class="dsv2-detail-label">Timestamp</span>
                    <span class="dsv2-detail-value">@entry.Timestamp.ToString("dd MMM yyyy HH:mm:ss")</span>
                </BodyContent>
            </DetailSectionV2>
        }
    </BodyContent>

</DetailPageV2>

@* =========================================================================
   Section: ViewModel wiring and form submission
   ========================================================================= *@
@code {
    [Parameter] public long Id { get; set; }

    private string PageTitle => ViewModel.Item is not null
        ? $"View Audit Entry #{ViewModel.Item.AuditId}"
        : "View Audit Entry";

    protected override async Task OnParametersSetAsync()
    {
        AppState.SetBreadcrumb("Audit Log", "View Entry");
        await ViewModel.LoadAsync(Id);
    }
}
