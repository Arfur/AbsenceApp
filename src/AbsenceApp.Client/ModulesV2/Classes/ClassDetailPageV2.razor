@* ===========================================================================
   File        : ClassDetailPageV2.razor
   Namespace   : AbsenceApp.Client.ModulesV2.Classes
   Author      : Michael
   Version     : 1.0.0
   Created     : 2026-03-21
   Updated     : 2026-03-21
   ---------------------------------------------------------------------------
   Purpose     : V2 Class detail page. Displays a single class record using
                 DetailPageV2 and DetailSectionV2 components. Delegates data
                 loading to ClassDetailViewModelV2.
   ---------------------------------------------------------------------------
   Changes     :
     - 1.0.0  2026-03-21  Initial implementation (Phase 7).
   ---------------------------------------------------------------------------
   Notes       :
     - Route: /v2/classes/{Id:long}
     - Register ClassDetailViewModelV2 as Scoped in Phase 10.
   ===========================================================================
*@

@page "/v2/classes/{Id:long}"
@layout AbsenceApp.Client.Components.Layout.MainLayoutV2
@using AbsenceApp.Client.Components.PageTemplatesV2
@using AbsenceApp.Client.ViewModels.V2
@inject ClassDetailViewModelV2 ViewModel
@inject AppStateService AppState
@inject NavigationManager Nav

@* =========================================================================
   Section: Class detail
   ========================================================================= *@
<DetailPageV2 PageTitle="@PageTitle"
              BackHref="/v2/classes"
              BackLabel="Classes">

    <ActionsContent>
        @if (ViewModel.Item is not null)
        {
            <a href="@($"/v2/classes/{Id}/edit")" class="dsv2-btn dsv2-btn--secondary">Edit</a>
        }
    </ActionsContent>

    <BodyContent>
        @if (ViewModel.IsLoading)
        {
            <p class="dsv2-loading-text">Loading�</p>
        }
        else if (ViewModel.Error is not null)
        {
            <div class="dsv2-alert dsv2-alert--danger" role="alert">@ViewModel.Error</div>
        }
        else if (ViewModel.Item is not null)
        {
            var item = ViewModel.Item;

            <DetailSectionV2 Title="Class Details" Icon="bi-mortarboard">
                <BodyContent>
                    <span class="dsv2-detail-label">Name</span>
                    <span class="dsv2-detail-value">@item.Name</span>

                    <span class="dsv2-detail-label">Code</span>
                    <span class="dsv2-detail-value">@(item.Code ?? "�")</span>

                    <span class="dsv2-detail-label">Description</span>
                    <span class="dsv2-detail-value">@(item.Description ?? "�")</span>
                </BodyContent>
            </DetailSectionV2>
        }
    </BodyContent>

</DetailPageV2>

@* =========================================================================
   Section: ViewModel wiring and navigation
   ========================================================================= *@
@code {
    [Parameter] public long Id { get; set; }

    private string PageTitle => ViewModel.Item is not null
        ? ViewModel.Item.Name
        : "Class";

    protected override async Task OnParametersSetAsync()
    {
        AppState.SetBreadcrumb("Classes", "Class Detail");
        await ViewModel.LoadAsync(Id);
    }
}
