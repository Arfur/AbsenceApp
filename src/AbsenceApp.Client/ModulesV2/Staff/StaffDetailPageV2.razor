@* ===========================================================================
   File        : StaffDetailPageV2.razor
   Namespace   : AbsenceApp.Client.ModulesV2.Staff
   Author      : Michael
   Version     : 1.0.0
   Created     : 2026-03-21
   Updated     : 2026-03-21
   ---------------------------------------------------------------------------
   Purpose     : V2 Staff detail page. Displays the details of a single staff
                 member using DetailPageV2 and DetailSectionV2 components.
                 Delegates data loading to StaffDetailViewModelV2.
   ---------------------------------------------------------------------------
   Changes     :
     - 1.0.0  2026-03-21  Initial implementation (Phase 7).
   ---------------------------------------------------------------------------
   Notes       :
     - Route: /v2/staff/{Id:long}
     - Register StaffDetailViewModelV2 as Scoped in Phase 10.
   ===========================================================================
*@

@page "/v2/staff/{Id:long}"
@layout AbsenceApp.Client.Components.Layout.MainLayoutV2
@using AbsenceApp.Client.Components.PageTemplatesV2
@using AbsenceApp.Client.ViewModels.V2
@inject StaffDetailViewModelV2 ViewModel
@inject AppStateService AppState
@inject NavigationManager Nav

@* =========================================================================
   Section: Staff detail
   ========================================================================= *@
<DetailPageV2 PageTitle="@PageTitle"
              BackHref="/v2/staff"
              BackLabel="Staff">

    <ActionsContent>
        @if (ViewModel.Item is not null)
        {
            <a href="@($"/v2/staff/{Id}/edit")" class="dsv2-btn dsv2-btn--secondary">Edit</a>
        }
    </ActionsContent>

    <BodyContent>
        @if (ViewModel.IsLoading)
        {
            <p class="dsv2-loading-text">Loading�</p>
        }
        else if (ViewModel.Error is not null)
        {
            <div class="dsv2-alert dsv2-alert--danger" role="alert">@ViewModel.Error</div>
        }
        else if (ViewModel.Item is not null)
        {
            var item = ViewModel.Item;

            <DetailSectionV2 Title="Personal Details" Icon="bi-person">
                <BodyContent>
                    <span class="dsv2-detail-label">Staff Number</span>
                    <span class="dsv2-detail-value">@item.StaffNumber</span>

                    <span class="dsv2-detail-label">Title</span>
                    <span class="dsv2-detail-value">@item.Title</span>

                    <span class="dsv2-detail-label">First Name</span>
                    <span class="dsv2-detail-value">@item.FirstName</span>

                    <span class="dsv2-detail-label">Preferred Name</span>
                    <span class="dsv2-detail-value">@(item.PreferredName ?? "�")</span>

                    <span class="dsv2-detail-label">Last Name</span>
                    <span class="dsv2-detail-value">@item.LastName</span>

                    <span class="dsv2-detail-label">Date of Birth</span>
                    <span class="dsv2-detail-value">@item.DateOfBirth.ToString("dd MMM yyyy")</span>

                    <span class="dsv2-detail-label">Gender</span>
                    <span class="dsv2-detail-value">@(item.Gender ?? "�")</span>

                    <span class="dsv2-detail-label">Work Email</span>
                    <span class="dsv2-detail-value">@item.WorkEmail</span>

                    <span class="dsv2-detail-label">Account Status</span>
                    <span class="dsv2-detail-value">@item.AccountStatus</span>
                </BodyContent>
            </DetailSectionV2>

            <DetailSectionV2 Title="Employment Details" Icon="bi-briefcase">
                <BodyContent>
                    <span class="dsv2-detail-label">Employment Type</span>
                    <span class="dsv2-detail-value">@item.EmploymentType</span>

                    <span class="dsv2-detail-label">Contract Type</span>
                    <span class="dsv2-detail-value">@item.ContractType</span>

                    <span class="dsv2-detail-label">Work Location</span>
                    <span class="dsv2-detail-value">@item.WorkLocation</span>

                    <span class="dsv2-detail-label">Hire Date</span>
                    <span class="dsv2-detail-value">@item.HireDate.ToString("dd MMM yyyy")</span>

                    <span class="dsv2-detail-label">End Date</span>
                    <span class="dsv2-detail-value">@(item.EndDate.HasValue ? item.EndDate.Value.ToString("dd MMM yyyy") : "�")</span>

                    <span class="dsv2-detail-label">Department</span>
                    <span class="dsv2-detail-value">@item.DepartmentName</span>

                    <span class="dsv2-detail-label">Job Title</span>
                    <span class="dsv2-detail-value">@item.JobTitleName</span>

                    <span class="dsv2-detail-label">Job Group</span>
                    <span class="dsv2-detail-value">@item.JobGroupName</span>

                    <span class="dsv2-detail-label">Reporting Manager</span>
                    <span class="dsv2-detail-value">@(item.ReportingManagerName ?? "�")</span>
                </BodyContent>
            </DetailSectionV2>

            @if (ViewModel.Absences.Count > 0)
            {
                <DetailSectionV2 Title="Absence History" Icon="bi-calendar-x">
                    <BodyContent>
                        @foreach (var absence in ViewModel.Absences)
                        {
                            <span class="dsv2-detail-label">Start Date</span>
                            <span class="dsv2-detail-value">@absence.StartDate.ToString("dd MMM yyyy")</span>

                            <span class="dsv2-detail-label">End Date</span>
                            <span class="dsv2-detail-value">@(absence.EndDate.HasValue ? absence.EndDate.Value.ToString("dd MMM yyyy") : "Ongoing")</span>
                        }
                    </BodyContent>
                </DetailSectionV2>
            }
        }
    </BodyContent>

</DetailPageV2>

@* =========================================================================
   Section: ViewModel wiring and navigation
   ========================================================================= *@
@code {
    [Parameter] public long Id { get; set; }

    private string PageTitle => ViewModel.Item is not null
        ? $"{ViewModel.Item.Title} {ViewModel.Item.FirstName} {ViewModel.Item.LastName}".Trim()
        : "Staff Member";

    protected override async Task OnParametersSetAsync()
    {
        AppState.SetBreadcrumb("Staff", "Staff Member");
        await ViewModel.LoadAsync(Id);
    }
}
