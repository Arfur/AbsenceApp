@* ===========================================================================
   File        : SidebarV2.razor
   Namespace   : AbsenceApp.Client.Components.LayoutV2
   Author      : Michael
   Version     : 1.0.0
   Created     : 2026-03-21
   Updated     : 2026-03-21
   ---------------------------------------------------------------------------
   Purpose     : V2 collapsible sidebar. Loads navigation groups from menu.json via NavigationServiceV2. Parallel to V1 SideBar.razor; does NOT modify or replace it.
   ---------------------------------------------------------------------------
   Changes     :
     - 1.0.0  2026-03-21  Initial implementation.
   ---------------------------------------------------------------------------
   Notes       :
     - Phase 3 component. Requires NavigationServiceV2.
   ===========================================================================
*@
@using AbsenceApp.Client.Services
@using AbsenceApp.Client.Models.V2
@inject NavigationServiceV2 NavService
@inject AppStateService AppState
@inject NavigationManager Nav
@implements IDisposable

<aside class="@SidebarClass" aria-label="Main navigation">
    @* =========================================================================
   Section: User panel
   ========================================================================= *@
    <div class="dsv2-sidebar__user @(AppState.SidebarCollapsed ? "dsv2-sidebar__user--collapsed" : "")">
        <div class="dsv2-sidebar__avatar">
            @(AppState.UserName.Length > 0 ? AppState.UserName[0].ToString().ToUpper() : "?")
        </div>
        @if (!AppState.SidebarCollapsed)
        {
            <div class="dsv2-sidebar__user-info">
                <span class="dsv2-sidebar__user-name">@AppState.UserName</span>
                <span class="dsv2-sidebar__user-role">@AppState.UserRole</span>
            </div>
        }
    </div>

@* =========================================================================
   Section: Navigation
   ========================================================================= *@
    <nav class="dsv2-sidebar__nav">
        @if (_menuGroups is not null)
        {
            @foreach (var group in _menuGroups)
            {
                var isOpen   = _openGroup == group.Group;
                var isActive = group.Items.Any(i => currentPath.StartsWith(i.Href, StringComparison.OrdinalIgnoreCase));

                @* Group toggle button *@
                <button class="dsv2-sidebar__group-btn @(isActive ? "dsv2-sidebar__group-btn--active" : "") @(isOpen ? "dsv2-sidebar__group-btn--open" : "")"
                        @onclick="@(() => ToggleGroup(group.Group))"
                        title="@(AppState.SidebarCollapsed ? group.Group : null)">
                    <i class="bi @group.Icon dsv2-sidebar__item-icon"></i>
                    @if (!AppState.SidebarCollapsed)
                    {
                        <span class="dsv2-sidebar__item-label">@group.Group</span>
                        <i class="bi bi-chevron-right dsv2-sidebar__chevron"></i>
                    }
                </button>

                @* Sub-items *@
                @if (isOpen && !AppState.SidebarCollapsed)
                {
                    <div class="dsv2-sidebar__submenu">
                        @foreach (var item in group.Items)
                        {
                            var itemActive = currentPath.Equals(item.Href, StringComparison.OrdinalIgnoreCase)
                                         || currentPath.StartsWith(item.Href + "/", StringComparison.OrdinalIgnoreCase);
                            <a class="dsv2-sidebar__sublink @(itemActive ? "dsv2-sidebar__sublink--active" : "")"
                               href="@item.Href"
                               title="@item.Description">
                                <i class="bi @item.Icon dsv2-sidebar__item-icon"></i>
                                <span class="dsv2-sidebar__item-label">@item.Title</span>
                                @if (item.Status != "Live")
                                {
                                    <span class="dsv2-sidebar__status-badge dsv2-sidebar__status-badge--@item.Status.ToLower()">@item.Status</span>
                                }
                            </a>
                        }
                    </div>
                }
            }
        }
        else
        {
            <div class="dsv2-sidebar__loading">
                <i class="bi bi-arrow-clockwise"></i>
                @if (!AppState.SidebarCollapsed) { <span>Loading…</span> }
            </div>
        }
    </nav>
</aside>

@code {
    private List<MenuGroupModel>? _menuGroups;
    private string _openGroup = string.Empty;
    private string currentPath = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        AppState.OnChange += StateHasChanged;
        Nav.LocationChanged += OnLocationChanged;
        currentPath = Nav.ToBaseRelativePath(Nav.Uri);
        if (!currentPath.StartsWith("/")) currentPath = "/" + currentPath;
        _menuGroups = await NavService.GetMenuGroupsAsync();

        // Auto-open the group matching the current path
        if (_menuGroups is not null)
        {
            _openGroup = _menuGroups
                .FirstOrDefault(g => g.Items.Any(i => currentPath.StartsWith(i.Href, StringComparison.OrdinalIgnoreCase)))
                ?.Group ?? string.Empty;
        }
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        currentPath = Nav.ToBaseRelativePath(e.Location);
        if (!currentPath.StartsWith("/")) currentPath = "/" + currentPath;
        InvokeAsync(StateHasChanged);
    }

    private void ToggleGroup(string group)
    {
        _openGroup = _openGroup == group ? string.Empty : group;
    }

    private string SidebarClass => string.Join(" ", new[]
    {
        "dsv2-sidebar",
        AppState.SidebarCollapsed ? "dsv2-sidebar--collapsed" : null
    }.Where(c => c is not null));

    public void Dispose()
    {
        AppState.OnChange -= StateHasChanged;
        Nav.LocationChanged -= OnLocationChanged;
    }
}
