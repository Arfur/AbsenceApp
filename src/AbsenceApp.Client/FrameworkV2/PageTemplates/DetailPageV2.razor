@* ===========================================================================
   File        : DetailPageV2.razor
   Namespace   : AbsenceApp.Client.Components.PageTemplatesV2
   Author      : Michael
   Version     : 1.0.0
   Created     : 2026-03-21
   Updated     : 2026-03-21
   ---------------------------------------------------------------------------
   Purpose     : Entity detail (view-only) page template. Composes PageTemplateV2 and provides slots for a back link, title, action buttons (e.g. Edit), and one or more DetailSectionV2 sections. Designed to display a single entity's fields in a structured field/value grid.
   ---------------------------------------------------------------------------
   Changes     :
     - 1.0.0  2026-03-21  Initial implementation.
   ---------------------------------------------------------------------------
   Notes       :
     - Phase 5 component. No DI registration required.
   ===========================================================================
*@
@using AbsenceApp.Client.Components.PageTemplatesV2

@* =========================================================================
   Section: Detail page shell
   ========================================================================= *@
<PageTemplateV2 PageTitleText="@PageTitle">

    <ActionsContent>
        @if (!string.IsNullOrEmpty(BackHref))
        {
            <a href="@BackHref"
               class="dsv2-detail-page__back-link">
                <i class="bi bi-arrow-left" aria-hidden="true"></i>
                @(string.IsNullOrEmpty(BackLabel) ? "Back" : BackLabel)
            </a>
        }
        @ActionsContent
    </ActionsContent>

    <BodyContent>
        <div class="dsv2-detail-page">
            @if (SummaryContent is not null)
            {
                <div class="dsv2-detail-page__summary">
                    @SummaryContent
                </div>
            }

            <div class="dsv2-detail-page__sections">
                @BodyContent
            </div>
        </div>
    </BodyContent>

</PageTemplateV2>

@* =========================================================================
   Section: Parameters and section rendering
   ========================================================================= *@
@code {
    // -------------------------------------------------------------------------
    // Parameters
    // -------------------------------------------------------------------------
    /// <summary>Entity name shown in the page title bar (e.g. "Florence Wilson").</summary>
    [Parameter] public string PageTitle { get; set; } = string.Empty;

    /// <summary>Optional href for the back navigation link (e.g. "/students").</summary>
    [Parameter] public string? BackHref { get; set; }

    /// <summary>Label for the back link. Defaults to "Back".</summary>
    [Parameter] public string? BackLabel { get; set; }

    /// <summary>Action buttons shown in the top-right of the title bar (e.g. Edit, Delete).</summary>
    [Parameter] public RenderFragment? ActionsContent { get; set; }

    /// <summary>Optional summary / avatar panel shown above the sections grid.</summary>
    [Parameter] public RenderFragment? SummaryContent { get; set; }

    /// <summary>The detail sections — one or more DetailSectionV2 components.</summary>
    [Parameter] public RenderFragment? BodyContent { get; set; }
}
