@*
  Mirror component for ClassDetailsPage.razor (/classes/{id}).
  Fully static branching on id value — matches production page exactly.
*@

<h3>Class Details</h3>

@if (id == "1")
{
    <p><strong>Class:</strong> Class One</p>
    <p><strong>Year Group:</strong> Year 7</p>
    <h4>Students</h4>
    <ul>
        <li><a href="/students/1">Alice Smith</a></li>
        <li><a href="/students/2">Bob Jones</a></li>
    </ul>
}
else if (id == "2")
{
    <p><strong>Class:</strong> Class Two</p>
    <p><strong>Year Group:</strong> Year 8</p>
    <h4>Students</h4>
    <ul>
        <li><a href="/students/3">Charlie Brown</a></li>
    </ul>
}
else
{
    <p>Class not found.</p>
}

@code {
    [Parameter] public string id { get; set; } = default!;
}
