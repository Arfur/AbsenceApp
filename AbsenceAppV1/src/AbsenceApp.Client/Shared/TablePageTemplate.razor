@* ===========================================================================
   File        : TablePageTemplate.razor
   Namespace   : AbsenceApp.Client.Shared
   Author      : Michael
   Version     : 1.2.0
   Created     : 2026-03-17
   Updated     : 2026-03-23
   ---------------------------------------------------------------------------
   Purpose     : Reusable five-section layout template for all table-based
                 pages (Students, Staff, Classes, etc.).

                 Section 1 — Filters area  : dropdown filters (Filters slot)
                                              + active chip strip + Clear All
                 Section 2 — Search line   : "Show X entries" (left) +
                                              optional ActionButtons + search
                 Section 3 — Column headers: dark header row; TableHeader slot
                                              supplies the <th> cells + sort
                 Section 4 — Data rows     : alternating colours; TableBody
                                              slot supplies the <tr> rows
                 Section 5 — Pagination    : "Showing X to Y of Z" (left) +
                                              Pagination slot (right)

                 Individual pages supply page-specific content exclusively
                 via the four required RenderFragment parameters.
   ---------------------------------------------------------------------------
   Notes       :
     - ActiveFilters is caller-owned: OnRemoveFilter / OnClearAllFilters
       fire callbacks so the caller can update its list and re-render.
     - Search and ShowEntries are persisted per page route using the existing
       AppStateService singleton; navigating away and back restores them.
     - Search is now button-triggered (and Enter-triggered) using the same
       existing OnSearchChanged filtering pipeline supplied by the page.
     - Clear All and individual chip removal optionally trigger the page's
       existing LoadAsync callback when supplied via OnReload.
     - ShowingFrom and ShowingTo are computed from CurrentPage, ShowEntries,
       and TotalRows. The caller must keep these parameters in sync.
     - Sort button markup (class="tpt-sort-btn asc|desc") is caller-provided
       inside TableHeader. The template CSS styles the buttons via ::deep.
     - All child-slot styling (th, td, tr, badges, action icons, page buttons)
       is defined in TablePageTemplate.razor.css using ::deep selectors.
   ---------------------------------------------------------------------------
   Changes     :
     - 1.2.0  2026-03-23  Suppressed CS0414 for _isRestoringState (reserved for
                          restoration flow) and retained full IDisposable
                          implementation to satisfy build contract.
     - 1.1.0  2026-03-18  Added Search button, filter persistence via
                          AppStateService, optional OnReload callback for
                          filter-clear/removal refresh, and stronger
                          horizontal-scroll behavior.
     - 1.0.0  2026-03-17  Initial implementation.
   ===========================================================================
*@
@using AbsenceApp.Client.Services
@using Microsoft.AspNetCore.Components.Web
@implements IDisposable
@inject AppStateService AppState
@inject NavigationManager Navigation

@* =========================================================================
   Section 1: Filters area
   — caller-supplied dropdown controls + auto-rendered active chip strip
   ========================================================================= *@
<div class="tpt-filters-area">

    @* Dropdown row: caller fills Filters slot; Clear All sits on the right *@
    <div class="tpt-filter-dropdowns">
        @Filters
        <button class="tpt-clear-all-btn" @onclick="HandleClearAll">CLEAR ALL</button>
    </div>

    @* Active chips — shown only when at least one filter is active *@
    @if (ActiveFilters is { Count: > 0 })
    {
        <div class="tpt-chips-row">
            @foreach (var chip in ActiveFilters)
            {
                var c = chip;
                <span class="tpt-chip">
                    <span class="tpt-chip-label">@c.Name:</span>&nbsp;@c.Value
                    <button class="tpt-chip-remove"
                            @onclick="() => HandleRemoveFilter(c)"
                            title="Remove @c.Name filter">
                        <i class="bi bi-x"></i>
                    </button>
                </span>
            }
        </div>
    }

</div>

@* =========================================================================
   Section 2: Search line
   — "Show X entries" on the left; action buttons + search box on the right
   ========================================================================= *@
<div class="tpt-search-line">

    @* Left: show-entries selector *@
    <div class="tpt-show-entries">
        <span class="tpt-show-label">Show</span>
        <select class="tpt-entries-select"
                value="@ShowEntries"
                @onchange="HandleShowEntriesChange">
            <option value="10">10</option>
            <option value="25">25</option>
            <option value="50">50</option>
            <option value="100">100</option>
        </select>
        <span class="tpt-show-label">entries</span>
    </div>

    @* Right: optional action buttons then search box *@
    <div class="tpt-search-right">

        @if (ActionButtons is not null)
        {
            <div class="tpt-action-buttons">
                @ActionButtons
            </div>
        }

        <div class="tpt-search-controls">
            <div class="tpt-search-box">
                <i class="bi bi-search tpt-search-icon"></i>
                <input class="tpt-search-input"
                       type="text"
                       placeholder="Search"
                       value="@_searchDraft"
                       @oninput="HandleSearchInput"
                       @onkeydown="HandleSearchKeyDown" />
            </div>
        </div>

    </div>

</div>

@* =========================================================================
   Sections 3 & 4: Table
   — dark-background header row (Section 3) + alternating data rows (Section 4)
   ========================================================================= *@
<div class="tpt-table-wrapper">
    <table class="tpt-table">
        <thead>
            <tr class="tpt-thead-row">
                @TableHeader
            </tr>
        </thead>
        <tbody>
            @TableBody
        </tbody>
    </table>
</div>

@* =========================================================================
   Section 5: Pagination footer
   — "Showing X to Y of Z entries" on the left; page controls on the right
   ========================================================================= *@
<div class="tpt-pagination-footer">

    <span class="tpt-showing-text">
        Showing @ShowingFrom to @ShowingTo of @TotalRows entries
    </span>

    <div class="tpt-page-controls">
        @Pagination
    </div>

</div>

@* =========================================================================
   Section: Component parameters, computed properties, and event handlers
   ========================================================================= *@
@code {

    // =========================================================================
    // Section: Required RenderFragment slots — all four must be supplied
    // =========================================================================

    /// <summary>Dropdown filter controls shown in Section 1.</summary>
    [Parameter, EditorRequired]
    public RenderFragment Filters { get; set; } = default!;

    /// <summary>Column <th> cells rendered inside the header row (Section 3).</summary>
    [Parameter, EditorRequired]
    public RenderFragment TableHeader { get; set; } = default!;

    /// <summary>Data <tr> rows rendered inside <tbody> (Section 4).</summary>
    [Parameter, EditorRequired]
    public RenderFragment TableBody { get; set; } = default!;

    /// <summary>Pagination buttons rendered on the right of Section 5.</summary>
    [Parameter, EditorRequired]
    public RenderFragment Pagination { get; set; } = default!;

    // =========================================================================
    // Section: Optional RenderFragment slot
    // =========================================================================

    /// <summary>
    /// Action buttons rendered between the entries selector and search box.
    /// Examples: "+ Add Student", "Download Report".
    /// </summary>
    [Parameter]
    public RenderFragment? ActionButtons { get; set; }

    // =========================================================================
    // Section: Page identity
    // =========================================================================

    /// <summary>Heading text displayed above the filters area.</summary>
    [Parameter] public string PageTitle { get; set; } = "Page Title";

    // =========================================================================
    // Section: Filter chip management (caller-owned list)
    // =========================================================================

    [Parameter] public List<FilterChip> ActiveFilters { get; set; } = new();
    [Parameter] public EventCallback<FilterChip> OnRemoveFilter { get; set; }
    [Parameter] public EventCallback OnClearAllFilters { get; set; }

    // =========================================================================
    // Section: Show-entries selector
    // =========================================================================

    [Parameter] public int ShowEntries { get; set; } = 10;
    [Parameter] public EventCallback<int> OnShowEntriesChanged { get; set; }

    // =========================================================================
    // Section: Search box
    // =========================================================================

    [Parameter] public string SearchValue { get; set; } = "";
    [Parameter] public EventCallback<string> OnSearchChanged { get; set; }

    // =========================================================================
    // Section: Optional reload callback
    // =========================================================================

    [Parameter] public EventCallback OnReload { get; set; }

    // =========================================================================
    // Section: Row counts used for "Showing X to Y of Z"
    // =========================================================================

    /// <summary>Total filtered rows (across all pages).</summary>
    [Parameter] public int TotalRows { get; set; }

    /// <summary>Currently active page number (1-based).</summary>
    [Parameter] public int CurrentPage { get; set; } = 1;

    // =========================================================================
    // Section: Internal state
    // =========================================================================

    private bool _hasRestoredState;

#pragma warning disable CS0414
    private bool _isRestoringState;
#pragma warning restore CS0414

    private string _searchDraft = string.Empty;
    private CancellationTokenSource? _searchDebounce;

    // =========================================================================
    // Section: State key (route-based)
    // =========================================================================

    private string PageStateKey
    {
        get
        {
            var route = Navigation.ToBaseRelativePath(Navigation.Uri).Split('?', '#')[0].Trim('/');
            return string.IsNullOrWhiteSpace(route) ? PageTitle : route;
        }
    }

    // =========================================================================
    // Section: Computed "Showing X to Y" range
    // =========================================================================

    private int ShowingFrom => TotalRows == 0 ? 0 : (CurrentPage - 1) * ShowEntries + 1;
    private int ShowingTo => Math.Min(CurrentPage * ShowEntries, TotalRows);

    // =========================================================================
    // Section: Lifecycle
    // =========================================================================

    protected override void OnParametersSet()
    {
        if (!_hasRestoredState)
        {
            _searchDraft = SearchValue;
            return;
        }

        // Do NOT sync _searchDraft from SearchValue here — re-renders triggered
        // by OnSearchChanged (e.g. clearing search for <2 chars) would reset
        // the input value while the user is still typing mid-debounce.
        PersistState();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _hasRestoredState)
            return;

        _hasRestoredState = true;

        var savedState = AppState.GetTablePageState(PageStateKey);
        if (savedState is null)
        {
            _searchDraft = SearchValue;
            PersistState();
            return;
        }

        _isRestoringState = true;

        ActiveFilters.Clear();
        foreach (var chip in savedState.ActiveFilters)
            ActiveFilters.Add(new FilterChip(chip.Name, chip.Value));

        _searchDraft = savedState.SearchValue;

        await OnShowEntriesChanged.InvokeAsync(savedState.ShowEntries);
        await OnSearchChanged.InvokeAsync(savedState.SearchValue);

        _isRestoringState = false;
        PersistState();
        await InvokeAsync(StateHasChanged);
    }

    // =========================================================================
    // Section: Event handlers
    // =========================================================================

    private async Task HandleRemoveFilter(FilterChip chip)
    {
        ActiveFilters.Remove(chip);
        await OnRemoveFilter.InvokeAsync(chip);
        await ReloadIfRequestedAsync();
        PersistState();
    }

    private async Task HandleClearAll()
    {
        ActiveFilters.Clear();
        await OnClearAllFilters.InvokeAsync();
        await ReloadIfRequestedAsync();
        PersistState();
    }

    private async Task HandleShowEntriesChange(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var val))
        {
            await OnShowEntriesChanged.InvokeAsync(val);
            PersistState(searchValueOverride: _searchDraft, showEntriesOverride: val);
        }
    }

    private async Task HandleSearchInput(ChangeEventArgs e)
    {
        _searchDraft = e.Value?.ToString() ?? string.Empty;

        _searchDebounce?.Cancel();
        _searchDebounce = null;

        // Fewer than 2 characters: clear any active search result but do NOT
        // reset the input value — the browser keeps what the user typed.
        if (_searchDraft.Length < 2)
        {
            await OnSearchChanged.InvokeAsync(string.Empty);
            PersistState(searchValueOverride: string.Empty);
            return;
        }

        _searchDebounce = new CancellationTokenSource();
        var cts = _searchDebounce;
        try
        {
            await Task.Delay(350, cts.Token);
            await OnSearchChanged.InvokeAsync(_searchDraft);
            PersistState(searchValueOverride: _searchDraft);
        }
        catch (OperationCanceledException) { }
    }

    private async Task HandleSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            _searchDebounce?.Cancel();
            _searchDebounce = null;
            await OnSearchChanged.InvokeAsync(_searchDraft);
            PersistState(searchValueOverride: _searchDraft);
        }
    }

    // =========================================================================
    // Section: Persistence helpers
    // =========================================================================

    private Task ReloadIfRequestedAsync()
        => OnReload.HasDelegate ? OnReload.InvokeAsync() : Task.CompletedTask;

    private void PersistState(string? searchValueOverride = null, int? showEntriesOverride = null)
    {
        AppState.SetTablePageState(
            PageStateKey,
            searchValueOverride ?? SearchValue,
            showEntriesOverride ?? ShowEntries,
            ActiveFilters);
    }

    // =========================================================================
    // Section: IDisposable
    // =========================================================================

    public void Dispose()
    {
        _searchDebounce?.Cancel();
        _searchDebounce?.Dispose();
    }
}
