@* ===========================================================================
   File        : SubjectListPage.razor
   Namespace   : AbsenceApp.Client.Components.Pages
   Route       : /subjects
   Author      : Michael
   Version     : 1.0.0
   Created     : 2026-03-13
   Updated     : 2026-03-13
   ---------------------------------------------------------------------------
   Purpose     : Displays a summary table of all subjects with teacher and
                 class assignments.  Each subject links to its details page.
   ---------------------------------------------------------------------------
   Notes       :
     - Data is fully static HTML; replace tbody rows with a foreach loop
       once a subject service or ViewModel property is available.
     - Subject ids in hrefs are hard-coded integers; keep in sync with any
       future subject repository seed data.
   ---------------------------------------------------------------------------
   Changes     :
     - 1.0.0  2026-03-13  Initial static implementation.
   ===========================================================================
*@
@page "/subjects"
@inject SubjectListViewModel ViewModel
@inject AppStateService AppState

<h3>Subjects</h3>

@if (ViewModel.IsLoading)
{
    <p><em>Loading...</em></p>
}
else if (ViewModel.ErrorMessage is not null)
{
    <div class="alert-box error">@ViewModel.ErrorMessage</div>
}
else
{
    <table>
        <thead>
            <tr>
                <th>Subject</th>
                <th>Description</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var s in ViewModel.Subjects)
            {
                <tr>
                    <td><a href="/subjects/@s.Id">@s.Name</a></td>
                    <td>@(s.Description ?? "\u2014")</td>
                </tr>
            }
            @if (!ViewModel.Subjects.Any())
            {
                <tr><td colspan="2"><em>No subjects found.</em></td></tr>
            }
        </tbody>
    </table>
}

@code {
    protected override async Task OnInitializedAsync()
    {
        AppState.SetBreadcrumb("Subjects", "All Subjects");
        await ViewModel.LoadAsync();
    }
}
