@* ===========================================================================
   File        : ParentListPage.razor
   Namespace   : AbsenceApp.Client.Components.Pages
   Route       : /parents
   Author      : Michael
   Version     : 1.0.0
   Created     : 2026-03-13
   Updated     : 2026-03-13
   ---------------------------------------------------------------------------
   Purpose     : Displays a summary table of all parents with name, email,
                 and phone number.  Each name links to the parent details page.
   ---------------------------------------------------------------------------
   Notes       :
     - Data is fully static HTML; replace tbody rows with a foreach loop
       once a parent service or ViewModel property is available.
     - Parent ids in hrefs are hard-coded integers; keep in sync with any
       future parent repository seed data.
   ---------------------------------------------------------------------------
   Changes     :
     - 1.0.0  2026-03-13  Initial static implementation.
   ===========================================================================
*@
@page "/parents"
@inject ParentListViewModel ViewModel
@inject AppStateService AppState

<h3>Parent / Guardian Contacts</h3>

<div class="form-card">
    <div class="form-field">
        <label>Student ID</label>
        <input type="number" @bind="_studentIdInput" placeholder="Enter student ID to load contacts" />
    </div>
    <button class="btn-primary" @onclick="Load">Load Contacts</button>
</div>

@if (ViewModel.IsLoading)
{
    <p><em>Loading...</em></p>
}
else if (ViewModel.ErrorMessage is not null)
{
    <div class="alert-box error">@ViewModel.ErrorMessage</div>
}
else if (ViewModel.Contacts.Any())
{
    <table>
        <thead>
            <tr>
                <th>Name</th>
                <th>Relationship</th>
                <th>Phone</th>
                <th>Email</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var c in ViewModel.Contacts)
            {
                <tr>
                    <td><a href="/parents/@c.Id">@c.ContactName</a></td>
                    <td>@c.Relationship</td>
                    <td>@c.PhoneMobile</td>
                    <td>@c.Email</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    string? _studentIdInput;

    protected override void OnInitialized()
        => AppState.SetBreadcrumb("Parents", "Parents");

    async Task Load()
    {
        if (long.TryParse(_studentIdInput, out var id))
            await ViewModel.LoadAsync(id);
    }
}
