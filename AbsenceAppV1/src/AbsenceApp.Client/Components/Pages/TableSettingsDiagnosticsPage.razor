@* ===========================================================================
   File        : TableSettingsDiagnosticsPage.razor
   Namespace   : AbsenceApp.Client.Components.Pages
   Route       : /settings/diagnostics
   Author      : Michael
   Version     : 1.0.0
   Created     : 2026-03-17
   Updated     : 2026-03-17
   ---------------------------------------------------------------------------
   Purpose     : Read-only admin diagnostic page for the schema-driven
                 Table Settings system.

                 For each mapped page it shows:
                   - Page key and entity type
                   - Schema fields (from EF metadata)
                   - Saved settings rows (from table_page_settings)
                   - Unsaved schema fields (new fields — getting defaults)
                   - Orphaned saved fields (stale rows — no longer in schema)
                   - Per-page status (OK / Warning / Error)

                 Globally it shows:
                   - Orphaned DB page keys (rows for unmapped pages)
                   - EF entities with no Table Settings mapping
                   - Overall status

                 This page is READ-ONLY. It does not modify any data.
   ---------------------------------------------------------------------------
   Changes     :
     - 1.0.0  2026-03-17  Initial implementation.
   ---------------------------------------------------------------------------
   Notes       :
     None.
   ===========================================================================
*@
@page "/settings/diagnostics"
@inject AppStateService        AppState
@inject ITableSettingsService  DiagService

@* =========================================================================
   Header banner — overall status
   ========================================================================= *@
@if (_report is not null)
{
    <div class="diag-overall-banner diag-status-@_report.OverallStatus.ToLower()">
        <i class="bi @StatusIcon(_report.OverallStatus)"></i>
        &nbsp;<strong>Overall Status: @_report.OverallStatus</strong>
        &nbsp;—&nbsp;Report generated @_report.GeneratedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")
    </div>
}

@* =========================================================================
   Controls row — Refresh button
   ========================================================================= *@
<div class="diag-controls-row">
    <h2 class="diag-title"><i class="bi bi-shield-check"></i> Table Settings Diagnostics</h2>
    <button class="diag-refresh-btn" @onclick="LoadReport" disabled="@_loading">
        @if (_loading)
        {
            <i class="bi bi-hourglass-split"></i>
            @:&nbsp;Running…
        }
        else
        {
            <i class="bi bi-arrow-clockwise"></i>
            @:&nbsp;Refresh
        }
    </button>
</div>

@* =========================================================================
   Loading indicator
   ========================================================================= *@
@if (_loading)
{
    <div class="diag-loading"><i class="bi bi-hourglass-split"></i> Generating diagnostic report…</div>
}

@* =========================================================================
   Error state
   ========================================================================= *@
@if (_error is not null)
{
    <div class="diag-error-banner">
        <i class="bi bi-exclamation-triangle-fill"></i>
        &nbsp;@_error
    </div>
}

@* =========================================================================
   Main report
   ========================================================================= *@
@if (_report is not null && !_loading)
{
    @* -----------------------------------------------------------------------
       Section 1: Per-page diagnostics
    ----------------------------------------------------------------------- *@
    <section class="diag-section">
        <h3 class="diag-section-title">Page Diagnostics (@_report.Pages.Count pages)</h3>

        @foreach (var pg in _report.Pages.OrderBy(p => p.PageKey))
        {
            <div class="diag-page-card diag-card-@pg.Status.ToLower()">

                <div class="diag-page-header">
                    <span class="diag-status-badge diag-badge-@pg.Status.ToLower()">
                        <i class="bi @StatusIcon(pg.Status)"></i> @pg.Status
                    </span>
                    <span class="diag-page-key">@pg.PageKey</span>
                    <span class="diag-entity-type">→ @pg.EntityTypeName</span>
                    @if (!pg.HasEntityMapping)
                    {
                        <span class="diag-no-mapping">⚠ No EF entity mapping found</span>
                    }
                </div>

                @if (pg.HasEntityMapping)
                {
                    <div class="diag-page-body">

                        @* Schema fields *@
                        <div class="diag-col">
                            <div class="diag-col-header">Schema Fields (@pg.SchemaFields.Count)</div>
                            @foreach (var f in pg.SchemaFields)
                            {
                                <div class="diag-field diag-field-schema">@f</div>
                            }
                        </div>

                        @* Saved settings *@
                        <div class="diag-col">
                            <div class="diag-col-header">Saved Settings (@pg.SavedFields.Count)</div>
                            @if (pg.SavedFields.Count == 0)
                            {
                                <div class="diag-field diag-field-none">— none (using defaults) —</div>
                            }
                            else
                            {
                                @foreach (var f in pg.SavedFields)
                                {
                                    <div class="diag-field diag-field-saved">@f</div>
                                }
                            }
                        </div>

                        @* Unsaved schema fields *@
                        <div class="diag-col">
                            <div class="diag-col-header">New Fields (using defaults) (@pg.UnsavedSchemaFields.Count)</div>
                            @if (pg.UnsavedSchemaFields.Count == 0)
                            {
                                <div class="diag-field diag-field-none">— all schema fields have saved settings —</div>
                            }
                            else
                            {
                                @foreach (var f in pg.UnsavedSchemaFields)
                                {
                                    <div class="diag-field diag-field-new">@f</div>
                                }
                            }
                        </div>

                        @* Orphaned saved fields *@
                        <div class="diag-col">
                            <div class="diag-col-header">Orphaned (stale DB rows) (@pg.OrphanedSavedFields.Count)</div>
                            @if (pg.OrphanedSavedFields.Count == 0)
                            {
                                <div class="diag-field diag-field-none">— none —</div>
                            }
                            else
                            {
                                @foreach (var f in pg.OrphanedSavedFields)
                                {
                                    <div class="diag-field diag-field-orphan">@f</div>
                                }
                            }
                        </div>

                    </div>
                }

            </div>
        }
    </section>

    @* -----------------------------------------------------------------------
       Section 2: Orphaned DB page keys
    ----------------------------------------------------------------------- *@
    <section class="diag-section">
        <h3 class="diag-section-title">
            Orphaned DB Page Keys
            @if (_report.OrphanedDbPageKeys.Count > 0)
            {
                <span class="diag-count-error">@_report.OrphanedDbPageKeys.Count</span>
            }
            else
            {
                <span class="diag-count-ok">none</span>
            }
        </h3>
        <p class="diag-section-desc">
            Rows in <code>table_page_settings</code> whose <code>page_name</code> is not
            in <code>PageEntityMap</code>. These rows can never be loaded and represent stale data.
        </p>
        @if (_report.OrphanedDbPageKeys.Count == 0)
        {
            <div class="diag-ok-row"><i class="bi bi-check-circle-fill"></i> No orphaned page keys found.</div>
        }
        else
        {
            <ul class="diag-list diag-list-error">
                @foreach (var key in _report.OrphanedDbPageKeys)
                {
                    <li><code>@key</code></li>
                }
            </ul>
        }
    </section>

    @* -----------------------------------------------------------------------
       Section 3: Unmapped EF entity types
    ----------------------------------------------------------------------- *@
    <section class="diag-section">
        <h3 class="diag-section-title">
            Unmapped EF Entity Types
            <span class="diag-count-info">@_report.UnmappedEntityTypes.Count</span>
        </h3>
        <p class="diag-section-desc">
            Entity types registered in <code>AppDbContext</code> that have no
            Table Settings page mapping. This is expected for audit tables, lookup tables,
            and junction tables. Informational only.
        </p>
        <div class="diag-unmapped-grid">
            @foreach (var name in _report.UnmappedEntityTypes)
            {
                <span class="diag-entity-chip">@name</span>
            }
        </div>
    </section>
}

@* =========================================================================
   Code-behind
   ========================================================================= *@
@code {
    private TableSettingsDiagnosticReport? _report;
    private bool   _loading;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        AppState.SetBreadcrumb("Home", "Settings", "Diagnostics");
        await LoadReport();
    }

    private async Task LoadReport()
    {
        _loading = true;
        _error   = null;
        _report  = null;

        try
        {
            _report = await DiagService.GetDiagnosticsAsync();
        }
        catch (Exception ex)
        {
            _error = $"Failed to generate report: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private static string StatusIcon(string status) => status switch
    {
        "Error"   => "bi-x-circle-fill",
        "Warning" => "bi-exclamation-triangle-fill",
        _         => "bi-check-circle-fill",
    };
}
