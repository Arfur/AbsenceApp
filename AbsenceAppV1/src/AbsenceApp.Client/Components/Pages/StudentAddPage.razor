@* ===========================================================================
   File        : StudentAddPage.razor
   Namespace   : AbsenceApp.Client.Components.Pages
   Route       : /students/add
   Author      : Michael
   Version     : 1.0.0
   Created     : 2026-03-17
   Updated     : 2026-03-17
   ---------------------------------------------------------------------------
   Purpose     : Placeholder page for enrolling a new student.
                 Will provide a form bound to a Student ViewModel for
                 creating new student records.
   ---------------------------------------------------------------------------
   Notes       :
     - Content is a placeholder; replace with the add-student form once
       the student management service layer is available.
   ---------------------------------------------------------------------------
   Changes     :
     - 1.0.0  2026-03-17  Initial placeholder implementation.
   ===========================================================================
*@
@page "/students/add"
@inject StudentAddViewModel ViewModel
@inject AppStateService AppState

@if (ViewModel.IsSaved)
{
    <div class="alert-box success">Student added successfully.</div>
    <a href="/students">Back to Students</a>
}
else
{
    <h3>Add Student</h3>

    @if (ViewModel.ErrorMessage is not null)
    {
        <div class="alert-box error">@ViewModel.ErrorMessage</div>
    }
    <div class="form-card">
        <div class="form-field">
            <label>First Name</label>
            <input type="text" @bind="ViewModel.NewStudent.FirstName" placeholder="First name" />
        </div>
        <div class="form-field">
            <label>Last Name</label>
            <input type="text" @bind="ViewModel.NewStudent.LastName" placeholder="Last name" />
        </div>
        <div class="form-field">
            <label>Admission Number</label>
            <input type="text" @bind="ViewModel.NewStudent.AdmissionNumber" placeholder="Admission number" />
        </div>
        <div class="form-field">
            <label>Status</label>
            <input type="text" @bind="ViewModel.NewStudent.Status" placeholder="e.g. Active" />
        </div>
        <div class="form-actions">
            <button class="btn-primary" @onclick="Save" disabled="@ViewModel.IsSaving">
                @(ViewModel.IsSaving ? "Saving..." : "Save Student")
            </button>
            <a href="/students">Cancel</a>
        </div>
    </div>
}

@code {
    protected override void OnInitialized()
        => AppState.SetBreadcrumb("Students", "Add Students");

    async Task Save() => await ViewModel.SaveAsync();
}
