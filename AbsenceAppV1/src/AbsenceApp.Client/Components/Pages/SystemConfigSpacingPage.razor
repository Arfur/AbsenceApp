@page "/system/config/spacing"
@inject AppStateService AppState
@inject NavigationManager Nav

<h3>Spacing / Panels / Cards</h3>
<p class="page-placeholder-msg">This configuration page is not yet implemented.</p>

@code {
    protected override void OnInitialized()
    {
        if (AppState.UserRole != "Super Admin")
        {
            Nav.NavigateTo("/dashboard/overview", replace: true);
            return;
        }
        AppState.SetBreadcrumb("System Management", "Global Configuration", "Spacing / Panels / Cards");
    }
}
