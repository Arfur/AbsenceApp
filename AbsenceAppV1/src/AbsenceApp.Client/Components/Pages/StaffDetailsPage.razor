@* ===========================================================================
   File        : StaffDetailsPage.razor
   Namespace   : AbsenceApp.Client.Components.Pages
   Route       : /staff/{id}
   Author      : Michael
   Version     : 1.0.0
   Created     : 2026-03-13
   Updated     : 2026-03-13
   ---------------------------------------------------------------------------
   Purpose     : Displays the full profile of a single staff member.
   ---------------------------------------------------------------------------
   Notes       :
     - All profile fields are hard-coded static values; replace with a staff
       service lookup keyed on {id} once a data layer exists.
     - No @code block or @inject directive; the page is purely presentational
       until dynamic data is wired in.
   ---------------------------------------------------------------------------
   Changes     :
     - 1.0.0  2026-03-13  Initial static implementation.
   ===========================================================================
*@
@page "/staff/{id}"
@inject StaffDetailsViewModel ViewModel
@inject AppStateService AppState

<h3>Staff Details</h3>

@if (ViewModel.IsLoading)
{
    <p><em>Loading...</em></p>
}
else if (ViewModel.ErrorMessage is not null)
{
    <div class="alert-box error">@ViewModel.ErrorMessage</div>
}
else if (ViewModel.Staff is not null)
{
    <div class="detail-card">
        <p><strong>Name:</strong> @ViewModel.Staff.FullName</p>
        <p><strong>Title:</strong> @ViewModel.Staff.Title</p>
        <p><strong>Work Email:</strong> @ViewModel.Staff.WorkEmail</p>
        <p><strong>Phone:</strong> @ViewModel.Staff.PhoneMobile</p>
        <p><strong>Employment Type:</strong> @ViewModel.Staff.EmploymentType</p>
        <p><strong>Contract:</strong> @ViewModel.Staff.ContractType</p>
        <p><strong>Hire Date:</strong> @ViewModel.Staff.HireDate.ToString("d MMM yyyy")</p>
        <p><strong>Work Location:</strong> @ViewModel.Staff.WorkLocation</p>
        <p><strong>Status:</strong> @ViewModel.Staff.AccountStatus</p>
    </div>
    <p><a href="/staff">Back to Staff List</a></p>
}
else
{
    <p>Staff member not found.</p>
}

@code {
    [Parameter] public string id { get; set; } = default!;

    protected override async Task OnParametersSetAsync()
    {
        AppState.SetBreadcrumb("Staff", "Staff Details");
        await ViewModel.LoadAsync(id);
    }
}
