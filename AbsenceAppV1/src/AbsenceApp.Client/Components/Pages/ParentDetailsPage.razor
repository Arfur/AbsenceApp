@* ===========================================================================
   File        : ParentDetailsPage.razor
   Namespace   : AbsenceApp.Client.Components.Pages
   Route       : /parents/{id}
   Author      : Michael
   Version     : 1.0.0
   Created     : 2026-03-13
   Updated     : 2026-03-13
   ---------------------------------------------------------------------------
   Purpose     : Displays the full profile of a single parent, including
                 contact details and links to their children’s profiles.
   ---------------------------------------------------------------------------   Notes       :
     - Parent data is resolved by if/else on the {id} string; replace with a
       parent service lookup once a data layer is available.
     - Children hrefs link directly to StudentsPage student detail routes;
       ensure student ids remain consistent across seed data files.
   ---------------------------------------------------------------------------   Changes     :
     - 1.0.0  2026-03-13  Initial static implementation.
   ===========================================================================
*@
@page "/parents/{id}"
@inject ParentDetailsViewModel ViewModel
@inject AppStateService AppState

<h3>Contact Details</h3>

@if (ViewModel.IsLoading)
{
    <p><em>Loading...</em></p>
}
else if (ViewModel.ErrorMessage is not null)
{
    <div class="alert-box error">@ViewModel.ErrorMessage</div>
}
else if (ViewModel.Contact is not null)
{
    <div class="detail-card">
        <p><strong>Name:</strong> @ViewModel.Contact.ContactName</p>
        <p><strong>Relationship:</strong> @ViewModel.Contact.Relationship</p>
        <p><strong>Mobile:</strong> @ViewModel.Contact.PhoneMobile</p>
        <p><strong>Home Phone:</strong> @ViewModel.Contact.PhoneHome</p>
        <p><strong>Email:</strong> @ViewModel.Contact.Email</p>
        <p><strong>Priority:</strong> @ViewModel.Contact.Priority</p>
        <p><strong>Parental Responsibility:</strong> @(ViewModel.Contact.HasParentalResponsibility ? "Yes" : "No")</p>
        @if (ViewModel.Contact.SafeguardingFlag == true)
        {
            <p><span class="badge badge-red">Safeguarding Flag</span></p>
        }
        @if (!string.IsNullOrEmpty(ViewModel.Contact.Notes))
        {
            <p><strong>Notes:</strong> @ViewModel.Contact.Notes</p>
        }
    </div>
    <p><a href="/students/@ViewModel.Contact.StudentId">View Student Profile</a></p>
}
else
{
    <p>Contact not found.</p>
}

@code {
    [Parameter] public string id { get; set; } = default!;

    protected override async Task OnParametersSetAsync()
    {
        AppState.SetBreadcrumb("Parents", "Contact Details");
        if (long.TryParse(id, out var longId))
            await ViewModel.LoadAsync(longId);
    }
}
