@* ===========================================================================
   File        : AttendanceStudentPage.razor
   Namespace   : AbsenceApp.Client.Components.Pages
   Route       : /attendance/student
   Author      : Michael
   Version     : 1.0.0
   Created     : 2026-03-17
   Updated     : 2026-03-17
   ---------------------------------------------------------------------------
   Purpose     : Placeholder page for viewing and managing student attendance.
                 Will display per-student attendance records and allow
                 attendance to be recorded by class or individual.
   ---------------------------------------------------------------------------
   Notes       :
     - Content is a placeholder; replace with attendance ViewModel and table
       once the student attendance service layer is available.
   ---------------------------------------------------------------------------
   Changes     :
     - 1.0.0  2026-03-17  Initial placeholder implementation.
   ===========================================================================
*@
@page "/attendance/student"
@inject AttendanceStudentViewModel ViewModel
@inject AppStateService AppState

<h3>Student Attendance Marks</h3>

<div class="form-card">
    <div class="form-field">
        <label>Register ID</label>
        <input type="number" @bind="_registerIdInput" placeholder="Enter register ID" />
    </div>
    <button class="btn-primary" @onclick="Load">Load Marks</button>
</div>

@if (ViewModel.IsLoading)
{
    <p><em>Loading...</em></p>
}
else if (ViewModel.ErrorMessage is not null)
{
    <div class="alert-box error">@ViewModel.ErrorMessage</div>
}
else if (ViewModel.Marks.Any())
{
    <table>
        <thead>
            <tr><th>Student ID</th><th>Mark</th><th>Late</th><th>Minutes Late</th><th>Notes</th></tr>
        </thead>
        <tbody>
            @foreach (var m in ViewModel.Marks)
            {
                <tr>
                    <td><a href="/students/@m.StudentId">@m.StudentId</a></td>
                    <td>@m.MarkCode</td>
                    <td>@(m.IsLate == true ? "Yes" : "No")</td>
                    <td>@(m.MinutesLate.HasValue ? m.MinutesLate.ToString() : "—")</td>
                    <td>@(m.Notes ?? "—")</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    string? _registerIdInput;

    protected override void OnInitialized()
        => AppState.SetBreadcrumb("Attendance", "Student Attendance");

    async Task Load()
    {
        if (long.TryParse(_registerIdInput, out var id))
            await ViewModel.LoadAsync(id);
    }
}
