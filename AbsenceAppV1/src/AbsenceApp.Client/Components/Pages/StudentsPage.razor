@* ===========================================================================
   File        : StudentsPage.razor
   Namespace   : AbsenceApp.Client.Components.Pages
   Route       : /students
   Author      : Michael
    Version     : 4.0.0
   Created     : 2026-03-13
    Updated     : 2026-03-18
   ---------------------------------------------------------------------------
    Purpose     : Displays the Full View student list inside TablePageTemplate.
                 Column visibility, labels, sort/search/filter flags, and
                 display order are read dynamically from ITableSettingsService
                 on page load and respected at runtime.
   ---------------------------------------------------------------------------
     Notes       :
         - Binds StudentFullViewDto rows loaded by StudentsViewModel.
         - Column settings are loaded from the "students_full" table key.
         - StudentFullViewDto intentionally has no Id, so this list page renders
             values only and does not generate detail/edit row links.
   ---------------------------------------------------------------------------
   Changes     :
     - 1.0.0  2026-03-13  Initial implementation (simple list).
     - 2.0.0  2026-03-17  Replaced with TablePageTemplate-based layout.
    - 3.0.0  2026-03-17  Dynamic columns driven by ITableSettingsService.
    - 4.0.0  2026-03-18  Switched to StudentFullViewDto + students_full
                     settings key. Removed raw-table-only link/actions.
   ===========================================================================
*@
@page "/students"
@inject AppStateService        AppState
@inject StudentsViewModel      ViewModel
@inject ITableSettingsService  TableSettingsService

@* =========================================================================
   Section: TablePageTemplate — five-section reusable layout
   ========================================================================= *@
<TablePageTemplate PageTitle="Student Management"
                   ActiveFilters="activeFilters"
                   OnRemoveFilter="RemoveFilter"
                   OnClearAllFilters="ClearAllFilters"
                   ShowEntries="showEntries"
                   OnShowEntriesChanged="OnShowEntriesChanged"
                   SearchValue="@searchValue"
                   OnSearchChanged="OnSearchChanged"
                   OnReload="ViewModel.LoadAsync"
                   TotalRows="FilteredStudents.Count()"
                   CurrentPage="currentPage">

    @* =========================================================================
       Section 1: Filters — one dropdown per filterable column from settings
       ========================================================================= *@
    <Filters>
        @foreach (var col in columnSettings.Where(c => c.IsVisible && c.IsFilterable))
        {
            var fc = col;
            <select class="tpt-filter-select"
                    @onchange='e => ApplyFilter(fc.FieldName, e.Value?.ToString() ?? "")'>
                <option value="">@fc.DisplayLabel</option>
                @foreach (var val in FilterOptions(fc.FieldName))
                {
                    <option value="@val">@val</option>
                }
            </select>
        }
    </Filters>

    @* =========================================================================
       Section 2: Action buttons
       ========================================================================= *@
    <ActionButtons>
        <a href="/students/add" class="tpt-btn tpt-btn-primary">
            <i class="bi bi-person-plus"></i> Add Student
        </a>
    </ActionButtons>

    @* =========================================================================
       Section 3: Column headers — generated from visible settings columns
       ========================================================================= *@
    <TableHeader>
        @foreach (var col in VisibleColumns)
        {
            var hc = col;
            <th>
                @hc.DisplayLabel
                @if (hc.IsSortable)
                {
                    <button class="tpt-sort-btn @SortClass(hc.FieldName)"
                            @onclick="() => SetSort(hc.FieldName)">
                        <span class="tpt-sort-up">▲</span>
                        <span class="tpt-sort-dn">▼</span>
                    </button>
                }
            </th>
        }
    </TableHeader>

    @* =========================================================================
       Section 4: Data rows — paged student records, cells driven by settings
       ========================================================================= *@
    <TableBody>
        @if (ViewModel.IsLoading)
        {
            <tr><td colspan="@ColSpan" style="text-align:center;padding:1.5rem;color:#64748b;">Loading…</td></tr>
        }
        else if (ViewModel.ErrorMessage is not null)
        {
            <tr><td colspan="@ColSpan" style="color:#dc2626;padding:1rem;">@ViewModel.ErrorMessage</td></tr>
        }
        else if (!PagedStudents.Any())
        {
            <tr><td colspan="@ColSpan" style="text-align:center;padding:1.5rem;color:#64748b;">No students found.</td></tr>
        }
        else
        {
            @foreach (var s in PagedStudents)
            {
                <tr>
                    @foreach (var col in VisibleColumns)
                    {
                        var bc = col;
                        <td>@(GetStudentValue(s, bc.FieldName) ?? string.Empty)</td>
                    }
                </tr>
            }
        }
    </TableBody>

    @* =========================================================================
       Section 5: Pagination controls
       ========================================================================= *@
    <Pagination>
        <button class="tpt-page-btn"
                disabled="@(currentPage <= 1)"
                @onclick="PrevPage">&#8592; Previous</button>

        @for (int p = 1; p <= Math.Min(TotalPages, 10); p++)
        {
            var pg = p;
            <button class="tpt-page-btn @(currentPage == pg ? "tpt-active" : "")"
                    @onclick="() => GoToPage(pg)">@pg</button>
        }
        @if (TotalPages > 10)
        {
            <span class="tpt-page-btn tpt-page-ellipsis">...</span>
        }

        <button class="tpt-page-btn"
                disabled="@(currentPage >= TotalPages)"
                @onclick="NextPage">Next &#8594;</button>
    </Pagination>

</TablePageTemplate>

@* =========================================================================
   Section: Code-behind — state, computed properties, and event handlers
   ========================================================================= *@
@code {

    // =========================================================================
    // State
    // =========================================================================

    private IReadOnlyList<TablePageSettingDto> columnSettings = [];
    private List<FilterChip>                   activeFilters  = new();
    private string                             searchValue    = "";
    private int                                showEntries    = 10;
    private int                                currentPage    = 1;
    private string                             sortCol        = "admission_number";
    private bool                               sortAsc        = true;

    // =========================================================================
    // Computed: visible columns ordered by DisplayOrder
    // =========================================================================

    private IEnumerable<TablePageSettingDto> VisibleColumns =>
        columnSettings.Where(c => c.IsVisible).OrderBy(c => c.DisplayOrder);

    // Colspan = visible data columns
    private int ColSpan => VisibleColumns.Count();

    // =========================================================================
    // Computed: distinct year groups for the Year Group filter dropdown
    // =========================================================================

    private IEnumerable<string> AvailableYearGroups =>
        (ViewModel.Students ?? Enumerable.Empty<StudentFullViewDto>())
            .Select(s => s.YearGroupName)
            .Where(y => !string.IsNullOrWhiteSpace(y))
            .Distinct()
            .OrderBy(y => y);

    // =========================================================================
    // Computed: filtered, sorted, and paged student rows
    // =========================================================================

    private IEnumerable<StudentFullViewDto> FilteredStudents
    {
        get
        {
            var items = ViewModel.Students ?? Enumerable.Empty<StudentFullViewDto>();

            // Apply chip filters (filterable columns only)
            foreach (var chip in activeFilters.Where(chip => columnSettings.Any(c => c.IsVisible && c.IsFilterable && c.FieldName == chip.Name)))
                items = items.Where(s => GetStudentValue(s, chip.Name) == chip.Value);

            // Apply free-text search (searchable columns only)
            if (!string.IsNullOrWhiteSpace(searchValue))
            {
                var term    = searchValue.Trim().ToLowerInvariant();
                var fields  = columnSettings.Where(c => c.IsVisible && c.IsSearchable).Select(c => c.FieldName).ToList();
                if (fields.Count > 0)
                    items = items.Where(s =>
                        fields.Any(f => (GetStudentValue(s, f) ?? "").ToLowerInvariant().Contains(term)));
            }

            // Apply column sort — named cases for type-aware ordering, reflection fallback
            if (string.IsNullOrWhiteSpace(sortCol)) return items;
            return (sortCol, sortAsc) switch
            {
                ("first_name",   true)  => items.OrderBy(s => s.FirstName).ThenBy(s => s.LastName),
                ("first_name",   false) => items.OrderByDescending(s => s.FirstName).ThenByDescending(s => s.LastName),
                ("last_name",    true)  => items.OrderBy(s => s.LastName).ThenBy(s => s.FirstName),
                ("last_name",    false) => items.OrderByDescending(s => s.LastName).ThenByDescending(s => s.FirstName),
                ("year_group_name", true)  => items.OrderBy(s => s.YearGroupName),
                ("year_group_name", false) => items.OrderByDescending(s => s.YearGroupName),
                (_, true)               => items.OrderBy(s => GetStudentValue(s, sortCol)),
                (_, false)              => items.OrderByDescending(s => GetStudentValue(s, sortCol))
            };
        }
    }

    private IEnumerable<StudentFullViewDto> PagedStudents =>
        FilteredStudents.Skip((currentPage - 1) * showEntries).Take(showEntries);

    private int TotalPages =>
        (int)Math.Ceiling((double)FilteredStudents.Count() / Math.Max(showEntries, 1));

    // =========================================================================
    // Filter options — per field name
    // =========================================================================

    private IEnumerable<string> FilterOptions(string fieldName) =>
        fieldName == "year_group_name"
            ? AvailableYearGroups
            : (ViewModel.Students ?? Enumerable.Empty<StudentFullViewDto>())
                .Select(s => GetStudentValue(s, fieldName))
                .Where(v => !string.IsNullOrWhiteSpace(v))
                .Distinct()
                .OrderBy(v => v)!;

    // =========================================================================
    // Sort helper
    // =========================================================================

    private string SortClass(string fieldName) =>
        sortCol == fieldName ? (sortAsc ? "asc" : "desc") : "";

    private void SetSort(string fieldName)
    {
        if (sortCol == fieldName) sortAsc = !sortAsc;
        else                      { sortCol = fieldName; sortAsc = true; }
    }

    // =========================================================================
    // Lifecycle — load settings + data, set breadcrumb
    // =========================================================================

    protected override async Task OnInitializedAsync()
    {
        AppState.SetBreadcrumb("Students", "All Students");
        columnSettings = await TableSettingsService.GetSettingsAsync("students_full");
        sortCol = VisibleColumns.FirstOrDefault(c => c.IsSortable)?.FieldName ?? "admission_number";
        await ViewModel.LoadAsync();
    }

    // =========================================================================
    // Filter handlers
    // =========================================================================

    private void ApplyFilter(string fieldName, string value)
    {
        if (string.IsNullOrWhiteSpace(value)) return;
        activeFilters.RemoveAll(c => c.Name == fieldName);
        activeFilters.Add(new FilterChip(fieldName, value));
        currentPage = 1;
    }

    private void RemoveFilter(FilterChip chip)
    {
        activeFilters.Remove(chip);
        currentPage = 1;
    }

    private void ClearAllFilters()
    {
        activeFilters.Clear();
        currentPage = 1;
    }

    // =========================================================================
    // Search and show-entries handlers
    // =========================================================================

    private void OnSearchChanged(string value)      { searchValue  = value; currentPage = 1; }
    private void OnShowEntriesChanged(int value)    { showEntries  = value; currentPage = 1; }

    // =========================================================================
    // Pagination handlers
    // =========================================================================

    private void GoToPage(int page)   => currentPage = page;
    private void PrevPage()           { if (currentPage > 1)          currentPage--; }
    private void NextPage()           { if (currentPage < TotalPages) currentPage++; }

    // =========================================================================
    // Value resolver — virtual + reflection-based fallback
    // =========================================================================

    private static string? GetStudentValue(StudentFullViewDto s, string fieldName) =>
        typeof(StudentFullViewDto).GetProperty(ToPascalCase(fieldName))?.GetValue(s)?.ToString();

    private static string ToPascalCase(string snake) =>
        string.Concat(snake.Split('_').Select(w => w.Length > 0
            ? char.ToUpperInvariant(w[0]) + w[1..]
            : w));
}
