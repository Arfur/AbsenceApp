@* ===========================================================================
   File        : ClassDetailsPage.razor
   Namespace   : AbsenceApp.Client.Components.Pages
   Route       : /classes/{id}
   Author      : Michael
   Version     : 1.0.0
   Created     : 2026-03-13
   Updated     : 2026-03-13
   ---------------------------------------------------------------------------
   Purpose     : Displays the details of a single class including year group
                 and the list of enrolled students.
   ---------------------------------------------------------------------------
   Notes       :
     - Class data is resolved by if/else on the {id} string; replace with a
       class service lookup once a data layer is available.
     - Student hrefs are hard-coded integer ids; ensure they remain in sync
       with seed data in StudentRepository when modifying either file.
   ---------------------------------------------------------------------------
   Changes     :
     - 1.0.0  2026-03-13  Initial static implementation.
   ===========================================================================
*@
@page "/classes/{id}"
@inject ClassDetailsViewModel ViewModel
@inject AppStateService AppState

@* =========================================================================
   Page content — ViewModel-driven class details
   ========================================================================= *@
@if (ViewModel.IsLoading)
{
    <p><em>Loading...</em></p>
}
else if (ViewModel.ErrorMessage is not null)
{
    <div class="alert-box error">@ViewModel.ErrorMessage</div>
}
else if (ViewModel.Class is not null)
{
    <div class="detail-card">
        <p><strong>Name:</strong> @ViewModel.Class.Name</p>
        @if (!string.IsNullOrEmpty(ViewModel.Class.Description))
        {
            <p><strong>Description:</strong> @ViewModel.Class.Description</p>
        }
    </div>
}
else
{
    <p>Class not found.</p>
}

@* =========================================================================
   Code block — load class by parsed route parameter
   ========================================================================= *@
@code {
    [Parameter] public string id { get; set; } = default!;

    protected override async Task OnParametersSetAsync()
    {
        AppState.SetBreadcrumb("Classes", "Class Details");
        await ViewModel.LoadAsync(id);
    }
}
