@page "/attendance/log"
@inject AttendanceLogViewModel ViewModel
@inject AppStateService AppState

<h3>Absence Log</h3>

<div class="form-card">
    <div class="form-field">
        <label>Student ID</label>
        <input type="number" @bind="_studentIdInput" placeholder="Enter student ID" />
    </div>
    <button class="btn-primary" @onclick="Load">Load Log</button>
</div>

@if (ViewModel.IsLoading)
{
    <p><em>Loading...</em></p>
}
else if (ViewModel.ErrorMessage is not null)
{
    <div class="alert-box error">@ViewModel.ErrorMessage</div>
}
else if (ViewModel.Absences.Any())
{
    <table>
        <thead>
            <tr><th>Date</th><th>Start</th><th>End</th><th>Authorised</th><th>Notes</th></tr>
        </thead>
        <tbody>
            @foreach (var a in ViewModel.Absences)
            {
                <tr>
                    <td>@a.Date</td>
                    <td>@(a.StartTime.HasValue ? a.StartTime.Value.ToString("HH:mm") : "—")</td>
                    <td>@(a.EndTime.HasValue ? a.EndTime.Value.ToString("HH:mm") : "—")</td>
                    <td>@(a.IsAuthorised ? "Yes" : "No")</td>
                    <td>@(a.Notes ?? "—")</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    string? _studentIdInput;

    protected override void OnInitialized()
        => AppState.SetBreadcrumb("Attendance", "Log Attendance");

    async Task Load()
    {
        if (long.TryParse(_studentIdInput, out var id))
            await ViewModel.LoadAsync(id);
    }
}
