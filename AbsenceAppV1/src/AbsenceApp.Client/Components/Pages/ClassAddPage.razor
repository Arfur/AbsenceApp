@* ===========================================================================
   File        : ClassAddPage.razor
   Namespace   : AbsenceApp.Client.Components.Pages
   Route       : /classes/add
   Author      : Michael
   Version     : 1.0.0
   Created     : 2026-03-17
   Updated     : 2026-03-17
   ---------------------------------------------------------------------------
   Purpose     : Placeholder page for creating a new class.
                 Will provide a form bound to a Classes ViewModel for
                 adding new class records.
   ---------------------------------------------------------------------------
   Notes       :
     - Content is a placeholder; replace with the add-class form once
       the class management service layer is available.
   ---------------------------------------------------------------------------
   Changes     :
     - 1.0.0  2026-03-17  Initial placeholder implementation.
   ===========================================================================
*@
@page "/classes/add"
@inject ClassAddViewModel ViewModel
@inject AppStateService AppState

@if (ViewModel.IsSaved)
{
    <div class="alert-box success">Class added. ID: @ViewModel.NewClass.Id</div>
    <a href="/classes">Back to Classes</a>
}
else
{
    <h3>Add Class</h3>

    @if (ViewModel.ErrorMessage is not null)
    {
        <div class="alert-box error">@ViewModel.ErrorMessage</div>
    }
    <div class="form-card">
        <div class="form-field">
            <label>Class Name</label>
            <input type="text" @bind="ViewModel.NewClass.Name" placeholder="e.g. 7A" />
        </div>
        <div class="form-field">
            <label>Description</label>
            <input type="text" @bind="ViewModel.NewClass.Description" placeholder="Optional" />
        </div>
        <div class="form-actions">
            <button class="btn-primary" @onclick="Save" disabled="@ViewModel.IsSaving">
                @(ViewModel.IsSaving ? "Saving..." : "Save Class")
            </button>
            <a href="/classes">Cancel</a>
        </div>
    </div>
}

@code {
    protected override void OnInitialized()
        => AppState.SetBreadcrumb("Classes", "Add Class");

    async Task Save() => await ViewModel.SaveAsync();
}
