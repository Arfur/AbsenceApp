@* ===========================================================================
   File        : SubjectDetailsPage.razor
   Namespace   : AbsenceApp.Client.Components.Pages
   Route       : /subjects/{id}
   Author      : Michael
   Version     : 1.0.0
   Created     : 2026-03-13
   Updated     : 2026-03-13
   ---------------------------------------------------------------------------
   Purpose     : Displays the full details of a single subject, including
                 teacher and class assignment.
   ---------------------------------------------------------------------------
   Notes       :
     - Subject data is resolved by if/else on the {id} string; replace with a
       subject service lookup once a data layer is available.
     - No @inject or @code block required; all rendering is conditional markup
       based on the route parameter only.
   ---------------------------------------------------------------------------
   Changes     :
     - 1.0.0  2026-03-13  Initial static implementation.
   ===========================================================================
*@
@page "/subjects/{id}"
@inject SubjectDetailsViewModel ViewModel
@inject AppStateService AppState

<h3>Subject Details</h3>

@if (ViewModel.IsLoading)
{
    <p><em>Loading...</em></p>
}
else if (ViewModel.ErrorMessage is not null)
{
    <div class="alert-box error">@ViewModel.ErrorMessage</div>
}
else if (ViewModel.Subject is not null)
{
    <div class="detail-card">
        <p><strong>Name:</strong> @ViewModel.Subject.Name</p>
        @if (!string.IsNullOrEmpty(ViewModel.Subject.Description))
        {
            <p><strong>Description:</strong> @ViewModel.Subject.Description</p>
        }
    </div>
}
else
{
    <p>Subject not found.</p>
}

@code {
    [Parameter] public string id { get; set; } = default!;

    protected override async Task OnParametersSetAsync()
    {
        AppState.SetBreadcrumb("Subjects", "Subject Details");
        if (int.TryParse(id, out var intId))
            await ViewModel.LoadAsync(intId);
    }
}
