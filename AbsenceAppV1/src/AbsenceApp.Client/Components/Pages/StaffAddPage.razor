@* ===========================================================================
   File        : StaffAddPage.razor
   Namespace   : AbsenceApp.Client.Components.Pages
   Route       : /staff/add
   Author      : Michael
   Version     : 1.0.0
   Created     : 2026-03-17
   Updated     : 2026-03-17
   ---------------------------------------------------------------------------
   Purpose     : Placeholder page for adding a new staff member.
                 Will provide a form bound to a Staff ViewModel for
                 creating new user records.
   ---------------------------------------------------------------------------
   Notes       :
     - Content is a placeholder; replace with the add-staff form once
       the user management service layer is available.
   ---------------------------------------------------------------------------
   Changes     :
     - 1.0.0  2026-03-17  Initial placeholder implementation.
   ===========================================================================
*@
@page "/staff/add"
@inject StaffAddViewModel ViewModel
@inject AppStateService AppState

@if (ViewModel.IsSaved)
{
    <div class="alert-box success">Staff member added successfully.</div>
    <a href="/staff">Back to Staff</a>
}
else
{
    <h3>Add Staff</h3>

    @if (ViewModel.ErrorMessage is not null)
    {
        <div class="alert-box error">@ViewModel.ErrorMessage</div>
    }
    <div class="form-card">
        <div class="form-field">
            <label>First Name</label>
            <input type="text" @bind="ViewModel.NewStaff.FirstName" placeholder="First name" />
        </div>
        <div class="form-field">
            <label>Last Name</label>
            <input type="text" @bind="ViewModel.NewStaff.LastName" placeholder="Last name" />
        </div>
        <div class="form-field">
            <label>Work Email</label>
            <input type="email" @bind="ViewModel.NewStaff.WorkEmail" placeholder="Work email" />
        </div>
        <div class="form-field">
            <label>Employment Type</label>
            <input type="text" @bind="ViewModel.NewStaff.EmploymentType" placeholder="e.g. Full-time" />
        </div>
        <div class="form-actions">
            <button class="btn-primary" @onclick="Save" disabled="@ViewModel.IsSaving">
                @(ViewModel.IsSaving ? "Saving..." : "Save Staff Member")
            </button>
            <a href="/staff">Cancel</a>
        </div>
    </div>
}

@code {
    protected override void OnInitialized()
        => AppState.SetBreadcrumb("Staff", "Add Staff");

    async Task Save() => await ViewModel.SaveAsync();
}
