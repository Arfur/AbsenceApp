@* ===========================================================================
   File        : AttendanceStaffPage.razor
   Namespace   : AbsenceApp.Client.Components.Pages
   Route       : /attendance/staff
   Author      : Michael
   Version     : 1.0.0
   Created     : 2026-03-17
   Updated     : 2026-03-17
   ---------------------------------------------------------------------------
   Purpose     : Placeholder page for viewing and managing staff attendance.
                 Will display per-staff attendance records and allow absence
                 reporting for each member of staff.
   ---------------------------------------------------------------------------
   Notes       :
     - Content is a placeholder; replace with attendance ViewModel and table
       once the staff attendance service layer is available.
   ---------------------------------------------------------------------------
   Changes     :
     - 1.0.0  2026-03-17  Initial placeholder implementation.
   ===========================================================================
*@
@page "/attendance/staff"
@inject AttendanceStaffViewModel ViewModel
@inject AppStateService AppState

<h3>Staff Attendance Registers</h3>

<div class="form-card">
    <div class="form-field">
        <label>Class ID</label>
        <input type="number" @bind="_classIdInput" placeholder="Enter class ID" />
    </div>
    <button class="btn-primary" @onclick="Load">Load Registers</button>
</div>

@if (ViewModel.IsLoading)
{
    <p><em>Loading...</em></p>
}
else if (ViewModel.ErrorMessage is not null)
{
    <div class="alert-box error">@ViewModel.ErrorMessage</div>
}
else if (ViewModel.Registers.Any())
{
    <table>
        <thead>
            <tr><th>Date</th><th>Session</th><th>Status</th><th>Opened By</th></tr>
        </thead>
        <tbody>
            @foreach (var r in ViewModel.Registers)
            {
                <tr>
                    <td>@r.Date</td>
                    <td>@r.Session</td>
                    <td>@r.Status</td>
                    <td>@r.OpenedBy</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    string? _classIdInput;

    protected override void OnInitialized()
        => AppState.SetBreadcrumb("Attendance", "Staff Attendance");

    async Task Load()
    {
        if (long.TryParse(_classIdInput, out var id))
            await ViewModel.LoadAsync(id);
    }
}
