@* ===========================================================================
   File        : IconButton.razor
   Namespace   : AbsenceApp.Client.Components.DesignSystem
   Author      : Michael
   Version     : 1.0.0
   Created     : 2026-03-21
   Updated     : 2026-03-21
   ---------------------------------------------------------------------------
   Purpose     : Reusable icon-only button component. Wraps Icon.razor in an accessible <button> element. Variants: ghost (default), primary, danger, success, warning. Sizes: sm, md (default), lg.
   ---------------------------------------------------------------------------
   Changes     :
     - 1.0.0  2026-03-21  Initial implementation.
   ---------------------------------------------------------------------------
   Notes       :
     - Phase 2 component. No DI registration required.
   ===========================================================================
*@

@* =========================================================================
   Section: IconButton element
   ========================================================================= *@
<button type="@Type"
        class="@CssClass"
        title="@Title"
        aria-label="@(AriaLabel ?? Title)"
        disabled="@Disabled"
        @onclick="OnClick"
        @onclick:stopPropagation="StopPropagation">
    <Icon Name="@Icon" Size="@IconSize" />
    @if (!string.IsNullOrEmpty(Label))
    {
        <span class="ds-icon-btn__label">@Label</span>
    }
</button>

@* =========================================================================
   Section: Parameters and CSS class builder
   ========================================================================= *@
@code {
    /// <summary>Bootstrap Icons name without "bi-" prefix.</summary>
    [Parameter, EditorRequired] public string Icon { get; set; } = string.Empty;

    /// <summary>Accessible label used for aria-label and title.</summary>
    [Parameter] public string? Title { get; set; }

    /// <summary>Explicit aria-label override. Falls back to Title.</summary>
    [Parameter] public string? AriaLabel { get; set; }

    /// <summary>Optional visible text label next to icon.</summary>
    [Parameter] public string? Label { get; set; }

    /// <summary>Variant: ghost | primary | danger | success | warning.</summary>
    [Parameter] public string Variant { get; set; } = "ghost";

    /// <summary>Size: sm | md | lg.</summary>
    [Parameter] public string Size { get; set; } = "md";

    /// <summary>Button type attribute.</summary>
    [Parameter] public string Type { get; set; } = "button";

    /// <summary>Disabled state.</summary>
    [Parameter] public bool Disabled { get; set; }

    /// <summary>Whether to stop click propagation.</summary>
    [Parameter] public bool StopPropagation { get; set; }

    /// <summary>Additional CSS classes.</summary>
    [Parameter] public string? Class { get; set; }

    /// <summary>Click handler.</summary>
    [Parameter] public EventCallback OnClick { get; set; }

    private string IconSize => Size switch
    {
        "sm" => "sm",
        "lg" => "lg",
        _    => "md"
    };

    private string CssClass => string.Join(" ", new[]
    {
        "ds-icon-btn",
        $"ds-icon-btn--{Variant}",
        $"ds-icon-btn--{Size}",
        Disabled ? "ds-icon-btn--disabled" : null,
        !string.IsNullOrEmpty(Label) ? "ds-icon-btn--labeled" : null,
        Class
    }.Where(c => !string.IsNullOrWhiteSpace(c)));
}
